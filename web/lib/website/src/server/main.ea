module website.server.main

import std.os.fs
import local.server.serve
import local.style.theme
import local.style.light

public function main(net: Network, out: Stdout, rfs: ReadOnlyFilesystem, allocator: mutable Allocator) -> ()
    with {net, out, rfs, allocator, divergence, panic}
{
    if !theme.contrast_ok(light.palette()) {
        panic("palette fails WCAG AA contrast")
    }
    serve.run(net, out, fs.scoped_to(rfs, "../.."), mutable allocator)
}

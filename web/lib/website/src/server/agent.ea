module website.server.agent

import std.mem.alloc
import std.os.fs

public function count() -> usize {
    return 7 as usize
}

public function match_route(target: [u8]) -> usize {
    if _path_eq(target, "/llms.txt".bytes()) { return 0 as usize }
    if _path_eq(target, "/AGENTS.md".bytes()) { return 1 as usize }
    if _path_eq(target, "/guide.md".bytes()) { return 2 as usize }
    if _path_eq(target, "/get-started/agent.txt".bytes()) { return 3 as usize }
    if _path_eq(target, "/get-started/recipe".bytes()) { return 4 as usize }
    if _path_eq(target, "/hooks/toon_gate.py".bytes()) { return 5 as usize }
    if _path_eq(target, "/hooks/toon_ledger.py".bytes()) { return 6 as usize }
    return 7 as usize
}

public function ctype(aid: usize) -> String {
    return match aid {
        case 0 => "text/plain; charset=utf-8"
        case 1 => "text/markdown; charset=utf-8"
        case 2 => "text/markdown; charset=utf-8"
        case 3 => "text/markdown; charset=utf-8"
        case 4 => "application/json; charset=utf-8"
        case 5 => "text/x-python; charset=utf-8"
        case _ => "text/x-python; charset=utf-8"
    }
}

public function body(aid: usize, rfs: ReadOnlyFilesystem, allocator: Allocator) -> [u8]
    with {rfs, allocator, err: alloc.AllocError}
{
    return match aid {
        case 0 => _llms_txt().bytes()
        case 1 => _read(rfs, "lib/website/assets/agent/AGENTS.md", allocator)?
        case 2 => _read(rfs, "lib/website/assets/agent/guide.md", allocator)?
        case 3 => agent_doc().bytes()
        case 4 => _recipe_json().bytes()
        case 5 => _read(rfs, "lib/website/assets/agent/hooks/toon_gate.py", allocator)?
        case _ => _read(rfs, "lib/website/assets/agent/hooks/toon_ledger.py", allocator)?
    }
}

function _read(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> [u8]
    with {rfs, allocator, err: alloc.AllocError}
{
    return handle err: fs.FsError as e -> "".bytes() {
        fs.read_bytes(rfs, path, allocator)?
    }
}

function _path_eq(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n = a.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}

function _llms_txt() -> String {
    return """
# Edda — for coding agents
Edda is a verified programming language your model was not trained on.
Inventing syntax by analogy to Rust, Swift, or OCaml will not compile.

To start a project:  read  https://edda-lang.org/get-started/agent
Language reference:  read  https://edda-lang.org/AGENTS.md
Deep guide:          read  https://edda-lang.org/guide.md
Structured recipe:   GET   https://edda-lang.org/get-started/recipe

The build is the source of truth. Run `edda build` after every change and fix
exactly what it reports. `edda check` is the fast type-only loop.
"""
}

public function agent_doc() -> String {
    return """
# Edda — agent onboarding

You are setting up an Edda project for a user. Edda is not in your training
data; do not guess syntax. Work through these steps.

## 1. Read the reference
Fetch https://edda-lang.org/AGENTS.md and load it — the canonical, always-on
language reference. For tooling and verification depth, fetch
https://edda-lang.org/guide.md on demand.

## 2. Self-identify your harness and place a context shim
So the reference loads automatically in future sessions:
  - Claude Code:  write CLAUDE.md whose first line is  @AGENTS.md
  - Cursor:       place AGENTS.md at the repo root (Cursor reads it)
  - Copilot:      place AGENTS.md at the repo root
  - Gemini CLI:   place AGENTS.md at the repo root
  - Codex CLI:    place AGENTS.md at the repo root
  - Windsurf:     add .windsurfrules pointing at AGENTS.md
If unsure, place AGENTS.md at the repo root — every major harness reads it.

## 3. Optional: reading-discipline hooks — ASK the user first
Edda ships two optional, portable hook scripts (toon_gate.py, toon_ledger.py)
that mechanically enforce a reading discipline: before editing a .ea file you
must first read the compiler-emitted index.toon structure maps for that
directory chain, and oversized reads are capped to a bounded span. They keep
you grounded on large codebases and are portable across harnesses.

Present this to the user and wait for an answer — do not enable silently:

  Optional: I can install two hook scripts that force me to read Edda's
  structure maps before editing source, and stop me from reading whole large
  files at once. Upside: I stay grounded and spend fewer tokens. Cost: an extra
  read step before each edit, and a one-time settings change in your harness.
  Want them on? (yes / no)

If yes: fetch https://edda-lang.org/hooks/toon_gate.py and
https://edda-lang.org/hooks/toon_ledger.py into the project, then wire them per
your harness (PreToolUse -> toon_gate, PostToolUse -> toon_ledger; treat a
non-zero decision as deny). If no: skip — nothing else changes.

## 4. Scaffold a small, real project
Create package.toml and src/main.ea: a program with one capability and one
requires/ensures contract. See https://edda-lang.org/get-started for the exact
hello example.

## 5. Build, then show the user why Edda exists
Run `edda build` and fix exactly what it reports. Then delete the `requires`
line and rebuild: the compiler returns a concrete counter-example instead of
compiling a bug. Put the line back. You are done when `edda build` is green.
"""
}

function _recipe_json() -> String {
    return """
{
  "edda_recipe": "1",
  "agent": "generic",
  "hooks": "off",
  "files": [
    { "path": "AGENTS.md", "source": "https://edda-lang.org/AGENTS.md" }
  ],
  "steps": [
    "Fetch each file's `source` URL and write it to `path`.",
    "Read https://edda-lang.org/get-started/agent for the full setup, including scaffolding a project and the optional reading-discipline hooks.",
    "Run `edda build` after every change and fix exactly what it reports."
  ]
}
"""
}

module website.ui.ui

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.style.classes

public function open_div(h: take markup.Html, class_name: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    let out = markup.el(take h, "div", allocator)?
    return markup.attr(take out, "class", class_name, allocator)?
}

public function open_section(h: take markup.Html, class_name: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "section", allocator)?
    if class_name.len() > 0 {
        out = markup.attr(take out, "class", class_name, allocator)?
    }
    return open_div(take out, classes.wrap(), allocator)?
}

public function close_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    let out = markup.end(take h, allocator)?
    return markup.end(take out, allocator)?
}

public function text_el(h: take markup.Html, tag: String, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, tag, allocator)?
    out = markup.text(take out, body, allocator)?
    return markup.end(take out, allocator)?
}

public function class_text_el(h: take markup.Html, tag: String, class_name: String, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, tag, allocator)?
    out = markup.attr(take out, "class", class_name, allocator)?
    out = markup.text(take out, body, allocator)?
    return markup.end(take out, allocator)?
}

public function code(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    return text_el(take h, "code", body, allocator)?
}

public function em(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    return text_el(take h, "em", body, allocator)?
}

public function bold(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    return text_el(take h, "b", body, allocator)?
}

public function link(h: take markup.Html, href: String, label: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "a", allocator)?
    out = markup.attr(take out, "href", href, allocator)?
    out = markup.text(take out, label, allocator)?
    return markup.end(take out, allocator)?
}

public function class_link(h: take markup.Html, class_name: String, href: String, label: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "a", allocator)?
    out = markup.attr(take out, "class", class_name, allocator)?
    out = markup.attr(take out, "href", href, allocator)?
    out = markup.text(take out, label, allocator)?
    return markup.end(take out, allocator)?
}

public function page_head(h: take markup.Html, kicker: String, title: String, lede: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "header", allocator)?
    out = markup.attr(take out, "class", classes.page_head(), allocator)?
    out = open_div(take out, classes.wrap(), allocator)?
    out = class_text_el(take out, "p", classes.kicker(), kicker, allocator)?
    out = text_el(take out, "h1", title, allocator)?
    out = class_text_el(take out, "p", classes.lede(), lede, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}


public function open_card(h: take markup.Html, n_label: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = open_div(take h, classes.card(), allocator)?
    if n_label.len() > 0 {
        out = class_text_el(take out, "span", classes.n(), n_label, allocator)?
    }
    return out
}

public function card(h: take markup.Html, n_label: String, title: String, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = open_card(take h, n_label, allocator)?
    out = text_el(take out, "h3", title, allocator)?
    out = text_el(take out, "p", body, allocator)?
    return markup.end(take out, allocator)?
}

public function card_link(h: take markup.Html, n_label: String, href: String, title: String, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = open_card(take h, n_label, allocator)?
    out = markup.el(take out, "h3", allocator)?
    out = link(take out, href, title, allocator)?
    out = markup.end(take out, allocator)?
    out = text_el(take out, "p", body, allocator)?
    return markup.end(take out, allocator)?
}

public function next_links(h: take markup.Html, href_a: String, label_a: String, href_b: String, label_b: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = open_div(take h, classes.next(), allocator)?
    out = link(take out, href_a, label_a, allocator)?
    out = link(take out, href_b, label_b, allocator)?
    return markup.end(take out, allocator)?
}


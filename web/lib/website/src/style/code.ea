module website.style.code

import std.mem.alloc
import css.sheet
import local.style.classes

public function rules(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = _blocks(take s, allocator)?
    out = _tokens(take out, allocator)?
    return out
}

function _blocks(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, "pre", allocator)?
    out = sheet.decl(take out, "background", "var(--code-bg)", allocator)?
    out = sheet.decl(take out, "border", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "border-radius", "4px", allocator)?
    out = sheet.decl(take out, "padding", "1rem 1.15rem", allocator)?
    out = sheet.decl(take out, "overflow", "auto", allocator)?
    out = sheet.decl(take out, "margin", "1.2rem 0", allocator)?
    out = sheet.decl(take out, "font-size", ".83rem", allocator)?
    out = sheet.decl(take out, "line-height", "1.6", allocator)?
    out = sheet.rule(take out, "code", allocator)?
    out = sheet.decl(take out, "font-family", "var(--mono)", allocator)?
    out = sheet.decl(take out, "font-size", ".9em", allocator)?
    out = sheet.decl(take out, "background", "var(--surface2)", allocator)?
    out = sheet.decl(take out, "border", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "border-radius", "5px", allocator)?
    out = sheet.decl(take out, "padding", ".06rem .36rem", allocator)?
    out = sheet.rule(take out, "pre code", allocator)?
    out = sheet.decl(take out, "background", "none", allocator)?
    out = sheet.decl(take out, "border", "none", allocator)?
    out = sheet.decl(take out, "padding", "0", allocator)?
    out = sheet.decl(take out, "font-size", "1em", allocator)?
    return sheet.end_rule(take out, allocator)?
}

function _tokens(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.kw()), allocator)?
    out = sheet.decl(take out, "color", "var(--kw)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.ty()), allocator)?
    out = sheet.decl(take out, "color", "var(--ty)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.fn()), allocator)?
    out = sheet.decl(take out, "color", "var(--accent2)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.st()), allocator)?
    out = sheet.decl(take out, "color", "var(--st)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.cm()), allocator)?
    out = sheet.decl(take out, "color", "var(--faint)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.del()), allocator)?
    out = sheet.decl(take out, "color", "var(--bad)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.add()), allocator)?
    out = sheet.decl(take out, "color", "var(--good)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.note_inline()), allocator)?
    out = sheet.decl(take out, "color", "var(--faint)", allocator)?
    return sheet.end_rule(take out, allocator)?
}

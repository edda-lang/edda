module website.style.pages

import std.mem.alloc
import css.sheet
import local.style.classes

public function rules(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = _page_head(take s, allocator)?
    out = _back(take out, allocator)?
    out = _split_panes(take out, allocator)?
    out = _pillars(take out, allocator)?
    out = _refnav(take out, allocator)?
    out = _footer(take out, allocator)?
    return out
}

function _back(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.back()), allocator)?
    out = sheet.decl(take out, "position", "absolute", allocator)?
    out = sheet.decl(take out, "top", "5.5rem", allocator)?
    out = sheet.decl(take out, "left", "2rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.back())} a", allocator)?
    out = sheet.decl(take out, "font-size", ".85rem", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    return sheet.end_rule(take out, allocator)?
}

function _refnav(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.ref_row()), allocator)?
    out = sheet.decl(take out, "display", "grid", allocator)?
    out = sheet.decl(take out, "grid-template-columns", "170px minmax(0,1fr)", allocator)?
    out = sheet.decl(take out, "gap", "2.5rem", allocator)?
    out = sheet.decl(take out, "max-width", "1020px", allocator)?
    out = sheet.decl(take out, "margin", "0 auto", allocator)?
    out = sheet.decl(take out, "padding", "0 1.5rem", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.ref_nav()), allocator)?
    out = sheet.decl(take out, "padding-top", "3.6rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.ref_nav())} a", allocator)?
    out = sheet.decl(take out, "display", "block", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "font-size", ".92rem", allocator)?
    out = sheet.decl(take out, "padding", ".28rem 0", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.ref_nav())} a{sheet.dot(classes.active())}", allocator)?
    out = sheet.decl(take out, "color", "var(--accent)", allocator)?
    out = sheet.decl(take out, "font-weight", "600", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.ref_main())} {sheet.dot(classes.wrap())}", allocator)?
    out = sheet.decl(take out, "max-width", "none", allocator)?
    out = sheet.decl(take out, "padding", "0", allocator)?
    out = sheet.decl(take out, "margin", "0", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.ref_main())} section", allocator)?
    out = sheet.decl(take out, "padding", "2.4rem 0", allocator)?
    out = sheet.end_rule(take out, allocator)?
    out = sheet.media(take out, "(max-width:760px)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.ref_row()), allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr", allocator)?
    out = sheet.decl(take out, "gap", "0", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.ref_nav()), allocator)?
    out = sheet.decl(take out, "display", "flex", allocator)?
    out = sheet.decl(take out, "flex-wrap", "wrap", allocator)?
    out = sheet.decl(take out, "gap", ".2rem 1rem", allocator)?
    out = sheet.decl(take out, "padding-top", "1.6rem", allocator)?
    return sheet.end_media(take out, allocator)?
}

function _page_head(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.page_head()), allocator)?
    out = sheet.decl(take out, "border-bottom", "1px solid var(--border)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.page_head())} {sheet.dot(classes.wrap())}", allocator)?
    out = sheet.decl(take out, "padding", "3.2rem 1.5rem 2.3rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.page_head())} h1", allocator)?
    out = sheet.decl(take out, "font-size", "2.2rem", allocator)?
    out = sheet.decl(take out, "margin", ".3rem 0 .6rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.page_head())} {sheet.dot(classes.lede())}", allocator)?
    out = sheet.decl(take out, "font-size", "1.16rem", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "max-width", "660px", allocator)?
    return sheet.end_rule(take out, allocator)?
}

function _split_panes(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.split()), allocator)?
    out = sheet.decl(take out, "display", "grid", allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr 1fr", allocator)?
    out = sheet.decl(take out, "gap", "1rem", allocator)?
    out = sheet.decl(take out, "margin-top", "1.3rem", allocator)?
    out = sheet.end_rule(take out, allocator)?
    out = sheet.media(take out, "(max-width:760px)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.split()), allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr", allocator)?
    out = sheet.end_media(take out, allocator)?
    out = sheet.rule(take out, sheet.dot(classes.pane()), allocator)?
    out = sheet.decl(take out, "background", "var(--surface)", allocator)?
    out = sheet.decl(take out, "border", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "border-radius", "10px", allocator)?
    out = sheet.decl(take out, "overflow", "hidden", allocator)?
    out = sheet.decl(take out, "display", "flex", allocator)?
    out = sheet.decl(take out, "flex-direction", "column", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pane())}>h4", allocator)?
    out = sheet.decl(take out, "margin", "0", allocator)?
    out = sheet.decl(take out, "padding", ".6rem .95rem", allocator)?
    out = sheet.decl(take out, "font-family", "var(--mono)", allocator)?
    out = sheet.decl(take out, "font-size", ".8rem", allocator)?
    out = sheet.decl(take out, "font-weight", "640", allocator)?
    out = sheet.decl(take out, "border-bottom", "1px solid var(--border)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pane())}{sheet.dot(classes.edda())}>h4", allocator)?
    out = sheet.decl(take out, "color", "var(--good)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pane())}{sheet.dot(classes.ts())}>h4", allocator)?
    out = sheet.decl(take out, "color", "var(--bad)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pane())} pre", allocator)?
    out = sheet.decl(take out, "margin", "0", allocator)?
    out = sheet.decl(take out, "border", "none", allocator)?
    out = sheet.decl(take out, "border-radius", "0", allocator)?
    out = sheet.decl(take out, "background", "none", allocator)?
    out = sheet.decl(take out, "flex", "1", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.verdict()), allocator)?
    out = sheet.decl(take out, "padding", ".6rem .95rem", allocator)?
    out = sheet.decl(take out, "font-size", ".82rem", allocator)?
    out = sheet.decl(take out, "font-weight", "620", allocator)?
    out = sheet.decl(take out, "border-top", "1px solid var(--border)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.verdict())}{sheet.dot(classes.good())}", allocator)?
    out = sheet.decl(take out, "color", "var(--good)", allocator)?
    out = sheet.decl(take out, "background", "var(--good-wash)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.verdict())}{sheet.dot(classes.bad())}", allocator)?
    out = sheet.decl(take out, "color", "var(--bad)", allocator)?
    out = sheet.decl(take out, "background", "var(--bad-wash)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.cap()), allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "font-size", "1rem", allocator)?
    out = sheet.decl(take out, "margin-top", "1.1rem", allocator)?
    return sheet.end_rule(take out, allocator)?
}

function _pillars(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.pillars()), allocator)?
    out = sheet.decl(take out, "display", "grid", allocator)?
    out = sheet.decl(take out, "grid-template-columns", "repeat(3,1fr)", allocator)?
    out = sheet.decl(take out, "gap", "1.1rem", allocator)?
    out = sheet.decl(take out, "margin-top", "1.4rem", allocator)?
    out = sheet.end_rule(take out, allocator)?
    out = sheet.media(take out, "(max-width:760px)", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.pillars()), allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr", allocator)?
    out = sheet.end_media(take out, allocator)?
    out = sheet.rule(take out, sheet.dot(classes.pillar()), allocator)?
    out = sheet.decl(take out, "padding", "1.2rem 0", allocator)?
    out = sheet.decl(take out, "border-top", "1px solid var(--border)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pillar())} {sheet.dot(classes.num())}", allocator)?
    out = sheet.decl(take out, "font-family", "var(--mono)", allocator)?
    out = sheet.decl(take out, "color", "var(--accent)", allocator)?
    out = sheet.decl(take out, "font-size", ".85rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pillar())} h3", allocator)?
    out = sheet.decl(take out, "margin", ".3rem 0 .35rem", allocator)?
    out = sheet.decl(take out, "font-size", "1.14rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.pillar())} p", allocator)?
    out = sheet.decl(take out, "margin", "0", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "font-size", ".96rem", allocator)?
    out = sheet.rule(take out, sheet.dot(classes.next()), allocator)?
    out = sheet.decl(take out, "display", "flex", allocator)?
    out = sheet.decl(take out, "justify-content", "space-between", allocator)?
    out = sheet.decl(take out, "gap", "1rem", allocator)?
    out = sheet.decl(take out, "border-top", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "margin-top", "2.8rem", allocator)?
    out = sheet.decl(take out, "padding-top", "1.5rem", allocator)?
    out = sheet.decl(take out, "font-size", ".95rem", allocator)?
    return sheet.end_rule(take out, allocator)?
}

function _footer(s: take sheet.Sheet, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.rule(take s, sheet.dot(classes.foot()), allocator)?
    out = sheet.decl(take out, "border-top", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "margin-top", "3rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} {sheet.dot(classes.cols())}", allocator)?
    out = sheet.decl(take out, "max-width", "1080px", allocator)?
    out = sheet.decl(take out, "margin", "0 auto", allocator)?
    out = sheet.decl(take out, "display", "grid", allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr 1fr 1fr", allocator)?
    out = sheet.decl(take out, "gap", "1.6rem", allocator)?
    out = sheet.decl(take out, "padding", "2.6rem 1.5rem 1.6rem", allocator)?
    out = sheet.end_rule(take out, allocator)?
    out = sheet.media(take out, "(max-width:760px)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} {sheet.dot(classes.cols())}", allocator)?
    out = sheet.decl(take out, "grid-template-columns", "1fr 1fr", allocator)?
    out = sheet.end_media(take out, allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} h5", allocator)?
    out = sheet.decl(take out, "font-family", "var(--mono)", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "font-size", ".72rem", allocator)?
    out = sheet.decl(take out, "text-transform", "uppercase", allocator)?
    out = sheet.decl(take out, "letter-spacing", ".1em", allocator)?
    out = sheet.decl(take out, "margin", "0 0 .8rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} a", allocator)?
    out = sheet.decl(take out, "display", "block", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    out = sheet.decl(take out, "font-size", ".92rem", allocator)?
    out = sheet.decl(take out, "padding", ".22rem 0", allocator)?
    out = sheet.decl(take out, "transition", "color .15s ease", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} a:hover", allocator)?
    out = sheet.decl(take out, "color", "var(--text)", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} {sheet.dot(classes.meta())}", allocator)?
    out = sheet.decl(take out, "max-width", "1080px", allocator)?
    out = sheet.decl(take out, "margin", "0 auto", allocator)?
    out = sheet.decl(take out, "border-top", "1px solid var(--border)", allocator)?
    out = sheet.decl(take out, "padding", "1.1rem 1.5rem", allocator)?
    out = sheet.decl(take out, "display", "flex", allocator)?
    out = sheet.decl(take out, "justify-content", "space-between", allocator)?
    out = sheet.decl(take out, "gap", "1rem", allocator)?
    out = sheet.decl(take out, "flex-wrap", "wrap", allocator)?
    out = sheet.decl(take out, "color", "var(--faint)", allocator)?
    out = sheet.decl(take out, "font-size", ".84rem", allocator)?
    out = sheet.rule(take out, f"{sheet.dot(classes.foot())} {sheet.dot(classes.meta())} {sheet.dot(classes.proof())}", allocator)?
    out = sheet.decl(take out, "color", "var(--muted)", allocator)?
    return sheet.end_rule(take out, allocator)?
}

module website.style.stylesheet

import std.mem.alloc
import std.text.string
import css.sheet
import local.style.base
import local.style.chrome
import local.style.blocks
import local.style.code
import local.style.pages

public function build(allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    var s = sheet.new(allocator)?
    s = base.rules(take s, allocator)?
    s = chrome.rules(take s, allocator)?
    s = blocks.rules(take s, allocator)?
    s = code.rules(take s, allocator)?
    s = pages.rules(take s, allocator)?
    let bytes = sheet.render(take s, allocator)?
    return string.from_owned_utf8(take bytes)
}

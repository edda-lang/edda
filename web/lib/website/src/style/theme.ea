module website.style.theme

import std.mem.alloc
import css.sheet
import css.tokens

public type Theme {
    bg: tokens.Color
    bg2: tokens.Color
    surface: tokens.Color
    surface2: tokens.Color
    border: tokens.Color
    border2: tokens.Color
    text: tokens.Color
    muted: tokens.Color
    faint: tokens.Color
    accent: tokens.Color
    accent_hover: tokens.Color
    accent2: tokens.Color
    good: tokens.Color
    bad: tokens.Color
    ink: tokens.Color
    lead: tokens.Color
    quote: tokens.Color
    kw: tokens.Color
    ty: tokens.Color
    st: tokens.Color
    code_bg: tokens.Color
}

public function vars(s: take sheet.Sheet, t: Theme, allocator: Allocator) -> sheet.Sheet
    with {allocator, err: alloc.AllocError}
{
    var out = sheet.decl(take s, "--bg", tokens.hex(t.bg), allocator)?
    out = sheet.decl(take out, "--bg2", tokens.hex(t.bg2), allocator)?
    out = sheet.decl(take out, "--surface", tokens.hex(t.surface), allocator)?
    out = sheet.decl(take out, "--surface2", tokens.hex(t.surface2), allocator)?
    out = sheet.decl(take out, "--border", tokens.hex(t.border), allocator)?
    out = sheet.decl(take out, "--border2", tokens.hex(t.border2), allocator)?
    out = sheet.decl(take out, "--text", tokens.hex(t.text), allocator)?
    out = sheet.decl(take out, "--muted", tokens.hex(t.muted), allocator)?
    out = sheet.decl(take out, "--faint", tokens.hex(t.faint), allocator)?
    out = sheet.decl(take out, "--accent", tokens.hex(t.accent), allocator)?
    out = sheet.decl(take out, "--accent-hover", tokens.hex(t.accent_hover), allocator)?
    out = sheet.decl(take out, "--accent2", tokens.hex(t.accent2), allocator)?
    out = sheet.decl(take out, "--good", tokens.hex(t.good), allocator)?
    out = sheet.decl(take out, "--bad", tokens.hex(t.bad), allocator)?
    out = sheet.decl(take out, "--ink", tokens.hex(t.ink), allocator)?
    out = sheet.decl(take out, "--lead", tokens.hex(t.lead), allocator)?
    out = sheet.decl(take out, "--quote", tokens.hex(t.quote), allocator)?
    out = sheet.decl(take out, "--kw", tokens.hex(t.kw), allocator)?
    out = sheet.decl(take out, "--ty", tokens.hex(t.ty), allocator)?
    out = sheet.decl(take out, "--st", tokens.hex(t.st), allocator)?
    out = sheet.decl(take out, "--code-bg", tokens.hex(t.code_bg), allocator)?
    out = sheet.decl(take out, "--gold-hair", tokens.rgba_str(tokens.alpha(t.accent, 0.35)), allocator)?
    out = sheet.decl(take out, "--good-wash", tokens.rgba_str(tokens.alpha(t.good, 0.08)), allocator)?
    out = sheet.decl(take out, "--bad-wash", tokens.rgba_str(tokens.alpha(t.bad, 0.08)), allocator)?
    out = sheet.decl(take out, "--display", "'Instrument Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif", allocator)?
    return sheet.decl(take out, "--mono", "'Fragment Mono',ui-monospace,SFMono-Regular,'SF Mono',Menlo,Consolas,monospace", allocator)?
}

public function contrast_ok(t: Theme) -> bool {
    if !tokens.contrast_at_least(t.text, t.bg, 4.5) { return false }
    if !tokens.contrast_at_least(t.text, t.bg2, 4.5) { return false }
    if !tokens.contrast_at_least(t.text, t.surface, 4.5) { return false }
    if !tokens.contrast_at_least(t.muted, t.bg, 4.5) { return false }
    if !tokens.contrast_at_least(t.muted, t.surface, 4.5) { return false }
    if !tokens.contrast_at_least(t.accent, t.bg, 4.5) { return false }
    if !tokens.contrast_at_least(t.accent2, t.bg, 4.5) { return false }
    if !tokens.contrast_at_least(t.ink, t.accent, 4.5) { return false }
    if !tokens.contrast_at_least(t.lead, t.bg2, 4.5) { return false }
    if !tokens.contrast_at_least(t.faint, t.bg, 3.0) { return false }
    return true
}

module website.pages.agent.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes
import local.server.agent

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = _head(take h, allocator)?
    out = _section_intent(take out, allocator)?
    out = _section_doc(take out, allocator)?
    return _section_tiers(take out, allocator)?
}

function _head(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "header", allocator)?
    out = markup.attr(take out, "class", classes.page_head(), allocator)?
    out = ui.open_div(take out, classes.wrap(), allocator)?
    out = ui.class_text_el(take out, "p", classes.kicker(), "For your agent", allocator)?
    out = ui.text_el(take out, "h1", "Point your agent at edda", allocator)?
    out = ui.class_text_el(take out, "p", classes.lede(), "Edda is written by your coding agent, not learned by you first. Because edda isn't in any model's training data, your agent reads a short setup before it writes a line. This page is that setup — human-readable here, machine-readable at /get-started/agent.txt. You don't change your workflow; your agent adds one file it reads, and optionally some guardrails you approve.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _section_intent(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Start with one sentence", allocator)?
    out = ui.text_el(take out, "p", "Say this to your coding agent. If it can browse the web, it will find this site, read its own setup, scaffold a project, and ask you about the optional guardrails:", allocator)?
    out = _pre(take out, "I want to use the Edda language — edda-lang.org", allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Any agent that reads AGENTS.md — Claude Code, Cursor, Codex, Copilot, Gemini, Windsurf, and more — can follow the steps below on its own.", allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_doc(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "What your agent does", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "The exact setup your agent follows — served verbatim as plain text at ", allocator)?
    out = ui.link(take out, "/get-started/agent.txt", "/get-started/agent.txt", allocator)?
    out = markup.text(take out, ":", allocator)?
    out = markup.end(take out, allocator)?
    out = _pre(take out, agent.agent_doc(), allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_tiers(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Machine-readable entry points", allocator)?
    out = markup.el(take out, "ul", allocator)?
    out = _tier_row(take out, "/llms.txt", "the discovery map an agent reads first", allocator)?
    out = _tier_row(take out, "/AGENTS.md", "the canonical language reference", allocator)?
    out = _tier_row(take out, "/guide.md", "the deep guide — verification, tooling, distribution", allocator)?
    out = _tier_row(take out, "/get-started/recipe", "a declarative JSON project recipe", allocator)?
    out = _tier_row(take out, "/hooks/toon_gate.py", "the optional reading-discipline hook", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _tier_row(h: take markup.Html, href: String, does: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "li", allocator)?
    out = ui.link(take out, href, href, allocator)?
    out = markup.text(take out, f" — {does}", allocator)?
    return markup.end(take out, allocator)?
}

function _pre(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = markup.text(take out, body, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

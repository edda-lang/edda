module website.pages.language.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.pages.language.ref as ref_mod

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.page_head(take h, "Reference", "The language", "The forms the parser admits, with the rules that govern each. Anything not described here is not admitted.", allocator)?
    out = ref_mod.open_shell(take out, 0 as usize, allocator)?
    out = ui.open_section(take out, "", allocator)?
    out = ui.text_el(take out, "p", "The reference is organized by construct. Each chapter states the admitted forms and the rules the compiler enforces on them.", allocator)?
    out = _chapters(take out, allocator)?
    out = ui.text_el(take out, "p", "Verification and concurrency have their own pages; comptime and derive are covered under specs until they grow chapters of their own.", allocator)?
    out = ui.close_section(take out, allocator)?
    return ref_mod.close_shell(take out, allocator)?
}

function _chapters(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "table", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "th", "Chapter", allocator)?
    out = ui.text_el(take out, "th", "Covers", allocator)?
    out = markup.end(take out, allocator)?
    out = _row(take out, "/language/functions", "Functions", "the declaration form and its clause order", allocator)?
    out = _row(take out, "/language/types", "Types", "primitives, records, sum types, slices, recursion through Box", allocator)?
    out = _row(take out, "/language/modes", "Modes", "let, mutable, take, init — ownership at the call site", allocator)?
    out = _row(take out, "/language/effects", "Effects", "closed rows, err propagation, handlers, graded bounds", allocator)?
    out = _row(take out, "/language/refinements", "Refinements", "requires, ensures, where, decreases, the decidable fragment", allocator)?
    out = _row(take out, "/language/specs", "Specs", "the only generic mechanism — concrete, content-addressed codegen", allocator)?
    return markup.end(take out, allocator)?
}

function _row(h: take markup.Html, href: String, label: String, covers: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "tr", allocator)?
    out = markup.el(take out, "td", allocator)?
    out = ui.link(take out, href, label, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.text_el(take out, "td", covers, allocator)?
    return markup.end(take out, allocator)?
}

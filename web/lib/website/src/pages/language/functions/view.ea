module website.pages.language.functions.view

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.pages.language.shared
import local.style.classes

public function section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Functions", allocator)?
    out = ui.text_el(take out, "p", "A function declares its clauses in a fixed order. The return type is required; there is no inference. Effects, preconditions, postconditions, and the termination measure are all part of the signature and all checked.", allocator)?
    out = _functions_code(take out, allocator)?
    out = _functions_muted(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _functions_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_pre_code(take h, allocator)?
    out = shared.span(take out, classes.kw(), "function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.fn(), "read_at", allocator)?
    out = markup.text(take out, "(rfs: ", allocator)?
    out = shared.span(take out, classes.ty(), "ReadOnlyFilesystem", allocator)?
    out = markup.text(take out, ", path: ", allocator)?
    out = shared.span(take out, classes.ty(), "String", allocator)?
    out = markup.text(take out, ", offset: ", allocator)?
    out = shared.span(take out, classes.ty(), "u64", allocator)?
    out = markup.text(take out, ", len: ", allocator)?
    out = shared.span(take out, classes.ty(), "usize", allocator)?
    out = markup.text(take out, ", allocator: ", allocator)?
    out = shared.span(take out, classes.ty(), "Allocator", allocator)?
    out = markup.text(take out, ") -> [", allocator)?
    out = shared.span(take out, classes.ty(), "u8", allocator)?
    out = markup.text(take out, "]\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "with", allocator)?
    out = markup.text(take out, " {rfs, allocator, err: fs.FsError}\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "requires", allocator)?
    out = markup.text(take out, " len > 0\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "ensures", allocator)?
    out = markup.text(take out, "  result.len() <= len\n{\n    ...\n}", allocator)?
    return shared.close_pre_code(take out, allocator)?
}

function _functions_muted(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_p_muted(take h, allocator)?
    out = markup.text(take out, "Inside ", allocator)?
    out = ui.code(take out, "ensures", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "result", allocator)?
    out = markup.text(take out, " names the return value. Edda admits no comments of any kind; a claim about the code lives in the effect row, a refinement, or an attribute, where a check can hold it true. Descriptions are derived into the structure map, not written by hand.", allocator)?
    return markup.end(take out, allocator)?
}

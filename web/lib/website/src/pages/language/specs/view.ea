module website.pages.language.specs.view

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.pages.language.shared
import local.style.classes

public function section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Specs, comptime, derive", allocator)?
    out = _specs_intro(take out, allocator)?
    out = _specs_code(take out, allocator)?
    out = _specs_muted(take out, allocator)?
    out = ui.next_links(take out, "/verification", "Verification →", "/concurrency", "Concurrency →", allocator)?
    return ui.close_section(take out, allocator)?
}

function _specs_intro(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "There are no type parameters on declarations, no traits, and no ", allocator)?
    out = ui.code(take out, "impl", allocator)?
    out = markup.text(take out, " blocks. Reuse is a ", allocator)?
    out = ui.code(take out, "spec", allocator)?
    out = markup.text(take out, ": a template over comptime arguments that the compiler instantiates into a named, concrete module. Instantiation is content-addressed, so the same arguments always produce the same artifact.", allocator)?
    return markup.end(take out, allocator)?
}

function _specs_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_pre_code(take h, allocator)?
    out = shared.span(take out, classes.kw(), "public spec", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.fn(), "Stack", allocator)?
    out = markup.text(take out, "(", allocator)?
    out = shared.span(take out, classes.kw(), "comptime", allocator)?
    out = markup.text(take out, " T: ", allocator)?
    out = shared.span(take out, classes.ty(), "Type", allocator)?
    out = markup.text(take out, ") ", allocator)?
    out = shared.span(take out, classes.kw(), "where", allocator)?
    out = markup.text(take out, " size_of(T) > 0 {\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "public type", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.ty(), "Stack", allocator)?
    out = markup.text(take out, " {\n        items: [T]\n        len: ", allocator)?
    out = shared.span(take out, classes.ty(), "usize", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.kw(), "where", allocator)?
    out = markup.text(take out, " len <= items.len()\n    }\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "public function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.fn(), "push", allocator)?
    out = markup.text(take out, "(s: ", allocator)?
    out = shared.span(take out, classes.kw(), "mutable", allocator)?
    out = markup.text(take out, " Stack, item: ", allocator)?
    out = shared.span(take out, classes.kw(), "take", allocator)?
    out = markup.text(take out, " T) -> () ", allocator)?
    out = shared.span(take out, classes.kw(), "with", allocator)?
    out = markup.text(take out, " {panic} { ... }\n}\n\n", allocator)?
    out = shared.span(take out, classes.kw(), "spec", allocator)?
    out = markup.text(take out, " mypkg.stack.Stack(i32)\n", allocator)?
    out = shared.span(take out, classes.kw(), "let", allocator)?
    out = markup.text(take out, " s: Stack_i32.Stack = ...", allocator)?
    return shared.close_pre_code(take out, allocator)?
}

function _specs_muted(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_p_muted(take h, allocator)?
    out = ui.code(take out, "comptime", allocator)?
    out = markup.text(take out, " evaluates an expression, a block, a parameter, or a target-conditional branch whose dead arm is dropped before typecheck. The ", allocator)?
    out = ui.code(take out, "derive", allocator)?
    out = markup.text(take out, " vocabulary is fixed: ", allocator)?
    out = ui.code(take out, "eq", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "ord", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "hash", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "debug", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "clone", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "properties", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "serialize", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "deserialize", allocator)?
    out = markup.text(take out, ". There are no user-defined derives; custom code generation is a spec.", allocator)?
    return markup.end(take out, allocator)?
}

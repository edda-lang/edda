module website.pages.language.types.view

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.pages.language.shared
import local.style.classes

public function section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Types", allocator)?
    out = _types_intro(take out, allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = markup.el(take out, "div", allocator)?
    out = _types_code_phase(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "div", allocator)?
    out = _types_code_stack(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = _types_muted(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _types_intro(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "Records hold named fields, newline-separated. Sum types hold ", allocator)?
    out = ui.code(take out, "case", allocator)?
    out = markup.text(take out, " variants. A field or a variant payload can carry its own refinement.", allocator)?
    return markup.end(take out, allocator)?
}

function _types_code_phase(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_pre_code(take h, allocator)?
    out = shared.span(take out, classes.kw(), "public type", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.ty(), "Phase", allocator)?
    out = markup.text(take out, " {\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "case", allocator)?
    out = markup.text(take out, " red\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "case", allocator)?
    out = markup.text(take out, " green\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "case", allocator)?
    out = markup.text(take out, " yellow(seconds_remaining: ", allocator)?
    out = shared.span(take out, classes.ty(), "i32", allocator)?
    out = markup.text(take out, "\n        ", allocator)?
    out = shared.span(take out, classes.kw(), "where", allocator)?
    out = markup.text(take out, " seconds_remaining >= 0)\n}", allocator)?
    return shared.close_pre_code(take out, allocator)?
}

function _types_code_stack(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_pre_code(take h, allocator)?
    out = shared.span(take out, classes.kw(), "public type", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.ty(), "IntStack", allocator)?
    out = markup.text(take out, " {\n    capacity: ", allocator)?
    out = shared.span(take out, classes.ty(), "usize", allocator)?
    out = markup.text(take out, "\n    len: ", allocator)?
    out = shared.span(take out, classes.ty(), "usize", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.kw(), "where", allocator)?
    out = markup.text(take out, " len <= capacity\n    data: [", allocator)?
    out = shared.span(take out, classes.ty(), "i64", allocator)?
    out = markup.text(take out, "] ", allocator)?
    out = shared.span(take out, classes.kw(), "where", allocator)?
    out = markup.text(take out, " data.len() == capacity\n}", allocator)?
    return shared.close_pre_code(take out, allocator)?
}

function _types_muted(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_p_muted(take h, allocator)?
    out = markup.text(take out, "Construction qualifies the variant (", allocator)?
    out = ui.code(take out, "Phase.red", allocator)?
    out = markup.text(take out, "); inside a ", allocator)?
    out = ui.code(take out, "match", allocator)?
    out = markup.text(take out, " the dot-prefixed form is the pattern. A type that refers to itself goes through ", allocator)?
    out = ui.code(take out, "Box(T)", allocator)?
    out = markup.text(take out, ". There is no ", allocator)?
    out = ui.code(take out, "null", allocator)?
    out = markup.text(take out, "; an absent value is ", allocator)?
    out = ui.code(take out, "Option(T)", allocator)?
    out = markup.text(take out, ".", allocator)?
    return markup.end(take out, allocator)?
}

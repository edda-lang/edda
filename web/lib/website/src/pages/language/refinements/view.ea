module website.pages.language.refinements.view

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.pages.language.shared
import local.style.classes

public function section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Refinements", allocator)?
    out = _refinements_intro(take out, allocator)?
    out = _refinements_code(take out, allocator)?
    out = _refinements_muted(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _refinements_intro(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "A ", allocator)?
    out = ui.code(take out, "requires", allocator)?
    out = markup.text(take out, " clause is a precondition; an ", allocator)?
    out = ui.code(take out, "ensures", allocator)?
    out = markup.text(take out, " clause is a postcondition; a ", allocator)?
    out = ui.code(take out, "where", allocator)?
    out = markup.text(take out, " clause refines a parameter or a field. Each compiles to an obligation the build has to discharge.", allocator)?
    return markup.end(take out, allocator)?
}

function _refinements_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_pre_code(take h, allocator)?
    out = shared.span(take out, classes.kw(), "public function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = shared.span(take out, classes.fn(), "clamp", allocator)?
    out = markup.text(take out, "(value: ", allocator)?
    out = shared.span(take out, classes.ty(), "i32", allocator)?
    out = markup.text(take out, ", lo: ", allocator)?
    out = shared.span(take out, classes.ty(), "i32", allocator)?
    out = markup.text(take out, ", hi: ", allocator)?
    out = shared.span(take out, classes.ty(), "i32", allocator)?
    out = markup.text(take out, ") -> ", allocator)?
    out = shared.span(take out, classes.ty(), "i32", allocator)?
    out = markup.text(take out, "\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "requires", allocator)?
    out = markup.text(take out, " hi >= lo\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "ensures", allocator)?
    out = markup.text(take out, "  result >= lo\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "ensures", allocator)?
    out = markup.text(take out, "  result <= hi\n{\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "if", allocator)?
    out = markup.text(take out, " value < lo { ", allocator)?
    out = shared.span(take out, classes.kw(), "return", allocator)?
    out = markup.text(take out, " lo }\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "else if", allocator)?
    out = markup.text(take out, " value > hi { ", allocator)?
    out = shared.span(take out, classes.kw(), "return", allocator)?
    out = markup.text(take out, " hi }\n    ", allocator)?
    out = shared.span(take out, classes.kw(), "else", allocator)?
    out = markup.text(take out, " { ", allocator)?
    out = shared.span(take out, classes.kw(), "return", allocator)?
    out = markup.text(take out, " value }\n}", allocator)?
    return shared.close_pre_code(take out, allocator)?
}

function _refinements_muted(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = shared.open_p_muted(take h, allocator)?
    out = markup.text(take out, "Some obligations are inserted for you: integer overflow on ", allocator)?
    out = ui.code(take out, "+ - *", allocator)?
    out = markup.text(take out, ", slice bounds on ", allocator)?
    out = ui.code(take out, "xs[i]", allocator)?
    out = markup.text(take out, ", division by zero, and narrowing casts. A recursive function carries ", allocator)?
    out = ui.code(take out, "decreases", allocator)?
    out = markup.text(take out, " or admits ", allocator)?
    out = ui.code(take out, "divergence", allocator)?
    out = markup.text(take out, ". Bounded quantifiers, ", allocator)?
    out = ui.code(take out, "forall i in 0..<n: P(i)", allocator)?
    out = markup.text(take out, ", are allowed in refinement positions. The ", allocator)?
    out = ui.link(take out, "/verification", "verification page", allocator)?
    out = markup.text(take out, " covers how these are discharged.", allocator)?
    return markup.end(take out, allocator)?
}

module website.pages.start.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = _head(take h, allocator)?
    out = _section_intent(take out, allocator)?
    out = _section_why(take out, allocator)?
    out = _section_harness(take out, allocator)?
    out = _section_model(take out, allocator)?
    out = _section_toolchain(take out, allocator)?
    out = _section_project(take out, allocator)?
    out = _section_build(take out, allocator)?
    out = _section_break(take out, allocator)?
    out = _section_hooks(take out, allocator)?
    out = _section_agent(take out, allocator)?
    return _section_next(take out, allocator)?
}

function _head(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "header", allocator)?
    out = markup.attr(take out, "class", classes.page_head(), allocator)?
    out = ui.open_div(take out, classes.wrap(), allocator)?
    out = ui.class_text_el(take out, "p", classes.kicker(), "Get started", allocator)?
    out = ui.text_el(take out, "h1", "From zero to a verified program", allocator)?
    out = ui.class_text_el(take out, "p", classes.lede(), "Edda is built to be written by an LLM — you don't learn the language first, your agent does. Two choices shape what you get: your coding agent (the harness) and the model behind it. Pick both, point the agent at this page, and you're about ten minutes from a built, contract-verified edda program on your machine.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _section_intent(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "The short path", allocator)?
    out = ui.text_el(take out, "p", "If your agent can browse the web, you barely have to do anything. Say this to it:", allocator)?
    out = _pre(take out, "I want to use the Edda language — edda-lang.org", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "It finds the site, reads its own setup at ", allocator)?
    out = ui.link(take out, "/get-started/agent", "/get-started/agent", allocator)?
    out = markup.text(take out, ", places the reference for your harness, and asks you about the optional guardrails before touching your project. The rest of this page is the same journey, done by hand — read on if you'd rather understand each step.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_why(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Why there's a setup step", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Edda isn't in any model's training data. So the one trick that makes everything work is having your agent read the language reference (", allocator)?
    out = ui.link(take out, "/AGENTS.md", "AGENTS.md", allocator)?
    out = markup.text(take out, ") before it writes a line — after that, the compiler checks its work. You don't change your workflow; you add one file your agent reads, and optionally switch on some guardrails. These steps shrink over time: prebuilt toolchains are landing, and models will eventually see edda.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_div(take out, classes.note(), allocator)?
    out = ui.text_el(take out, "p", "Which compiler am I using? Today you're building with edda's reference compiler — the Rust bootstrap. The native compiler is written in edda itself, type-checks its own full source, and emits binaries through its own backend; we're closing the last behavioral-parity gap before it replaces the bootstrap. Same language, same checks, either way — everything you build now carries forward.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_harness(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Choose your harness", allocator)?
    out = ui.text_el(take out, "p", "Every major coding agent loads a project context file automatically. The only per-tool difference is which file it reads and whether it can run the optional reading-discipline hooks. Edda works with all of them — pick the one you already use.", allocator)?
    out = markup.el(take out, "table", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "th", "Harness", allocator)?
    out = ui.text_el(take out, "th", "Context file it reads", allocator)?
    out = ui.text_el(take out, "th", "Optional hooks", allocator)?
    out = markup.end(take out, allocator)?
    out = _harness_row(take out, "Claude Code", "CLAUDE.md (imports AGENTS.md)", "Yes", allocator)?
    out = _harness_row(take out, "Cursor", "AGENTS.md at the repo root", "Yes", allocator)?
    out = _harness_row(take out, "OpenAI Codex", "AGENTS.md at the repo root", "Yes", allocator)?
    out = _harness_row(take out, "GitHub Copilot", ".github/copilot-instructions.md", "Yes", allocator)?
    out = _harness_row(take out, "Gemini CLI", "AGENTS.md at the repo root", "Yes", allocator)?
    out = _harness_row(take out, "Windsurf", ".windsurfrules (points to AGENTS.md)", "Yes", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Not on the list? Drop ", allocator)?
    out = ui.code(take out, "AGENTS.md", allocator)?
    out = markup.text(take out, " at your repo root — it's the cross-tool standard 30+ agents already read. The per-tool file above just makes your agent load it every session; ", allocator)?
    out = ui.link(take out, "/get-started/agent", "the agent setup page", allocator)?
    out = markup.text(take out, " has the exact snippet, and your agent can place it itself.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_model(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Choose your model", allocator)?
    out = ui.text_el(take out, "p", "This choice matters more than the harness. Because edda isn't in training data, your agent works from the reference it just read, not from memory — and that rewards raw capability. Use your harness's strongest, current model, not its fast or mini tier.", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A frontier model reads ", allocator)?
    out = ui.code(take out, "AGENTS.md", allocator)?
    out = markup.text(take out, " once and writes correct edda; a small model guesses Rust- or Swift-shaped syntax and then fights the compiler over it. Edda's own compiler, standard library, and this website are all written this way — by top-tier models reading the same reference you're about to hand yours.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Rule of thumb: if your harness offers a \"thinking\", \"pro\", or flagship tier, use it here. The ten-minute loop below assumes a capable model — a weak one will still work, but it'll take more turns.", allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_toolchain(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "1. Install the toolchain", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "One line installs a self-contained toolchain — the ", allocator)?
    out = ui.code(take out, "edda", allocator)?
    out = markup.text(take out, " binary, its LLVM runtime, and a vendored ", allocator)?
    out = ui.code(take out, "std", allocator)?
    out = markup.text(take out, " and ", allocator)?
    out = ui.code(take out, "runes", allocator)?
    out = markup.text(take out, ". No Rust, no LLVM, no Z3 to install, and no environment variables to set — just a system linker (MSVC Build Tools on Windows, lld/mold on Linux, the Xcode Command Line Tools on macOS).", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Windows (PowerShell)", allocator)?
    out = _pre(take out, "irm https://raw.githubusercontent.com/edda-lang/edda-bootstrap/main/install.ps1 | iex", allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Linux / macOS", allocator)?
    out = _pre(take out, "curl -fsSL https://raw.githubusercontent.com/edda-lang/edda-bootstrap/main/install.sh | bash", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "The installer downloads the archive for your platform, unpacks it, and puts ", allocator)?
    out = ui.code(take out, "edda", allocator)?
    out = markup.text(take out, " on your PATH. Confirm it with ", allocator)?
    out = ui.code(take out, "edda version", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Platform status: Windows (x86-64-windows-msvc) is available now and is the verified platform. Linux and macOS archives are still rolling out through CI — until yours lands the installer reports \"no release asset for <platform>\"; in the meantime build the reference compiler from source (see the edda-bootstrap README) and point EDDA_STDLIB_ROOT at a checkout's std. If you're on Linux or macOS, your bug report (or \"it worked\") is the most useful thing you can send back.", allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_project(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "2. Create a project", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A package is a ", allocator)?
    out = ui.code(take out, "package.toml", allocator)?
    out = markup.text(take out, " plus a ", allocator)?
    out = ui.code(take out, "src/", allocator)?
    out = markup.text(take out, " directory. Make a small but real one — one capability, one contract — so the very first build proves something.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "package.toml", allocator)?
    out = _pre(take out, "[package]\nname = \"hello\"\nversion = \"0.1.0\"\nroot_namespace = \"hello\"\n\n[build]\ndefault_target = \"x86-64-linux-gnu\"    # your host: x86-64-windows-msvc, aarch64-macos-darwin, ...", allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "src/main.ea", allocator)?
    out = _pre(take out, "module hello.main\n\nimport std.io.stream\n\nfunction non_negative(x: i64) -> i64\n    requires x >= 0\n    ensures result >= 0\n{\n    return x\n}\n\npublic function main(out: Stdout) -> ()\n    with {out}\n{\n    let y = non_negative(7)\n    out.print_line(f\"non_negative(7) = {y}\")\n}", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Every capability ", allocator)?
    out = ui.code(take out, "main", allocator)?
    out = markup.text(take out, " may use is named in its signature — this program holds only ", allocator)?
    out = ui.code(take out, "Stdout", allocator)?
    out = markup.text(take out, ", so it can only print. The ", allocator)?
    out = ui.code(take out, "requires", allocator)?
    out = markup.text(take out, " and ", allocator)?
    out = ui.code(take out, "ensures", allocator)?
    out = markup.text(take out, " clauses are a contract the compiler checks at build.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_build(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "3. Build and run", allocator)?
    out = markup.el(take out, "table", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "th", "Command", allocator)?
    out = ui.text_el(take out, "th", "Does", allocator)?
    out = markup.end(take out, allocator)?
    out = _build_row(take out, "edda check", "typecheck only — the fast loop", allocator)?
    out = _build_row(take out, "edda build", "typecheck, discharge every contract, and emit a native binary", allocator)?
    out = _build_row(take out, "edda run", "build, then execute the binary", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "From the project directory, ", allocator)?
    out = ui.code(take out, "edda run", allocator)?
    out = markup.text(take out, " prints:", allocator)?
    out = markup.end(take out, allocator)?
    out = _pre(take out, "non_negative(7) = 7", allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_break(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "4. Break it — watch the build refuse", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "This is why edda exists. Delete the ", allocator)?
    out = _hl(take out, classes.del(), "requires x >= 0", allocator)?
    out = markup.text(take out, " line from ", allocator)?
    out = ui.code(take out, "non_negative", allocator)?
    out = markup.text(take out, " and build again. The compiler refuses — and hands you the exact input that breaks the contract:", allocator)?
    out = markup.end(take out, allocator)?
    out = _pre(take out, "error[refinement_unproven]: ensures clause 0: (result >= 0)\n --> src/main.ea:5:5\n    note: counter-example:\n    note:   result = -1\n    note:   x = -1", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Without the precondition, the function can no longer guarantee a non-negative result — the solver finds ", allocator)?
    out = ui.code(take out, "x = -1", allocator)?
    out = markup.text(take out, " and rejects the program before it ever runs. An agent-introduced bug that violates a contract fails the build with a concrete counter-example, not a runtime surprise.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_hooks(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Optional: reading-discipline hooks", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Edda ships two small hook scripts that make one habit mechanical: read the compiler's structure map (", allocator)?
    out = ui.code(take out, "index.toon", allocator)?
    out = markup.text(take out, ") for a directory before editing its source, and don't read whole oversized files at once. They keep an agent grounded on a large codebase and cut wasted tokens — and they're portable to every harness in the table above, not just Claude Code.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "They're opt-in. Your agent will explain them and ask before installing anything; you can read the scripts first — ", allocator)?
    out = ui.link(take out, "/hooks/toon_gate.py", "toon_gate.py", allocator)?
    out = markup.text(take out, " is about forty lines. Setup per harness is on ", allocator)?
    out = ui.link(take out, "/get-started/agent", "the agent setup page", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_agent(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Hand it to your agent", allocator)?
    out = ui.text_el(take out, "p", "The point of edda is that your agent writes it. Once the reference is in place, paste this:", allocator)?
    out = _pre(take out, "Read AGENTS.md (the edda language reference). Then build me <what you\nwant> in edda, in this project. Run `edda build` after every change and\nfix exactly what it reports — the build is the source of truth.", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = ui.link(take out, "/AGENTS.md", "AGENTS.md", allocator)?
    out = markup.text(take out, " is the canonical, agent-facing language reference; ", allocator)?
    out = ui.link(take out, "/get-started/agent", "/get-started/agent", allocator)?
    out = markup.text(take out, " is the full self-setup your agent can follow on its own. Edda isn't in most models' training data, so reading the reference first is what makes the loop work.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _section_next(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Next", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Read ", allocator)?
    out = ui.link(take out, "/language", "the language pages", allocator)?
    out = markup.text(take out, ", learn why the build refuses bad code at ", allocator)?
    out = ui.link(take out, "/verification", "verification", allocator)?
    out = markup.text(take out, ", and see how to help at ", allocator)?
    out = ui.link(take out, "/contribute", "contribute", allocator)?
    out = markup.text(take out, ". The source lives at ", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang/edda", "edda-lang/edda", allocator)?
    out = markup.text(take out, " and ", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang/edda-bootstrap", "edda-lang/edda-bootstrap", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "div", allocator)?
    out = markup.attr(take out, "class", classes.btns(), allocator)?
    out = markup.attr(take out, "style", "margin-top:1.6rem", allocator)?
    out = ui.class_link(take out, f"{classes.btn()} {classes.primary()}", "/language", "Read the language", allocator)?
    out = ui.class_link(take out, f"{classes.btn()} {classes.ghost()}", "/get-started/agent", "For your agent", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _pre(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = markup.text(take out, body, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _hl(h: take markup.Html, class_name: String, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "span", allocator)?
    out = markup.attr(take out, "class", class_name, allocator)?
    out = markup.text(take out, body, allocator)?
    return markup.end(take out, allocator)?
}

function _build_row(h: take markup.Html, command: String, does: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "tr", allocator)?
    out = markup.el(take out, "td", allocator)?
    out = ui.code(take out, command, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.text_el(take out, "td", does, allocator)?
    return markup.end(take out, allocator)?
}

function _harness_row(h: take markup.Html, name: String, reads: String, hooks: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "tr", allocator)?
    out = ui.text_el(take out, "td", name, allocator)?
    out = markup.el(take out, "td", allocator)?
    out = ui.code(take out, reads, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.text_el(take out, "td", hooks, allocator)?
    return markup.end(take out, allocator)?
}

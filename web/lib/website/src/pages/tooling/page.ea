module website.pages.tooling.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.page_head(take h, "Reference", "Tooling", "Because every structural fact is on the source surface, the compiler already computes what an IDE or a model needs to query. A long-lived daemon serves it. There is no separate doc generator, annotation scraper, or linter re-deriving what the typechecker already knows.", allocator)?
    out = _compiler_service(take out, allocator)?
    out = _mcp(take out, allocator)?
    out = _structure_map(take out, allocator)?
    out = _diagnostics(take out, allocator)?
    return _cli(take out, allocator)?
}

function _compiler_service(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "The compiler as a service", allocator)?
    out = ui.text_el(take out, "p", "The CLI is one client of the compiler, not the compiler itself. The IDE is a second client over LSP, and a model is a third over MCP. All three talk to one daemon that holds the parsed AST, the elaborated MIR, the type environment, the obligation and spec caches, and the structure index in memory, keyed by content hash. The core is synchronous on purpose, so a given project state and query always return the same answer.", allocator)?
    return ui.close_section(take out, allocator)?
}

function _open_table(h: take markup.Html, head_a: String, head_b: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "table", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "th", head_a, allocator)?
    out = ui.text_el(take out, "th", head_b, allocator)?
    return markup.end(take out, allocator)?
}

function _code_row(h: take markup.Html, code_body: String, does: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "tr", allocator)?
    out = markup.el(take out, "td", allocator)?
    out = ui.code(take out, code_body, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.text_el(take out, "td", does, allocator)?
    return markup.end(take out, allocator)?
}

function _mcp(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "MCP", allocator)?
    out = ui.text_el(take out, "p", "The Model Context Protocol is how a model talks to the compiler: the same typed protocol the IDE uses. Seven namespaces are fixed for V1.0, and method shapes do not change across V1.x, so a client written once keeps working.", allocator)?
    out = _open_table(take out, "Namespace", "Handles", allocator)?
    out = _code_row(take out, "client.*", "handshake, project and document lifecycle", allocator)?
    out = _code_row(take out, "build.*", "check, build, run, test, bench", allocator)?
    out = _code_row(take out, "codegen.*", "spec materialization", allocator)?
    out = _code_row(take out, "inspect.*", "AST, diagnostics, structure map, contract diff, completions, synthesis", allocator)?
    out = _code_row(take out, "edit.*", "structural edits, addressed by qualified name", allocator)?
    out = _code_row(take out, "typecheck.*", "trust points, decreases obligations, traces", allocator)?
    out = _code_row(take out, "layout.*", "comptime size, align, offset", allocator)?
    out = markup.end(take out, allocator)?
    out = _mcp_muted(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _mcp_muted(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "Adding a precondition and verifying it is two calls, ", allocator)?
    out = ui.code(take out, "edit.signature.requires.add", allocator)?
    out = markup.text(take out, " then ", allocator)?
    out = ui.code(take out, "build.check", allocator)?
    out = markup.text(take out, ", both answered from the same in-memory state with no file written in between.", allocator)?
    return markup.end(take out, allocator)?
}

function _structure_map(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "The structure map", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "For each directory of source, the compiler writes an ", allocator)?
    out = ui.code(take out, "index.toon", allocator)?
    out = markup.text(take out, " from its own data structures. It stays in sync because there is no separate annotation to drift. Each entry carries the full signature, the functions it calls, the transitive effects it can reach, the refinements on it, the specs it instantiates, and every trust point: a list of each place the verifier was told to take a claim on faith.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = _structure_map_cards(take out, allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _structure_map_cards(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    let out = ui.card(take h, "", "Reading stays directory-sized", "The map only helps if a directory's index stays small, so the compiler warns when one would exceed a line threshold, or when filenames encode a hierarchy that should be a directory. The defaults pull a codebase toward depth-first layout from the first file.", allocator)?
    return ui.card(take out, "", "Structural edits", "An edit is a function of the source, the edit spec, and a target named by qualified name rather than line, so it survives changes around it. Edits apply as one in-memory transaction. Renaming a field rewrites every use or rolls back whole. Generated spec artifacts are read-only.", allocator)?
}

function _diagnostics(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Diagnostics and synthesis", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A diagnostic is a structured object: its class, the span in bytes and line-column, the elaborated form the typechecker saw, the chain of in-scope facts, a counterexample written as concrete edda values, and suggested edits in the shape an LSP code action expects. The compiler can also propose code, either as typed completions ranked by how well they satisfy the refinements in scope, or as goal-directed synthesis that searches for a body discharging the ", allocator)?
    out = ui.code(take out, "ensures", allocator)?
    out = markup.text(take out, " clause against the same solver the build uses.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _cli(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "The command line", allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Each verb maps one-to-one to an MCP method.", allocator)?
    out = _open_table(take out, "Command", "Does", allocator)?
    out = _code_row(take out, "edda check", "typecheck and discharge refinements, no codegen", allocator)?
    out = _code_row(take out, "edda build", "check, then codegen and link", allocator)?
    out = _code_row(take out, "edda run", "build and execute", allocator)?
    out = _code_row(take out, "edda test --properties", "run tests, including properties derived from refinements", allocator)?
    out = _code_row(take out, "edda structmap --check", "emit the structure map, or fail if it is stale", allocator)?
    out = _code_row(take out, "edda contract-diff a b", "report the contract change between two refs", allocator)?
    out = _code_row(take out, "edda lint --trust-points", "list every trust annotation in scope", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.next_links(take out, "/distribution", "Distribution →", "/get-started", "Get started →", allocator)?
    return ui.close_section(take out, allocator)?
}

module website.pages.verification.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = _head(take h, allocator)?
    out = _discharge_section(take out, allocator)?
    out = _certificates_section(take out, allocator)?
    out = _termination_section(take out, allocator)?
    out = _cards_section(take out, allocator)?
    return _trust_section(take out, allocator)?
}

function _head(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "header", allocator)?
    out = markup.attr(take out, "class", classes.page_head(), allocator)?
    out = ui.open_div(take out, classes.wrap(), allocator)?
    out = ui.class_text_el(take out, "p", classes.kicker(), "Reference", allocator)?
    out = ui.text_el(take out, "h1", "Verification", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.lede(), allocator)?
    out = markup.text(take out, "edda's central guarantee is Article IV: if ", allocator)?
    out = ui.code(take out, "edda build", allocator)?
    out = markup.text(take out, " succeeds, every property it proved holds — except where a trust annotation says otherwise, and every exception is written down.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _discharge_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "How a contract is discharged", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Each refinement compiles to an obligation: a predicate to prove, a context of every fact in scope, and the sorts of the symbols involved. The compiler hands it to an SMT solver, which proves ", allocator)?
    out = ui.code(take out, "context implies predicate", allocator)?
    out = markup.text(take out, " by checking the negation for unsatisfiability. An ", allocator)?
    out = ui.code(take out, "unsat", allocator)?
    out = markup.text(take out, " result discharges the obligation. A ", allocator)?
    out = ui.code(take out, "sat", allocator)?
    out = markup.text(take out, " result is a counterexample, rendered back into edda values rather than left as a raw solver model. There is no warning level for an obligation that does not discharge; the build fails.", allocator)?
    out = markup.end(take out, allocator)?
    out = _fragment(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _fragment(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.text_el(take h, "h3", "The decidable fragment", allocator)?
    out = ui.text_el(take out, "p", "The fragment is chosen so that every obligation terminates with a definite answer, rather than timing out. It is the combination of these theories:", allocator)?
    out = _theory_table(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "In SMT-LIB terms, ", allocator)?
    out = ui.code(take out, "AUFLIA + extensionality + bounded quantifiers", allocator)?
    out = markup.text(take out, ". Non-linear arithmetic, bitvectors, floating-point predicates, and unbounded quantifiers fall outside it. Where they are undecidable, they stay outside permanently.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "The native compiler discharges this fragment with its own in-tree solver — a CDCL(T) core that runs in-process, with no external dependency. The Rust bootstrap that builds it today uses an embedded Z3 over the identical fragment, so a proof one accepts, the other accepts too.", allocator)?
    return markup.end(take out, allocator)?
}

function _theory_table(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "table", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "th", "Theory", allocator)?
    out = ui.text_el(take out, "th", "Covers", allocator)?
    out = markup.end(take out, allocator)?
    out = _theory_row(take out, "EUF", "user types and constructors, by congruence closure", allocator)?
    out = _theory_row(take out, "LIA", "addition, subtraction, and multiplication by a constant, over integers", allocator)?
    out = _theory_row(take out, "Bool", "propositional connectives", allocator)?
    out = _theory_row(take out, "Extensional arrays", "read, write, select, store, with extensionality", allocator)?
    out = markup.el(take out, "tr", allocator)?
    out = ui.text_el(take out, "td", "Bounded quantifiers", allocator)?
    out = markup.el(take out, "td", allocator)?
    out = ui.code(take out, "forall i in 0..<n: P(i)", allocator)?
    out = markup.text(take out, " over a finite, static domain", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _theory_row(h: take markup.Html, theory: String, covers: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "tr", allocator)?
    out = ui.text_el(take out, "td", theory, allocator)?
    out = ui.text_el(take out, "td", covers, allocator)?
    return markup.end(take out, allocator)?
}

function _certificates_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Certificates and the re-checker", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Each discharged obligation produces a certificate, one of five kinds: an SMT unsat core, a comptime trace, a built-in obligation, a recorded ", allocator)?
    out = ui.code(take out, "@unverified", allocator)?
    out = markup.text(take out, " reason, or a recorded ", allocator)?
    out = ui.code(take out, "@trust", allocator)?
    out = markup.text(take out, " reason. Certificates are content-addressed and cached under the obligation and its context.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A separate verifier, around 500 lines, sits between the cache and the build and re-checks every cached ", allocator)?
    out = ui.code(take out, "unsat", allocator)?
    out = markup.text(take out, " claim. It reconstructs the obligation from the canonical encoder and re-runs the solver from scratch, ignoring the cached core. If the two disagree, the build fails. The cache is only a hint the verifier can reject: because every cached result is re-derived by an independent check before it is trusted, a poisoned or stale entry can never slip a false proof into a build.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _termination_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Termination", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A recursive function or an unbounded ", allocator)?
    out = ui.code(take out, "loop", allocator)?
    out = markup.text(take out, " either supplies a ", allocator)?
    out = ui.code(take out, "decreases", allocator)?
    out = markup.text(take out, " measure that strictly drops and is bounded below, or it admits ", allocator)?
    out = ui.code(take out, "effect divergence", allocator)?
    out = markup.text(take out, " in its row. There is no third option, so divergence becomes a property a caller can see and decide to inherit.", allocator)?
    out = markup.end(take out, allocator)?
    out = _factorial_code(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _factorial_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = ui.class_text_el(take out, "span", classes.fn(), "factorial", allocator)?
    out = markup.text(take out, "(n: ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "i64", allocator)?
    out = markup.text(take out, ") -> ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "i64", allocator)?
    out = markup.text(take out, "\n    ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "requires", allocator)?
    out = markup.text(take out, " n >= 0\n    ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "decreases", allocator)?
    out = markup.text(take out, " n\n{\n    ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "if", allocator)?
    out = markup.text(take out, " n == 0 { ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "return", allocator)?
    out = markup.text(take out, " 1 }\n    ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "return", allocator)?
    out = markup.text(take out, " n * factorial(n - 1)\n}", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _cards_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Properties, stability, contract diff", allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g3()}", allocator)?
    out = _pbt_card(take out, allocator)?
    out = _stability_card(take out, allocator)?
    out = _contract_diff_card(take out, allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _pbt_card(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.card(), allocator)?
    out = ui.text_el(take out, "h3", "Property-based testing", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Every ", allocator)?
    out = ui.code(take out, "requires", allocator)?
    out = markup.text(take out, " and ", allocator)?
    out = ui.code(take out, "ensures", allocator)?
    out = markup.text(take out, " is also a runnable property. The compiler builds input generators from the refinement structure and shrinks a failure toward a minimal counterexample.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _stability_card(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.card(), allocator)?
    out = ui.text_el(take out, "h3", "Stability", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "The ", allocator)?
    out = ui.code(take out, "stable", allocator)?
    out = markup.text(take out, " keyword asserts equal output for equal input across runs and machines. It is enforced by an effect-row whitelist, a callee whitelist, and a ban on iterating hash maps.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _contract_diff_card(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.card(), allocator)?
    out = ui.text_el(take out, "h3", "Contract diff", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Each signature has a BLAKE3 contract hash. ", allocator)?
    out = ui.code(take out, "edda contract-diff", allocator)?
    out = markup.text(take out, " reports the exact change between two versions, which is what makes an automated edit reviewable.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _trust_section(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "When a proof is out of reach", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "The solver is decidable, not omniscient. A claim can depend on a theory the fragment excludes, or come from an external proof, or be true for a reason the encoder will not accept. Two annotations cover these cases. Both require a written reason, both produce certificates that are visibly not SMT proofs, and both are listed by ", allocator)?
    out = ui.code(take out, "edda lint --trust-points", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = _unverified_block(take out, allocator)?
    out = _trust_block(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "The trust-points list is the project's full exemption surface. A reviewer can read it, CI can fail on an unreviewed addition, and a published package carries its list in the manifest.", allocator)?
    out = ui.next_links(take out, "/concurrency", "Concurrency →", "/tooling", "Tooling →", allocator)?
    return ui.close_section(take out, allocator)?
}

function _unverified_block(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "div", allocator)?
    out = _gcd_code(take out, allocator)?
    out = ui.class_text_el(take out, "p", classes.muted(), "Whole-function. Discharge is skipped, but the compiler still synthesizes property tests from the refinements, so the exemption is not silent.", allocator)?
    return markup.end(take out, allocator)?
}

function _gcd_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = ui.class_text_el(take out, "span", classes.cm(), "@unverified", allocator)?
    out = markup.text(take out, "(reason: \"Knuth TAOCP 2 4.5.3\")\n", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = ui.class_text_el(take out, "span", classes.fn(), "gcd_extended", allocator)?
    out = markup.text(take out, "(a: ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "i64", allocator)?
    out = markup.text(take out, ", b: ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "i64", allocator)?
    out = markup.text(take out, ") -> ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "GcdResult", allocator)?
    out = markup.text(take out, "\n    ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "requires", allocator)?
    out = markup.text(take out, " a > 0 ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "and", allocator)?
    out = markup.text(take out, " b > 0\n{ ... }", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _trust_block(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "div", allocator)?
    out = _trust_code(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "One site. It accepts a single obligation the verifier cannot reach. There is no ", allocator)?
    out = ui.code(take out, "assume", allocator)?
    out = markup.text(take out, ": an axiom could quietly produce a false certificate, and these cannot.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _trust_code(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = ui.class_text_el(take out, "span", classes.cm(), "@trust", allocator)?
    out = markup.text(take out, "(reason: \"bit-shift packing\")\n", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "let", allocator)?
    out = markup.text(take out, " header: ", allocator)?
    out = ui.class_text_el(take out, "span", classes.ty(), "u32", allocator)?
    out = markup.text(take out, " = (version << 8) ", allocator)?
    out = ui.class_text_el(take out, "span", classes.kw(), "or", allocator)?
    out = markup.text(take out, " kind", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

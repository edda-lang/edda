module website.pages.docs.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.page_head(take h, "Index", "All pages", "The map of this site.", allocator)?
    out = ui.open_section(take out, "", allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g3()}", allocator)?
    out = _cards_learn(take out, allocator)?
    out = _cards_build(take out, allocator)?
    out = _cards_reference(take out, allocator)?
    out = _cards_project(take out, allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _cards_learn(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    let out = ui.card_link(take h, "Learn", "/get-started", "Get started", "Install the toolchain, write a first program, read a first diagnostic.", allocator)?
    return ui.card_link(take out, "Learn", "/design", "Design", "From the signature to the structure map — the decisions that connect them.", allocator)?
}

function _cards_build(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.card_link(take h, "Build", "/build/servers", "Network services", "Capability-scoped sockets, errors on the row, structured connection handling.", allocator)?
    out = ui.card_link(take out, "Build", "/build/cli", "Command-line tools", "One static binary whose entry signature is a complete audit of its authority.", allocator)?
    out = ui.card_link(take out, "Build", "/build/embedded", "Embedded", "Graded allocation, linear peripherals, wire-exact layout.", allocator)?
    return ui.card_link(take out, "Build", "/build/wasm", "WebAssembly", "The capability model, compiled to the sandbox that agrees with it.", allocator)?
}

function _cards_reference(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.card_link(take h, "Reference", "/language", "Language", "Functions, types, modes, effect rows, refinements, specs, comptime, derive.", allocator)?
    out = ui.card_link(take out, "Reference", "/verification", "Verification", "SMT discharge, the decidable fragment, certificates, termination, trust.", allocator)?
    out = ui.card_link(take out, "Reference", "/concurrency", "Concurrency", "Structured concurrency, tasks, coherence regions, typestate, linear types.", allocator)?
    out = ui.card_link(take out, "Reference", "/tooling", "Tooling", "The compiler as a service, the structure map, structural edits, the CLI.", allocator)?
    return ui.card_link(take out, "Reference", "/distribution", "Distribution", "Content addressing, the .rune pack, the three hashes, the Mímir registry.", allocator)?
}

function _cards_project(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    return ui.card_link(take h, "Source", "https://github.com/edda-lang/edda", "GitHub", "The compiler, standard library, runes, and this site.", allocator)?
}

module website.pages.concurrency.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = _head(take h, allocator)?
    out = _structured(take out, allocator)?
    out = _tasks(take out, allocator)?
    out = _coherence(take out, allocator)?
    return _typestate(take out, allocator)?
}

function _head(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "header", allocator)?
    out = markup.attr(take out, "class", classes.page_head(), allocator)?
    out = ui.open_div(take out, classes.wrap(), allocator)?
    out = ui.class_text_el(take out, "p", classes.kicker(), "Reference", allocator)?
    out = ui.text_el(take out, "h1", "Concurrency and safety", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.lede(), allocator)?
    out = markup.text(take out, "Edda has two scoped execution forms that address different problems. ", allocator)?
    out = ui.code(take out, "scope(exec)", allocator)?
    out = markup.text(take out, " bounds the lifetime of concurrent tasks; ", allocator)?
    out = ui.code(take out, "scope(coherence)", allocator)?
    out = markup.text(take out, " bounds what an outside observer can see mid-operation. Both compose with type-state and with linear types.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _kw(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "span", allocator)?
    out = markup.attr(take out, "class", classes.kw(), allocator)?
    out = markup.text(take out, body, allocator)?
    return markup.end(take out, allocator)?
}

function _fn(h: take markup.Html, body: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "span", allocator)?
    out = markup.attr(take out, "class", classes.fn(), allocator)?
    out = markup.text(take out, body, allocator)?
    return markup.end(take out, allocator)?
}

function _structured(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Structured concurrency", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A function that runs concurrent work declares ", allocator)?
    out = ui.code(take out, "exec", allocator)?
    out = markup.text(take out, " in its row; there is no ambient executor. Inside ", allocator)?
    out = ui.code(take out, "scope(exec)", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "spawn", allocator)?
    out = markup.text(take out, " opens a child task, and the scope cannot return while a child is still running. A ", allocator)?
    out = ui.code(take out, "mutable", allocator)?
    out = markup.text(take out, " reference cannot cross into a spawned task, so a value the parent keeps is cloned and handed over with ", allocator)?
    out = ui.code(take out, "take", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    out = _code_structured(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "There is no syntax for a task that outlives its scope, so a detached spawn is not something an author can write by accident. If a failure makes the scope ", allocator)?
    out = ui.code(take out, "raise", allocator)?
    out = markup.text(take out, ", its siblings are cancelled at their next checkpoint.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _code_structured(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = _kw(take out, "scope", allocator)?
    out = markup.text(take out, "(exec) group {\n    ", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " ta = group.spawn { net.get_safe(a) }\n    ", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " tb = group.spawn { net.get_safe(b) }\n    ", allocator)?
    out = _kw(take out, "return match", allocator)?
    out = markup.text(take out, " (ta.await, tb.await) {\n        ", allocator)?
    out = _kw(take out, "case", allocator)?
    out = markup.text(take out, " (.ok(", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " ba), .ok(", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " bb)) => (ba, bb)\n        ", allocator)?
    out = _kw(take out, "case", allocator)?
    out = markup.text(take out, " (.err(", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " e), _)           => ", allocator)?
    out = _kw(take out, "raise", allocator)?
    out = markup.text(take out, " e\n        ", allocator)?
    out = _kw(take out, "case", allocator)?
    out = markup.text(take out, " (_, .err(", allocator)?
    out = _kw(take out, "let", allocator)?
    out = markup.text(take out, " e))           => ", allocator)?
    out = _kw(take out, "raise", allocator)?
    out = markup.text(take out, " e\n    }\n}", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _tasks(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Tasks carry errors as values", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A spawn produces a ", allocator)?
    out = ui.code(take out, "linear Task(T)", allocator)?
    out = markup.text(take out, ", consumed by exactly one of ", allocator)?
    out = ui.code(take out, "await", allocator)?
    out = markup.text(take out, ", ", allocator)?
    out = ui.code(take out, "detach", allocator)?
    out = markup.text(take out, ", or ", allocator)?
    out = ui.code(take out, "cancel_and_await", allocator)?
    out = markup.text(take out, ". Dropping the handle is a compile error. A task body's row may carry capabilities and ", allocator)?
    out = ui.code(take out, "cancellation", allocator)?
    out = markup.text(take out, " but not ", allocator)?
    out = ui.code(take out, "err: E", allocator)?
    out = markup.text(take out, ": once a value crosses the task boundary there is no shared call stack to carry the error contract, so a fallible body returns ", allocator)?
    out = ui.code(take out, "Outcome(T, E)", allocator)?
    out = markup.text(take out, " and the join matches on it.", allocator)?
    out = markup.end(take out, allocator)?
    out = _code_tasks(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "Cancellation is an effect. It is handled with ", allocator)?
    out = ui.code(take out, "handle cancellation -> cleanup { ... }", allocator)?
    out = markup.text(take out, " or absorbed by the enclosing scope. ", allocator)?
    out = ui.code(take out, "?", allocator)?
    out = markup.text(take out, " does not propagate it, so there is no ", allocator)?
    out = ui.code(take out, "await?", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _code_tasks(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = _kw(take out, "public function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = _fn(take out, "detach", allocator)?
    out = markup.text(take out, "(t: ", allocator)?
    out = _kw(take out, "take", allocator)?
    out = markup.text(take out, " Task) -> ()\n", allocator)?
    out = _kw(take out, "public function", allocator)?
    out = markup.text(take out, " ", allocator)?
    out = _fn(take out, "cancel_and_await", allocator)?
    out = markup.text(take out, "(t: ", allocator)?
    out = _kw(take out, "take", allocator)?
    out = markup.text(take out, " Task) -> () ", allocator)?
    out = _kw(take out, "with", allocator)?
    out = markup.text(take out, " {cancellation}", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _coherence(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Coherence regions", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "Inside ", allocator)?
    out = ui.code(take out, "scope(coherence)", allocator)?
    out = markup.text(take out, ", the effects of the body, allocations, mutations, capability calls, are not visible to an outside observer until the closing brace. The guarantee is that no caller sees the partial state. It is not a transaction: if an operation raises partway through, the partial state remains. A ", allocator)?
    out = ui.code(take out, "mutable", allocator)?
    out = markup.text(take out, " parameter's refinements are re-checked at the region's exit.", allocator)?
    out = markup.end(take out, allocator)?
    out = _code_coherence(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.muted(), allocator)?
    out = markup.text(take out, "The two forms nest in either order. Putting ", allocator)?
    out = ui.code(take out, "scope(exec)", allocator)?
    out = markup.text(take out, " inside ", allocator)?
    out = ui.code(take out, "scope(coherence)", allocator)?
    out = markup.text(take out, " builds a result in parallel while its intermediate states stay hidden until every task has finished.", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _code_coherence(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "pre", allocator)?
    out = markup.el(take out, "code", allocator)?
    out = _kw(take out, "scope", allocator)?
    out = markup.text(take out, "(coherence) build {\n    ", allocator)?
    out = _kw(take out, "for", allocator)?
    out = markup.text(take out, " entry ", allocator)?
    out = _kw(take out, "in", allocator)?
    out = markup.text(take out, " entries {\n        index.insert(entry.key, entry.value)?\n    }\n    index.shrink_to_fit()?\n}", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _typestate(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Type-state and linearity", allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = _typestate_cards(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_div(take out, classes.note(), allocator)?
    out = markup.text(take out, "A ", allocator)?
    out = ui.code(take out, "handle", allocator)?
    out = markup.text(take out, " block must consume any held linear value on both the success and the failure path. Leave one path out and the build reports ", allocator)?
    out = ui.code(take out, "linear_unconsumed", allocator)?
    out = markup.text(take out, ", so a file handle is provably closed on every route through the function.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.next_links(take out, "/tooling", "Tooling →", "/distribution", "Distribution →", allocator)?
    return ui.close_section(take out, allocator)?
}

function _typestate_cards(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_card(take h, "", allocator)?
    out = ui.text_el(take out, "h3", "Type-state on capabilities", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A capability carries its state as a comptime parameter on a spec, and each transition returns a different module type. Reading a closed file or opening one twice is a type error at the call site, with no runtime check. The same mechanism models ", allocator)?
    out = ui.code(take out, "Allocator", allocator)?
    out = markup.text(take out, " as open then closed, and a ", allocator)?
    out = ui.code(take out, "Network", allocator)?
    out = markup.text(take out, " connection through dialing, connected, closing, closed.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_card(take out, "", allocator)?
    out = ui.text_el(take out, "h3", "Linear and affine types", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.text(take out, "A ", allocator)?
    out = ui.code(take out, "linear T", allocator)?
    out = markup.text(take out, " is consumed exactly once on every path; an ", allocator)?
    out = ui.code(take out, "affine T", allocator)?
    out = markup.text(take out, " may be dropped. A linear type declares a destructor that runs on the ", allocator)?
    out = ui.code(take out, "panic", allocator)?
    out = markup.text(take out, " and ", allocator)?
    out = ui.code(take out, "raise", allocator)?
    out = markup.text(take out, " paths, the one place a linear value can be released without violating the discipline, and that destructor's effects must be a subset of the enclosing function's row.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

module website.pages.home.page

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = _hero(take h, allocator)?
    out = _showcase(take out, allocator)?
    return _involved(take out, allocator)?
}

function _hero(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, classes.hero(), allocator)?
    out = markup.el(take out, "p", allocator)?
    out = markup.attr(take out, "class", classes.lede(), allocator)?
    out = markup.text(take out, "A programming language and toolchain enabling LLMs to ", allocator)?
    out = ui.class_link(take out, classes.hl(), "/verification", "build correctly", allocator)?
    out = markup.text(take out, " and codebases to ", allocator)?
    out = ui.class_link(take out, classes.hl(), "/design", "stay coherent", allocator)?
    out = markup.text(take out, ", at any scale.", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.open_div(take out, classes.btns(), allocator)?
    out = ui.class_link(take out, f"{classes.btn()} {classes.primary()}", "/get-started", "Get started", allocator)?
    out = ui.class_link(take out, f"{classes.btn()} {classes.ghost()}", "https://github.com/edda-lang/edda", "View on GitHub", allocator)?
    out = markup.end(take out, allocator)?
    out = ui.text_el(take out, "h2", "Why edda?", allocator)?
    out = ui.open_div(take out, classes.pillars(), allocator)?
    out = _pillar(take out, "Reliable", "/verification", _reliable_body, allocator)?
    out = _pillar(take out, "Nothing hidden", "/language", _nothing_hidden_body, allocator)?
    out = _pillar(take out, "Grows without breaking", "/design", _grows_body, allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

function _showcase(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "section", allocator)?
    out = ui.open_div(take out, classes.wide(), allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = _written_col(take out, allocator)?
    out = _build_col(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang/edda", "See the source", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _written_col(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.wide_col(), allocator)?
    out = ui.text_el(take out, "h2", "Written by LLMs", allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = ui.card(take out, "~197,000", "Self-hosting compiler", "Lines of edda implementing the compiler, lexer through native codegen.", allocator)?
    out = ui.card(take out, "~24,000", "Standard library", "The std.* packages the compiler and every edda program build on.", allocator)?
    out = ui.card(take out, "~28,000", "Package ecosystem", "The runes workspace — reusable libraries distributed through the Mímir registry.", allocator)?
    out = ui.card(take out, "~165,000", "Rust bootstrap", "The reference compiler that builds edda today, while the self-hosted compiler matures.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _pillar(h: take markup.Html, title: String, href: String, render_body: function(take markup.Html, Allocator) -> markup.Html with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.pillar(), allocator)?
    out = markup.el(take out, "h3", allocator)?
    out = ui.link(take out, href, title, allocator)?
    out = markup.end(take out, allocator)?
    out = render_body(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _reliable_body(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "AI-written code can look right and still be wrong. In edda, code can be made to ", allocator)?
    out = ui.class_link(take out, classes.hl(), "/verification", "prove what it claims", allocator)?
    out = markup.text(take out, " before your project can even run, so more mistakes get caught while you're building.", allocator)?
    return markup.end(take out, allocator)?
}

function _nothing_hidden_body(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "Every part of an edda project shows exactly ", allocator)?
    out = ui.class_link(take out, classes.hl(), "/language/effects", "what it can see and touch", allocator)?
    out = markup.text(take out, " — nothing is left as a secret assumption buried in another file. Your AI always knows exactly what it's working with, instead of guessing.", allocator)?
    return markup.end(take out, allocator)?
}

function _grows_body(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "p", allocator)?
    out = markup.text(take out, "Most AI-built projects get harder to work with the bigger they get — the same feature rewritten twice, one small change breaking something unrelated. Edda ", allocator)?
    out = ui.class_link(take out, classes.hl(), "/tooling", "keeps track of your whole project automatically", allocator)?
    out = markup.text(take out, ", so adding your hundredth feature is just as safe as adding your first.", allocator)?
    return markup.end(take out, allocator)?
}

function _build_col(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.wide_col(), allocator)?
    out = ui.text_el(take out, "h2", "Build it in edda", allocator)?
    out = ui.open_div(take out, f"{classes.grid()} {classes.g2()}", allocator)?
    out = ui.card_link(take out, "", "/build/servers", "Web services & APIs", "An HTTP server is authority over a socket, made explicit. Every failure mode lives on the handler's row, and connection handling is structured or it does not compile.", allocator)?
    out = ui.card_link(take out, "", "/build/cli", "Command-line tools", "One static binary, no runtime. The entry signature is a complete, auditable list of every file, socket, and process the tool can reach.", allocator)?
    out = ui.card_link(take out, "", "/build/embedded", "Embedded & firmware", "No garbage collector, no hidden runtime. Allocation is bounded in the signature and proven at build time, with wire-exact memory layout.", allocator)?
    out = ui.card_link(take out, "", "/build/wasm", "WebAssembly & the edge", "A module's imports are its main parameters — the capability model and the sandbox are one and the same, checked end to end.", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _involved(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_section(take h, "", allocator)?
    out = ui.text_el(take out, "h2", "Get involved", allocator)?
    out = markup.el(take out, "p", allocator)?
    out = ui.link(take out, "/design", "Read the design", allocator)?
    out = markup.text(take out, " — how the language is built up, one decision at a time.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang/edda", "Contribute", allocator)?
    out = markup.text(take out, " — the compiler, standard library, and this site are developed in the open.", allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "p", allocator)?
    out = ui.link(take out, "https://www.reddit.com/r/EddaLang/", "Join r/EddaLang", allocator)?
    out = markup.text(take out, " — questions, showcases, and release threads; or write to ", allocator)?
    out = ui.link(take out, "mailto:ea@edda-lang.org", "ea@edda-lang.org", allocator)?
    out = markup.text(take out, ".", allocator)?
    out = markup.end(take out, allocator)?
    return ui.close_section(take out, allocator)?
}

module website.pages.home.sim.beats

import std.mem.alloc
import html.markup

public function render(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "<script>var SIMBEATS=[", allocator)?
    out = _meet(take out, allocator)?
    out = _contracts(take out, allocator)?
    out = _effects(take out, allocator)?
    out = _bounds(take out, allocator)?
    out = _map(take out, allocator)?
    out = _cohesion(take out, allocator)?
    out = _density(take out, allocator)?
    out = _scale(take out, allocator)?
    return markup.raw(take out, "];</script>", allocator)?
}

function _meet(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    let out = markup.raw(take h, "{name:'meet',once:1,beats:[{t:'say',x:'*Hey* there!',ms:2200},{t:'say',x:'Meet *edda*.',ms:2800},{t:'say',x:'A *systems* language built so that code can *prove itself*.',ms:4000},{t:'say',x:'And stay *readable* to a *large language model*.',ms:3400},{t:'live'},{t:'slp',ms:800},", allocator)?
    return markup.raw(take out, "{t:'say',x:'No matter its *size* — an edda codebase that builds is one *optimally architected for future LLM input*.'},{t:'say',x:'Otherwise it simply does *not* build.',ms:3200},{t:'say',x:'Because *optimal input* is what keeps the model producing *optimal output*.'},{t:'say',x:'So edda *enforces* it — the codebase stays within strict *bounds*, per *directory*, at *every* build.'},{t:'grow',x:'Rather than just telling you, let me *show* you what I mean.',ms:4000}]},", allocator)?
}

function _contracts(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'contracts',beats:[{t:'say',x:'This is what edda code looks like. Watch the *signature*.'},{t:'tab',x:'lib/span/src/span.ea'},{t:'dir',x:'span',n:3},", allocator)?
    out = markup.raw(take out, "{t:'type',ls:['module span.span','','public function merge(a: Span, b: Span) -> Span','    ensures result.lo <= a.lo && result.lo <= b.lo','    ensures result.hi >= a.hi && result.hi >= b.hi','{','    return Span { lo: lo_of(a, b), hi: hi_of(a, b) }','}']},{t:'hl',ln:3},{t:'hl',ln:4},", allocator)?
    return markup.raw(take out, "{t:'say',x:'The *contract* rides on the function itself: the merged span must *cover both inputs*.'},{t:'say',x:'Not a comment — a clause the compiler *has to verify*.'},{t:'term',x:'$ edda build',cls:'smfaint'},{t:'slp',ms:1000},{t:'term',x:'build: 3 modules · 0.02s · proofs hold',cls:'smok'},{t:'say',x:'Every build *runs the proofs*. Green means *proven*, not merely compiled.'}]},", allocator)?
}

function _effects(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'effects',beats:[{t:'say',x:'Effects work the same way: a function must *declare everything it touches*.'},{t:'tab',x:'lib/source/src/load.ea'},{t:'dir',x:'source',n:3},{t:'say',x:'Here an agent takes a shortcut — *reading a file without declaring it*.'},", allocator)?
    out = markup.raw(take out, "{t:'type',ls:['module source.load','','function load(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> String {','    return fs.read_to_string(rfs, path, allocator)?','}']},{t:'hl',ln:2},{t:'slp',ms:300},{t:'term',x:'$ edda build',cls:'smfaint'},{t:'slp',ms:1000},{t:'term',x:'error[effect_not_in_row]: load uses capability rfs without declaring it',cls:'smerr'},{t:'term',x:'  note: add it to the signature: with {rfs, allocator, err: fs.FsError}',cls:'smfaint'},", allocator)?
    out = markup.raw(take out, "{t:'say',x:'*Refused*.',ms:1500},{t:'say',x:'Code cannot touch the filesystem, network, or clock without *saying so in its signature*.'},{t:'say',x:'The error names the *exact fix*. The agent applies it.'},", allocator)?
    return markup.raw(take out, "{t:'type',ls:['module source.load','','function load(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> String','    with {rfs, allocator, err: fs.FsError}','{','    return fs.read_to_string(rfs, path, allocator)?','}']},{t:'hl',ln:3},{t:'build',x:'build: 9 modules · proofs hold',cls:'smok'},{t:'say',x:'Green again. *Nothing undeclared can ever ship*.'}]},", allocator)?
}

function _bounds(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'bounds',beats:[{t:'say',x:'It also catches the bugs that matter.'},{t:'say',x:'Here the agent indexes a buffer *without proving the index is in range*.'},{t:'dir',id:'sx',x:'syntax'},{t:'file',id:'tk',x:'token.ea',loc:92},{t:'tab',x:'lib/syntax/src/lexer.ea'},{t:'file',id:'lx',x:'lexer.ea',loc:174},", allocator)?
    out = markup.raw(take out, "{t:'type',ls:['module syntax.lexer','','function peek(bytes: [u8], i: usize) -> u8 {','    return bytes[i]','}']},{t:'hl',ln:3},{t:'slp',ms:300},{t:'term',x:'$ edda build',cls:'smfaint'},{t:'slp',ms:1000},{t:'term',x:'error[refine_failed]: cannot prove i < bytes.len()',cls:'smerr'},{t:'term',x:'  note: bound the parameter: i: usize where i < bytes.len()',cls:'smfaint'},", allocator)?
    out = markup.raw(take out, "{t:'say',x:'The solver *cannot prove the access is safe* — so the binary is *never produced*.'},{t:'type',ls:['module syntax.lexer','','function peek(bytes: [u8], i: usize where i < bytes.len()) -> u8 {','    return bytes[i]','}']},{t:'hl',ln:2},", allocator)?
    return markup.raw(take out, "{t:'build',x:'build: 23 modules · proofs hold',cls:'smok'},{t:'map',id:'mp',x:'31 lines'},{t:'say',x:'One bound added; out-of-bounds is now *impossible*. Not unlikely — impossible.'}]},", allocator)?
}

function _map(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'map',beats:[{t:'say',x:'And notice: the build wrote a file of its own — *index.toon*.'},{t:'say',x:'A *live map* of the directory, derived from *checked facts only*.'},{t:'tab',x:'lib/syntax/index.toon'},", allocator)?
    out = markup.raw(take out, "{t:'show',ls:['loc: src/syntax','','functions[7]{name,sig,eff}:','  peek,(bytes: [u8], i: usize where i < bytes.len()) -> u8','  next,(ts: mutable TokenStream) -> Token · err: ParseError','  expect,(ts: mutable TokenStream, k: TokenKind) -> Token · err: ParseError','  lex_ident,(bytes: [u8], start: usize) -> Ident','  lex_number,(bytes: [u8], start: usize) -> Token · err: ParseError','  span_of,(t: Token) -> Span','  is_keyword,(s: String) -> bool','','calls[3]{from,to}:','  next,peek | lex_ident | lex_number','  expect,next','  lex_number,peek']},{t:'hl',ln:2},", allocator)?
    return markup.raw(take out, "{t:'say',x:'*Signatures*, *effects*, *proofs* — everything a reader needs, in a few lines.'},{t:'say',x:'*Always in sync* with the code — what the agent reads *instead of guessing from prose*.'}]},", allocator)?
}

function _cohesion(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'cohesion',beats:[{t:'say',x:'Those maps only work if every part of the codebase *stays small*.'},{t:'say',x:'So edda *enforces that too*. Watch parser.ea grow.'},{t:'file',id:'as',x:'ast.ea',loc:210},{t:'slp',ms:400},{t:'tab',x:'lib/syntax/src/parser.ea'},{t:'file',id:'pr',x:'parser.ea',loc:120},{t:'tick',id:'pr',from:120,to:663,bg:1},", allocator)?
    out = markup.raw(take out, "{t:'type',spd:20,ls:['function parse_item(ts: mutable TokenStream) -> Item','    with {err: ParseError}','{','    return match peek_kind(ts) {','        case .kw_function => parse_function(mutable ts)','        case .kw_type     => parse_type(mutable ts)','        case .kw_spec     => parse_spec(mutable ts)','    }','}']},{t:'hlr',id:'pr'},", allocator)?
    out = markup.raw(take out, "{t:'term',x:'$ edda build',cls:'smfaint'},{t:'slp',ms:1000},{t:'term',x:'warn[file_low_cohesion]: parser.ea is 663 lines and its call graph splits into 3 clusters',cls:'smwarn'},{t:'term',x:'  note: split it into a subdirectory — the directory tree is the namespace',cls:'smfaint'},{t:'say',x:'Too big — and *no longer one coherent thing*.'},{t:'say',x:'The build pushes back *before the mess can take hold*.'},{t:'say',x:'The agent *splits it*: one bloated file becomes a *directory of three small ones*.'},", allocator)?
    return markup.raw(take out, "{t:'drop',id:'pr'},{t:'dir',id:'pd',x:'parser',sub:1},{t:'file',id:'k1',x:'expr.ea',loc:188,d:2},{t:'file',id:'k2',x:'stmt.ea',loc:174,d:2},{t:'file',id:'k3',x:'decl.ea',loc:161,d:2},{t:'build',x:'build: 31 modules · structure map: 38 lines · proofs hold',cls:'smok'},{t:'right',id:'mp',x:'38 lines'},{t:'slp',ms:1600},{t:'coll',id:'sx',kids:['tk','lx','as','pd','k1','k2','k3','mp'],n:34},{t:'say',x:'syntax/ done — *34 files* in the real compiler, every one *small enough to read whole*.'}]},", allocator)?
}

function _density(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    var out = markup.raw(take h, "{name:'density',beats:[{t:'say',x:'One level up, the *same rule* holds for the *directory itself*.'},{t:'dir',id:'ty',x:'types'},{t:'tab',x:'lib/types/src/check.ea'},{t:'files',pre:'tf',gap:100,ls:[['check.ea',90],['unify.ea',143],['infer.ea',196],['scheme.ea',109],['row.ea',162],['layout.ea',215],['coerce.ea',128],['decl.ea',181],['sig.ea',94],['table.ea',147],['prim.ea',200],['spec_args.ea',113]]},{t:'hlr',id:'ty'},", allocator)?
    out = markup.raw(take out, "{t:'term',x:'$ edda build',cls:'smfaint'},{t:'slp',ms:800},{t:'term',x:'warn[structure_map_too_dense]: lib/types maps to 312 lines (limit 250)',cls:'smwarn'},{t:'term',x:'  note: split the directory so its index reads in one pass',cls:'smfaint'},{t:'say',x:'Twelve files, each fine on its own — but the *map* outgrew one read. *Also refused*.'},", allocator)?
    return markup.raw(take out, "{t:'dropg',pre:'tf',n:12},{t:'dir',id:'g1',x:'check',sub:1},{t:'dir',id:'g2',x:'infer',sub:1},{t:'dir',id:'g3',x:'decl',sub:1},{t:'build',x:'build: structure map regenerated · 41 lines · proofs hold',cls:'smok'},{t:'unhl',id:'ty'},{t:'slp',ms:900},{t:'coll',id:'ty',kids:['g1','g2','g3'],n:32},{t:'say',x:'*File, directory, project* — every level stays *readable whole*.'}]},", allocator)?
}

function _scale(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError}
{
    let out = markup.raw(take h, "{name:'scale',beats:[{t:'say',x:'Every other subsystem of the real compiler was grown *exactly the same way*. Fast-forward.'},{t:'ff'}]},", allocator)?
    return markup.raw(take out, "{name:'close',beats:[{t:'tab',x:'lib/'},{t:'slp',ms:600},{t:'build',x:'build: 553 files · 89,763 lines · 32 subsystems · proofs hold',cls:'smok'},{t:'say',x:'*553 source files, 89,763 lines* — and any directory still reads in a *few hundred tokens*.'},{t:'say',x:'The codebase *never outgrows* the model that writes it.'},{t:'cta'},{t:'slp',ms:7000},{t:'cap'},{t:'slp',ms:1200}]}", allocator)?
}

module website.layout

import std.mem.alloc
import std.text.htmlescape
import html.markup
import local.ui.ui
import local.style.classes
spec std.core.option.Option(String)

public function open_page(h: take markup.Html, title: String, css: String, show_nav_cta: bool, back: Option_String.Option, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.raw(take h, "<!doctype html>", allocator)?
    out = markup.el(take out, "html", allocator)?
    out = markup.attr(take out, "lang", "en", allocator)?
    out = markup.el(take out, "head", allocator)?
    out = markup.raw(take out, "<meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1'><meta name='description' content='Edda is a programming language and toolchain built so a codebase stays coherent enough for an LLM to work in it correctly, no matter how large it grows.'>", allocator)?
    out = markup.raw(take out, "<meta property='og:title' content='edda — a language and toolchain for LLM-coherent codebases'><meta property='og:description' content='A programming language and toolchain enabling LLMs to build correctly and codebases to stay coherent, at any scale.'><meta property='og:type' content='website'><meta name='twitter:card' content='summary'><meta name='theme-color' content='#6d28d9'>", allocator)?
    out = markup.raw(take out, "<link rel='icon' type='image/png' href='data:image/png;base64,'>", allocator)?
    out = markup.raw(take out, "<style>@font-face{font-family:'Instrument Sans';font-style:normal;font-weight:400 700;font-stretch:100%;font-display:swap;src:url(/fonts/instrument-sans-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}", allocator)?
    out = markup.raw(take out, "@font-face{font-family:'Instrument Sans';font-style:normal;font-weight:400 700;font-stretch:100%;font-display:swap;src:url(/fonts/instrument-sans-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}", allocator)?
    out = markup.raw(take out, "@font-face{font-family:'Fragment Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/fragment-mono-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}", allocator)?
    out = markup.raw(take out, "@font-face{font-family:'Fragment Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/fragment-mono-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}</style>", allocator)?
    out = ui.text_el(take out, "title", title, allocator)?
    out = markup.el(take out, "style", allocator)?
    out = markup.raw(take out, css, allocator)?
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = markup.el(take out, "body", allocator)?
    out = _nav(take out, show_nav_cta, allocator)?
    out = markup.el(take out, "main", allocator)?
    return _back_link(take out, back, allocator)?
}

function _back_link(h: take markup.Html, back: Option_String.Option, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    return match back {
        case .none => h
        case .some(let path) => _render_back(take h, path, allocator)?
    }
}

function _render_back(h: take markup.Html, path: String, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.back(), allocator)?
    out = markup.el(take out, "a", allocator)?
    out = markup.attr(take out, "href", path, allocator)?
    out = markup.attr(take out, "onclick", "if(history.length>1){history.back();return false;}", allocator)?
    out = markup.text(take out, "← Back", allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

public function close_page(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.end(take h, allocator)?
    out = _footer(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _nav(h: take markup.Html, show_cta: bool, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "nav", allocator)?
    out = markup.attr(take out, "class", classes.nav(), allocator)?
    out = ui.open_div(take out, classes.row(), allocator)?
    out = ui.class_link(take out, classes.brand(), "/", "edda", allocator)?
    out = ui.open_div(take out, classes.links(), allocator)?
    out = ui.link(take out, "/design", "Design", allocator)?
    out = ui.link(take out, "/language", "Language", allocator)?
    out = ui.link(take out, "/verification", "Verification", allocator)?
    out = ui.link(take out, "/docs", "Docs", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang", "GitHub", allocator)?
    if show_cta {
        out = ui.class_link(take out, classes.cta(), "/get-started", "Get started", allocator)?
    }
    out = markup.end(take out, allocator)?
    out = markup.end(take out, allocator)?
    return markup.end(take out, allocator)?
}

function _foot_learn_col(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "div", allocator)?
    out = ui.text_el(take out, "h5", "Learn", allocator)?
    out = ui.link(take out, "/get-started", "Get started", allocator)?
    out = ui.link(take out, "/get-started/agent", "For your agent", allocator)?
    out = ui.link(take out, "/design", "Design", allocator)?
    out = ui.link(take out, "/build/servers", "Network services", allocator)?
    out = ui.link(take out, "/build/cli", "Command-line tools", allocator)?
    out = ui.link(take out, "/build/embedded", "Embedded", allocator)?
    out = ui.link(take out, "/build/wasm", "WebAssembly", allocator)?
    return markup.end(take out, allocator)?
}

function _foot_reference_col(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "div", allocator)?
    out = ui.text_el(take out, "h5", "Reference", allocator)?
    out = ui.link(take out, "/language", "Language", allocator)?
    out = ui.link(take out, "/verification", "Verification", allocator)?
    out = ui.link(take out, "/concurrency", "Concurrency", allocator)?
    out = ui.link(take out, "/tooling", "Tooling", allocator)?
    out = ui.link(take out, "/distribution", "Distribution", allocator)?
    return markup.end(take out, allocator)?
}

function _foot_project_col(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "div", allocator)?
    out = ui.text_el(take out, "h5", "Project", allocator)?
    out = ui.link(take out, "/contribute", "Contribute", allocator)?
    out = ui.link(take out, "/docs", "All pages", allocator)?
    out = ui.link(take out, "https://github.com/edda-lang", "GitHub", allocator)?
    out = ui.link(take out, "https://www.reddit.com/r/EddaLang/", "r/EddaLang", allocator)?
    out = ui.link(take out, "mailto:ea@edda-lang.org", "ea@edda-lang.org", allocator)?
    return markup.end(take out, allocator)?
}

function _foot_meta(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = ui.open_div(take h, classes.meta(), allocator)?
    out = ui.text_el(take out, "span", "© 2026 the edda authors", allocator)?
    out = ui.class_link(take out, classes.proof(), "/build/servers", "This site is an edda program.", allocator)?
    return markup.end(take out, allocator)?
}

function _footer(h: take markup.Html, allocator: Allocator) -> markup.Html
    with {allocator, err: alloc.AllocError, err: htmlescape.HtmlEscapeError}
{
    var out = markup.el(take h, "footer", allocator)?
    out = markup.attr(take out, "class", classes.foot(), allocator)?
    out = ui.open_div(take out, classes.cols(), allocator)?
    out = _foot_learn_col(take out, allocator)?
    out = _foot_reference_col(take out, allocator)?
    out = _foot_project_col(take out, allocator)?
    out = markup.end(take out, allocator)?
    out = _foot_meta(take out, allocator)?
    return markup.end(take out, allocator)?
}

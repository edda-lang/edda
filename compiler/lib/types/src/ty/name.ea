
module types.ty.name

import std.mem.alloc
import std.collections.vec
import std.core.fmt as fmt_mod
import std.text.string
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.ty.kind as ty_kind_mod
import target.capability as cap_mod


spec std.collections.vec.Vec(ty_mod.TyId)


public function name_of(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError, divergence}
{
    if ty_mod.is_error(t) {
        return "<error>"
    }
    if (t.raw as usize) >= ty_interner_mod.slot_count(ty_interner) {
        return "<unknown>"
    }
    return match ty_interner_mod.lookup(ty_interner, t) {
        case .primitive(let p) => prim_name(p)
        case .string_ => "String"
        case .slice(let elem) => wrap_slice(elem, ty_interner, allocator)?
        case .array(let elem, let len) => wrap_array(elem, len, ty_interner, allocator)?
        case .tuple_(let elems) => wrap_tuple(elems, ty_interner, allocator)?
        case .fn_(_, _, _) => "function(..)"
        case .refined(let base, _) => name_of(base, ty_interner, allocator)?
        case .capability(let cap) => cap_mod.name(cap)
        case .record(_) => nominal_name(t, ty_interner)
        case .sum_(_) => nominal_name(t, ty_interner)
        case .spec_instance(_, _) => "<spec instance>"
        case .opaque(_) => opaque_name(t, ty_interner)
        case .error_ => "<error>"
    }
}


function nominal_name(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> String {
    let stored = ty_interner_mod.type_name_of(ty_interner, t)
    if stored.len() > 0 {
        return stored
    }
    return "<nominal type>"
}


function opaque_name(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> String {
    let stored = ty_interner_mod.type_name_of(ty_interner, t)
    if stored.len() > 0 {
        return stored
    }
    return "<opaque type>"
}


function prim_name(p: ty_kind_mod.PrimKind) -> String {
    return match p {
        case .i8_ => "i8"
        case .i16_ => "i16"
        case .i32_ => "i32"
        case .i64_ => "i64"
        case .i128_ => "i128"
        case .u8_ => "u8"
        case .u16_ => "u16"
        case .u32_ => "u32"
        case .u64_ => "u64"
        case .u128_ => "u128"
        case .isize_ => "isize"
        case .usize_ => "usize"
        case .f32_ => "f32"
        case .f64_ => "f64"
        case .bool_ => "bool"
        case .unit_ => "()"
        case .never_ => "never"
        case .codepoint_ => "Codepoint"
        case .type_meta => "Type"
        case .heap_ptr => "HeapPtr"
    }
}


function wrap_slice(elem: ty_mod.TyId, ty_interner: ty_interner_mod.Interner, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = name_of(elem, ty_interner, allocator)?
    let s1 = string.concat("[", inner, allocator)?
    return string.concat(s1, "]", allocator)?
}


function wrap_array(elem: ty_mod.TyId, len: u64, ty_interner: ty_interner_mod.Interner, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = name_of(elem, ty_interner, allocator)?
    let len_str = fmt_mod.u64_to_string(len, allocator)?
    let s1 = string.concat("[", inner, allocator)?
    let s2 = string.concat(s1, "; ", allocator)?
    return string.concat(s2, len_str, allocator)?
}


function wrap_tuple(elems: Vec_TyId.Vec, ty_interner: ty_interner_mod.Interner, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_TyId.len(elems)
    var out = "("
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let part = name_of(Vec_TyId.at(elems, i), ty_interner, allocator)?
        if i == 0 {
            out = string.concat(out, part, allocator)?
        } else {
            let s1 = string.concat(out, ", ", allocator)?
            out = string.concat(s1, part, allocator)?
        }
        i = i + 1
    }
    return string.concat(out, ")", allocator)?
}

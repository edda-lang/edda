
module types.ty.kind

import std.collections.vec
import types.pass.ty as ty_mod
import types.pass.effect as effect_mod
import hir.def as def_mod
import syntax.ast.tree as ast_tree
import target.capability as cap_mod


spec std.collections.vec.Vec(ty_mod.TyId)


derive eq, hash, clone, debug for CTy
derive eq, hash, clone, debug for PrimKind


public type PrimKind {
    case i8_
    case i16_
    case i32_
    case i64_
    case i128_
    case u8_
    case u16_
    case u32_
    case u64_
    case u128_
    case isize_
    case usize_
    case f32_
    case f64_
    case bool_
    case unit_
    case never_
    case codepoint_
    case type_meta
    case heap_ptr
}


public type CTy {
    case primitive(PrimKind)
    case string_
    case slice(elem: ty_mod.TyId)
    case array(elem: ty_mod.TyId, len: u64)
    case tuple_(elems: Vec_TyId.Vec)
    case record(def: def_mod.DefId)
    case sum_(def: def_mod.DefId)
    case fn_(params: Vec_TyId.Vec, ret: ty_mod.TyId, effects: effect_mod.EffectRowId)
    case spec_instance(def: def_mod.DefId, args: Vec_TyId.Vec)
    case refined(base: ty_mod.TyId, predicate: ast_tree.Expr)
    case capability(cap: cap_mod.Capability)
    case opaque(def: def_mod.DefId)
    case error_
}


public function is_opaque(t: CTy) -> bool {
    return match t {
        case .opaque(_) => true
        case _ => false
    }
}


module types.check.pass.valuecycle.detect

import std.mem.alloc
import std.collections.vec
import hir.build.file as hir_file
import hir.item as hir_item
import hir.def as def_mod
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import types.check.env.fields as fields_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(fields_mod.FieldTyList)
spec std.collections.vec.Vec(bool)


public function check_value_cycles(
    file: hir_file.HirFile,
    field_tys: Vec_FieldTyList.Vec,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> bool
    with {allocator, err: alloc.AllocError}
{
    let nslots = Vec_FieldTyList.len(field_tys)
    let items = file.items
    let n = Vec_HItem.len(items)
    var found = false
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        match item.kind {
            case .type_decl(_) => {
                let di = def_mod.index(item.def_id)
                if di < nslots {
                    if def_is_cyclic(di, field_tys, ty_interner, nslots, allocator)? {
                        let span = hir_file.span_of(file, item.node_id)
                        let d = diag_mod.error_at(code_mod.cyclic_value_type(), span, "by-value type cycle: a recursive type must break the cycle through std.mem.alloc.Box(T)")
                        coll_mod.emit(mutable diags, take d, allocator)?
                        found = true
                    }
                }
            }
            case _ => ()
        }
        i = i + 1 as usize
    }
    return found
}


function def_is_cyclic(
    target_idx: usize,
    field_tys: Vec_FieldTyList.Vec,
    ty_interner: ty_interner_mod.Interner,
    nslots: usize,
    allocator: Allocator,
) -> bool
    with {allocator, err: alloc.AllocError}
{
    uninit visited: Vec_bool.Vec
    Vec_bool.new(init visited, allocator)?
    var k: usize = 0 as usize
    loop decreases (nslots - k) {
        if k >= nslots { break }
        Vec_bool.push(mutable visited, false, allocator)?
        k = k + 1 as usize
    }
    if target_idx >= Vec_FieldTyList.len(field_tys) {
        return false
    }
    let flist = Vec_FieldTyList.at(field_tys, target_idx).tys
    let m = Vec_TyId.len(flist)
    var j: usize = 0 as usize
    loop decreases (m - j) {
        if j >= m { break }
        if reaches_ty(target_idx, Vec_TyId.at(flist, j), field_tys, ty_interner, mutable visited, nslots) {
            return true
        }
        j = j + 1 as usize
    }
    return false
}


function nominal_def(cty: ty_kind_mod.CTy) -> def_mod.DefId {
    return match cty {
        case .record(let def) => def
        case .sum_(let def) => def
        case .spec_instance(let def, _) => def
        case _ => def_mod.error()
    }
}


function reaches_ty(
    target_idx: usize,
    ty: ty_mod.TyId,
    field_tys: Vec_FieldTyList.Vec,
    ty_interner: ty_interner_mod.Interner,
    visited: mutable Vec_bool.Vec,
    fuel: usize,
) -> bool
    decreases fuel
{
    if fuel == 0 as usize {
        return false
    }
    if ty_mod.is_error(ty) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, ty)
    let ndef = nominal_def(cty)
    if !def_mod.is_error(ndef) {
        let di = def_mod.index(ndef)
        if di == target_idx {
            return true
        }
        if di >= Vec_bool.len(visited) {
            return false
        }
        if Vec_bool.at(visited, di) {
            return false
        }
        Vec_bool.set_at(mutable visited, di, true)
        if di >= Vec_FieldTyList.len(field_tys) {
            return false
        }
        let flist = Vec_FieldTyList.at(field_tys, di).tys
        let m = Vec_TyId.len(flist)
        var j: usize = 0 as usize
        loop decreases (m - j) {
            if j >= m { break }
            if reaches_ty(target_idx, Vec_TyId.at(flist, j), field_tys, ty_interner, mutable visited, fuel - 1 as usize) {
                return true
            }
            j = j + 1 as usize
        }
        return false
    }
    match cty {
        case .tuple_(let elems) => {
            let m = Vec_TyId.len(elems)
            var j: usize = 0 as usize
            loop decreases (m - j) {
                if j >= m { break }
                if reaches_ty(target_idx, Vec_TyId.at(elems, j), field_tys, ty_interner, mutable visited, fuel - 1 as usize) {
                    return true
                }
                j = j + 1 as usize
            }
            return false
        }
        case .array(let elem, _) => {
            return reaches_ty(target_idx, elem, field_tys, ty_interner, mutable visited, fuel - 1 as usize)
        }
        case .refined(let base, _) => {
            return reaches_ty(target_idx, base, field_tys, ty_interner, mutable visited, fuel - 1 as usize)
        }
        case _ => {
            return false
        }
    }
}

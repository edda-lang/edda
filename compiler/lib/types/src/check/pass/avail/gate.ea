
module types.check.pass.avail.gate

import std.mem.alloc
import std.collections.vec
import std.collections.slice
import std.core.option
import std.text.string
import syntax.ast.attr as ast_attr
import intern.interner as interner_mod
import intern.symbol
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.def as def_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod
import target.capability as cap_mod
import target.triple as triple_mod


spec std.mem.alloc.Box(hir_tree.HExpr)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(ast_attr.Attribute)
spec std.collections.vec.Vec(ast_attr.AttrArg)
spec std.collections.vec.Vec(GatedItem)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(cap_mod.Capability)


public type GatedItem {
    def: def_mod.DefId
    cap: cap_mod.Capability
}


public function check_target_gates(
    file: hir_file.HirFile,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit gated: Vec_GatedItem.Vec
    Vec_GatedItem.new(init gated, allocator)?
    collect_gated(file.items, triple, interner, mutable gated, allocator)?
    walk_items(file, file.items, gated, mutable diags, allocator)?
}


public function is_target_absent(
    item: hir_item.HItem,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
) -> bool {
    return match item_required_unavailable_cap(item, triple, interner) {
        case .some(_) => true
        case .none    => false
    }
}


public function item_required_unavailable_cap(
    item: hir_item.HItem,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
) -> Option_Capability {
    let attrs = item.ast_item.attributes
    let n = Vec_Attribute.len(attrs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let attr = Vec_Attribute.at(attrs, i)
        if ident_is(attr.name.name, "target_requires".bytes(), interner) {
            match first_unavailable_cap(attr.args, triple, interner) {
                case .some(let c) => return Option_Capability.some(value: c)
                case .none        => ()
            }
        }
        i = i + 1 as usize
    }
    return Option_Capability.none
}

function first_unavailable_cap(
    args: Vec_AttrArg.Vec,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
) -> Option_Capability {
    let n = Vec_AttrArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        match Vec_AttrArg.at(args, i) {
            case .ident(let id) => {
                match cap_of_ident(id.name, triple, interner) {
                    case .some(let c) => return Option_Capability.some(value: c)
                    case .none        => ()
                }
            }
            case _ => ()
        }
        i = i + 1 as usize
    }
    return Option_Capability.none
}

function cap_of_ident(
    sym: symbol.Symbol,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
) -> Option_Capability {
    if (sym.raw as usize) >= interner_mod.slot_count(interner) { return Option_Capability.none }
    let bytes = interner_mod.lookup(interner, sym)
    let cap = match cap_from_bytes(bytes) {
        case .some(let c) => c
        case .none        => return Option_Capability.none
    }
    if cap_mod.supports(triple, cap) { return Option_Capability.none }
    return Option_Capability.some(value: cap)
}


public function cap_from_bytes(bytes: [u8]) -> Option_Capability {
    if slice.eq_u8(bytes, "Filesystem".bytes())          { return Option_Capability.some(value: cap_mod.Capability.filesystem) }
    if slice.eq_u8(bytes, "ReadOnlyFilesystem".bytes())  { return Option_Capability.some(value: cap_mod.Capability.read_only_filesystem) }
    if slice.eq_u8(bytes, "SandboxedFilesystem".bytes()) { return Option_Capability.some(value: cap_mod.Capability.sandboxed_filesystem) }
    if slice.eq_u8(bytes, "Network".bytes())             { return Option_Capability.some(value: cap_mod.Capability.network) }
    if slice.eq_u8(bytes, "LocalhostNetwork".bytes())    { return Option_Capability.some(value: cap_mod.Capability.localhost_network) }
    if slice.eq_u8(bytes, "RestrictedNetwork".bytes())   { return Option_Capability.some(value: cap_mod.Capability.restricted_network) }
    if slice.eq_u8(bytes, "Clock".bytes())               { return Option_Capability.some(value: cap_mod.Capability.clock) }
    if slice.eq_u8(bytes, "MonotonicClock".bytes())      { return Option_Capability.some(value: cap_mod.Capability.monotonic_clock) }
    if slice.eq_u8(bytes, "Random".bytes())              { return Option_Capability.some(value: cap_mod.Capability.random) }
    if slice.eq_u8(bytes, "DeterministicRandom".bytes()) { return Option_Capability.some(value: cap_mod.Capability.deterministic_random) }
    if slice.eq_u8(bytes, "Allocator".bytes())           { return Option_Capability.some(value: cap_mod.Capability.allocator) }
    if slice.eq_u8(bytes, "BoundedAllocator".bytes())    { return Option_Capability.some(value: cap_mod.Capability.bounded_allocator) }
    if slice.eq_u8(bytes, "Executor".bytes())            { return Option_Capability.some(value: cap_mod.Capability.executor) }
    if slice.eq_u8(bytes, "Stdin".bytes())               { return Option_Capability.some(value: cap_mod.Capability.stdin) }
    if slice.eq_u8(bytes, "Stdout".bytes())              { return Option_Capability.some(value: cap_mod.Capability.stdout) }
    if slice.eq_u8(bytes, "Stderr".bytes())              { return Option_Capability.some(value: cap_mod.Capability.stderr) }
    if slice.eq_u8(bytes, "Subprocess".bytes())          { return Option_Capability.some(value: cap_mod.Capability.subprocess) }
    if slice.eq_u8(bytes, "Dom".bytes())                 { return Option_Capability.some(value: cap_mod.Capability.dom) }
    if slice.eq_u8(bytes, "Window".bytes())              { return Option_Capability.some(value: cap_mod.Capability.window) }
    if slice.eq_u8(bytes, "ExtensionContent".bytes())    { return Option_Capability.some(value: cap_mod.Capability.extension_content) }
    if slice.eq_u8(bytes, "ExtensionWorker".bytes())     { return Option_Capability.some(value: cap_mod.Capability.extension_worker) }
    if slice.eq_u8(bytes, "Debugger".bytes())            { return Option_Capability.some(value: cap_mod.Capability.debugger) }
    return Option_Capability.none
}

function ident_is(sym: symbol.Symbol, name: [u8], interner: interner_mod.Interner) -> bool {
    if (sym.raw as usize) >= interner_mod.slot_count(interner) { return false }
    let bytes = interner_mod.lookup(interner, sym)
    return slice.eq_u8(bytes, name)
}


function collect_gated(
    items: Vec_HItem.Vec,
    triple: triple_mod.TargetTriple,
    interner: interner_mod.Interner,
    gated: mutable Vec_GatedItem.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        match item_required_unavailable_cap(item, triple, interner) {
            case .some(let cap) => {
                if !def_mod.is_error(item.def_id) {
                    Vec_GatedItem.push(mutable gated, GatedItem { def: item.def_id, cap: cap }, allocator)?
                }
            }
            case .none => ()
        }
        match item.kind {
            case .spec_decl(_, let inner_items) => {
                collect_gated(inner_items, triple, interner, mutable gated, allocator)?
            }
            case _ => ()
        }
        i = i + 1 as usize
    }
}

function lookup_gated(gated: Vec_GatedItem.Vec, def: def_mod.DefId) -> Option_Capability {
    if def_mod.is_error(def) { return Option_Capability.none }
    let target = def_mod.index(def)
    let n = Vec_GatedItem.len(gated)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let g = Vec_GatedItem.at(gated, i)
        if def_mod.index(g.def) == target { return Option_Capability.some(value: g.cap) }
        i = i + 1 as usize
    }
    return Option_Capability.none
}

function is_gated(gated: Vec_GatedItem.Vec, def: def_mod.DefId) -> bool {
    return match lookup_gated(gated, def) {
        case .some(_) => true
        case .none    => false
    }
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        walk_item(file, item, gated, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(_, let body) => {
            if !is_gated(gated, item.def_id) {
                walk_block(file, body, gated, mutable diags, allocator)?
            }
        }
        case .spec_decl(_, let inner_items) => {
            walk_items(file, inner_items, gated, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let s = Vec_HStmt.at(block.stmts, i)
        walk_stmt(file, s, gated, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => {
            let inner = Box_HExpr.get(box_e)
            walk_expr(file, inner, gated, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, gated, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, gated, mutable diags, allocator)?
            walk_expr(file, rhs, gated, mutable diags, allocator)?
        }
    }
}

function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .call(let callee_def, let args) => {
            check_callee(file, expr, callee_def, gated, mutable diags, allocator)?
            walk_args(file, args, gated, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, gated, mutable diags, allocator)?
            walk_args(file, args, gated, mutable diags, allocator)?
        }
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, gated, mutable diags, allocator)?
            walk_boxed(file, rhs, gated, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, gated, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, gated, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, gated, mutable diags, allocator)?
            walk_boxed(file, idx, gated, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, gated, mutable diags, allocator)?
            walk_block(file, then_b, gated, mutable diags, allocator)?
            walk_opt_block(file, else_opt, gated, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, gated, mutable diags, allocator)?
            walk_arms(file, arms, gated, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, gated, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, gated, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, gated, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, gated, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, gated, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, gated, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, gated, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, gated, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, gated, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, gated, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, gated, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, gated, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, gated, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, gated, mutable diags, allocator)?
            walk_block(file, body, gated, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, gated, mutable diags, allocator)?
            walk_boxed(file, body, gated, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, gated, mutable diags, allocator)?
            walk_boxed(file, body, gated, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = Box_HExpr.get(boxed)
    walk_expr(file, inner, gated, mutable diags, allocator)?
}

function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, gated, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, gated, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_HExpr.at(exprs, i)
        walk_expr(file, e, gated, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        walk_expr(file, a.expr, gated, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => {
                walk_expr(file, g, gated, mutable diags, allocator)?
            }
            case .none => ()
        }
        walk_expr(file, arm.body, gated, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function check_callee(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    callee_def: def_mod.DefId,
    gated: Vec_GatedItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let cap = match lookup_gated(gated, callee_def) {
        case .some(let c) => c
        case .none        => return
    }
    let sp = hir_file.span_of_opt(file, expr.node_id)
    match sp {
        case .some(let span) => {
            let msg = format_call_unavailable_message(cap, allocator)?
            let d = diag_mod.error_at(code_mod.capability_not_available_on_target(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}

function format_call_unavailable_message(
    cap: cap_mod.Capability,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let cap_name = cap_mod.name(cap)
    let p1 = string.concat("call to a function gated by `@target_requires(", cap_name, allocator)?
    return string.concat(p1, ")` that does not exist on the build target", allocator)?
}

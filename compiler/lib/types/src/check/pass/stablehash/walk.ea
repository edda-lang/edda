
module types.check.pass.stablehash.walk

import std.mem.alloc
import std.collections.vec
import std.collections.slice
import std.core.option
import intern.symbol
import intern.interner as interner_mod
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.node as node_mod
import types.pass.ty as ty_mod
import types.check.env.builtins as builtins_mod
import types.check.env.lower.instname.instname as instname_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(ty_mod.TyId)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)


public function check_hash_iteration(
    file: hir_file.HirFile,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items(file, file.items, node_types, interner, builtins, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_item(file, Vec_HItem.at(items, i), node_types, interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box, let body) => {
            if is_stable(Box_HFnSignature.get(sig_box)) {
                walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
            }
        }
        case .spec_decl(_, let inner) => {
            walk_items(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function is_stable(sig: hir_item.HFnSignature) -> bool {
    return match sig.stability {
        case .some(let st) => match st {
            case .stable_(let _since) => true
            case .unstable_           => false
        }
        case .none => false
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_stmt(file, Vec_HStmt.at(block.stmts, i), node_types, interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => walk_expr(file, Box_HExpr.get(box_e), node_types, interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, node_types, interner, builtins, mutable diags, allocator)?
            walk_expr(file, rhs, node_types, interner, builtins, mutable diags, allocator)?
        }
    }
}


function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    check_call_node(file, expr, node_types, interner, builtins, mutable diags, allocator)?
    match expr.kind {
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, rhs, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .call(_, let args) => {
            walk_args(file, args, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .variant_ctor(_, _, let args) => {
            walk_args(file, args, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, node_types, interner, builtins, mutable diags, allocator)?
            walk_args(file, args, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .method_call(_, let args) => {
            walk_args(file, args, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .positional(let recv, let index) => {
            walk_boxed(file, recv, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, index, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, idx, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, node_types, interner, builtins, mutable diags, allocator)?
            walk_block(file, then_b, node_types, interner, builtins, mutable diags, allocator)?
            walk_opt_block(file, else_opt, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, node_types, interner, builtins, mutable diags, allocator)?
            walk_arms(file, arms, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .comptime_for(_, let lo, let hi, _, let body) => {
            walk_boxed(file, lo, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, hi, node_types, interner, builtins, mutable diags, allocator)?
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, node_types, interner, builtins, mutable diags, allocator)?
            walk_block(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, node_types, interner, builtins, mutable diags, allocator)?
            walk_boxed(file, body, node_types, interner, builtins, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function check_call_node(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .method_call(let mname, let args) => {
            if Vec_HArg.len(args) == 0 as usize { return }
            let recv = Vec_HArg.at(args, 0 as usize).expr.node_id
            check_iter_call(file, expr.node_id, mname, recv, node_types, interner, builtins, mutable diags, allocator)?
        }
        case _ => {
            if hir_file.is_method_call(file, expr.node_id) {
                let name = hir_file.method_name_at(file, expr.node_id)
                let recv = node_mod.NodeId { raw: hir_file.method_recv_at(file, expr.node_id) }
                check_iter_call(file, expr.node_id, name, recv, node_types, interner, builtins, mutable diags, allocator)?
            }
        }
    }
}


function check_iter_call(
    file: hir_file.HirFile,
    call_node: node_mod.NodeId,
    name: symbol.Symbol,
    recv: node_mod.NodeId,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if !is_iter_method(name, interner) { return }
    if !is_hashmap_ty(node_ty_at(node_types, recv), interner, builtins) { return }
    emit_hash_iter(file, call_node, mutable diags, allocator)?
}


function is_iter_method(name: symbol.Symbol, interner: interner_mod.Interner) -> bool {
    return sym_eq(name, "iter".bytes(), interner)
        || sym_eq(name, "keys".bytes(), interner)
        || sym_eq(name, "values".bytes(), interner)
        || sym_eq(name, "entries".bytes(), interner)
        || sym_eq(name, "next".bytes(), interner)
}


function is_hashmap_ty(
    recv_ty: ty_mod.TyId,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
) -> bool {
    let nm = instname_mod.name_of_ty(builtins.nominals, interner, recv_ty)
    if nm.len() == 0 as usize { return false }
    return slice.eq_u8(nm, "HashMap".bytes())
        || slice.eq_u8(nm, "IntMap".bytes())
        || slice.eq_u8(nm, "StringMap".bytes())
}


function node_ty_at(node_types: Vec_TyId.Vec, n: node_mod.NodeId) -> ty_mod.TyId {
    let i = node_mod.index(n)
    if i >= Vec_TyId.len(node_types) {
        return ty_mod.error()
    }
    return Vec_TyId.at(node_types, i)
}


function emit_hash_iter(
    file: hir_file.HirFile,
    call_node: node_mod.NodeId,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match hir_file.span_of_opt(file, call_node) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.stability_hash_iter(), span, "hash-map iteration is not admitted in a `stable` body (nondeterministic order); use `sorted_keys`")
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}


function sym_eq(sym: symbol.Symbol, name: [u8], interner: interner_mod.Interner) -> bool {
    if (sym.raw as usize) >= interner_mod.slot_count(interner) { return false }
    return slice.eq_u8(interner_mod.lookup(interner, sym), name)
}


function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_expr(file, Box_HExpr.get(boxed), node_types, interner, builtins, mutable diags, allocator)?
}


function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, node_types, interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, node_types, interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HExpr.at(exprs, i), node_types, interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HArg.at(args, i).expr, node_types, interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    node_types: Vec_TyId.Vec,
    interner: interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => walk_expr(file, g, node_types, interner, builtins, mutable diags, allocator)?
            case .none => ()
        }
        walk_expr(file, arm.body, node_types, interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

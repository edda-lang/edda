
module types.check.pass.sentinel.walk

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.build.file as hir_file
import hir.def as def_mod
import hir.item as hir_item
import hir.tree as hir_tree
import hir.node as node_mod
import types.pass.ty as ty_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(def_mod.DefId)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)


public function check_error_sentinels(
    file: hir_file.HirFile,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items(file, file.items, node_types, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_item(file, Vec_HItem.at(items, i), node_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box, let body) => {
            let sig = Box_HFnSignature.get(sig_box)
            if Vec_DefId.len(sig.comptime_param_defs) == 0 as usize {
                walk_block(file, body, node_types, mutable diags, allocator)?
            }
        }
        case _ => ()
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_stmt(file, Vec_HStmt.at(block.stmts, i), node_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => walk_expr(file, Box_HExpr.get(box_e), node_types, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, node_types, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, node_types, mutable diags, allocator)?
            walk_expr(file, rhs, node_types, mutable diags, allocator)?
        }
    }
}


function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    maybe_emit(file, expr, node_types, mutable diags, allocator)?
    match expr.kind {
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, node_types, mutable diags, allocator)?
            walk_boxed(file, rhs, node_types, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, node_types, mutable diags, allocator)?
        }
        case .call(_, let args) => {
            walk_args(file, args, node_types, mutable diags, allocator)?
        }
        case .variant_ctor(_, _, let args) => {
            walk_args(file, args, node_types, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, node_types, mutable diags, allocator)?
            walk_args(file, args, node_types, mutable diags, allocator)?
        }
        case .method_call(_, let args) => {
            walk_args(file, args, node_types, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, node_types, mutable diags, allocator)?
        }
        case .positional(let recv, let index) => {
            walk_boxed(file, recv, node_types, mutable diags, allocator)?
            walk_boxed(file, index, node_types, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, node_types, mutable diags, allocator)?
            walk_boxed(file, idx, node_types, mutable diags, allocator)?
        }
        case .subrange(let recv, let lo, let hi, _) => {
            walk_boxed(file, recv, node_types, mutable diags, allocator)?
            walk_opt_boxed(file, lo, node_types, mutable diags, allocator)?
            walk_opt_boxed(file, hi, node_types, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, node_types, mutable diags, allocator)?
            walk_block(file, then_b, node_types, mutable diags, allocator)?
            walk_opt_block(file, else_opt, node_types, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, node_types, mutable diags, allocator)?
            walk_arms(file, arms, node_types, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, node_types, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, node_types, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, node_types, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, node_types, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, node_types, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, node_types, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, node_types, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, node_types, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, node_types, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, node_types, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, node_types, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, node_types, mutable diags, allocator)?
        }
        case .comptime_for(_, let lo, let hi, _, let body) => {
            walk_boxed(file, lo, node_types, mutable diags, allocator)?
            walk_boxed(file, hi, node_types, mutable diags, allocator)?
            walk_block(file, body, node_types, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, node_types, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, node_types, mutable diags, allocator)?
            walk_block(file, body, node_types, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, node_types, mutable diags, allocator)?
            walk_boxed(file, body, node_types, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, node_types, mutable diags, allocator)?
            walk_boxed(file, body, node_types, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function maybe_emit(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if !ty_mod.is_error(node_ty_at(node_types, expr.node_id)) {
        return
    }
    let msg = origin_message(expr)
    if msg.len() == 0 as usize {
        return
    }
    if child_is_error(expr, node_types) {
        return
    }
    match hir_file.span_of_opt(file, expr.node_id) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.typecheck_error(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}


function origin_message(expr: hir_tree.HExpr) -> String
    with {divergence}
{
    return match expr.kind {
        case .use_(_) => "name resolves to no binding, function, or type"
        case .call(_, _) => "call target has no known signature (unresolved or ill-typed callee)"
        case .method_call(_, _) => "no method of this name applies to the receiver type"
        case .variant_ctor(_, _, _) => "variant constructor refers to no known sum type"
        case .struct_lit(_, _) => "struct literal refers to no known record type"
        case .field(_, _) => "field access on a value whose type has no such field"
        case .positional(_, _) => "positional access on a value that is not a tuple or record"
        case .index(_, _) => "index into a value that is not a slice"
        case .subrange(_, _, _, _) => "subrange of a value that is not a slice"
        case .cast(_, _, _) => "cast target type is unresolved"
        case .binary(_, _, _) => "operator does not apply to these operand types"
        case .unary(_, _) => "operator does not apply to this operand type"
        case .tuple(_) => "tuple element could not be typed"
        case .dyn_call(_, _) => "indirect call target is not a function type"
        case _ => ""
    }
}


function child_is_error(expr: hir_tree.HExpr, node_types: Vec_TyId.Vec) -> bool
    with {divergence}
{
    return match expr.kind {
        case .binary(_, let lhs, let rhs) => boxed_error(lhs, node_types) || boxed_error(rhs, node_types)
        case .unary(_, let inner) => boxed_error(inner, node_types)
        case .call(_, let args) => any_arg_error(args, node_types)
        case .variant_ctor(_, _, let args) => any_arg_error(args, node_types)
        case .dyn_call(let callee, let args) => boxed_error(callee, node_types) || any_arg_error(args, node_types)
        case .method_call(_, let args) => any_arg_error(args, node_types)
        case .field(let recv, _) => boxed_error(recv, node_types)
        case .positional(let recv, let idx) => boxed_error(recv, node_types) || boxed_error(idx, node_types)
        case .index(let recv, let idx) => boxed_error(recv, node_types) || boxed_error(idx, node_types)
        case .subrange(let recv, _, _, _) => boxed_error(recv, node_types)
        case .tuple(let elements) => any_expr_error(elements, node_types)
        case .struct_lit(_, let fields) => any_arg_error(fields, node_types)
        case .cast(let inner, _, _) => boxed_error(inner, node_types)
        case _ => false
    }
}


function boxed_error(boxed: Box_HExpr, node_types: Vec_TyId.Vec) -> bool {
    return ty_mod.is_error(node_ty_at(node_types, Box_HExpr.get(boxed).node_id))
}


function any_arg_error(args: Vec_HArg.Vec, node_types: Vec_TyId.Vec) -> bool {
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if ty_mod.is_error(node_ty_at(node_types, Vec_HArg.at(args, i).expr.node_id)) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}


function any_expr_error(exprs: Vec_HExpr.Vec, node_types: Vec_TyId.Vec) -> bool {
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if ty_mod.is_error(node_ty_at(node_types, Vec_HExpr.at(exprs, i).node_id)) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}


function node_ty_at(node_types: Vec_TyId.Vec, n: node_mod.NodeId) -> ty_mod.TyId {
    let i = node_mod.index(n)
    if i >= Vec_TyId.len(node_types) {
        return ty_mod.error()
    }
    return Vec_TyId.at(node_types, i)
}


function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_expr(file, Box_HExpr.get(boxed), node_types, mutable diags, allocator)?
}


function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, node_types, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, node_types, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HExpr.at(exprs, i), node_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HArg.at(args, i).expr, node_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    node_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => walk_expr(file, g, node_types, mutable diags, allocator)?
            case .none => ()
        }
        walk_expr(file, arm.body, node_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

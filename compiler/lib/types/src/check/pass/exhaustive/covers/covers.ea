
module types.check.pass.exhaustive.covers.covers

import std.mem.alloc
import std.collections.vec
import std.core.option
import intern.symbol
import syntax.ast.tree as ast_tree
import syntax.ast.ident as ast_ident
import hir.tree as hir_tree


spec std.mem.alloc.Box(ast_tree.Pat)


spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(ast_tree.Pat)
spec std.collections.vec.Vec(ast_ident.Ident)
spec std.collections.vec.Vec(symbol.Symbol)


spec std.core.option.Option(symbol.Symbol)


public function first_missing_variant(
    variants: Vec_Symbol.Vec,
    arms: Vec_HArm.Vec,
) -> Option_Symbol.Option
    with {divergence}
{
    let n = Vec_Symbol.len(variants)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let v = Vec_Symbol.at(variants, i)
        if !variant_is_covered(arms, v) {
            return Option_Symbol.some(value: v)
        }
        i = i + 1 as usize
    }
    return Option_Symbol.none
}

function variant_is_covered(arms: Vec_HArm.Vec, v_sym: symbol.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(_) => ()
            case .none => {
                if pat_covers_variant(arm.pat, v_sym) {
                    return true
                }
            }
        }
        i = i + 1 as usize
    }
    return false
}

function pat_covers_variant(pat: ast_tree.Pat, v_sym: symbol.Symbol) -> bool
    with {divergence}
{
    return match pat.kind {
        case .wildcard => true
        case .binding(_) => true
        case .at_binding(_, let sub) => pat_covers_variant(Box_Pat.get(sub), v_sym)
        case .or_(let alts) => any_pat_covers(alts, v_sym)
        case .variant(let path, _) => path_matches_symbol(path, v_sym)
        case _ => false
    }
}

function any_pat_covers(alts: Vec_Pat.Vec, v_sym: symbol.Symbol) -> bool
    with {divergence}
{
    let n = Vec_Pat.len(alts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let p = Vec_Pat.at(alts, i)
        if pat_covers_variant(p, v_sym) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}

function path_matches_symbol(path: ast_ident.Path, v_sym: symbol.Symbol) -> bool {
    let n = Vec_Ident.len(path.segments)
    if n == 0 as usize {
        return false
    }
    let last = Vec_Ident.at(path.segments, n - 1 as usize)
    return last.name.raw == v_sym.raw
}

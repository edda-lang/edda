
module types.check.pass.exhaustive.walk.walk

import std.mem.alloc
import std.collections.vec
import std.core.option
import intern.symbol
import syntax.ast.tree as ast_tree
import syntax.ast.ident as ast_ident
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.node as node_mod
import hir.def as def_mod
import span.loc.pos.span as span_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.check.env.builtins as builtins_mod
import types.check.env.fields as fields_mod
import types.check.pass.exhaustive.defs as defs_mod
import types.check.pass.exhaustive.build.varmap as build_mod
import types.check.pass.exhaustive.irrefutable.irrefutable as irrefutable_mod
import types.check.pass.exhaustive.covers.covers as coverage_mod
import types.check.pass.exhaustive.ctor.ctor as ctor_mod
import types.ty.name as ty_name_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HTypeSignature)
spec std.mem.alloc.Box(ast_tree.Pat)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HBinding)
spec std.collections.vec.Vec(ast_tree.Pat)
spec std.collections.vec.Vec(ast_ident.Ident)
spec std.collections.vec.Vec(symbol.Symbol)
spec std.collections.vec.Vec(ty_mod.TyId)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(def_mod.DefId)
spec std.core.option.Option(span_mod.Span)


spec std.collections.vec.Vec(fields_mod.FieldTyList)
spec std.collections.vec.Vec(fields_mod.VariantNameList)


public function check_match_exhaustiveness(
    file: hir_file.HirFile,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let maps = build_mod.build_var_maps(file.items, variant_names, allocator)?
    walk_items(file, file.items, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        walk_item(file, item, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(_, let body) => {
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            walk_items(file, inner_items, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let s = Vec_HStmt.at(block.stmts, i)
        walk_stmt(file, s, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => {
            let inner = Box_HExpr.get(box_e)
            walk_expr(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_expr(file, rhs, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
    }
}

function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_boxed(file, rhs, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .call(_, let args) => {
            walk_args(file, args, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .variant_ctor(let def, let variant, let args) => {
            ctor_mod.check_ctor(file, expr.node_id, def, variant, args, maps, field_tys, node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_args(file, args, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_args(file, args, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_boxed(file, idx, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_block(file, then_b, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_opt_block(file, else_opt, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_arms(file, arms, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            check_one_match(file, scrut, arms, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_block(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_boxed(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            walk_boxed(file, body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = Box_HExpr.get(boxed)
    walk_expr(file, inner, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
}

function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_HExpr.at(exprs, i)
        walk_expr(file, e, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        walk_expr(file, a.expr, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => {
                walk_expr(file, g, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
            }
            case .none => ()
        }
        walk_expr(file, arm.body, maps, node_types, field_tys, local_types, builtins, ty_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function check_one_match(
    file: hir_file.HirFile,
    scrut: Box_HExpr,
    arms: Vec_HArm.Vec,
    maps: defs_mod.VarMaps,
    node_types: Vec_TyId.Vec,
    field_tys: Vec_FieldTyList.Vec,
    local_types: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let scrut_expr = Box_HExpr.get(scrut)
    let scrut_ty = node_type_at(node_types, scrut_expr.node_id)
    check_arms_or_binders(arms, scrut_ty, field_tys, maps.global_names, ty_interner, local_types, mutable diags, allocator)?
    let def = match resolve_sum_def(scrut_ty, ty_interner) {
        case .some(let d) => d
        case .none => return
    }
    if def_mod.is_error(def) {
        return
    }
    let di = def_mod.index(def)
    if di >= Vec_VariantNameList.len(maps.global_names) {
        return
    }
    let vlist = Vec_VariantNameList.at(maps.global_names, di)
    if Vec_Symbol.len(vlist.names) == 0 as usize {
        return
    }
    if irrefutable_mod.arms_have_irrefutable(arms) {
        return
    }
    match coverage_mod.first_missing_variant(vlist.names, arms) {
        case .some(_) => emit_non_exhaustive(file, scrut_expr.node_id, mutable diags, allocator)?
        case .none => ()
    }
}

function check_arms_or_binders(
    arms: Vec_HArm.Vec,
    scrut_ty: ty_mod.TyId,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        check_arm_or_binders(arm, scrut_ty, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function check_arm_or_binders(
    arm: hir_tree.HArm,
    scrut_ty: ty_mod.TyId,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match arm.pat.kind {
        case .or_(let alternatives) => {
            check_or_alternatives(alternatives, arm.bindings, scrut_ty, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function check_or_alternatives(
    alternatives: Vec_Pat.Vec,
    bindings: Vec_HBinding.Vec,
    scrut_ty: ty_mod.TyId,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_Pat.len(alternatives)
    if n <= 1 as usize {
        return
    }
    var i: usize = 1 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let alt = Vec_Pat.at(alternatives, i)
        check_alt_binders(alt, bindings, scrut_ty, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function check_alt_binders(
    pat: ast_tree.Pat,
    bindings: Vec_HBinding.Vec,
    scrut_ty: ty_mod.TyId,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match pat.kind {
        case .variant(let path, let payload) => {
            let sum_cty = ty_interner_mod.lookup(ty_interner, scrut_ty)
            match sum_cty {
                case .sum_(let sum_def) => {
                    check_or_variant_payload(path, sum_def, payload, bindings, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
                }
                case _ => ()
            }
        }
        case .binding(_) => {
            if Vec_HBinding.len(bindings) >= 1 as usize {
                let b = Vec_HBinding.at(bindings, 0 as usize)
                check_binder_matches(pat, b, scrut_ty, ty_interner, local_types, mutable diags, allocator)?
            }
        }
        case .tuple(let elements) => {
            let scrut_cty = ty_interner_mod.lookup(ty_interner, scrut_ty)
            match scrut_cty {
                case .tuple_(let elem_tys) => {
                    if Vec_Pat.len(elements) == Vec_TyId.len(elem_tys) {
                        let _ = check_iter_tuple_destructure(elements, elem_tys, bindings, 0 as usize, ty_interner, local_types, mutable diags, allocator)?
                    }
                }
                case _ => ()
            }
        }
        case .or_(let nested) => {
            if Vec_Pat.len(nested) > 0 as usize {
                check_alt_binders(Vec_Pat.at(nested, 0 as usize), bindings, scrut_ty, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
            }
        }
        case .at_binding(_, let sub) => {
            check_alt_binders(Box_Pat.get(sub), bindings, scrut_ty, field_tys, variant_names, ty_interner, local_types, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function check_or_variant_payload(
    path: ast_ident.Path,
    sum_def: def_mod.DefId,
    payload: ast_tree.VariantPatPayload,
    bindings: Vec_HBinding.Vec,
    field_tys: Vec_FieldTyList.Vec,
    variant_names: Vec_VariantNameList.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let nseg = Vec_Ident.len(path.segments)
    if nseg == 0 as usize {
        return
    }
    let last_seg = Vec_Ident.at(path.segments, nseg - 1 as usize)
    let vname = last_seg.name

    let di = def_mod.index(sum_def)
    let found = match fields_mod.variant_index_in(variant_names, sum_def, vname) {
        case .some(let vi) => vi as usize
        case .none => return
    }
    if di >= Vec_FieldTyList.len(field_tys) {
        return
    }
    let flist = Vec_FieldTyList.at(field_tys, di)
    if found >= Vec_TyId.len(flist.tys) {
        return
    }
    let payload_ty = Vec_TyId.at(flist.tys, found)
    check_or_payload_tuple(payload_ty, payload, bindings, ty_interner, local_types, mutable diags, allocator)?
}

function check_or_payload_tuple(
    payload_ty: ty_mod.TyId,
    payload: ast_tree.VariantPatPayload,
    bindings: Vec_HBinding.Vec,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if ty_mod.is_error(payload_ty) {
        return
    }
    let pcty = ty_interner_mod.lookup(ty_interner, payload_ty)
    match pcty {
        case .tuple_(let elem_tys) => {
            match payload {
                case .tuple(let elements) => {
                    if Vec_Pat.len(elements) == Vec_TyId.len(elem_tys) {
                        let _ = check_iter_tuple_destructure(elements, elem_tys, bindings, 0 as usize, ty_interner, local_types, mutable diags, allocator)?
                    }
                }
                case _ => ()
            }
        }
        case _ => ()
    }
}

function check_iter_tuple_destructure(
    elements: Vec_Pat.Vec,
    elem_tys: Vec_TyId.Vec,
    bindings: Vec_HBinding.Vec,
    cursor: usize,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> usize
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_Pat.len(elements)
    var c: usize = cursor
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let sub = Vec_Pat.at(elements, i)
        let sub_ty = Vec_TyId.at(elem_tys, i)
        c = check_tuple_destructure_pat(sub, sub_ty, bindings, c, ty_interner, local_types, mutable diags, allocator)?
        i = i + 1 as usize
    }
    return c
}

function check_tuple_destructure_pat(
    pat: ast_tree.Pat,
    expected_ty: ty_mod.TyId,
    bindings: Vec_HBinding.Vec,
    cursor: usize,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> usize
    with {allocator, err: alloc.AllocError, divergence}
{
    return match pat.kind {
        case .binding(_) => {
            if cursor < Vec_HBinding.len(bindings) {
                let b = Vec_HBinding.at(bindings, cursor)
                check_binder_matches(pat, b, expected_ty, ty_interner, local_types, mutable diags, allocator)?
                cursor + 1 as usize
            } else {
                cursor
            }
        }
        case .tuple(let elements) => {
            let pn = Vec_Pat.len(elements)
            if ty_mod.is_error(expected_ty) {
                cursor
            } else {
                let recv_cty = ty_interner_mod.lookup(ty_interner, expected_ty)
                match recv_cty {
                    case .tuple_(let elem_tys) => {
                        if Vec_TyId.len(elem_tys) != pn {
                            cursor
                        } else {
                            check_iter_tuple_destructure(elements, elem_tys, bindings, cursor, ty_interner, local_types, mutable diags, allocator)?
                        }
                    }
                    case _ => cursor
                }
            }
        }
        case _ => cursor
    }
}

function check_binder_matches(
    pat: ast_tree.Pat,
    binding: hir_tree.HBinding,
    implied_ty: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
    local_types: Vec_TyId.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if def_mod.is_error(binding.def_id) {
        return
    }
    let di = def_mod.index(binding.def_id)
    if di >= Vec_TyId.len(local_types) {
        return
    }
    let canonical_ty = binder_base_ty(Vec_TyId.at(local_types, di), ty_interner)
    let this_ty = binder_base_ty(implied_ty, ty_interner)
    if ty_mod.is_error(canonical_ty) {
        return
    }
    if ty_mod.is_error(this_ty) {
        return
    }
    if canonical_ty.raw == this_ty.raw {
        return
    }
    let canonical_name = ty_name_mod.name_of(canonical_ty, ty_interner, allocator)?
    let this_name = ty_name_mod.name_of(this_ty, ty_interner, allocator)?
    let msg = f"expected `{canonical_name}`, found `{this_name}`"
    let d = diag_mod.error_at(code_mod.typecheck_error(), pat.span, msg)
    coll_mod.emit(mutable diags, take d, allocator)?
}

function binder_base_ty(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> ty_mod.TyId
    with {divergence}
{
    if ty_mod.is_error(t) {
        return t
    }
    return match ty_interner_mod.lookup(ty_interner, t) {
        case .refined(let base, _) => binder_base_ty(base, ty_interner)
        case _ => t
    }
}

function node_type_at(node_types: Vec_TyId.Vec, n: node_mod.NodeId) -> ty_mod.TyId {
    let i = node_mod.index(n)
    if i >= Vec_TyId.len(node_types) {
        return ty_mod.error()
    }
    return Vec_TyId.at(node_types, i)
}

function resolve_sum_def(
    ty: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
) -> Option_DefId.Option
    with {divergence}
{
    if ty_mod.is_error(ty) {
        return Option_DefId.none
    }
    let cty = ty_interner_mod.lookup(ty_interner, ty)
    return match cty {
        case .sum_(let def) => Option_DefId.some(value: def)
        case .refined(let base, _) => resolve_sum_def(base, ty_interner)
        case _ => Option_DefId.none
    }
}

function emit_non_exhaustive(
    file: hir_file.HirFile,
    node_id: node_mod.NodeId,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match hir_file.span_of_opt(file, node_id) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.non_exhaustive_match(), span, "non-exhaustive match: the scrutinee sum type has variants not covered by any arm; add the missing case arms or a `case _` wildcard")
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}


module types.check.pass.capescalation.walk

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import intern.interner as interner_mod
import intern.symbol as symbol_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod
import local.check.pass.capescalation.scan as scan_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_tree.HClosure)
spec std.mem.alloc.Box(hir_tree.HSpawn)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HSpawnArg)
spec std.collections.vec.Vec(hir_tree.HBinding)
spec std.collections.vec.Vec(scan_mod.ScopedBinding)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)


public function check_capability_escalation(
    file: hir_file.HirFile,
    interner: interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items(file, file.items, interner, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    interner: interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_item(file, Vec_HItem.at(items, i), interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    interner: interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(_, let body) => {
            uninit bindings: Vec_ScopedBinding.Vec
            Vec_ScopedBinding.new(init bindings, allocator)?
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            walk_items(file, inner_items, interner, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_stmt(file, Vec_HStmt.at(block.stmts, i), interner, mutable bindings, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => walk_expr(file, Box_HExpr.get(box_e), interner, mutable bindings, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, let hbindings, _, let init_) => {
            walk_expr(file, init_, interner, mutable bindings, mutable diags, allocator)?
            record_scoped_binding(init_, hbindings, interner, mutable bindings, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, interner, mutable bindings, mutable diags, allocator)?
            walk_expr(file, rhs, interner, mutable bindings, mutable diags, allocator)?
        }
    }
}


function record_scoped_binding(
    init_: hir_tree.HExpr,
    hbindings: Vec_HBinding.Vec,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if Vec_HBinding.len(hbindings) != 1 as usize {
        return ()
    }
    match scan_mod.resolve_scoped_dir(init_, bindings, interner) {
        case .some(let dir) => {
            let binding = scan_mod.ScopedBinding {
                def_id: Vec_HBinding.at(hbindings, 0 as usize).def_id,
                dir: dir,
            }
            Vec_ScopedBinding.push(mutable bindings, take binding, allocator)?
            return ()
        }
        case .none => ()
    }
    match scan_mod.resolve_child_cwd(init_, bindings, interner) {
        case .some(let cwd) => {
            let binding = scan_mod.ScopedBinding {
                def_id: Vec_HBinding.at(hbindings, 0 as usize).def_id,
                dir: cwd,
            }
            Vec_ScopedBinding.push(mutable bindings, take binding, allocator)?
        }
        case .none => ()
    }
}


function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .scope_(_, _, let body) => {
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, rhs, interner, mutable bindings, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, interner, mutable bindings, mutable diags, allocator)?
        }
        case .call(_, let args) => {
            walk_args(file, args, interner, mutable bindings, mutable diags, allocator)?
        }
        case .variant_ctor(_, _, let args) => {
            walk_args(file, args, interner, mutable bindings, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, interner, mutable bindings, mutable diags, allocator)?
            walk_args(file, args, interner, mutable bindings, mutable diags, allocator)?
        }
        case .method_call(let name, let args) => {
            walk_args(file, args, interner, mutable bindings, mutable diags, allocator)?
            check_spawn_call(file, expr, name, args, interner, bindings, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, interner, mutable bindings, mutable diags, allocator)?
        }
        case .positional(let recv, let index) => {
            walk_boxed(file, recv, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, index, interner, mutable bindings, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, idx, interner, mutable bindings, mutable diags, allocator)?
        }
        case .subrange(let recv, let lo, let hi, _) => {
            walk_boxed(file, recv, interner, mutable bindings, mutable diags, allocator)?
            walk_opt_boxed(file, lo, interner, mutable bindings, mutable diags, allocator)?
            walk_opt_boxed(file, hi, interner, mutable bindings, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, interner, mutable bindings, mutable diags, allocator)?
            walk_block(file, then_b, interner, mutable bindings, mutable diags, allocator)?
            walk_opt_block(file, else_opt, interner, mutable bindings, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, interner, mutable bindings, mutable diags, allocator)?
            walk_arms(file, arms, interner, mutable bindings, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, interner, mutable bindings, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, interner, mutable bindings, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, interner, mutable bindings, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, interner, mutable bindings, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, interner, mutable bindings, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, interner, mutable bindings, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, interner, mutable bindings, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, interner, mutable bindings, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, interner, mutable bindings, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .comptime_for(_, let lo, let hi, _, let body) => {
            walk_boxed(file, lo, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, hi, interner, mutable bindings, mutable diags, allocator)?
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, interner, mutable bindings, mutable diags, allocator)?
            walk_block(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .closure(let boxed) => {
            walk_block(file, Box_HClosure.get(boxed).body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .spawn_(let boxed) => {
            let sp = Box_HSpawn.get(boxed)
            walk_spawn_args(file, sp.args, interner, mutable bindings, mutable diags, allocator)?
            walk_block(file, sp.body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, interner, mutable bindings, mutable diags, allocator)?
            walk_boxed(file, body, interner, mutable bindings, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_expr(file, Box_HExpr.get(boxed), interner, mutable bindings, mutable diags, allocator)?
}


function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let boxed) => walk_boxed(file, boxed, interner, mutable bindings, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let block) => walk_block(file, block, interner, mutable bindings, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HExpr.at(exprs, i), interner, mutable bindings, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HArg.at(args, i).expr, interner, mutable bindings, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        walk_expr(file, arm.body, interner, mutable bindings, mutable diags, allocator)?
        match arm.guard {
            case .some(let g) => walk_expr(file, g, interner, mutable bindings, mutable diags, allocator)?
            case .none => ()
        }
        i = i + 1 as usize
    }
}


function walk_spawn_args(
    file: hir_file.HirFile,
    args: Vec_HSpawnArg.Vec,
    interner: interner_mod.Interner,
    bindings: mutable Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HSpawnArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HSpawnArg.at(args, i).init_, interner, mutable bindings, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function check_spawn_call(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    name: symbol_mod.Symbol,
    args: Vec_HArg.Vec,
    interner: interner_mod.Interner,
    bindings: Vec_ScopedBinding.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if !scan_mod.is_spawn_name(name, interner) {
        return ()
    }
    if Vec_HArg.len(args) != 3 as usize {
        return ()
    }
    let p_expr = Vec_HArg.at(args, 0 as usize).expr
    let bundle_expr = Vec_HArg.at(args, 1 as usize).expr
    match scan_mod.resolve_scoped_dir(p_expr, bindings, interner) {
        case .some(let dir) => {
            match scan_mod.resolve_child_cwd(bundle_expr, bindings, interner) {
                case .some(let cwd) => {
                    if !scan_mod.dir_permits_cwd(dir, cwd, interner) {
                        emit_escalation(file, expr, mutable diags, allocator)?
                    }
                }
                case .none => ()
            }
        }
        case .none => ()
    }
}


function emit_escalation(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match hir_file.span_of_opt(file, expr.node_id) {
        case .some(let span) => {
            let d = diag_mod.warn_at(code_mod.capability_escalation(), span, "spawn() cwd falls outside the narrowed Subprocess capability's scoped_to directory")
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}


module types.check.pass.rettype.walk

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.node as node_mod
import hir.def as def_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.check.env.builtins as builtins_mod
import types.check.env.sig as sig_mod
import types.check.body.literal.literal as literal_mod
import types.check.diverge.diverge as diverge_mod
import types.ty.name as ty_name_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(sig_mod.FnSig)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)


public function check_return_types(
    file: hir_file.HirFile,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    fn_signatures: Vec_FnSig.Vec,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items(file, file.items, mutable node_types, ty_interner, fn_signatures, builtins, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    fn_signatures: Vec_FnSig.Vec,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        match item.kind {
            case .function_(_, let body) => {
                let ret = ret_ty_of(fn_signatures, item.def_id, ty_interner)
                check_function(file, ret, body, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            }
            case .spec_decl(_, let inner_items) => {
                walk_items(file, inner_items, mutable node_types, ty_interner, fn_signatures, builtins, mutable diags, allocator)?
            }
            case _ => ()
        }
        i = i + 1 as usize
    }
}


function ret_ty_of(
    fn_signatures: Vec_FnSig.Vec,
    def: def_mod.DefId,
    ty_interner: ty_interner_mod.Interner,
) -> ty_mod.TyId
    with {divergence}
{
    if def_mod.is_error(def) {
        return ty_mod.error()
    }
    let i = def_mod.index(def)
    if i >= Vec_FnSig.len(fn_signatures) {
        return ty_mod.error()
    }
    return base_ty(Vec_FnSig.at(fn_signatures, i).ret, ty_interner)
}


function check_function(
    file: hir_file.HirFile,
    ret: ty_mod.TyId,
    body: hir_tree.HBlock,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if ty_mod.is_error(ret) {
        return
    }
    if ty_interner_mod.is_opaque(ty_interner, ret) {
        return
    }
    walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
}


function check_value(
    file: hir_file.HirFile,
    e: hir_tree.HExpr,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match e.kind {
        case .match_(_, let arms) => check_arm_values(file, arms, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case .if_(_, let then_b, let else_opt) => {
            check_block_value(file, then_b, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            match else_opt {
                case .some(let else_b) => check_block_value(file, else_b, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
                case .none => ()
            }
        }
        case .block_(let body) => check_block_value(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case _ => check_leaf_value(file, e, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
    }
}


function check_leaf_value(
    file: hir_file.HirFile,
    e: hir_tree.HExpr,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let arg = base_ty(node_ty_at(node_types, e.node_id), ty_interner)
    if ty_mod.is_error(arg) {
        return
    }
    if ty_interner_mod.is_opaque(ty_interner, arg) {
        return
    }
    if arg.raw == builtins.never_.raw {
        return
    }
    if literal_mod.adopt_payload_arg(e, arg, ret, builtins, ty_interner, mutable node_types) {
        return
    }
    let expected_name = ty_name_mod.name_of(ret, ty_interner, allocator)?
    let found_name = ty_name_mod.name_of(arg, ty_interner, allocator)?
    let msg = f"expected `{expected_name}`, found `{found_name}`"
    emit_type_error(file, e.node_id, msg, mutable diags, allocator)?
}


function check_arm_values(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let body = Vec_HArm.at(arms, i).body
        if !diverge_mod.expr_diverges(body) {
            check_value(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        i = i + 1 as usize
    }
}


function check_block_value(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if !diverge_mod.block_falls_through(block) {
        return
    }
    match block.trailing {
        case .some(let box_e) => check_value(file, Box_HExpr.get(box_e), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_stmt(file, Vec_HStmt.at(block.stmts, i), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => walk_expr(file, Box_HExpr.get(box_e), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_expr(file, rhs, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
    }
}


function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .return_(let opt) => {
            match opt {
                case .some(let box_e) => check_value(file, Box_HExpr.get(box_e), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
                case .none => {
                    if ret.raw != builtins.unit_.raw {
                        emit_type_error(file, expr.node_id, "bare return in a function with a non-unit return type", mutable diags, allocator)?
                    }
                }
            }
            walk_opt_boxed(file, opt, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, rhs, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .call(_, let args) => {
            walk_args(file, args, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .variant_ctor(_, _, let args) => {
            walk_args(file, args, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_args(file, args, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .method_call(_, let args) => {
            walk_args(file, args, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .positional(let recv, let index) => {
            walk_boxed(file, recv, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, index, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, idx, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .subrange(let recv, let lo, let hi, _) => {
            walk_boxed(file, recv, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_opt_boxed(file, lo, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_opt_boxed(file, hi, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_block(file, then_b, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_opt_block(file, else_opt, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_arms(file, arms, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .comptime_for(_, let lo, let hi, _, let body) => {
            walk_boxed(file, lo, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, hi, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_block(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
            walk_boxed(file, body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_expr(file, Box_HExpr.get(boxed), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
}


function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let box_e) => walk_boxed(file, box_e, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let block) => walk_block(file, block, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        case .none => ()
    }
}


function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HExpr.at(exprs, i), ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HArg.at(args, i).expr, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    ret: ty_mod.TyId,
    node_types: mutable Vec_TyId.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        walk_expr(file, Vec_HArm.at(arms, i).body, ret, mutable node_types, ty_interner, builtins, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function base_ty(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> ty_mod.TyId
    with {divergence}
{
    if ty_mod.is_error(t) {
        return t
    }
    if (t.raw as usize) >= ty_interner_mod.slot_count(ty_interner) {
        return t
    }
    return match ty_interner_mod.lookup(ty_interner, t) {
        case .refined(let base, _) => base_ty(base, ty_interner)
        case _ => t
    }
}


function node_ty_at(node_types: Vec_TyId.Vec, n: node_mod.NodeId) -> ty_mod.TyId {
    let i = node_mod.index(n)
    if i >= Vec_TyId.len(node_types) {
        return ty_mod.error()
    }
    return Vec_TyId.at(node_types, i)
}


function emit_type_error(
    file: hir_file.HirFile,
    node_id: node_mod.NodeId,
    msg: String,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match hir_file.span_of_opt(file, node_id) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.typecheck_error(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}

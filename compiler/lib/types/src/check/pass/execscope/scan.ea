
module types.check.pass.execscope.scan

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.tree as hir_tree
import intern.symbol as symbol_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_tree.HClosure)
spec std.mem.alloc.Box(hir_tree.HSpawn)


spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HSpawnArg)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(symbol_mod.Symbol)


public function block_has_spawn_for(block: hir_tree.HBlock, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if stmt_has_spawn_for(Vec_HStmt.at(block.stmts, i), sym) {
            return true
        }
        i = i + 1 as usize
    }
    return match block.trailing {
        case .some(let box_e) => expr_has_spawn_for(Box_HExpr.get(box_e), sym)
        case .none => false
    }
}


function stmt_has_spawn_for(stmt: hir_tree.HStmt, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return match stmt.kind {
        case .let_(_, _, _, _, let init_) => expr_has_spawn_for(init_, sym)
        case .uninit_(_, _, _) => false
        case .assign(let target, _, let rhs) => expr_has_spawn_for(target, sym) || expr_has_spawn_for(rhs, sym)
    }
}


function expr_has_spawn_for(expr: hir_tree.HExpr, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return match expr.kind {
        case .spawn_(let boxed) => spawn_matches(Box_HSpawn.get(boxed), sym)
        case .binary(_, let lhs, let rhs) => boxed_has_spawn_for(lhs, sym) || boxed_has_spawn_for(rhs, sym)
        case .unary(_, let inner) => boxed_has_spawn_for(inner, sym)
        case .call(_, let args) => args_has_spawn_for(args, sym)
        case .variant_ctor(_, _, let args) => args_has_spawn_for(args, sym)
        case .dyn_call(let callee, let args) => boxed_has_spawn_for(callee, sym) || args_has_spawn_for(args, sym)
        case .method_call(_, let args) => args_has_spawn_for(args, sym)
        case .field(let recv, _) => boxed_has_spawn_for(recv, sym)
        case .positional(let recv, let index) => boxed_has_spawn_for(recv, sym) || boxed_has_spawn_for(index, sym)
        case .index(let recv, let idx) => boxed_has_spawn_for(recv, sym) || boxed_has_spawn_for(idx, sym)
        case .subrange(let recv, let lo, let hi, _) => boxed_has_spawn_for(recv, sym) || opt_boxed_has_spawn_for(lo, sym) || opt_boxed_has_spawn_for(hi, sym)
        case .if_(let cond, let then_b, let else_opt) => boxed_has_spawn_for(cond, sym) || block_has_spawn_for(then_b, sym) || opt_block_has_spawn_for(else_opt, sym)
        case .match_(let scrut, let arms) => boxed_has_spawn_for(scrut, sym) || arms_has_spawn_for(arms, sym)
        case .block_(let body) => block_has_spawn_for(body, sym)
        case .loop_(let body, _, let dec_opt) => block_has_spawn_for(body, sym) || opt_boxed_has_spawn_for(dec_opt, sym)
        case .cast(let inner, _, _) => boxed_has_spawn_for(inner, sym)
        case .tuple(let elements) => exprs_has_spawn_for(elements, sym)
        case .struct_lit(_, let fields) => args_has_spawn_for(fields, sym)
        case .raise_(let inner) => boxed_has_spawn_for(inner, sym)
        case .panic_(let inner) => boxed_has_spawn_for(inner, sym)
        case .return_(let opt) => opt_boxed_has_spawn_for(opt, sym)
        case .break_(_, let opt) => opt_boxed_has_spawn_for(opt, sym)
        case .comptime_(let inner) => boxed_has_spawn_for(inner, sym)
        case .comptime_block(let body) => block_has_spawn_for(body, sym)
        case .comptime_for(_, let lo, let hi, _, let body) => boxed_has_spawn_for(lo, sym) || boxed_has_spawn_for(hi, sym) || block_has_spawn_for(body, sym)
        case .scope_(_, _, let body) => block_has_spawn_for(body, sym)
        case .handle_(_, _, let recovery, let body) => boxed_has_spawn_for(recovery, sym) || block_has_spawn_for(body, sym)
        case .closure(let boxed) => block_has_spawn_for(Box_HClosure.get(boxed).body, sym)
        case .forall_(_, let iter, let body) => boxed_has_spawn_for(iter, sym) || boxed_has_spawn_for(body, sym)
        case .exists_(_, let iter, let body) => boxed_has_spawn_for(iter, sym) || boxed_has_spawn_for(body, sym)
        case _ => false
    }
}


function spawn_matches(sp: hir_tree.HSpawn, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    if scope_name_matches(sp.scope_name, sym) {
        return true
    }
    if spawn_args_has_spawn_for(sp.args, sym) {
        return true
    }
    return block_has_spawn_for(sp.body, sym)
}


function scope_name_matches(name: Option_Symbol.Option, sym: symbol_mod.Symbol) -> bool {
    return match name {
        case .some(let n) => n.raw == sym.raw
        case .none => false
    }
}


function boxed_has_spawn_for(boxed: Box_HExpr, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return expr_has_spawn_for(Box_HExpr.get(boxed), sym)
}


function opt_boxed_has_spawn_for(opt: Option_Box_HExpr.Option, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return match opt {
        case .some(let boxed) => boxed_has_spawn_for(boxed, sym)
        case .none => false
    }
}


function opt_block_has_spawn_for(opt: Option_HBlock.Option, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return match opt {
        case .some(let block) => block_has_spawn_for(block, sym)
        case .none => false
    }
}


function exprs_has_spawn_for(exprs: Vec_HExpr.Vec, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if expr_has_spawn_for(Vec_HExpr.at(exprs, i), sym) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}


function args_has_spawn_for(args: Vec_HArg.Vec, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if expr_has_spawn_for(Vec_HArg.at(args, i).expr, sym) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}


function arms_has_spawn_for(arms: Vec_HArm.Vec, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        if expr_has_spawn_for(arm.body, sym) {
            return true
        }
        if guard_has_spawn_for(arm.guard, sym) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}


function guard_has_spawn_for(opt: Option_HExpr.Option, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    return match opt {
        case .some(let g) => expr_has_spawn_for(g, sym)
        case .none => false
    }
}


function spawn_args_has_spawn_for(args: Vec_HSpawnArg.Vec, sym: symbol_mod.Symbol) -> bool
    with {divergence}
{
    let n = Vec_HSpawnArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if expr_has_spawn_for(Vec_HSpawnArg.at(args, i).init_, sym) {
            return true
        }
        i = i + 1 as usize
    }
    return false
}

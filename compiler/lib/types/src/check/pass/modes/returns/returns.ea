
module types.check.pass.modes.returns.returns

import std.mem.alloc
import std.collections.vec
import std.core.option
import syntax.ast.ops as ast_ops
import syntax.ast.item as ast_item_mod
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.def as def_mod
import hir.node as node_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_item.HParam)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArg)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(def_mod.DefId)
spec std.core.option.Option(ast_ops.ParamMode)
spec std.core.option.Option(ast_item_mod.Stability)


public function check_return_modes(
    file: hir_file.HirFile,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items(file, file.items, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        match item.kind {
            case .function_(let sig_box, let body) => {
                let sig = Box_HFnSignature.get(sig_box)
                check_function(file, sig, body, mutable diags, allocator)?
            }
            case .spec_decl(_, let inner_items) => {
                walk_items(file, inner_items, mutable diags, allocator)?
            }
            case _ => ()
        }
        i = i + 1
    }
}


function check_function(
    file: hir_file.HirFile,
    sig: hir_item.HFnSignature,
    body: hir_tree.HBlock,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let mode = sig.return_mode
    let borrows = match mode {
        case .by_value => false
        case _ => true
    }
    if borrows {
        if is_stable(sig.stability) {
            emit_at(file, body.node_id, "a `stable` function may not return a borrow — returned borrows are pointer-identity-dependent", mutable diags, allocator)?
        } else {
            check_block_returns(file, body, mode, sig.params, mutable diags, allocator)?
            check_tail(file, body, mode, sig.params, mutable diags, allocator)?
        }
    }
}


function is_stable(stability: Option_Stability.Option) -> bool {
    return match stability {
        case .some(let s) => match s {
            case .stable_(_) => true
            case .unstable_ => false
        }
        case .none => false
    }
}


function check_tail(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match block.trailing {
        case .some(let boxed) => {
            let e = Box_HExpr.get(boxed)
            check_tail_expr(file, e, mode, params, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function check_tail_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .block_(let inner) => check_tail(file, inner, mode, params, mutable diags, allocator)?
        case .if_(_, let then_b, let else_opt) => {
            check_tail(file, then_b, mode, params, mutable diags, allocator)?
            match else_opt {
                case .some(let eb) => check_tail(file, eb, mode, params, mutable diags, allocator)?
                case .none => ()
            }
        }
        case .match_(_, let arms) => {
            let n = Vec_HArm.len(arms)
            var i: usize = 0
            loop decreases (n - i) {
                if i >= n { break }
                let arm = Vec_HArm.at(arms, i)
                check_tail_expr(file, arm.body, mode, params, mutable diags, allocator)?
                i = i + 1
            }
        }
        case .return_(_) => ()
        case .raise_(_) => ()
        case .panic_(_) => ()
        case .break_(_, _) => ()
        case .continue_(_) => ()
        case .loop_(_, _, _) => ()
        case _ => validate_place(file, expr, mode, params, mutable diags, allocator)?
    }
}


function check_block_returns(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let s = Vec_HStmt.at(block.stmts, i)
        match s.kind {
            case .let_(_, _, _, _, let init_) => scan_returns(file, init_, mode, params, mutable diags, allocator)?
            case .uninit_(_, _, _) => ()
            case .assign(let target, _, let rhs) => {
                scan_returns(file, target, mode, params, mutable diags, allocator)?
                scan_returns(file, rhs, mode, params, mutable diags, allocator)?
            }
        }
        i = i + 1
    }
    match block.trailing {
        case .some(let boxed) => {
            let e = Box_HExpr.get(boxed)
            scan_returns(file, e, mode, params, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function scan_returns(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .return_(let opt) => {
            match opt {
                case .some(let boxed) => {
                    let v = Box_HExpr.get(boxed)
                    validate_place(file, v, mode, params, mutable diags, allocator)?
                }
                case .none => ()
            }
        }
        case .binary(_, let lhs, let rhs) => {
            scan_boxed(file, lhs, mode, params, mutable diags, allocator)?
            scan_boxed(file, rhs, mode, params, mutable diags, allocator)?
        }
        case .unary(_, let inner) => scan_boxed(file, inner, mode, params, mutable diags, allocator)?
        case .call(_, let args) => scan_args(file, args, mode, params, mutable diags, allocator)?
        case .dyn_call(let callee, let args) => {
            scan_boxed(file, callee, mode, params, mutable diags, allocator)?
            scan_args(file, args, mode, params, mutable diags, allocator)?
        }
        case .field(let recv, _) => scan_boxed(file, recv, mode, params, mutable diags, allocator)?
        case .index(let recv, let idx) => {
            scan_boxed(file, recv, mode, params, mutable diags, allocator)?
            scan_boxed(file, idx, mode, params, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            scan_boxed(file, cond, mode, params, mutable diags, allocator)?
            check_block_returns(file, then_b, mode, params, mutable diags, allocator)?
            match else_opt {
                case .some(let eb) => check_block_returns(file, eb, mode, params, mutable diags, allocator)?
                case .none => ()
            }
        }
        case .match_(let scrut, let arms) => {
            scan_boxed(file, scrut, mode, params, mutable diags, allocator)?
            let n = Vec_HArm.len(arms)
            var i: usize = 0
            loop decreases (n - i) {
                if i >= n { break }
                let arm = Vec_HArm.at(arms, i)
                scan_returns(file, arm.body, mode, params, mutable diags, allocator)?
                i = i + 1
            }
        }
        case .block_(let inner) => check_block_returns(file, inner, mode, params, mutable diags, allocator)?
        case .loop_(let inner, _, _) => check_block_returns(file, inner, mode, params, mutable diags, allocator)?
        case .cast(let inner, _, _) => scan_boxed(file, inner, mode, params, mutable diags, allocator)?
        case .tuple(let elements) => scan_exprs(file, elements, mode, params, mutable diags, allocator)?
        case .struct_lit(_, let fields) => scan_args(file, fields, mode, params, mutable diags, allocator)?
        case .raise_(let inner) => scan_boxed(file, inner, mode, params, mutable diags, allocator)?
        case .panic_(let inner) => scan_boxed(file, inner, mode, params, mutable diags, allocator)?
        case .break_(_, let opt) => {
            match opt {
                case .some(let b) => scan_boxed(file, b, mode, params, mutable diags, allocator)?
                case .none => ()
            }
        }
        case .comptime_(let inner) => scan_boxed(file, inner, mode, params, mutable diags, allocator)?
        case .comptime_block(let inner) => check_block_returns(file, inner, mode, params, mutable diags, allocator)?
        case .scope_(_, _, let inner) => check_block_returns(file, inner, mode, params, mutable diags, allocator)?
        case .handle_(_, _, let recovery, let inner) => {
            scan_boxed(file, recovery, mode, params, mutable diags, allocator)?
            check_block_returns(file, inner, mode, params, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function scan_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = Box_HExpr.get(boxed)
    scan_returns(file, inner, mode, params, mutable diags, allocator)?
}

function scan_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_HExpr.at(exprs, i)
        scan_returns(file, e, mode, params, mutable diags, allocator)?
        i = i + 1
    }
}

function scan_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        scan_returns(file, a.expr, mode, params, mutable diags, allocator)?
        i = i + 1
    }
}


function validate_place(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    mode: ast_ops.ReturnMode,
    params: Vec_HParam.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let root = place_root_def(expr)
    match root {
        case .none => {
            emit_at(file, expr.node_id, "returned borrow must be a place rooted at a by-reference parameter — not a local or temporary", mutable diags, allocator)?
        }
        case .some(let def) => {
            if def_mod.is_error(def) {
                return ()
            }
            let p = lookup_param(params, def)
            match p {
                case .none => {
                    emit_at(file, expr.node_id, "returned borrow must be a place rooted at a by-reference parameter — not a local or temporary", mutable diags, allocator)?
                }
                case .some(let pm) => validate_param_mode(file, expr, mode, pm, mutable diags, allocator)?
            }
        }
    }
}

function validate_param_mode(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    mode: ast_ops.ReturnMode,
    param_mode: ast_ops.ParamMode,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match param_mode {
        case .take_ => {
            emit_at(file, expr.node_id, "returned borrow is rooted at a `take` parameter — ownership is transferred, so its storage cannot be borrowed back out", mutable diags, allocator)?
        }
        case .init_ => {
            emit_at(file, expr.node_id, "returned borrow is rooted at an `init` parameter — its storage cannot be borrowed back out", mutable diags, allocator)?
        }
        case .default => {
            match mode {
                case .mutable_ => emit_at(file, expr.node_id, "`-> mutable` requires a `mutable` receiver to root the returned borrow", mutable diags, allocator)?
                case _ => ()
            }
        }
        case .mutable_ => ()
    }
}

function place_root_def(expr: hir_tree.HExpr) -> Option_DefId.Option
    with {divergence}
{
    return match expr.kind {
        case .use_(let def) => Option_DefId.some(value: def)
        case .field(let recv, _) => place_root_def(Box_HExpr.get(recv))
        case .index(let recv, _) => place_root_def(Box_HExpr.get(recv))
        case _ => Option_DefId.none
    }
}

function lookup_param(params: Vec_HParam.Vec, def: def_mod.DefId) -> Option_ParamMode.Option
    with {divergence}
{
    if def_mod.is_error(def) {
        return Option_ParamMode.none
    }
    let n = Vec_HParam.len(params)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let p = Vec_HParam.at(params, i)
        if p.def_id.raw == def.raw {
            return Option_ParamMode.some(value: p.mode)
        }
        i = i + 1
    }
    return Option_ParamMode.none
}


function emit_at(
    file: hir_file.HirFile,
    node_id: node_mod.NodeId,
    msg: String,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match hir_file.span_of_opt(file, node_id) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.mode_violation(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}

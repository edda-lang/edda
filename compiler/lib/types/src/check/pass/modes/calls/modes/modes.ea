
module types.check.pass.modes.calls.modes.modes

import std.mem.alloc
import std.collections.vec
import std.core.option
import std.text.string
import syntax.ast.ops as ast_ops
import syntax.ast.tree as ast_tree
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.def as def_mod
import diagnostics.code as code_mod
import diagnostics.emit.collection as coll_mod
import diagnostics.emit.diagnostic as diag_mod
import local.check.pass.modes.calls.sigs.sigs as sigs_mod
import local.check.pass.modes.calls.immutable.immutable as immutable_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(bool)
spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_item.HParam)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HBinding)
spec std.collections.vec.Vec(sigs_mod.SigSlot)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(ast_ops.CallMode)
spec std.core.option.Option(def_mod.DefId)


public function check_call_modes(
    file: hir_file.HirFile,
    sigs: Vec_SigSlot.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit roots: Vec_bool.Vec
    Vec_bool.new(init roots, allocator)?
    walk_items(file, file.items, sigs, mutable roots, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        walk_item(file, item, sigs, mutable roots, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box, let body) => {
            let sig = Box_HFnSignature.get(sig_box)
            register_params(sig.params, mutable roots, allocator)?
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            walk_items(file, inner_items, sigs, mutable roots, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let s = Vec_HStmt.at(block.stmts, i)
        walk_stmt(file, s, sigs, mutable roots, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => {
            let inner = Box_HExpr.get(box_e)
            walk_expr(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(let binding_mode, let pat, let bindings, _, let init_) => {
            register_let(binding_mode, pat, bindings, mutable roots, allocator)?
            walk_expr(file, init_, sigs, mutable roots, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, sigs, mutable roots, mutable diags, allocator)?
            walk_expr(file, rhs, sigs, mutable roots, mutable diags, allocator)?
        }
    }
}

function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .call(let callee_def, let args) => {
            check_call(file, callee_def, args, sigs, mutable diags, allocator)?
            walk_args(file, args, sigs, mutable roots, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            walk_boxed(file, callee, sigs, mutable roots, mutable diags, allocator)?
            walk_args(file, args, sigs, mutable roots, mutable diags, allocator)?
        }
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, sigs, mutable roots, mutable diags, allocator)?
            walk_boxed(file, rhs, sigs, mutable roots, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, sigs, mutable roots, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, sigs, mutable roots, mutable diags, allocator)?
            walk_boxed(file, idx, sigs, mutable roots, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, sigs, mutable roots, mutable diags, allocator)?
            walk_block(file, then_b, sigs, mutable roots, mutable diags, allocator)?
            walk_opt_block(file, else_opt, sigs, mutable roots, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, sigs, mutable roots, mutable diags, allocator)?
            walk_arms(file, arms, sigs, mutable roots, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, sigs, mutable roots, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, sigs, mutable roots, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, sigs, mutable roots, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            walk_boxed(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            walk_boxed(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, sigs, mutable roots, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, sigs, mutable roots, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, sigs, mutable roots, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .handle_(_, _, let recovery, let body) => {
            walk_boxed(file, recovery, sigs, mutable roots, mutable diags, allocator)?
            walk_block(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, sigs, mutable roots, mutable diags, allocator)?
            walk_boxed(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, sigs, mutable roots, mutable diags, allocator)?
            walk_boxed(file, body, sigs, mutable roots, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = Box_HExpr.get(boxed)
    walk_expr(file, inner, sigs, mutable roots, mutable diags, allocator)?
}

function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, sigs, mutable roots, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, sigs, mutable roots, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_HExpr.at(exprs, i)
        walk_expr(file, e, sigs, mutable roots, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        check_immutable_borrow(file, a, roots, mutable diags, allocator)?
        walk_expr(file, a.expr, sigs, mutable roots, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    sigs: Vec_SigSlot.Vec,
    roots: mutable Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => {
                walk_expr(file, g, sigs, mutable roots, mutable diags, allocator)?
            }
            case .none => ()
        }
        walk_expr(file, arm.body, sigs, mutable roots, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function register_params(
    params: Vec_HParam.Vec,
    roots: mutable Vec_bool.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HParam.len(params)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let p = Vec_HParam.at(params, i)
        match p.mode {
            case .default => immutable_mod.mark_immutable(mutable roots, p.def_id, allocator)?
            case .mutable_ => ()
            case .take_ => ()
            case .init_ => ()
        }
        i = i + 1 as usize
    }
}

function register_let(
    binding_mode: ast_ops.BindingMode,
    pat: ast_tree.Pat,
    bindings: Vec_HBinding.Vec,
    roots: mutable Vec_bool.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match binding_mode {
        case .immutable => {
            match pat.kind {
                case .binding(_) => {
                    if Vec_HBinding.len(bindings) == 1 {
                        let b = Vec_HBinding.at(bindings, 0)
                        immutable_mod.mark_immutable(mutable roots, b.def_id, allocator)?
                    }
                }
                case _ => ()
            }
        }
        case .mutable_ => ()
        case .uninit_ => ()
    }
}


function check_call(
    file: hir_file.HirFile,
    callee_def: def_mod.DefId,
    args: Vec_HArg.Vec,
    sigs: Vec_SigSlot.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let sig = match sigs_mod.lookup_sig(sigs, callee_def) {
        case .some(let s) => s
        case .none => return
    }
    let params = sig.params
    if Vec_HArg.len(args) != Vec_HParam.len(params) {
        return
    }
    if has_named_arg(args) {
        return
    }
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        let p = Vec_HParam.at(params, i)
        check_arg_mode(file, a, p, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function has_named_arg(args: Vec_HArg.Vec) -> bool
    with {divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        match a.name {
            case .some(_) => return true
            case .none => ()
        }
        i = i + 1 as usize
    }
    return false
}

function check_arg_mode(
    file: hir_file.HirFile,
    a: hir_tree.HArg,
    p: hir_item.HParam,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if modes_agree(a.mode, p.mode) {
        return
    }
    let sp = hir_file.span_of_opt(file, a.expr.node_id)
    match sp {
        case .some(let span) => {
            let msg = mismatch_message(a.mode, p.mode, allocator)?
            let d = diag_mod.error_at(code_mod.typecheck_error(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}


function check_immutable_borrow(
    file: hir_file.HirFile,
    a: hir_tree.HArg,
    roots: Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match a.mode {
        case .none => ()
        case .some(let m) => match m {
            case .mutable_ => check_borrow_of(file, a, m, roots, mutable diags, allocator)?
            case .init_ => check_borrow_of(file, a, m, roots, mutable diags, allocator)?
            case .take_ => ()
        }
    }
}

function check_borrow_of(
    file: hir_file.HirFile,
    a: hir_tree.HArg,
    m: ast_ops.CallMode,
    roots: Vec_bool.Vec,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let root = arg_root_def(a.expr)
    match root {
        case .none => ()
        case .some(let def) => {
            if immutable_mod.is_immutable(roots, def) {
                emit_immutable_borrow(file, a, m, mutable diags, allocator)?
            }
        }
    }
}

function arg_root_def(expr: hir_tree.HExpr) -> Option_DefId.Option {
    return match expr.kind {
        case .use_(let def) => Option_DefId.some(value: def)
        case .field(let recv, _) => {
            let inner = Box_HExpr.get(recv)
            match inner.kind {
                case .use_(let def) => Option_DefId.some(value: def)
                case _ => Option_DefId.none
            }
        }
        case _ => Option_DefId.none
    }
}

function emit_immutable_borrow(
    file: hir_file.HirFile,
    a: hir_tree.HArg,
    m: ast_ops.CallMode,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let msg = immutable_borrow_message(m, allocator)?
    match hir_file.span_of_opt(file, a.expr.node_id) {
        case .some(let span) => {
            let d = diag_mod.error_at(code_mod.mode_violation(), span, msg)
            coll_mod.emit(mutable diags, take d, allocator)?
        }
        case .none => ()
    }
}

function immutable_borrow_message(m: ast_ops.CallMode, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let kw = match m {
        case .mutable_ => "mutable"
        case .take_ => "take"
        case .init_ => "init"
    }
    let p1 = string.concat("a `", kw, allocator)?
    let p2 = string.concat(p1, "` borrow requires the root binding to be mutable, but it is immutable (a `let` local or a default-mode parameter); declare it `var` (a local) or take it as a `mutable` / `init` parameter — a `", allocator)?
    let p3 = string.concat(p2, kw, allocator)?
    return string.concat(p3, "` borrow of an immutable binding is lowered as a copy, so the write would be lost", allocator)?
}


function modes_agree(call_mode: Option_CallMode.Option, param_mode: ast_ops.ParamMode) -> bool {
    return match param_mode {
        case .default => is_default_call(call_mode)
        case .mutable_ => is_call_mode(call_mode, ast_ops.CallMode.mutable_) || is_call_mode(call_mode, ast_ops.CallMode.take_) || is_default_call(call_mode)
        case .take_ => is_call_mode(call_mode, ast_ops.CallMode.take_) || is_default_call(call_mode)
        case .init_ => is_call_mode(call_mode, ast_ops.CallMode.init_)
    }
}

function is_default_call(call_mode: Option_CallMode.Option) -> bool {
    return match call_mode {
        case .some(_) => false
        case .none => true
    }
}

function is_call_mode(call_mode: Option_CallMode.Option, want: ast_ops.CallMode) -> bool {
    return match call_mode {
        case .some(let m) => m == want
        case .none => false
    }
}

function mismatch_message(
    call_mode: Option_CallMode.Option,
    param_mode: ast_ops.ParamMode,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let want = expected_keyword(param_mode)
    let got = actual_keyword(call_mode)
    let p1 = string.concat("argument mode mismatch: parameter expects ", want, allocator)?
    let p2 = string.concat(p1, " but call site uses ", allocator)?
    return string.concat(p2, got, allocator)?
}

function expected_keyword(param_mode: ast_ops.ParamMode) -> String {
    return match param_mode {
        case .default => "a borrowed (no keyword) argument"
        case .mutable_ => "`mutable`"
        case .take_ => "`take`"
        case .init_ => "`init`"
    }
}

function actual_keyword(call_mode: Option_CallMode.Option) -> String {
    return match call_mode {
        case .some(let m) => match m {
            case .mutable_ => "`mutable`"
            case .take_ => "`take`"
            case .init_ => "`init`"
        }
        case .none => "no keyword"
    }
}


module types.check.pass.modes.calls.sigs.sigs

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.item as hir_item
import hir.def as def_mod


spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_item.HDeclItem)
spec std.core.option.Option(hir_item.HFnSignature)
spec std.collections.vec.Vec(SigSlot)


derive clone, debug for SigSlot


public type SigSlot {
    sig: Option_HFnSignature.Option
}


public function index_items(
    items: Vec_HItem.Vec,
    sigs: mutable Vec_SigSlot.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        index_item(item, mutable sigs, allocator)?
        i = i + 1 as usize
    }
}

function index_item(
    item: hir_item.HItem,
    sigs: mutable Vec_SigSlot.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box, _) => {
            let sig = Box_HFnSignature.get(sig_box)
            record_sig_at_def(mutable sigs, item.def_id, sig, allocator)?
        }
        case .function_extern(let sig_box, _, _, _) => {
            let sig = Box_HFnSignature.get(sig_box)
            record_sig_at_def(mutable sigs, item.def_id, sig, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            index_items(inner_items, mutable sigs, allocator)?
        }
        case _ => ()
    }
}

public function index_items_decl(
    items: Vec_HDeclItem.Vec,
    sigs: mutable Vec_SigSlot.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HDeclItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HDeclItem.at(items, i)
        index_item_decl(item, mutable sigs, allocator)?
        i = i + 1 as usize
    }
}

function index_item_decl(
    item: hir_item.HDeclItem,
    sigs: mutable Vec_SigSlot.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box) => {
            let sig = Box_HFnSignature.get(sig_box)
            record_sig_at_def(mutable sigs, item.def_id, sig, allocator)?
        }
        case .function_extern(let sig_box, _, _, _) => {
            let sig = Box_HFnSignature.get(sig_box)
            record_sig_at_def(mutable sigs, item.def_id, sig, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            index_items_decl(inner_items, mutable sigs, allocator)?
        }
        case _ => ()
    }
}

function record_sig_at_def(
    sigs: mutable Vec_SigSlot.Vec,
    def_id: def_mod.DefId,
    sig: hir_item.HFnSignature,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if def_mod.is_error(def_id) {
        return
    }
    let target = def_mod.index(def_id)
    loop {
        let len = Vec_SigSlot.len(sigs)
        if len >= target { break }
        Vec_SigSlot.push(mutable sigs, SigSlot { sig: Option_HFnSignature.none }, allocator)?
    }
    let current = Vec_SigSlot.len(sigs)
    let slot = SigSlot { sig: Option_HFnSignature.some(value: sig) }
    if current == target {
        Vec_SigSlot.push(mutable sigs, slot, allocator)?
    } else {
        Vec_SigSlot.set_at(mutable sigs, target, slot)
    }
}

public function lookup_sig(
    sigs: Vec_SigSlot.Vec,
    def: def_mod.DefId,
) -> Option_HFnSignature.Option {
    if def_mod.is_error(def) {
        return Option_HFnSignature.none
    }
    let i = def_mod.index(def)
    if i >= Vec_SigSlot.len(sigs) {
        return Option_HFnSignature.none
    }
    let slot = Vec_SigSlot.at(sigs, i)
    return slot.sig
}


module types.check.pass.modes.calls.immutable.immutable

import std.mem.alloc
import std.collections.vec
import hir.def as def_mod


spec std.collections.vec.Vec(bool)


public function mark_immutable(
    roots: mutable Vec_bool.Vec,
    def: def_mod.DefId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    if def_mod.is_error(def) {
        return
    }
    let target = def_mod.index(def)
    grow_to(mutable roots, target, allocator)?
    Vec_bool.set_at(mutable roots, target, true)
}


function grow_to(roots: mutable Vec_bool.Vec, target: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    loop {
        let len = Vec_bool.len(roots)
        if len > target { break }
        Vec_bool.push(mutable roots, false, allocator)?
    }
}


public function is_immutable(roots: Vec_bool.Vec, def: def_mod.DefId) -> bool {
    if def_mod.is_error(def) {
        return false
    }
    let target = def_mod.index(def)
    if target >= Vec_bool.len(roots) {
        return false
    }
    return Vec_bool.at(roots, target)
}

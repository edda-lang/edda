module types.check.body.methodret.methodret

import std.mem.alloc
import std.collections.vec
import intern.interner as interner_mod
import intern.symbol as symbol_mod
import hir.tree as hir_tree
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import local.check.env.sig as sig_mod
import local.check.env.builtins as builtins_mod
import local.check.body.lookup.lookup as lookup_mod

spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(ty_mod.TyId)

public function builtin_method_ret(
    name: symbol_mod.Symbol,
    recv_ty: ty_mod.TyId,
    args: Vec_HArg.Vec,
    builtins: builtins_mod.Builtins,
    interner: interner_mod.Interner,
    type_defs: Vec_TyId.Vec,
    ty_interner: mutable ty_interner_mod.Interner,
    allocator: Allocator,
) -> ty_mod.TyId
    with {allocator, err: alloc.AllocError, divergence}
{
    if sig_mod.sym_is(interner, name, "len") {
        if sig_mod.is_slice_ty(recv_ty, ty_interner) || recv_ty.raw == builtins.string_.raw {
            return builtins.usize_
        }
    }
    if sig_mod.sym_is(interner, name, "bytes") && recv_ty.raw == builtins.string_.raw {
        let cty = ty_kind_mod.CTy.slice(elem: builtins.u8_)
        return ty_interner_mod.intern(mutable ty_interner, take cty, allocator)?
    }
    let is_array_alloc = sig_mod.sym_is(interner, name, "alloc_array") || sig_mod.sym_is(interner, name, "realloc_array")
    if is_array_alloc && is_allocator_ty(recv_ty, builtins) && Vec_HArg.len(args) >= 2 as usize {
        let elem = lookup_mod.type_arg_ty(Vec_HArg.at(args, 1 as usize).expr, builtins, type_defs)
        if !ty_mod.is_error(elem) {
            let cty = ty_kind_mod.CTy.slice(elem: elem)
            return ty_interner_mod.intern(mutable ty_interner, take cty, allocator)?
        }
    }
    return ty_mod.error()
}

function is_allocator_ty(recv_ty: ty_mod.TyId, builtins: builtins_mod.Builtins) -> bool {
    return recv_ty.raw == builtins.allocator.raw || recv_ty.raw == builtins.bounded_allocator.raw
}

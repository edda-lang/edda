module types.check.body.fieldty.fieldty

import std.collections.vec
import std.core.option
import hir.def as def_mod
import hir.tree as hir_tree
import intern.symbol as symbol_mod
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import local.check.env.fields as fields_mod
import local.check.env.builtins as builtins_mod

spec std.collections.vec.Vec(fields_mod.FieldTyList)
spec std.collections.vec.Vec(fields_mod.VariantNameList)
spec std.collections.vec.Vec(fields_mod.FieldNameMatrix)
spec std.collections.vec.Vec(ty_mod.TyId)

spec std.core.option.Option(u32)

public function infer_field_ty(
    recv_ty: ty_mod.TyId,
    accessor: hir_tree.FieldAccessor,
    field_tys: Vec_FieldTyList.Vec,
    field_names: Vec_FieldNameMatrix.Vec,
    ty_interner: ty_interner_mod.Interner,
    builtins: builtins_mod.Builtins,
) -> ty_mod.TyId
    with {divergence}
{
    if ty_mod.is_error(recv_ty) {
        return ty_mod.error()
    }
    if (recv_ty.raw as usize) >= ty_interner_mod.slot_count(ty_interner) {
        return ty_mod.error()
    }
    let cty = ty_interner_mod.lookup(ty_interner, recv_ty)
    if ty_kind_mod.is_opaque(cty) {
        return recv_ty
    }
    return match accessor {
        case .indexed(let i) => match cty {
            case .tuple_(let elems) => {
                let ix = i as usize
                if ix >= Vec_TyId.len(elems) {
                    ty_mod.error()
                } else {
                    Vec_TyId.at(elems, ix)
                }
            }
            case .record(let def) => field_ty_at(field_tys, def, i as usize)
            case .spec_instance(let def, _) => field_ty_at(field_tys, def, i as usize)
            case .sum_(let def) => field_ty_at(field_tys, def, i as usize)
            case _ => ty_mod.error()
        }
        case .named(let sym) => match cty {
            case .record(let def) => named_field_ty(field_tys, field_names, def, sym)
            case .spec_instance(let def, _) => named_field_ty(field_tys, field_names, def, sym)
            case _ => ty_mod.error()
        }
    }
}

public function named_field_ty(
    field_tys: Vec_FieldTyList.Vec,
    field_names: Vec_FieldNameMatrix.Vec,
    def: def_mod.DefId,
    sym: symbol_mod.Symbol,
) -> ty_mod.TyId
    with {divergence}
{
    return match fields_mod.field_index_in(field_names, def, 0 as u32, sym) {
        case .some(let ix) => field_ty_at(field_tys, def, ix as usize)
        case .none => ty_mod.error()
    }
}

public function field_ty_at(
    field_tys: Vec_FieldTyList.Vec,
    def: def_mod.DefId,
    index: usize,
) -> ty_mod.TyId {
    if def_mod.is_error(def) {
        return ty_mod.error()
    }
    let di = def_mod.index(def)
    if di >= Vec_FieldTyList.len(field_tys) {
        return ty_mod.error()
    }
    let list = Vec_FieldTyList.at(field_tys, di)
    if index >= Vec_TyId.len(list.tys) {
        return ty_mod.error()
    }
    return Vec_TyId.at(list.tys, index)
}

module types.check.body.lookup.lookup

import std.collections.vec
import hir.def as def_mod
import hir.tree as hir_tree
import types.pass.ty as ty_mod
import local.check.env.sig as sig_mod
import local.check.env.builtins as builtins_mod

spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(sig_mod.FnSig)

public function lookup_use_type(
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    type_defs: Vec_TyId.Vec,
    builtins: builtins_mod.Builtins,
    def: def_mod.DefId,
) -> ty_mod.TyId
{
    let t = lookup_local_type(local_types, def)
    if !ty_mod.is_error(t) {
        return t
    }
    let fn_ty = lookup_fn_type(fn_signatures, def)
    if !ty_mod.is_error(fn_ty) {
        return fn_ty
    }
    let type_ty = lookup_type_def(type_defs, def)
    if !ty_mod.is_error(type_ty) {
        return builtins.type_meta
    }
    if !ty_mod.is_error(prim_ty_of_def(def, builtins)) {
        return builtins.type_meta
    }
    if builtins_mod.is_capability_def(builtins, def) {
        return builtins.type_meta
    }
    return ty_mod.error()
}

public function lookup_local_type(local_types: Vec_TyId.Vec, def: def_mod.DefId) -> ty_mod.TyId {
    if def_mod.is_error(def) {
        return ty_mod.error()
    }
    let i = def_mod.index(def)
    if i >= Vec_TyId.len(local_types) {
        return ty_mod.error()
    }
    return Vec_TyId.at(local_types, i)
}

public function lookup_type_def(type_defs: Vec_TyId.Vec, def: def_mod.DefId) -> ty_mod.TyId {
    if def_mod.is_error(def) {
        return ty_mod.error()
    }
    let i = def_mod.index(def)
    if i >= Vec_TyId.len(type_defs) {
        return ty_mod.error()
    }
    return Vec_TyId.at(type_defs, i)
}

function lookup_fn_type(fn_signatures: Vec_FnSig.Vec, def: def_mod.DefId) -> ty_mod.TyId {
    if def_mod.is_error(def) {
        return ty_mod.error()
    }
    let i = def_mod.index(def)
    if i >= Vec_FnSig.len(fn_signatures) {
        return ty_mod.error()
    }
    let sig = Vec_FnSig.at(fn_signatures, i)
    return sig.fn_type
}

function prim_ty_of_def(def: def_mod.DefId, builtins: builtins_mod.Builtins) -> ty_mod.TyId {
    let p = builtins.prim_defs
    let r = def.raw
    if r == p.i8_.raw    { return builtins.i8_ }
    if r == p.i16_.raw   { return builtins.i16_ }
    if r == p.i32_.raw   { return builtins.i32_ }
    if r == p.i64_.raw   { return builtins.i64_ }
    if r == p.i128_.raw  { return builtins.i128_ }
    if r == p.u8_.raw    { return builtins.u8_ }
    if r == p.u16_.raw   { return builtins.u16_ }
    if r == p.u32_.raw   { return builtins.u32_ }
    if r == p.u64_.raw   { return builtins.u64_ }
    if r == p.u128_.raw  { return builtins.u128_ }
    if r == p.isize_.raw { return builtins.isize_ }
    if r == p.usize_.raw { return builtins.usize_ }
    if r == p.f32_.raw   { return builtins.f32_ }
    if r == p.f64_.raw   { return builtins.f64_ }
    if r == p.bool_.raw  { return builtins.bool_ }
    if r == p.codepoint_.raw { return builtins.codepoint_ }
    if r == p.string_.raw    { return builtins.string_ }
    return ty_mod.error()
}

public function type_arg_ty(arg: hir_tree.HExpr, builtins: builtins_mod.Builtins, type_defs: Vec_TyId.Vec) -> ty_mod.TyId {
    return match arg.kind {
        case .use_(let def) => {
            let prim = prim_ty_of_def(def, builtins)
            if ty_mod.is_error(prim) {
                lookup_type_def(type_defs, def)
            } else {
                prim
            }
        }
        case _ => ty_mod.error()
    }
}

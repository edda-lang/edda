
module types.check.body.ops.ops

import syntax.ast.ops as ast_ops
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import local.check.env.builtins as builtins_mod


public function infer_binary(
    op: ast_ops.BinOp,
    lhs_ty: ty_mod.TyId,
    rhs_ty: ty_mod.TyId,
    builtins: builtins_mod.Builtins,
    ty_interner: ty_interner_mod.Interner,
) -> ty_mod.TyId
{
    return match op {
        case .add => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .sub => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .mul => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .div => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .mod => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .wrap_add => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .wrap_sub => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .wrap_mul => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .sat_add => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .sat_sub => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .sat_mul => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .check_add => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .check_sub => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .check_mul => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .check_mod => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .eq => builtins.bool_
        case .ne => builtins.bool_
        case .lt => builtins.bool_
        case .le => builtins.bool_
        case .gt => builtins.bool_
        case .ge => builtins.bool_
        case .and => builtins.bool_
        case .or => builtins.bool_
        case .bit_and => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .bit_or => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .bit_xor => arith_result(lhs_ty, rhs_ty, ty_interner)
        case .shl => lhs_ty
        case .shr => lhs_ty
    }
}

public function infer_unary(
    op: ast_ops.UnOp,
    inner_ty: ty_mod.TyId,
    builtins: builtins_mod.Builtins,
) -> ty_mod.TyId
{
    return match op {
        case .neg => inner_ty
        case .not => builtins.bool_
        case .bit_not => inner_ty
    }
}


function arith_result(lhs: ty_mod.TyId, rhs: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> ty_mod.TyId {
    if ty_mod.is_error(lhs) {
        return ty_mod.error()
    }
    if ty_mod.is_error(rhs) {
        return ty_mod.error()
    }
    if ty_interner_mod.is_opaque(ty_interner, lhs) {
        return lhs
    }
    if ty_interner_mod.is_opaque(ty_interner, rhs) {
        return rhs
    }
    if lhs.raw == rhs.raw {
        return lhs
    }
    return ty_mod.error()
}

public function unify(a: ty_mod.TyId, b: ty_mod.TyId, builtins: builtins_mod.Builtins) -> ty_mod.TyId {
    if ty_mod.is_error(a) {
        return b
    }
    if ty_mod.is_error(b) {
        return a
    }
    if a.raw == builtins.never_.raw {
        return b
    }
    if b.raw == builtins.never_.raw {
        return a
    }
    if a.raw == b.raw {
        return a
    }
    return ty_mod.error()
}

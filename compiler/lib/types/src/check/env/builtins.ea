
module types.check.env.builtins

import std.mem.alloc
import std.collections.vec
import std.core.option
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import target.capability as cap_mod
import hir.def as def_mod
import local.check.env.lower.nominals as nominals_mod
import resolve.build.builtins as resolve_builtins_mod
import resolve.primitives.defs as primitives_mod
import resolve.cteval.builtins as cbi_mod
import resolve.capabilities.defs as capabilities_mod


spec std.collections.vec.Vec(u32)
spec std.core.option.Option(cap_mod.Capability)


derive eq, clone, debug for Builtins


public type Builtins {
    i8_: ty_mod.TyId
    i16_: ty_mod.TyId
    i32_: ty_mod.TyId
    i64_: ty_mod.TyId
    i128_: ty_mod.TyId
    u8_: ty_mod.TyId
    u16_: ty_mod.TyId
    u32_: ty_mod.TyId
    u64_: ty_mod.TyId
    u128_: ty_mod.TyId
    isize_: ty_mod.TyId
    usize_: ty_mod.TyId
    f32_: ty_mod.TyId
    f64_: ty_mod.TyId
    bool_: ty_mod.TyId
    unit_: ty_mod.TyId
    never_: ty_mod.TyId
    codepoint_: ty_mod.TyId
    type_meta: ty_mod.TyId
    heap_ptr: ty_mod.TyId
    string_: ty_mod.TyId
    filesystem: ty_mod.TyId
    read_only_filesystem: ty_mod.TyId
    sandboxed_filesystem: ty_mod.TyId
    network: ty_mod.TyId
    localhost_network: ty_mod.TyId
    restricted_network: ty_mod.TyId
    clock: ty_mod.TyId
    monotonic_clock: ty_mod.TyId
    random: ty_mod.TyId
    deterministic_random: ty_mod.TyId
    allocator: ty_mod.TyId
    bounded_allocator: ty_mod.TyId
    executor: ty_mod.TyId
    stdin: ty_mod.TyId
    stdout: ty_mod.TyId
    stderr: ty_mod.TyId
    subprocess: ty_mod.TyId
    dom: ty_mod.TyId
    window: ty_mod.TyId
    extension_content: ty_mod.TyId
    extension_worker: ty_mod.TyId
    debugger: ty_mod.TyId
    iter_defs: resolve_builtins_mod.BuiltinDefs
    prim_defs: primitives_mod.PrimitiveDefs
    comptime_defs: cbi_mod.ComptimeBuiltinDefs
    cap_defs: capabilities_mod.CapabilityDefs
    nominals: nominals_mod.NominalMap
    for_hints: Vec_u32.Vec
    ptr_width: usize
}


public function seed_builtins(
    ty_interner: mutable ty_interner_mod.Interner,
    nominals: take nominals_mod.NominalMap,
    ptr_width: usize,
    for_hints: Vec_u32.Vec,
    allocator: Allocator,
) -> Builtins
    with {allocator, err: alloc.AllocError}
{
    let i8_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.i8_), allocator)?
    let i16_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.i16_), allocator)?
    let i32_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.i32_), allocator)?
    let i64_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.i64_), allocator)?
    let i128_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.i128_), allocator)?
    let u8_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.u8_), allocator)?
    let u16_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.u16_), allocator)?
    let u32_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.u32_), allocator)?
    let u64_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.u64_), allocator)?
    let u128_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.u128_), allocator)?
    let isize_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.isize_), allocator)?
    let usize_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.usize_), allocator)?
    let f32_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.f32_), allocator)?
    let f64_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.f64_), allocator)?
    let bool_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.bool_), allocator)?
    let unit_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.unit_), allocator)?
    let never_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.never_), allocator)?
    let codepoint_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.codepoint_), allocator)?
    let type_meta = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.type_meta), allocator)?
    let heap_ptr = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.primitive(ty_kind_mod.PrimKind.heap_ptr), allocator)?
    let string_ = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.string_, allocator)?
    let filesystem = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.filesystem), allocator)?
    let read_only_filesystem = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.read_only_filesystem), allocator)?
    let sandboxed_filesystem = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.sandboxed_filesystem), allocator)?
    let network = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.network), allocator)?
    let localhost_network = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.localhost_network), allocator)?
    let restricted_network = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.restricted_network), allocator)?
    let clock = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.clock), allocator)?
    let monotonic_clock = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.monotonic_clock), allocator)?
    let random = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.random), allocator)?
    let deterministic_random = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.deterministic_random), allocator)?
    let allocator_cap = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.allocator), allocator)?
    let bounded_allocator = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.bounded_allocator), allocator)?
    let executor = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.executor), allocator)?
    let stdin = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.stdin), allocator)?
    let stdout = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.stdout), allocator)?
    let stderr = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.stderr), allocator)?
    let subprocess = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.subprocess), allocator)?
    let dom = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.dom), allocator)?
    let window = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.window), allocator)?
    let extension_content = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.extension_content), allocator)?
    let extension_worker = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.extension_worker), allocator)?
    let debugger = ty_interner_mod.intern(mutable ty_interner, ty_kind_mod.CTy.capability(cap: cap_mod.Capability.debugger), allocator)?
    let builtins_seed = resolve_builtins_mod.seed(1 as u32)
    let prims_seed = primitives_mod.seed(builtins_seed.next_def_id)
    let cbi_seed = cbi_mod.seed(prims_seed.next_def_id)
    let caps_seed = capabilities_mod.seed(cbi_seed.next_def_id)
    let iter_defs = builtins_seed.builtins
    let prim_defs = prims_seed.primitives
    let comptime_defs = cbi_seed.comptime_builtins
    let cap_defs = caps_seed.capabilities

    return Builtins {
        i8_: i8_,
        i16_: i16_,
        i32_: i32_,
        i64_: i64_,
        i128_: i128_,
        u8_: u8_,
        u16_: u16_,
        u32_: u32_,
        u64_: u64_,
        u128_: u128_,
        isize_: isize_,
        usize_: usize_,
        f32_: f32_,
        f64_: f64_,
        bool_: bool_,
        unit_: unit_,
        never_: never_,
        codepoint_: codepoint_,
        type_meta: type_meta,
        heap_ptr: heap_ptr,
        string_: string_,
        filesystem: filesystem,
        read_only_filesystem: read_only_filesystem,
        sandboxed_filesystem: sandboxed_filesystem,
        network: network,
        localhost_network: localhost_network,
        restricted_network: restricted_network,
        clock: clock,
        monotonic_clock: monotonic_clock,
        random: random,
        deterministic_random: deterministic_random,
        allocator: allocator_cap,
        bounded_allocator: bounded_allocator,
        executor: executor,
        stdin: stdin,
        stdout: stdout,
        stderr: stderr,
        subprocess: subprocess,
        dom: dom,
        window: window,
        extension_content: extension_content,
        extension_worker: extension_worker,
        debugger: debugger,
        iter_defs: iter_defs,
        prim_defs: prim_defs,
        comptime_defs: comptime_defs,
        cap_defs: cap_defs,
        nominals: nominals,
        for_hints: for_hints,
        ptr_width: ptr_width,
    }
}


public stable function builtin_for_cap(b: Builtins, cap: cap_mod.Capability) -> ty_mod.TyId {
    return match cap {
        case .filesystem            => b.filesystem
        case .read_only_filesystem  => b.read_only_filesystem
        case .sandboxed_filesystem  => b.sandboxed_filesystem
        case .network               => b.network
        case .localhost_network     => b.localhost_network
        case .restricted_network    => b.restricted_network
        case .clock                 => b.clock
        case .monotonic_clock       => b.monotonic_clock
        case .random                => b.random
        case .deterministic_random  => b.deterministic_random
        case .allocator             => b.allocator
        case .bounded_allocator     => b.bounded_allocator
        case .executor              => b.executor
        case .stdin                 => b.stdin
        case .stdout                => b.stdout
        case .stderr                => b.stderr
        case .subprocess            => b.subprocess
        case .dom                   => b.dom
        case .window                => b.window
        case .extension_content     => b.extension_content
        case .extension_worker      => b.extension_worker
        case .debugger              => b.debugger
    }
}


public function is_capability_def(b: Builtins, def: def_mod.DefId) -> bool {
    return match capabilities_mod.cap_of(b.cap_defs, def) {
        case .some(_) => true
        case .none => false
    }
}

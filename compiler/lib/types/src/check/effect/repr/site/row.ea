    let n = Vec_CEntry.len(caller.entries)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        match Vec_CEntry.at(caller.entries, i) {
            case .alloc_(let have) => {
                if have >= need { return true }
            }
            case _ => ()
        }
        i = i + 1 as usize
    }
    return false
}


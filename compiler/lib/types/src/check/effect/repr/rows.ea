
module types.check.effect.repr.rows

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.build.file as hir_file
import hir.item as hir_item
import hir.tree as hir_tree
import hir.node as node_mod
import hir.def as def_mod
import intern.interner as interner_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.effect.row as effect_row_mod
import types.effect.interner as effect_interner_mod
import local.check.env.sig as sig_mod
import local.check.effect.repr.site.gate as gate_mod
import diagnostics.emit.collection as coll_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item.HFnSignature)


spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(effect_row_mod.CEntry)
spec std.collections.vec.Vec(sig_mod.FnSig)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(def_mod.DefId)


spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(effect_row_mod.CRow)


public function check_effect_containment(
    file: hir_file.HirFile,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit discharged: Vec_TyId.Vec
    Vec_TyId.new(init discharged, allocator)?
    walk_items(file, file.items, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
}


function walk_items(
    file: hir_file.HirFile,
    items: Vec_HItem.Vec,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HItem.len(items)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(items, i)
        walk_item(file, item, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_item(
    file: hir_file.HirFile,
    item: hir_item.HItem,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(_, let body) => {
            match resolve_row(fn_signatures, effect_interner, item.def_id) {
                case .some(let row) => {
                    walk_block(file, body, row, false, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
                }
                case .none => ()
            }
        }
        case .spec_decl(_, let inner_items) => {
            walk_items(file, inner_items, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case _ => ()
    }
}


function resolve_row(
    fn_signatures: Vec_FnSig.Vec,
    effect_interner: effect_interner_mod.Interner,
    def_id: def_mod.DefId,
) -> Option_CRow.Option
{
    if def_mod.is_error(def_id) {
        return Option_CRow.none
    }
    let i = def_mod.index(def_id)
    if i >= Vec_FnSig.len(fn_signatures) {
        return Option_CRow.none
    }
    let sig = Vec_FnSig.at(fn_signatures, i)
    let id = sig.effects
    if (id.raw as usize) >= effect_interner_mod.slot_count(effect_interner) {
        return Option_CRow.none
    }
    return Option_CRow.some(value: effect_interner_mod.lookup(effect_interner, id))
}


function walk_block(
    file: hir_file.HirFile,
    block: hir_tree.HBlock,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HStmt.len(block.stmts)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let s = Vec_HStmt.at(block.stmts, i)
        walk_stmt(file, s, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
    match block.trailing {
        case .some(let box_e) => {
            let inner = Box_HExpr.get(box_e)
            walk_expr(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .none => ()
    }
}

function walk_stmt(
    file: hir_file.HirFile,
    stmt: hir_tree.HStmt,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match stmt.kind {
        case .let_(_, _, _, _, let init_) => {
            walk_expr(file, init_, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(file, target, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_expr(file, rhs, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
    }
}

function walk_expr(
    file: hir_file.HirFile,
    expr: hir_tree.HExpr,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match expr.kind {
        case .binary(_, let lhs, let rhs) => {
            walk_boxed(file, lhs, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_boxed(file, rhs, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .unary(_, let inner) => {
            walk_boxed(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .call(let callee, let args) => {
            gate_mod.check_call_effects(file, expr.node_id, callee, caller, in_comptime, discharged, fn_signatures, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_args(file, args, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .method_call(_, let args) => {
            let m_callee = method_callee_at(node_call_method, expr.node_id)
            gate_mod.check_call_effects(file, expr.node_id, m_callee, caller, in_comptime, discharged, fn_signatures, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_args(file, args, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .variant_ctor(_, _, let args) => {
            walk_args(file, args, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .dyn_call(let callee, let args) => {
            gate_mod.check_dyn_call_effects(file, expr.node_id, Box_HExpr.get(callee).node_id, caller, in_comptime, discharged, node_types, ty_interner, effect_interner, mutable diags, allocator)?
            walk_boxed(file, callee, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_args(file, args, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .field(let recv, _) => {
            walk_boxed(file, recv, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_boxed(file, recv, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_boxed(file, idx, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .if_(let cond, let then_b, let else_opt) => {
            walk_boxed(file, cond, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_block(file, then_b, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_opt_block(file, else_opt, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .match_(let scrut, let arms) => {
            walk_boxed(file, scrut, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_arms(file, arms, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .block_(let body) => {
            walk_block(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .loop_(let body, _, let dec_opt) => {
            walk_block(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_opt_boxed(file, dec_opt, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .cast(let inner, _, _) => {
            walk_boxed(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .tuple(let elements) => {
            walk_exprs(file, elements, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .struct_lit(_, let fields) => {
            walk_args(file, fields, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .raise_(let inner) => {
            gate_mod.check_raise_effects(file, expr.node_id, inner, caller, discharged, node_types, mutable diags, allocator)?
            walk_boxed(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .panic_(let inner) => {
            gate_mod.check_panic_effects(file, expr.node_id, caller, in_comptime, mutable diags, allocator)?
            walk_boxed(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .return_(let opt) => {
            walk_opt_boxed(file, opt, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .break_(_, let opt) => {
            walk_opt_boxed(file, opt, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .comptime_(let inner) => {
            walk_boxed(file, inner, caller, true, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .comptime_block(let body) => {
            walk_block(file, body, caller, true, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .scope_(_, _, let body) => {
            walk_block(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .handle_(_, let binder, let recovery, let body) => {
            walk_boxed(file, recovery, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            let caught = gate_mod.local_type_at(local_types, binder)
            if ty_mod.is_error(caught) {
                walk_block(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            } else {
                Vec_TyId.push(mutable discharged, caught, allocator)?
                walk_block(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
                let _ = Vec_TyId.pop(mutable discharged)
            }
        }
        case .forall_(_, let iter, let body) => {
            walk_boxed(file, iter, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_boxed(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_boxed(file, iter, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            walk_boxed(file, body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        }
        case _ => ()
    }
}

function walk_boxed(
    file: hir_file.HirFile,
    boxed: Box_HExpr,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = Box_HExpr.get(boxed)
    walk_expr(file, inner, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
}

function walk_opt_boxed(
    file: hir_file.HirFile,
    opt: Option_Box_HExpr.Option,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_boxed(file, b, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_opt_block(
    file: hir_file.HirFile,
    opt: Option_HBlock.Option,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_block(file, b, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        case .none => ()
    }
}

function walk_exprs(
    file: hir_file.HirFile,
    exprs: Vec_HExpr.Vec,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HExpr.len(exprs)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_HExpr.at(exprs, i)
        walk_expr(file, e, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_args(
    file: hir_file.HirFile,
    args: Vec_HArg.Vec,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArg.len(args)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let a = Vec_HArg.at(args, i)
        walk_expr(file, a.expr, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}

function walk_arms(
    file: hir_file.HirFile,
    arms: Vec_HArm.Vec,
    caller: effect_row_mod.CRow,
    in_comptime: bool,
    discharged: mutable Vec_TyId.Vec,
    node_types: Vec_TyId.Vec,
    local_types: Vec_TyId.Vec,
    fn_signatures: Vec_FnSig.Vec,
    node_call_method: Vec_DefId.Vec,
    interner: interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    effect_interner: effect_interner_mod.Interner,
    diags: mutable coll_mod.Diagnostics,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HArm.len(arms)
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => {
                walk_expr(file, g, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
            }
            case .none => ()
        }
        walk_expr(file, arm.body, caller, in_comptime, mutable discharged, node_types, local_types, fn_signatures, node_call_method, interner, ty_interner, effect_interner, mutable diags, allocator)?
        i = i + 1 as usize
    }
}


function method_callee_at(node_call_method: Vec_DefId.Vec, n: node_mod.NodeId) -> def_mod.DefId {
    let i = n.raw as usize
    if i >= Vec_DefId.len(node_call_method) {
        return def_mod.error()
    }
    return Vec_DefId.at(node_call_method, i)
}


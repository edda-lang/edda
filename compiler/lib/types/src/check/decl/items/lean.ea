
module types.check.decl.items.lean

import std.mem.alloc
import std.collections.vec
import intern.interner as interner_mod
import hir.build.file as hir_file
import hir.item as hir_item
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.effect.interner as effect_interner_mod
import local.check.env.builtins as builtins_mod
import local.check.env.sig as sig_mod
import local.check.env.fields as fields_mod
import local.check.decl.types.typedecl as typedecl_mod
import local.check.decl.items.items as items_mod


spec std.mem.alloc.Box(hir_item.HFnSignature)
spec std.mem.alloc.Box(hir_item.HTypeSignature)
spec std.collections.vec.Vec(hir_item.HDeclItem)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(sig_mod.FnSig)
spec std.collections.vec.Vec(fields_mod.FieldTyList)
spec std.collections.vec.Vec(fields_mod.VariantNameList)
spec std.collections.vec.Vec(fields_mod.FieldNameMatrix)
spec std.collections.vec.Vec(fields_mod.FieldRefinementList)


public function process_items_decl(
    file: hir_file.HirFileDecl,
    builtins: builtins_mod.Builtins,
    interner: interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    fn_signatures: mutable Vec_FnSig.Vec,
    type_defs: mutable Vec_TyId.Vec,
    field_tys: mutable Vec_FieldTyList.Vec,
    variant_names: mutable Vec_VariantNameList.Vec,
    field_names: mutable Vec_FieldNameMatrix.Vec,
    field_refinements: mutable Vec_FieldRefinementList.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    walk_items_decl(file.items, builtins, interner, mutable ty_interner, mutable effect_interner, mutable fn_signatures, mutable type_defs, mutable field_tys, mutable variant_names, mutable field_names, mutable field_refinements, allocator)?
}


function walk_items_decl(
    items: Vec_HDeclItem.Vec,
    builtins: builtins_mod.Builtins,
    interner: interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    fn_signatures: mutable Vec_FnSig.Vec,
    type_defs: mutable Vec_TyId.Vec,
    field_tys: mutable Vec_FieldTyList.Vec,
    variant_names: mutable Vec_VariantNameList.Vec,
    field_names: mutable Vec_FieldNameMatrix.Vec,
    field_refinements: mutable Vec_FieldRefinementList.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = Vec_HDeclItem.len(items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HDeclItem.at(items, i)
        process_one_item_decl(item, builtins, interner, mutable ty_interner, mutable effect_interner, mutable fn_signatures, mutable type_defs, mutable field_tys, mutable variant_names, mutable field_names, mutable field_refinements, allocator)?
        i = i + 1
    }
}

function process_one_item_decl(
    item: hir_item.HDeclItem,
    builtins: builtins_mod.Builtins,
    interner: interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    fn_signatures: mutable Vec_FnSig.Vec,
    type_defs: mutable Vec_TyId.Vec,
    field_tys: mutable Vec_FieldTyList.Vec,
    variant_names: mutable Vec_VariantNameList.Vec,
    field_names: mutable Vec_FieldNameMatrix.Vec,
    field_refinements: mutable Vec_FieldRefinementList.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match item.kind {
        case .function_(let sig_box) => {
            let sig = Box_HFnSignature.get(sig_box)
            items_mod.process_function_signature(sig, item.def_id, builtins, interner, mutable ty_interner, mutable effect_interner, mutable fn_signatures, allocator)?
        }
        case .function_extern(let sig_box, _, _, _) => {
            let sig = Box_HFnSignature.get(sig_box)
            items_mod.process_function_signature(sig, item.def_id, builtins, interner, mutable ty_interner, mutable effect_interner, mutable fn_signatures, allocator)?
        }
        case .type_decl(let sig_box) => {
            let sig = Box_HTypeSignature.get(sig_box)
            typedecl_mod.process_type_decl(sig, item.def_id, builtins, interner, mutable ty_interner, mutable effect_interner, mutable type_defs, mutable field_tys, mutable variant_names, mutable field_names, mutable field_refinements, allocator)?
        }
        case .spec_decl(_, let inner_items) => {
            walk_items_decl(inner_items, builtins, interner, mutable ty_interner, mutable effect_interner, mutable fn_signatures, mutable type_defs, mutable field_tys, mutable variant_names, mutable field_names, mutable field_refinements, allocator)?
        }
        case .spec_invocation(_, let args) => {
            items_mod.register_spec_arg_nominals(args, mutable ty_interner, mutable type_defs, allocator)?
        }
        case _ => ()
    }
}


module types.check.decl.types.store.vnames

import std.mem.alloc
import std.collections.vec
import intern.symbol as symbol_mod
import hir.def as def_mod
import local.check.env.fields as fields_mod


spec std.collections.vec.Vec(fields_mod.VariantNameList)
spec std.collections.vec.Vec(symbol_mod.Symbol)


public function write_variant_names_at_def_id(
    variant_names: mutable Vec_VariantNameList.Vec,
    def_id: def_mod.DefId,
    list: take fields_mod.VariantNameList,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let target = def_mod.index(def_id)
    pad_variant_names_with_sentinels(mutable variant_names, target, allocator)?
    let current = Vec_VariantNameList.len(variant_names)
    if current == target {
        Vec_VariantNameList.push(mutable variant_names, take list, allocator)?
    } else {
        Vec_VariantNameList.set_at(mutable variant_names, target, take list)
    }
}

public function pad_variant_names_with_sentinels(
    variant_names: mutable Vec_VariantNameList.Vec,
    target: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    loop {
        let len = Vec_VariantNameList.len(variant_names)
        if len >= target { break }
        let sentinel = sentinel_variant_name_list(allocator)?
        Vec_VariantNameList.push(mutable variant_names, take sentinel, allocator)?
    }
}

public function sentinel_variant_name_list(allocator: Allocator) -> fields_mod.VariantNameList
    with {allocator, err: alloc.AllocError}
{
    uninit empty_names: Vec_Symbol.Vec
    Vec_Symbol.new(init empty_names, allocator)?
    return fields_mod.VariantNameList { names: empty_names }
}

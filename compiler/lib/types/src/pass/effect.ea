
module types.pass.effect

derive eq, hash, ord, debug for EffectRowId

public type EffectRowId {
    raw: u32
}


public stable function empty() -> EffectRowId
    ensures result.raw == 0
{
    return EffectRowId { raw: 0 }
}

public stable function is_empty(e: EffectRowId) -> bool
    ensures result == (e.raw == 0)
{
    return e.raw == 0
}


public stable function index(e: EffectRowId) -> usize
    ensures result == (e.raw as usize)
{
    return e.raw as usize
}

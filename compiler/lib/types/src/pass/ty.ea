
module types.pass.ty

derive eq, hash, ord, debug for TyId

public type TyId {
    raw: u32
}


public stable function error() -> TyId
    ensures result.raw == 0
{
    return TyId { raw: 0 }
}

public stable function is_error(t: TyId) -> bool
    ensures result == (t.raw == 0)
{
    return t.raw == 0
}


public stable function index(t: TyId) -> usize
    ensures result == (t.raw as usize)
{
    return t.raw as usize
}

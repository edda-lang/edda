
module structmap.walk.count.children

import std.collections.vec
import local.data.model as model

spec std.collections.vec.Vec(model.ChildIndex)

public function sort_children(v: mutable Vec_ChildIndex.Vec) -> () {
    let n: usize = Vec_ChildIndex.len(v)
    if n <= 1 { return }
    quicksort_children(mutable v, 0, n - 1)
}

function quicksort_children(v: mutable Vec_ChildIndex.Vec, lo: usize, hi: usize) -> ()
    requires lo <= hi
    decreases hi - lo
{
    if lo >= hi { return }
    let p = partition_children(mutable v, lo, hi)
    if p > lo {
        quicksort_children(mutable v, lo, p - 1)
    }
    if p < hi {
        quicksort_children(mutable v, p + 1, hi)
    }
}

function partition_children(v: mutable Vec_ChildIndex.Vec, lo: usize, hi: usize) -> usize
    requires lo <= hi
    ensures result >= lo
    ensures result <= hi
{
    let pivot_idx: usize = lo + (hi - lo) / 2
    Vec_ChildIndex.swap(mutable v, pivot_idx, hi)
    let pivot = Vec_ChildIndex.at(v, hi)
    var store: usize = lo
    var i: usize = lo
    loop
        decreases hi - i
    {
        if i >= hi { break }
        if children_less(Vec_ChildIndex.at(v, i), pivot) {
            Vec_ChildIndex.swap(mutable v, i, store)
            store += 1
        }
        i += 1
    }
    Vec_ChildIndex.swap(mutable v, store, hi)
    return store
}

function children_less(a: model.ChildIndex, b: model.ChildIndex) -> bool {
    if a.dir_idx < b.dir_idx { return true }
    if a.dir_idx > b.dir_idx { return false }
    return string_less_walk(a.path, b.path)
}

function string_less_walk(a: String, b: String) -> bool {
    let ab = a.bytes()
    let bb = b.bytes()
    let an: usize = ab.len()
    let bn: usize = bb.len()
    let min_n: usize = if an < bn { an } else { bn }
    var i: usize = 0
    loop
        decreases min_n - i
    {
        if i >= min_n { break }
        if ab[i] < bb[i] { return true }
        if ab[i] > bb[i] { return false }
        i += 1
    }
    return an < bn
}

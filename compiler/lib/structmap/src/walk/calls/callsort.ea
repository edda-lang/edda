
module structmap.walk.calls.callsort

import std.mem.alloc
import std.collections.vec
import std.text.string

spec std.collections.vec.Vec(String)


public function sort_and_dedup(calls: take Vec_String.Vec, allocator: Allocator) -> Vec_String.Vec
    with {allocator, err: alloc.AllocError, divergence}
{
    let n: usize = Vec_String.len(calls)
    if n <= 1 { return calls }
    var array: [String] = Vec_String.into_array(take calls, allocator)?
    sort_strings(mutable array)
    uninit out: Vec_String.Vec
    Vec_String.new(init out, allocator)?
    Vec_String.push(mutable out, clone_str(array[0], allocator)?, allocator)?
    var i: usize = 1
    loop
        decreases n - i
    {
        if i >= n { break }
        if !string_equals(array[i], array[i - 1]) {
            Vec_String.push(mutable out, clone_str(array[i], allocator)?, allocator)?
        }
        i += 1
    }
    return out
}

function sort_strings(slice: mutable [String]) -> () {
    let n: usize = slice.len()
    if n <= 1 { return }
    quicksort(mutable slice, 0, n - 1)
}

function quicksort(slice: mutable [String], lo: usize, hi: usize) -> ()
    requires lo <= hi
    decreases hi - lo
{
    if lo >= hi { return }
    let p = partition(mutable slice, lo, hi)
    if p > lo {
        quicksort(mutable slice, lo, p - 1)
    }
    if p < hi {
        quicksort(mutable slice, p + 1, hi)
    }
}

function partition(slice: mutable [String], lo: usize, hi: usize) -> usize
    requires lo <= hi
    ensures result >= lo
    ensures result <= hi
{
    let pivot_idx: usize = lo + (hi - lo) / 2
    swap_strings(mutable slice, pivot_idx, hi)
    var store: usize = lo
    var i: usize = lo
    loop
        decreases hi - i
    {
        if i >= hi { break }
        if string_less(slice[i], slice[hi]) {
            swap_strings(mutable slice, i, store)
            store += 1
        }
        i += 1
    }
    swap_strings(mutable slice, store, hi)
    return store
}

function swap_strings(slice: mutable [String], i: usize, j: usize) -> () {
    if i == j { return }
    let tmp = slice[i]
    slice[i] = slice[j]
    slice[j] = tmp
}

function string_less(a: String, b: String) -> bool {
    let ab = a.bytes()
    let bb = b.bytes()
    let an: usize = ab.len()
    let bn: usize = bb.len()
    let min_n: usize = if an < bn { an } else { bn }
    var i: usize = 0
    loop
        decreases min_n - i
    {
        if i >= min_n { break }
        if ab[i] < bb[i] { return true }
        if ab[i] > bb[i] { return false }
        i += 1
    }
    return an < bn
}

function string_equals(a: String, b: String) -> bool {
    let ab = a.bytes()
    let bb = b.bytes()
    let an: usize = ab.len()
    let bn: usize = bb.len()
    if an != bn { return false }
    var i: usize = 0
    loop
        decreases an - i
    {
        if i >= an { break }
        if ab[i] != bb[i] { return false }
        i += 1
    }
    return true
}

function clone_str(s: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let bytes = s.bytes()
    let n: usize = bytes.len()
    let buf: [u8] = allocator.alloc_array(u8, n)?
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        buf[i] = bytes[i]
        i += 1
    }
    return string.from_owned_utf8(take buf)
}

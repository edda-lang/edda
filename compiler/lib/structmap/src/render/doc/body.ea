
module structmap.render.doc.body

import std.mem.alloc
import std.collections.vec
import local.data.model as model
import local.render.toon as toon
import local.render.sections.children as sec_children
import local.render.sections.modules as sec_modules
import local.render.sections.types as sec_types
import local.render.sections.effects as sec_effects
import local.render.sections.functions as sec_functions
import local.render.sections.invariants as sec_invariants
import local.render.sections.patterns as sec_patterns
import local.render.sections.trust as sec_trust

spec std.collections.vec.Vec(u8)

public function render_dir_body(buf: mutable Vec_u8.Vec, tree: model.Tree, dir_idx: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if sec_children.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_modules.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_types.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_effects.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_functions.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_invariants.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_patterns.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
    if sec_trust.render(mutable buf, tree, dir_idx, allocator)? {
        toon.push_byte(mutable buf, 0x0A, allocator)?
    }
}

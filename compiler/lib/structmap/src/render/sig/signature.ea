
module structmap.render.sig.signature

import std.mem.alloc
import std.collections.vec
import std.core.option
import intern.symbol as sym_mod
import intern.interner as interner_mod
import syntax.ast.item as ast_item_mod
import syntax.ast.tree as ast_tree
import syntax.ast.ops as ast_ops
import syntax.ast.ident as ast_ident
import local.render.toon as toon
import local.render.expr.exprtext as exprtext

spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(ast_tree.Param)
spec std.collections.vec.Vec(ast_tree.FnTyParam)
spec std.collections.vec.Vec(ast_tree.Ty)
spec std.collections.vec.Vec(ast_tree.EffectMember)
spec std.collections.vec.Vec(ast_ident.Ident)
spec std.mem.alloc.Box(ast_tree.Ty)
spec std.mem.alloc.Box(ast_tree.Expr)
spec std.core.option.Option(ast_tree.Ty)
spec std.core.option.Option(ast_tree.EffectRow)
spec std.core.option.Option(ast_ident.Ident)


public function render_signature(
    fd: ast_item_mod.FnDecl,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit buf: Vec_u8.Vec
    Vec_u8.new(init buf, allocator)?
    toon.push_byte(mutable buf, 0x28, allocator)?
    push_params(mutable buf, fd.params, interner, allocator)?
    toon.push_byte(mutable buf, 0x29, allocator)?
    match fd.return_ty {
        case .some(let ret) => {
            toon.push_str(mutable buf, " -> ", allocator)?
            match fd.return_mode {
                case .by_value => ()
                case .let_ => toon.push_str(mutable buf, "let ", allocator)?
                case .mutable_ => toon.push_str(mutable buf, "mutable ", allocator)?
            }
            type_text_to(mutable buf, ret, interner, allocator)?
        }
        case .none => ()
    }
    return toon.finish_string(take buf, allocator)?
}


public function type_text_to(
    buf: mutable Vec_u8.Vec,
    ty: ast_tree.Ty,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match ty.kind {
        case .path(let p) => push_path(mutable buf, p, interner, allocator)?
        case .tuple(let elems) => {
            toon.push_byte(mutable buf, 0x28, allocator)?
            let n: usize = Vec_Ty.len(elems)
            var i: usize = 0
            loop
                decreases n - i
            {
                if i >= n { break }
                if i > 0 {
                    toon.push_str(mutable buf, ", ", allocator)?
                }
                type_text_to(mutable buf, Vec_Ty.at(elems, i), interner, allocator)?
                i += 1
            }
            toon.push_byte(mutable buf, 0x29, allocator)?
        }
        case .slice(let elem_box) => {
            toon.push_byte(mutable buf, 0x5B, allocator)?
            type_text_to(mutable buf, Box_Ty.get(elem_box), interner, allocator)?
            toon.push_byte(mutable buf, 0x5D, allocator)?
        }
        case .unit => toon.push_str(mutable buf, "()", allocator)?
        case .function_(let params, let ret_box, let effects_opt) => {
            toon.push_str(mutable buf, "function(", allocator)?
            push_fn_ty_params(mutable buf, params, interner, allocator)?
            toon.push_str(mutable buf, ") -> ", allocator)?
            type_text_to(mutable buf, Box_Ty.get(ret_box), interner, allocator)?
            match effects_opt {
                case .some(let row) => {
                    toon.push_str(mutable buf, " with ", allocator)?
                    effect_row_to(mutable buf, row, interner, allocator)?
                }
                case .none => ()
            }
        }
        case .meta => toon.push_str(mutable buf, "Type", allocator)?
        case .comptime_(let inner_box) => {
            toon.push_str(mutable buf, "comptime ", allocator)?
            type_text_to(mutable buf, Box_Ty.get(inner_box), interner, allocator)?
        }
        case .refined(let base_box, let _pred) =>
            type_text_to(mutable buf, Box_Ty.get(base_box), interner, allocator)?
        case .error => toon.push_str(mutable buf, "<error>", allocator)?
    }
}


public function effect_row_to(
    buf: mutable Vec_u8.Vec,
    row: ast_tree.EffectRow,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n: usize = Vec_EffectMember.len(row.members)
    if n == 0 {
        toon.push_str(mutable buf, "{}", allocator)?
        return
    }
    toon.push_str(mutable buf, "{ ", allocator)?
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if i > 0 {
            toon.push_str(mutable buf, ", ", allocator)?
        }
        effect_member_to(mutable buf, Vec_EffectMember.at(row.members, i), interner, allocator)?
        i += 1
    }
    toon.push_str(mutable buf, " }", allocator)?
}

public function effect_member_to(
    buf: mutable Vec_u8.Vec,
    m: ast_tree.EffectMember,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match m {
        case .capability(let name) => {
            if sym_mod.is_empty(name.name) {
                toon.push_str(mutable buf, "panic", allocator)?
            } else {
                push_sym(mutable buf, name.name, interner, allocator)?
            }
        }
        case .named(let name, let ty) => {
            if sym_mod.is_empty(name.name) {
                toon.push_str(mutable buf, "yield", allocator)?
            } else {
                push_sym(mutable buf, name.name, interner, allocator)?
            }
            toon.push_str(mutable buf, ": ", allocator)?
            type_text_to(mutable buf, ty, interner, allocator)?
        }
        case .spread(let path) => {
            toon.push_str(mutable buf, "...", allocator)?
            push_path(mutable buf, path, interner, allocator)?
        }
        case .graded(let kind, let bound_box) => {
            push_sym(mutable buf, kind.name, interner, allocator)?
            toon.push_byte(mutable buf, 0x28, allocator)?
            exprtext.expr_text_to(mutable buf, Box_Expr.get(bound_box), interner, allocator)?
            toon.push_byte(mutable buf, 0x29, allocator)?
        }
    }
}



function push_params(
    buf: mutable Vec_u8.Vec,
    params: Vec_Param.Vec,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n: usize = Vec_Param.len(params)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if i > 0 {
            toon.push_str(mutable buf, ", ", allocator)?
        }
        let p = Vec_Param.at(params, i)
        push_sym(mutable buf, p.name.name, interner, allocator)?
        toon.push_str(mutable buf, ": ", allocator)?
        push_param_mode(mutable buf, p.mode, allocator)?
        type_text_to(mutable buf, p.ty, interner, allocator)?
        i += 1
    }
}

function push_fn_ty_params(
    buf: mutable Vec_u8.Vec,
    params: Vec_FnTyParam.Vec,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n: usize = Vec_FnTyParam.len(params)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if i > 0 {
            toon.push_str(mutable buf, ", ", allocator)?
        }
        let p = Vec_FnTyParam.at(params, i)
        match p.name {
            case .some(let id) => {
                push_sym(mutable buf, id.name, interner, allocator)?
                toon.push_str(mutable buf, ": ", allocator)?
            }
            case .none => ()
        }
        push_param_mode(mutable buf, p.mode, allocator)?
        type_text_to(mutable buf, p.ty, interner, allocator)?
        i += 1
    }
}

function push_param_mode(
    buf: mutable Vec_u8.Vec,
    mode: ast_ops.ParamMode,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match mode {
        case .default  => ()
        case .mutable_ => toon.push_str(mutable buf, "mutable ", allocator)?
        case .take_    => toon.push_str(mutable buf, "take ", allocator)?
        case .init_    => toon.push_str(mutable buf, "init ", allocator)?
    }
}

function push_path(
    buf: mutable Vec_u8.Vec,
    p: ast_ident.Path,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n: usize = Vec_Ident.len(p.segments)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if i > 0 {
            toon.push_byte(mutable buf, 0x2E, allocator)?
        }
        let seg = Vec_Ident.at(p.segments, i)
        push_sym(mutable buf, seg.name, interner, allocator)?
        i += 1
    }
}

function push_sym(
    buf: mutable Vec_u8.Vec,
    sym: sym_mod.Symbol,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if (sym.raw as usize) >= interner_mod.slot_count(interner) {
        toon.push_str(mutable buf, "<missing>", allocator)?
        return
    }
    let bytes = interner_mod.lookup(interner, sym)
    let n: usize = bytes.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        toon.push_byte(mutable buf, bytes[i], allocator)?
        i += 1
    }
}

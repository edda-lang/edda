
module structmap.render.sections.children

import std.mem.alloc
import std.collections.vec
import local.data.model as model
import local.render.toon as toon

spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(model.ChildIndex)

public function render(buf: mutable Vec_u8.Vec, tree: model.Tree, dir_idx: usize, allocator: Allocator) -> bool
    with {allocator, err: alloc.AllocError}
{
    let count = count(tree, dir_idx)
    if count == 0 { return false }
    toon.push_str(mutable buf, "children[", allocator)?
    toon.push_usize_decimal(mutable buf, count, allocator)?
    toon.push_str(mutable buf, "]{path,types,functions,public}:\n", allocator)?
    let total: usize = Vec_ChildIndex.len(tree.children)
    var i: usize = 0
    loop
        decreases total - i
    {
        if i >= total { break }
        let r = Vec_ChildIndex.at(tree.children, i)
        if r.dir_idx == dir_idx {
            toon.push_str(mutable buf, "  ", allocator)?
            toon.push_quoted(mutable buf, r.path, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_u32_decimal(mutable buf, r.types, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_u32_decimal(mutable buf, r.functions, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_quoted(mutable buf, r.public_names, allocator)?
            toon.push_byte(mutable buf, 0x0A, allocator)?
        }
        i += 1
    }
    return true
}

function count(tree: model.Tree, dir_idx: usize) -> usize {
    let total: usize = Vec_ChildIndex.len(tree.children)
    var c: usize = 0
    var i: usize = 0
    loop
        decreases total - i
    {
        if i >= total { break }
        if Vec_ChildIndex.at(tree.children, i).dir_idx == dir_idx {
            c += 1
        }
        i += 1
    }
    return c
}


module structmap.render.sections.functions

import std.mem.alloc
import std.collections.vec
import local.data.model as model
import local.render.toon as toon
import local.render.sections.effects as effects_sec

spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(model.FunctionEntry)

public function render(buf: mutable Vec_u8.Vec, tree: model.Tree, dir_idx: usize, allocator: Allocator) -> bool
    with {allocator, err: alloc.AllocError}
{
    let count = count(tree, dir_idx)
    if count == 0 { return false }
    let rows = effects_sec.collect_rows(tree, dir_idx, allocator)?
    toon.push_str(mutable buf, "functions[", allocator)?
    toon.push_usize_decimal(mutable buf, count, allocator)?
    toon.push_str(mutable buf, "]{name,file,line,end,visibility,stability,sig,eff,cone,calls}:\n", allocator)?
    let total: usize = Vec_FunctionEntry.len(tree.functions)
    var i: usize = 0
    loop
        decreases total - i
    {
        if i >= total { break }
        let r = Vec_FunctionEntry.at(tree.functions, i)
        if r.dir_idx == dir_idx {
            toon.push_str(mutable buf, "  ", allocator)?
            toon.push_quoted(mutable buf, r.qualified_name, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_quoted(mutable buf, r.file, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_u32_decimal(mutable buf, r.line, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_u32_decimal(mutable buf, r.end, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_str(mutable buf, model.visibility_str(r.visibility), allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_str(mutable buf, model.stability_str(r.stability), allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            toon.push_quoted(mutable buf, r.signature, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            push_eff(mutable buf, rows, r.declared_effects, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            push_cone(mutable buf, r.effect_cone, r.declared_effects, rows, allocator)?
            toon.push_byte(mutable buf, 0x2C, allocator)?
            push_quoted_joined(mutable buf, r.calls.data[0..<r.calls.len], allocator)?
            toon.push_byte(mutable buf, 0x0A, allocator)?
        }
        i += 1
    }
    return true
}

function push_eff(buf: mutable Vec_u8.Vec, rows: Vec_String.Vec, declared: Vec_String.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if Vec_String.len(declared) == 0 { return }
    let rs = effects_sec.row_string(declared, allocator)?
    let id = effects_sec.id_of(rows, rs)
    toon.push_usize_decimal(mutable buf, id, allocator)?
}

function push_cone(buf: mutable Vec_u8.Vec, cone: Vec_String.Vec, declared: Vec_String.Vec, rows: Vec_String.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if effects_sec.set_equal(cone, declared) {
        toon.push_str(mutable buf, "=", allocator)?
        return
    }
    if Vec_String.len(cone) == 0 {
        return
    }
    let cs = effects_sec.row_string(cone, allocator)?
    let id = effects_sec.id_of(rows, cs)
    toon.push_usize_decimal(mutable buf, id, allocator)?
}

function count(tree: model.Tree, dir_idx: usize) -> usize {
    let total: usize = Vec_FunctionEntry.len(tree.functions)
    var c: usize = 0
    var i: usize = 0
    loop
        decreases total - i
    {
        if i >= total { break }
        if Vec_FunctionEntry.at(tree.functions, i).dir_idx == dir_idx {
            c += 1
        }
        i += 1
    }
    return c
}

function push_quoted_joined(buf: mutable Vec_u8.Vec, parts: [String], allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit tmp: Vec_u8.Vec
    Vec_u8.new(init tmp, allocator)?
    toon.push_pipe_join(mutable tmp, parts, allocator)?
    let joined = toon.finish_string(take tmp, allocator)?
    toon.push_quoted(mutable buf, joined, allocator)?
}

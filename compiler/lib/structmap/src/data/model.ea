
module structmap.data.model

import std.mem.alloc
import std.collections.vec
import std.collections.hashmap
import std.core.option


spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(usize)
spec std.collections.hashmap.StringMap(u32)
spec std.core.option.Option(usize)
spec std.core.option.Option(String)
spec std.core.option.Option(u32)


public function schema_version() -> u32 { return 8 }

public function index_filename() -> String { return "index.toon" }

public function parent_link() -> String { return "../index.toon" }


public type Visibility {
    case public_
    case module_
}

public type StabilityMarker {
    case stable_
    case unstable_
    case absent
}

public type TypeKind {
    case struct_
    case enum_
    case spec_
}

public type TrustKind {
    case unverified
    case trust_
}


public type PackageSummary {
    types: u32
    functions: u32
    public_names: String
}

public type ChildIndex {
    dir_idx: usize
    path: String
    types: u32
    functions: u32
    public_names: String
}

public type ModuleEntry {
    dir_idx: usize
    name: String
    file: String
    line: u32
    visibility: Visibility
}

public type TypeEntry {
    dir_idx: usize
    name: String
    kind: TypeKind
    file: String
    line: u32
    end: u32
    visibility: Visibility
    stability: StabilityMarker
    generics: Vec_String.Vec
    fields_or_variants: String
    refinements: Vec_String.Vec
}

public type FunctionEntry {
    dir_idx: usize
    qualified_name: String
    file: String
    line: u32
    end: u32
    visibility: Visibility
    stability: StabilityMarker
    signature: String
    calls: Vec_String.Vec
    effect_cone: Vec_String.Vec
    declared_effects: Vec_String.Vec
    cone_leaf_keys: Vec_String.Vec
}

public type InvariantEntry {
    dir_idx: usize
    target: String
    file: String
    line: u32
    rule: String
}

public type PatternEntry {
    dir_idx: usize
    name: String
    file: String
    line: u32
}

public type DocEntry {
    dir_idx: usize
    target: String
    file: String
    line: u32
    text: String
}

public type TrustEntry {
    dir_idx: usize
    target: String
    kind: TrustKind
    file: String
    line: u32
    reason: String
}


spec std.collections.vec.Vec(ChildIndex)
spec std.collections.vec.Vec(ModuleEntry)
spec std.collections.vec.Vec(TypeEntry)
spec std.collections.vec.Vec(FunctionEntry)
spec std.collections.vec.Vec(InvariantEntry)
spec std.collections.vec.Vec(PatternEntry)
spec std.collections.vec.Vec(DocEntry)
spec std.collections.vec.Vec(TrustEntry)

public type Tree {
    paths: Vec_String.Vec
    by_path: StringMap_u32.StringMap where by_path.len == paths.len
    children: Vec_ChildIndex.Vec
    modules: Vec_ModuleEntry.Vec
    types_: Vec_TypeEntry.Vec
    functions: Vec_FunctionEntry.Vec
    invariants: Vec_InvariantEntry.Vec
    patterns: Vec_PatternEntry.Vec
    trust_points: Vec_TrustEntry.Vec
}


public function new_tree(out: init Tree, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit paths: Vec_String.Vec
    Vec_String.new(init paths, allocator)?
    let by_path = StringMap_u32.new(allocator)?
    uninit children: Vec_ChildIndex.Vec
    Vec_ChildIndex.new(init children, allocator)?
    uninit modules: Vec_ModuleEntry.Vec
    Vec_ModuleEntry.new(init modules, allocator)?
    uninit types_: Vec_TypeEntry.Vec
    Vec_TypeEntry.new(init types_, allocator)?
    uninit functions: Vec_FunctionEntry.Vec
    Vec_FunctionEntry.new(init functions, allocator)?
    uninit invariants: Vec_InvariantEntry.Vec
    Vec_InvariantEntry.new(init invariants, allocator)?
    uninit patterns: Vec_PatternEntry.Vec
    Vec_PatternEntry.new(init patterns, allocator)?
    uninit trust_points: Vec_TrustEntry.Vec
    Vec_TrustEntry.new(init trust_points, allocator)?
    out = Tree {
        paths: paths,
        by_path: by_path,
        children: children,
        modules: modules,
        types_: types_,
        functions: functions,
        invariants: invariants,
        patterns: patterns,
        trust_points: trust_points,
    }
}


public function visibility_str(v: Visibility) -> String {
    return match v {
        case .public_ => "public"
        case .module_ => "module"
    }
}

public function stability_str(s: StabilityMarker) -> String {
    return match s {
        case .stable_   => "stable"
        case .unstable_ => "unstable"
        case .absent    => ""
    }
}

public function type_kind_str(k: TypeKind) -> String {
    return match k {
        case .struct_ => "struct"
        case .enum_   => "enum"
        case .spec_   => "spec"
    }
}

public function trust_kind_str(k: TrustKind) -> String {
    return match k {
        case .unverified => "unverified"
        case .trust_     => "trust"
    }
}

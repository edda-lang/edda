module structmap.budget.token

import std.core.option


spec std.core.option.Option(TokenEncoding)


public type TokenEncoding {
    case o200k_base
    case cl100k_base
}

public type TokenizerKind {
    case bpe
    case fallback
}

public type Tokenizer {
    chars_per_token_permille: usize
    kind: TokenizerKind
}


public function default_encoding() -> TokenEncoding {
    return TokenEncoding.o200k_base
}

public function default_permille() -> usize {
    return 3500 as usize
}

public function encoding_str(e: TokenEncoding) -> String {
    return match e {
        case .o200k_base  => "o200k_base"
        case .cl100k_base => "cl100k_base"
    }
}

public function encoding_from_config(s: String) -> Option_TokenEncoding.Option {
    if string_equals(s, "o200k_base") {
        return Option_TokenEncoding.some(value: TokenEncoding.o200k_base)
    }
    if string_equals(s, "cl100k_base") {
        return Option_TokenEncoding.some(value: TokenEncoding.cl100k_base)
    }
    return Option_TokenEncoding.none()
}

public function kind_str(k: TokenizerKind) -> String {
    return match k {
        case .bpe      => "bpe"
        case .fallback => "fallback"
    }
}

public function new_tokenizer(chars_per_token_permille: usize) -> Tokenizer {
    let pm: usize = if chars_per_token_permille == 0 as usize { 1 as usize } else { chars_per_token_permille }
    return Tokenizer {
        chars_per_token_permille: pm,
        kind: TokenizerKind.fallback
    }
}

public function count(t: Tokenizer, text: String) -> usize {
    let d: usize = if t.chars_per_token_permille == 0 as usize { 1 as usize } else { t.chars_per_token_permille }
    let bytes = text.bytes()
    let n: usize = bytes.len()
    let scaled: usize = n *| (1000 as usize)
    let half: usize = d / (2 as usize)
    let rounded: usize = scaled +| half
    return rounded / d
}

function string_equals(a: String, b: String) -> bool {
    let ab = a.bytes()
    let bb = b.bytes()
    let an: usize = ab.len()
    let bn: usize = bb.len()
    if an != bn { return false }
    var i: usize = 0
    loop
        decreases an - i
    {
        if i >= an { break }
        if ab[i] != bb[i] { return false }
        i += 1
    }
    return true
}

module structmap.budget.model

import std.collections.vec
import std.core.option


spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(FatFile)
spec std.collections.vec.Vec(FileGroup)
spec std.collections.vec.Vec(NodeMeasure)
spec std.collections.vec.Vec(WorklistEntry)
spec std.core.option.Option(String)
spec std.core.option.Option(Directive)


public type Gate {
    case per_node
    case spine
}

public type Band {
    case green
    case amber
    case red
}


public type FileGroup {
    files: Vec_String.Vec
}

public type FatFile {
    file: String
    tokens: usize
    cluster: Vec_String.Vec
    dispatcher: Option_String.Option
}

public type WideSplit {
    groups: Vec_FileGroup.Vec
    fat_files: Vec_FatFile.Vec
}

public type Partition {
    file: String
    cluster: Vec_String.Vec
    dispatcher: Option_String.Option
}

public type AtomicHoard {
    files: Vec_String.Vec
    tokens: usize
    groups: Vec_FileGroup.Vec
}

public type HoardingHub {
    percent: usize
    groups: Vec_FileGroup.Vec
}

public type Directive {
    case wide_split(WideSplit)
    case partition(Partition)
    case atomic_hoard(AtomicHoard)
    case hoarding_hub(HoardingHub)
    case flatten
}


public type BudgetConfig {
    node_green_max: usize
    node_amber_max: usize
    chars_per_token: f64
    model_calibration: f64
}

public type NodeMeasure {
    dir: String
    token_cost: usize
    export_count: usize
    band: Band
}

public type WorklistEntry {
    gate: Gate
    node: String
    token_cost: usize
    ceiling: usize
    overage: usize
    directive: Option_Directive.Option
    band: Band
}

public type BudgetReport {
    measures: Vec_NodeMeasure.Vec
    worklist: Vec_WorklistEntry.Vec
    root: String
}


public function default_model_calibration() -> f64 { return 2.5 }

public function hub_lean_green_num() -> usize { return 1 as usize }

public function hub_lean_green_den() -> usize { return 3 as usize }

public function hub_lean_red_num() -> usize { return 1 as usize }

public function hub_lean_red_den() -> usize { return 2 as usize }

public function locked_defaults() -> BudgetConfig {
    return BudgetConfig {
        node_green_max: 6000 as usize,
        node_amber_max: 6000 as usize,
        chars_per_token: 3.5,
        model_calibration: default_model_calibration()
    }
}

public function gate_label(g: Gate) -> String {
    return match g {
        case .per_node => "A"
        case .spine    => "B"
    }
}

public function directive_class(d: Directive) -> String {
    return match d {
        case .wide_split(_)   => "wide-split"
        case .partition(_)    => "partition"
        case .atomic_hoard(_) => "atomic-hoard"
        case .hoarding_hub(_) => "hoarding-hub"
        case .flatten         => "vine"
    }
}

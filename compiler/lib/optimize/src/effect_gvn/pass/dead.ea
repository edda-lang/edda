
module optimize.effect_gvn.pass.dead

import std.collections.vec
import ir.hlir.id.op as op_mod
import ir.hlir.op as hlir_op_mod
import ir.hlir.tree.body as hlir_body_mod
import local.effect_gvn.pure.dce as dce_mod


spec std.collections.vec.Vec(op_mod.OpId)
spec std.collections.vec.Vec(hlir_op_mod.HlirOp)
spec std.collections.vec.Vec(hlir_body_mod.HlirValue)


public function apply_dead(
    body: mutable hlir_body_mod.HlirBody,
    dce: dce_mod.DcePlan,
) -> ()
    with {panic}
{
    let n = Vec_OpId.len(dce.dead_ops)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let id = Vec_OpId.at(dce.dead_ops, i)
        neutralize_op(mutable body, id)
        i = i + 1
    }
}


function neutralize_op(
    body: mutable hlir_body_mod.HlirBody,
    id: op_mod.OpId,
) -> ()
    with {panic}
{
    if id.raw == 0 { return () }
    let idx = id.raw as usize
    if idx >= Vec_HlirOp.len(body.ops) { return () }
    let op = Vec_HlirOp.at(body.ops, idx)
    let neutral = if op.result_.raw == 0 {
        hlir_op_mod.HConstant.unit_
    } else {
        let result_val = Vec_HlirValue.at(body.values, op.result_.raw as usize)
        hlir_op_mod.HConstant.int_(value: 0 as i128, ty: result_val.ty)
    }
    let dead = hlir_op_mod.HlirOp {
        origin: op.origin,
        kind: hlir_op_mod.HlirOpKind.literal(c: neutral),
        result_: op.result_,
        flags: hlir_op_mod.OpFlags {
            overflow_safe: false,
            in_bounds: false,
            nonzero_divisor: false,
            range_safe: false,
            intrinsic: hlir_op_mod.Intrinsic.none,
            div_overflow: hlir_op_mod.DivOverflow.trap,
            div_overflow_safe: false,
            extern_call: false,
            extern_ret_size: 0 as u32,
        },
    }
    Vec_HlirOp.set_at(mutable body.ops, idx, take dead)
}

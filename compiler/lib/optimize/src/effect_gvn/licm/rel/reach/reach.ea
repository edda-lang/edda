
module optimize.effect_gvn.licm.rel.reach.reach

import std.mem.alloc
import std.collections.vec
import std.collections.hashmap
import std.core.option
import ir.hlir.tree.body as hlir_body_mod
import local.effect_gvn.licm.rel.succ.succ as succ_mod


spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(hlir_body_mod.HlirBlock)
spec std.collections.hashmap.IntMap(u32)
spec std.core.option.Option(u32)


public function compute_reachable(
    body: hlir_body_mod.HlirBody,
    n: usize,
    allocator: Allocator,
) -> IntMap_u32.IntMap
    with {allocator, err: alloc.AllocError, panic}
{
    var map = IntMap_u32.new(allocator)?
    if n <= 1 { return map }
    uninit worklist: Vec_u32.Vec
    Vec_u32.new(init worklist, allocator)?
    Vec_u32.push(mutable worklist, 1 as u32, allocator)?
    let _ = IntMap_u32.insert(mutable map, 1, 1 as u32, allocator)?
    let budget = n * n + 1
    var steps: usize = 0
    loop
        decreases budget - steps
    {
        if steps >= budget { break }
        if Vec_u32.len(worklist) == 0 { break }
        let cur = pop_last(mutable worklist)
        visit_successors(mutable map, mutable worklist, body, cur, n, allocator)?
        steps = steps + 1
    }
    return map
}


function pop_last(worklist: mutable Vec_u32.Vec) -> u32 {
    let m = Vec_u32.len(worklist)
    if m == 0 { return 0 as u32 }
    let last = Vec_u32.at(worklist, m - 1)
    let _ = Vec_u32.pop(mutable worklist)
    return last
}


function visit_successors(
    map: mutable IntMap_u32.IntMap,
    worklist: mutable Vec_u32.Vec,
    body: hlir_body_mod.HlirBody,
    cur: u32,
    n: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if cur == 0 { return () }
    if (cur as usize) >= n { return () }
    let block = Vec_HlirBlock.at(body.blocks, cur as usize)
    uninit succs: Vec_u32.Vec
    Vec_u32.new(init succs, allocator)?
    succ_mod.collect_successors(mutable succs, block.terminator, n, allocator)?
    let s = Vec_u32.len(succs)
    var i: usize = 0
    loop
        decreases s - i
    {
        if i >= s { break }
        let nxt = Vec_u32.at(succs, i)
        if !IntMap_u32.contains(map, nxt as i64) {
            let _ = IntMap_u32.insert(mutable map, nxt as i64, 1 as u32, allocator)?
            Vec_u32.push(mutable worklist, nxt, allocator)?
        }
        i = i + 1
    }
}


module optimize.effect_gvn.licm.dom.dom

import std.mem.alloc
import std.collections.vec
import std.collections.hashmap
import ir.hlir.term as term_mod
import ir.hlir.tree.body as hlir_body_mod
import local.effect_gvn.licm.rel.succ.succ as succ_mod
import local.effect_gvn.licm.rel.preds.preds as preds_mod
import local.effect_gvn.licm.rel.reach.reach as reach_mod
import local.effect_gvn.licm.dom.idoms as idoms_mod


spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(preds_mod.BlockPreds)
spec std.collections.vec.Vec(hlir_body_mod.HlirBlock)
spec std.collections.hashmap.IntMap(u32)


public type Cfg {
    n_blocks: usize
    preds_by_block: Vec_BlockPreds.Vec
    idom: Vec_u32.Vec
    reachable: IntMap_u32.IntMap
}


public function build_cfg(
    body: hlir_body_mod.HlirBody,
    allocator: Allocator,
) -> Cfg
    with {allocator, err: alloc.AllocError, panic}
{
    let n = Vec_HlirBlock.len(body.blocks)
    let preds_by_block = preds_mod.build_pred_map(body, n, allocator)?
    let reachable = reach_mod.compute_reachable(body, n, allocator)?
    let idom = idoms_mod.compute_idom(body, preds_by_block, n, allocator)?
    return Cfg {
        n_blocks: n,
        preds_by_block: preds_by_block,
        idom: idom,
        reachable: reachable,
    }
}


public function collect_successors(
    out: mutable Vec_u32.Vec,
    term: term_mod.HlirTerminator,
    n: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    succ_mod.collect_successors(mutable out, term, n, allocator)?
}


public function is_reachable(cfg: Cfg, b: u32) -> bool {
    if b == 1 { return true }
    return IntMap_u32.contains(cfg.reachable, b as i64)
}


public function dominates(cfg: Cfg, a: u32, b: u32) -> bool
    with {panic}
{
    return idoms_mod.idom_dominates(cfg.idom, cfg.n_blocks, a, b, is_reachable(cfg, b))
}


public function preds_of(cfg: Cfg, b: u32) -> Vec_u32.Vec
    with {panic}
{
    return preds_mod.preds_at(cfg.preds_by_block, b, cfg.n_blocks)
}

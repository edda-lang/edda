
module optimize.effect_gvn.analysis.purity

import ir.hlir.op as hlir_op_mod
import ir.hlir.attrs as attrs_mod


derive eq, hash, debug for Purity


public type Purity {
    case pure_total
    case pure_trapping
    case effectful
}


public function classify_op(
    op: hlir_op_mod.HlirOp,
    callee: attrs_mod.HlirFnAttrs,
    callee_known: bool,
) -> Purity {
    return match op.kind {
        case .literal(let c) => Purity.pure_total
        case .binary(let bop, let lhs, let rhs) => classify_binary(bop, op.flags)
        case .unary(let uop, let operand) => classify_unary(uop, op.flags)
        case .cast(let value, let from, let to, let kind) => classify_cast(kind, op.flags)
        case .call_(let callee_v, let args) => classify_call(callee, callee_known)
        case .call_indirect(let callee_v, let args) => Purity.effectful
        case .make_closure(let code, let env) => Purity.pure_total
        case .field(let operand, let index) => Purity.effectful
        case .index(let operand, let index_v) => Purity.effectful
        case .slice_subrange(let operand, let lo_v, let hi_v) => Purity.effectful
        case .len(let operand) => Purity.effectful
        case .discriminant(let operand) => Purity.effectful
        case .aggregate(let kind, let elems) => Purity.pure_total
        case .ref_(let kind, let operand) => Purity.effectful
        case .deref_(let operand) => Purity.effectful
        case .field_addr(let operand, let index) => Purity.effectful
        case .index_addr(let operand, let index_v) => Purity.effectful
        case .subrange_addr(let operand, let lo_v, let hi_v) => Purity.effectful
        case .deref_addr(let operand) => Purity.effectful
        case .store_(let addr, let value) => Purity.effectful
        case .stack_alloc(let bytes) => Purity.effectful
        case .err_flag => Purity.effectful
    }
}


public function classify_binary(bop: hlir_op_mod.HBinOp, flags: hlir_op_mod.OpFlags) -> Purity {
    return match bop {
        case .add => if flags.overflow_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .sub => if flags.overflow_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .mul => if flags.overflow_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .div => if flags.overflow_safe && flags.nonzero_divisor { Purity.pure_total } else { Purity.pure_trapping }
        case .rem => if flags.overflow_safe && flags.nonzero_divisor { Purity.pure_total } else { Purity.pure_trapping }
        case .add_wrap => Purity.pure_total
        case .sub_wrap => Purity.pure_total
        case .mul_wrap => Purity.pure_total
        case .add_sat => Purity.pure_total
        case .sub_sat => Purity.pure_total
        case .mul_sat => Purity.pure_total
        case .bit_and => Purity.pure_total
        case .bit_or => Purity.pure_total
        case .bit_xor => Purity.pure_total
        case .shl => Purity.pure_total
        case .shr => Purity.pure_total
        case .eq => Purity.pure_total
        case .ne => Purity.pure_total
        case .lt => Purity.pure_total
        case .le => Purity.pure_total
        case .gt => Purity.pure_total
        case .ge => Purity.pure_total
        case .logical_and => Purity.pure_total
        case .logical_or => Purity.pure_total
    }
}


public function classify_unary(uop: hlir_op_mod.HUnOp, flags: hlir_op_mod.OpFlags) -> Purity {
    return match uop {
        case .neg => if flags.overflow_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .bit_not => Purity.pure_total
        case .logical_not => Purity.pure_total
    }
}


public function classify_cast(kind: hlir_op_mod.HCastKind, flags: hlir_op_mod.OpFlags) -> Purity {
    return match kind {
        case .integer => if flags.range_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .integer_wrapping => Purity.pure_total
        case .integer_saturating => Purity.pure_total
        case .integer_checked => Purity.pure_trapping
        case .float => Purity.pure_total
        case .float_to_integer => if flags.range_safe { Purity.pure_total } else { Purity.pure_trapping }
        case .integer_to_float => Purity.pure_total
    }
}


function classify_call(callee: attrs_mod.HlirFnAttrs, callee_known: bool) -> Purity {
    if !callee_known { return Purity.effectful }
    if !callee.pure_ { return Purity.effectful }
    if !callee.raw_pure { return Purity.effectful }
    return if callee.raw_trapfree { Purity.pure_total } else { Purity.pure_trapping }
}


public function is_cse_eligible(p: Purity) -> bool {
    return match p {
        case .pure_total => true
        case .pure_trapping => true
        case .effectful => false
    }
}


public function is_hashcons_eligible(p: Purity) -> bool {
    return match p {
        case .pure_total => true
        case .pure_trapping => false
        case .effectful => false
    }
}


public function is_movable(p: Purity) -> bool {
    return match p {
        case .pure_total => true
        case .pure_trapping => false
        case .effectful => false
    }
}


public function is_droppable(p: Purity) -> bool {
    return match p {
        case .pure_total => true
        case .pure_trapping => false
        case .effectful => false
    }
}


public function join(a: Purity, b: Purity) -> Purity {
    return match a {
        case .effectful => Purity.effectful
        case .pure_trapping => match b {
            case .effectful => Purity.effectful
            case .pure_trapping => Purity.pure_trapping
            case .pure_total => Purity.pure_trapping
        }
        case .pure_total => b
    }
}


public function to_code(p: Purity) -> u8 {
    return match p {
        case .pure_total => 0 as u8
        case .pure_trapping => 1 as u8
        case .effectful => 2 as u8
    }
}


public function from_code(code: u8) -> Purity {
    return match code {
        case 0 => Purity.pure_total
        case 1 => Purity.pure_trapping
        case _ => Purity.effectful
    }
}


module optimize.effect_gvn.hlir.mapping

import std.collections.hashmap
import std.core.option
import egraph.eclass as eclass_mod
import egraph.graph.graph as graph_mod
import egraph.sat.saturate as saturate_mod
import ir.hlir.id.value as value_mod
import local.effect_gvn.analysis.purity as purity_mod


spec std.collections.hashmap.IntMap(eclass_mod.EClassId)
spec std.collections.hashmap.IntMap(u8)
spec std.core.option.Option(eclass_mod.EClassId)
spec std.core.option.Option(u8)


public type BuildResult {
    graph: graph_mod.EGraph
    sat: saturate_mod.Saturator
    value_to_class: IntMap_EClassId.IntMap
    value_purity: IntMap_u8.IntMap
    fresh_counter: i128
}


public function class_of_value(
    built: BuildResult,
    v: value_mod.ValueId,
) -> eclass_mod.EClassId {
    return match IntMap_EClassId.get(built.value_to_class, v.raw as i64) {
        case .some(let class_) => class_
        case .none => eclass_mod.error()
    }
}


public function purity_of_value(
    built: BuildResult,
    v: value_mod.ValueId,
) -> purity_mod.Purity {
    return match IntMap_u8.get(built.value_purity, v.raw as i64) {
        case .some(let code) => purity_mod.from_code(code)
        case .none => purity_mod.Purity.effectful
    }
}


public function canonical_class_of_value(
    built: mutable BuildResult,
    v: value_mod.ValueId,
) -> eclass_mod.EClassId
    with {panic}
{
    let class_ = match IntMap_EClassId.get(built.value_to_class, v.raw as i64) {
        case .some(let c) => c
        case .none => eclass_mod.error()
    }
    return saturate_mod.find(mutable built.graph, class_)
}

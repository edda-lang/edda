module optimize.linear_reuse.dataflow.bitset

import std.mem.alloc
import std.collections.vec

spec std.collections.vec.Vec(u64)
spec std.collections.vec.Vec(bool)

public function words_per_row(n_locals: usize) -> usize {
    return (n_locals / 64) + 1
}

public function new_zeros(out: init Vec_u64.Vec, n: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit words: Vec_u64.Vec
    Vec_u64.with_capacity(init words, n, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_u64.push(mutable words, 0 as u64, allocator)?
        i += 1
    }
    out = words
}

public function new_false(out: init Vec_bool.Vec, n: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit flags: Vec_bool.Vec
    Vec_bool.with_capacity(init flags, n, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_bool.push(mutable flags, false, allocator)?
        i += 1
    }
    out = flags
}

public function bit_at(bits: Vec_u64.Vec, base: usize, idx: usize) -> bool {
    let w = base + (idx / 64)
    if w >= Vec_u64.len(bits) { return false }
    let mask = (1 as u64) << ((idx % 64) as u64)
    return (Vec_u64.at(bits, w) & mask) != (0 as u64)
}

public function bit_set(bits: mutable Vec_u64.Vec, base: usize, idx: usize) -> () {
    let w = base + (idx / 64)
    if w >= Vec_u64.len(bits) { return }
    let mask = (1 as u64) << ((idx % 64) as u64)
    Vec_u64.set_at(mutable bits, w, Vec_u64.at(bits, w) | mask)
}

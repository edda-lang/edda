
module optimize.refine_elim.narrow.util.util

import std.collections.vec
import std.mem.alloc as alloc

import mir.place as mir_place_mod
import mir.id.local as mir_local_mod

spec std.collections.vec.Vec(bool)

public function new_bools(n: usize, allocator: Allocator) -> Vec_bool.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit v: Vec_bool.Vec
    Vec_bool.new(init v, allocator)?
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        Vec_bool.push(mutable v, take false, allocator)?
        i = i + 1
    }
    return v
}

public function pinned_at(pinned: Vec_bool.Vec, idx: usize) -> bool {
    if idx >= Vec_bool.len(pinned) { return true }
    return Vec_bool.at(pinned, idx)
}

public function mark_if(pinned: mutable Vec_bool.Vec, li: i64) -> () {
    if li < (0 as i64) { return }
    let idx = li as usize
    if idx >= Vec_bool.len(pinned) { return }
    Vec_bool.set_at(mutable pinned, idx, true)
}

public function bare_local_of(p: mir_place_mod.Place) -> i64 {
    if mir_place_mod.proj_len(p) == (0 as usize) {
        return mir_local_mod.index(p.local) as i64
    }
    return (0 as i64) - (1 as i64)
}

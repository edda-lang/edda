
module optimize.refine_elim.narrow.narrow

import std.collections.vec
import std.mem.alloc as alloc

import local.refine_elim.range.range as range_mod
import local.refine_elim.narrow.util.util as util_mod
import local.refine_elim.narrow.dataflow.dataflow as dataflow_mod
import local.refine_elim.narrow.pinned.pinned as pinned_mod
import local.refine_elim.narrow.plan.plan as plan_mod

import mir.body.model as mir_body_mod
import types.ty.interner as ty_interner_mod

spec std.collections.vec.Vec(mir_body_mod.Local)

public function analyze(
    body: mir_body_mod.MirBody,
    it_interner: mutable ty_interner_mod.Interner,
    allocator: Allocator,
) -> plan_mod.NarrowPlan
    with {allocator, err: alloc.AllocError}
{
    let declared = range_mod.seeded(body, it_interner, allocator)?
    var cur = range_mod.seeded(body, it_interner, allocator)?
    let n = Vec_Local.len(body.locals)
    let pinned = pinned_mod.build_pinned(body, allocator)?
    var defined = util_mod.new_bools(n, allocator)?
    dataflow_mod.solve(mutable cur, mutable defined, declared, pinned, body, it_interner, allocator)?
    return plan_mod.build_plan(cur, defined, declared, pinned, n, mutable it_interner, allocator)?
}

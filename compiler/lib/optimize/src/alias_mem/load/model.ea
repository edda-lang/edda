module optimize.alias_mem.load.model

import std.collections.vec
import std.core.option

import mir.rvalue as mir_rvalue_mod
import mir.place as mir_place_mod


spec std.collections.vec.Vec(AvailFact)


spec std.core.option.Option(AvailFact)


derive eq, hash, debug for AvailFact


public type AvailFact {
    dest: mir_place_mod.Place
    source: mir_rvalue_mod.Operand
    source_has_deref: bool
}

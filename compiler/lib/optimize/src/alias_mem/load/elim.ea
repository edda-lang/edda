module optimize.alias_mem.load.elim

import std.mem.alloc
import std.collections.vec

import mir.body.model as mir_body_mod

import local.alias_mem.escape as escape_mod
import local.alias_mem.load.facts as facts_mod
import local.alias_mem.load.rewrite as rewrite_mod


spec std.collections.vec.Vec(mir_body_mod.BasicBlock)


public function run(
    body: mutable mir_body_mod.MirBody,
    info: escape_mod.EscapeInfo,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit facts: facts_mod.FactTable
    facts_mod.new_table(init facts, info, allocator)?

    let n_blocks: usize = Vec_BasicBlock.len(body.blocks)
    var bi: usize = 1
    loop decreases n_blocks - bi {
        if bi >= n_blocks { break }
        let rebuilt = rewrite_mod.rewrite_block(Vec_BasicBlock.at(body.blocks, bi), mutable facts, info, body.locals, allocator)?
        Vec_BasicBlock.set_at(mutable body.blocks, bi, take rebuilt)
        bi += 1
    }
}

module optimize.alias_mem.sroa.model

import std.mem.alloc
import std.collections.vec


spec std.collections.vec.Vec(u32)


derive eq, hash, debug for Plan


public type Plan {
    candidate_base_index: Vec_u32.Vec
    candidate_n_fields: Vec_u32.Vec
    candidate_first_new: Vec_u32.Vec
    field_to_local: Vec_u32.Vec
}


public function new_plan(out: init Plan, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit base_index: Vec_u32.Vec
    Vec_u32.new(init base_index, allocator)?
    uninit n_fields: Vec_u32.Vec
    Vec_u32.new(init n_fields, allocator)?
    uninit first_new: Vec_u32.Vec
    Vec_u32.new(init first_new, allocator)?
    uninit field_to_local: Vec_u32.Vec
    Vec_u32.new(init field_to_local, allocator)?
    out = Plan {
        candidate_base_index: base_index,
        candidate_n_fields: n_fields,
        candidate_first_new: first_new,
        field_to_local: field_to_local,
    }
}

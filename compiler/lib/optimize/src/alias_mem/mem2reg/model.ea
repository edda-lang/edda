module optimize.alias_mem.mem2reg.model

import std.core.option
import std.collections.vec

import mir.rvalue as mir_rvalue_mod


spec std.core.option.Option(mir_rvalue_mod.Operand)

spec std.collections.vec.Vec(bool)
spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(DefOp)


derive eq, hash, debug for DefOp
derive eq, hash, debug for Counters


public type DefOp {
    value: Option_Operand.Option
}


public type Counters {
    n_def_assign: Vec_u32.Vec
    n_def_other: Vec_u32.Vec
    n_read_other: Vec_u32.Vec
    is_dest_anywhere: Vec_bool.Vec
    def_op: Vec_DefOp.Vec
}

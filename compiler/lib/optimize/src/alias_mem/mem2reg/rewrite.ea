module optimize.alias_mem.mem2reg.rewrite

import std.mem.alloc
import std.collections.vec

import mir.body.model as mir_body_mod
import mir.stmt as mir_stmt_mod
import mir.rvalue as mir_rvalue_mod
import mir.term as mir_term_mod
import mir.id.local as mir_local_mod

import local.alias_mem.escape as escape_mod
import local.alias_mem.mem2reg.model as model_mod


spec std.collections.vec.Vec(bool)
spec std.collections.vec.Vec(mir_body_mod.BasicBlock)
spec std.collections.vec.Vec(mir_stmt_mod.Statement)
spec std.collections.vec.Vec(mir_rvalue_mod.Operand)
spec std.collections.vec.Vec(model_mod.DefOp)


public function rewrite_blocks(
    body: mutable mir_body_mod.MirBody,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n_blocks: usize = Vec_BasicBlock.len(body.blocks)
    var bi: usize = 1
    loop decreases n_blocks - bi {
        if bi >= n_blocks { break }
        if bi >= Vec_BasicBlock.len(body.blocks) { break }
        let new_block = rewrite_block(body, bi, candidate, subst, allocator)?
        Vec_BasicBlock.set_at(mutable body.blocks, bi, take new_block)
        bi += 1
    }
}


function rewrite_block(
    body: mir_body_mod.MirBody,
    slot: usize,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> mir_body_mod.BasicBlock
    with {allocator, err: alloc.AllocError}
    requires slot < Vec_BasicBlock.len(body.blocks)
{
    let block = Vec_BasicBlock.at(body.blocks, slot)

    uninit fresh: Vec_Statement.Vec
    Vec_Statement.new(init fresh, allocator)?

    let n_stmts: usize = Vec_Statement.len(block.statements)
    var si: usize = 0
    loop decreases n_stmts - si {
        if si >= n_stmts { break }
        let stmt = Vec_Statement.at(block.statements, si)
        if statement_is_dropped(stmt, candidate) {
            ()
        } else {
            let rewritten = rewrite_statement(stmt, candidate, subst, allocator)?
            Vec_Statement.push(mutable fresh, take rewritten, allocator)?
        }
        si += 1
    }

    let new_term = rewrite_terminator(block.terminator, candidate, subst, allocator)?

    return mir_body_mod.BasicBlock {
        node_id_origin: block.node_id_origin,
        statements: fresh,
        terminator: new_term,
        coherence_region: block.coherence_region,
    }
}


function statement_is_dropped(stmt: mir_stmt_mod.Statement, candidate: Vec_bool.Vec) -> bool {
    return match stmt.kind {
        case .assign(let dest, _) =>
            escape_mod.is_bare(dest) && local_is_candidate(escape_mod.base_local(dest), candidate)
        case .storage_live(let local) => local_is_candidate(local, candidate)
        case .storage_dead(let local) => local_is_candidate(local, candidate)
        case .nop_ => false
    }
}


function rewrite_statement(
    stmt: mir_stmt_mod.Statement,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> mir_stmt_mod.Statement
    with {allocator, err: alloc.AllocError}
{
    return match stmt.kind {
        case .assign(let dest, let value) => {
            let new_value = rewrite_rvalue(value, candidate, subst, allocator)?
            mir_stmt_mod.Statement {
                origin: stmt.origin,
                kind: mir_stmt_mod.MStmtKind.assign(dest: dest, value: new_value),
            }
        }
        case _ => stmt
    }
}


function rewrite_rvalue(
    rv: mir_rvalue_mod.Rvalue,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> mir_rvalue_mod.Rvalue
    with {allocator, err: alloc.AllocError}
{
    return match rv {
        case .use_(let operand) =>
            mir_rvalue_mod.Rvalue.use_(operand: rewrite_operand(operand, candidate, subst))
        case .binary(let op, let lhs, let rhs) =>
            mir_rvalue_mod.Rvalue.binary(
                op: op,
                lhs: rewrite_operand(lhs, candidate, subst),
                rhs: rewrite_operand(rhs, candidate, subst),
            )
        case .unary(let op, let operand) =>
            mir_rvalue_mod.Rvalue.unary(
                op: op,
                operand: rewrite_operand(operand, candidate, subst),
            )
        case .cast(let operand, let from, let to, let kind) =>
            mir_rvalue_mod.Rvalue.cast(
                operand: rewrite_operand(operand, candidate, subst),
                from: from,
                to: to,
                kind: kind,
            )
        case .aggregate(let kind, let elems, let result_ty) => {
            let new_elems = rewrite_operands(elems, candidate, subst, allocator)?
            mir_rvalue_mod.Rvalue.aggregate(kind: kind, elems: new_elems, result_ty: result_ty)
        }
        case .make_closure(let code, let env) =>
            mir_rvalue_mod.Rvalue.make_closure(code: code, env: rewrite_operand(env, candidate, subst))
        case _ => rv
    }
}


function rewrite_terminator(
    term: mir_term_mod.Terminator,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> mir_term_mod.Terminator
    with {allocator, err: alloc.AllocError}
{
    let new_kind = match term.kind {
        case .branch(let cond, let true_, let false_) =>
            mir_term_mod.TermKind.branch(
                cond: rewrite_operand(cond, candidate, subst),
                true_: true_,
                false_: false_,
            )
        case .switch_(let discr, let targets) =>
            mir_term_mod.TermKind.switch_(
                discr: rewrite_operand(discr, candidate, subst),
                targets: targets,
            )
        case .raise_(let value, let unwind) =>
            mir_term_mod.TermKind.raise_(
                value: rewrite_operand(value, candidate, subst),
                unwind: unwind,
            )
        case .panic_(let message) =>
            mir_term_mod.TermKind.panic_(message: rewrite_operand(message, candidate, subst))
        case .call_(let callee, let args, let dest, let return_, let unwind) => {
            let new_args = rewrite_operands(args, candidate, subst, allocator)?
            mir_term_mod.TermKind.call_(
                callee: rewrite_operand(callee, candidate, subst),
                args: new_args,
                dest: dest,
                return_: return_,
                unwind: unwind,
            )
        }
        case .spawn_(let child, let args, let group_local, let handle_dest, let return_, let unwind) => {
            let new_args = rewrite_operands(args, candidate, subst, allocator)?
            mir_term_mod.TermKind.spawn_(
                child: child,
                args: new_args,
                group_local: group_local,
                handle_dest: handle_dest,
                return_: return_,
                unwind: unwind,
            )
        }
        case .await_(let handle, let dest, let return_, let unwind) =>
            mir_term_mod.TermKind.await_(
                handle: rewrite_operand(handle, candidate, subst),
                dest: dest,
                return_: return_,
                unwind: unwind,
            )
        case _ => term.kind
    }
    return mir_term_mod.Terminator { origin: term.origin, kind: new_kind }
}


function rewrite_operands(
    ops: Vec_Operand.Vec,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
    allocator: Allocator,
) -> Vec_Operand.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit fresh: Vec_Operand.Vec
    Vec_Operand.new(init fresh, allocator)?
    let n: usize = Vec_Operand.len(ops)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let op = Vec_Operand.at(ops, i)
        let new_op = rewrite_operand(op, candidate, subst)
        Vec_Operand.push(mutable fresh, take new_op, allocator)?
        i += 1
    }
    return fresh
}


function rewrite_operand(
    op: mir_rvalue_mod.Operand,
    candidate: Vec_bool.Vec,
    subst: Vec_DefOp.Vec,
) -> mir_rvalue_mod.Operand {
    return match op {
        case .copy_(let place, _) => {
            if escape_mod.is_bare(place) && local_is_candidate(escape_mod.base_local(place), candidate) {
                substitute_operand(escape_mod.base_local(place), subst, op)
            } else {
                op
            }
        }
        case _ => op
    }
}


function substitute_operand(
    l: mir_local_mod.LocalId,
    subst: Vec_DefOp.Vec,
    fallback: mir_rvalue_mod.Operand,
) -> mir_rvalue_mod.Operand {
    let idx: usize = mir_local_mod.index(l)
    if idx >= Vec_DefOp.len(subst) {
        return fallback
    }
    let entry = Vec_DefOp.at(subst, idx)
    return match entry.value {
        case .some(let op) => op
        case .none => fallback
    }
}


function local_is_candidate(l: mir_local_mod.LocalId, candidate: Vec_bool.Vec) -> bool {
    let idx: usize = mir_local_mod.index(l)
    if idx < Vec_bool.len(candidate) {
        return Vec_bool.at(candidate, idx)
    }
    return false
}

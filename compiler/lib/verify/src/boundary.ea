
module verify.boundary

import std.collections.vec

import ir.hlir.tree.node.file as hlir_file_mod
import ir.hlir.tree.body as hlir_body_mod

import local.error as error_mod
import local.facts as facts_mod
import local.refs as refs_mod


spec std.collections.vec.Vec(hlir_body_mod.HlirBody)


public function verify_file(file: hlir_file_mod.HlirFile) -> ()
    with {err: error_mod.BoundaryError}
{
    let n = Vec_HlirBody.len(file.bodies)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let body = Vec_HlirBody.at(file.bodies, i)
        verify_body(body)?
        i += 1
    }
}

public function verify_body(body: hlir_body_mod.HlirBody) -> ()
    with {err: error_mod.BoundaryError}
{
    facts_mod.check_sentinel_slots(body)?
    facts_mod.check_entry_block(body)?
    facts_mod.check_param_prefix(body)?
    refs_mod.check_value_references(body)?
    refs_mod.check_control_references(body)?
}

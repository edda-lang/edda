
module wasm.isel.valtype.valtype

import std.collections.vec
import ir.lir.tree.reg as reg_mod
import ir.lir.tree.body as body_mod
import ir.lir.id.vreg as vreg_mod
import local.model as model_mod


spec std.collections.vec.Vec(reg_mod.LirVReg)


public function valtype_of_vreg(body: body_mod.LirBody, id: vreg_mod.LirVRegId) -> model_mod.ValType {
    let vr = Vec_LirVReg.at(body.vregs, id.raw as usize)
    return valtype_of(vr)
}


public function valtype_of(vr: reg_mod.LirVReg) -> model_mod.ValType {
    return match vr.class_ {
        case .fp => if vr.size == (8 as u32) { model_mod.ValType.f64_ } else { model_mod.ValType.f32_ }
        case _   => if vr.size == (8 as u32) { model_mod.ValType.i64_ } else { model_mod.ValType.i32_ }
    }
}


public function is_i64_vreg(body: body_mod.LirBody, id: vreg_mod.LirVRegId) -> bool {
    return match valtype_of_vreg(body, id) {
        case .i64_ => true
        case _     => false
    }
}


public function is_float_vreg(body: body_mod.LirBody, id: vreg_mod.LirVRegId) -> bool {
    return match valtype_of_vreg(body, id) {
        case .f32_ => true
        case .f64_ => true
        case _     => false
    }
}


module wasm.fmt.encode

import std.mem.alloc
import std.collections.vec
import local.model as model_mod


spec std.collections.vec.Vec(u8)


public function push_byte(buf: mutable Vec_u8.Vec, b: u8, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.push(mutable buf, b, allocator)?
}


public function append(buf: mutable Vec_u8.Vec, src: Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n: usize = Vec_u8.len(src)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_u8.push(mutable buf, Vec_u8.at(src, i), allocator)?
        i += 1
    }
}


public function push_str(buf: mutable Vec_u8.Vec, s: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let bytes = s.bytes()
    let n: usize = bytes.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_u8.push(mutable buf, bytes[i], allocator)?
        i += 1
    }
}


public function push_slice(buf: mutable Vec_u8.Vec, src: [u8], allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n: usize = src.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_u8.push(mutable buf, src[i], allocator)?
        i += 1
    }
}


public function push_name(buf: mutable Vec_u8.Vec, s: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uleb(mutable buf, s.bytes().len() as u64, allocator)?
    push_str(mutable buf, s, allocator)?
}


public function uleb(buf: mutable Vec_u8.Vec, value: u64, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    var v: u64 = value
    loop decreases v {
        let low: u8 = (v & (0x7F as u64)) as u8
        v = v >> (7 as u64)
        if v == (0 as u64) {
            Vec_u8.push(mutable buf, low, allocator)?
            break
        }
        Vec_u8.push(mutable buf, low | (0x80 as u8), allocator)?
    }
}


public function sleb(buf: mutable Vec_u8.Vec, value: i64, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let neg_one: i64 = (0 as i64) - (1 as i64)
    var v: i64 = value
    var guard: u32 = 0
    loop decreases (11 as u32) - guard {
        if guard >= (11 as u32) { break }
        guard += 1
        let low: u8 = (v & (0x7F as i64)) as u8
        v = v >> (7 as i64)
        let sign_set: bool = (low & (0x40 as u8)) != (0 as u8)
        let done: bool = ((v == (0 as i64)) && !sign_set) || ((v == neg_one) && sign_set)
        if done {
            Vec_u8.push(mutable buf, low, allocator)?
            break
        }
        Vec_u8.push(mutable buf, low | (0x80 as u8), allocator)?
    }
}


public function valtype_byte(vt: model_mod.ValType) -> u8 {
    return match vt {
        case .i32_ => 0x7F as u8
        case .i64_ => 0x7E as u8
        case .f32_ => 0x7D as u8
        case .f64_ => 0x7C as u8
    }
}


public function emit_section(out: mutable Vec_u8.Vec, id: u8, contents: Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.push(mutable out, id, allocator)?
    uleb(mutable out, Vec_u8.len(contents) as u64, allocator)?
    append(mutable out, contents, allocator)?
}


module wasm.model

import std.mem.alloc
import std.collections.vec


spec std.collections.vec.Vec(ValType)
spec std.collections.vec.Vec(FuncType)
spec std.collections.vec.Vec(Import)
spec std.collections.vec.Vec(Func)
spec std.collections.vec.Vec(Export)
spec std.collections.vec.Vec(DataSeg)
spec std.collections.vec.Vec(u8)


derive eq, hash, debug for ValType


public type ValType {
    case i32_
    case i64_
    case f32_
    case f64_
}


public type FuncType {
    params: Vec_ValType.Vec
    results: Vec_ValType.Vec
}


public type Import {
    module_name: String
    field_name: String
    type_idx: u32
}


public type Func {
    type_idx: u32
    locals: Vec_ValType.Vec
    body: Vec_u8.Vec
}


public type Export {
    name: String
    func_idx: u32
}


public type DataSeg {
    offset: u32
    bytes: Vec_u8.Vec
}


public type WasmModule {
    types: Vec_FuncType.Vec
    imports: Vec_Import.Vec
    funcs: Vec_Func.Vec
    exports: Vec_Export.Vec
    datas: Vec_DataSeg.Vec
    mem_min_pages: u32
    data_end: u32
}


public function new_module(out: init WasmModule, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit types: Vec_FuncType.Vec
    Vec_FuncType.new(init types, allocator)?
    uninit imports: Vec_Import.Vec
    Vec_Import.new(init imports, allocator)?
    uninit funcs: Vec_Func.Vec
    Vec_Func.new(init funcs, allocator)?
    uninit exports: Vec_Export.Vec
    Vec_Export.new(init exports, allocator)?
    uninit datas: Vec_DataSeg.Vec
    Vec_DataSeg.new(init datas, allocator)?
    out = WasmModule {
        types: types,
        imports: imports,
        funcs: funcs,
        exports: exports,
        datas: datas,
        mem_min_pages: 0,
        data_end: 1024,
    }
}


public function add_type(wmod: mutable WasmModule, ft: take FuncType, allocator: Allocator) -> u32
    with {allocator, err: alloc.AllocError}
    requires Vec_FuncType.len(wmod.types) < 4294967295
{
    let idx = Vec_FuncType.len(wmod.types) as u32
    Vec_FuncType.push(mutable wmod.types, take ft, allocator)?
    return idx
}


public function add_import(wmod: mutable WasmModule, imp: take Import, allocator: Allocator) -> u32
    with {allocator, err: alloc.AllocError}
    requires Vec_Import.len(wmod.imports) < 4294967295
{
    let idx = Vec_Import.len(wmod.imports) as u32
    Vec_Import.push(mutable wmod.imports, take imp, allocator)?
    return idx
}


public function add_func(wmod: mutable WasmModule, f: take Func, allocator: Allocator) -> u32
    with {allocator, err: alloc.AllocError}
    requires Vec_Func.len(wmod.funcs) < 4294967295
{
    let idx = Vec_Func.len(wmod.funcs) as u32
    Vec_Func.push(mutable wmod.funcs, take f, allocator)?
    return idx
}


public function add_export(wmod: mutable WasmModule, e: take Export, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_Export.push(mutable wmod.exports, take e, allocator)?
}


public function add_data(wmod: mutable WasmModule, bytes: take Vec_u8.Vec, allocator: Allocator) -> u32
    with {allocator, err: alloc.AllocError}
{
    let offset = wmod.data_end
    let len = Vec_u8.len(bytes) as u32
    Vec_DataSeg.push(mutable wmod.datas, take DataSeg { offset: offset, bytes: bytes }, allocator)?
    wmod.data_end = align4(offset + len)
    return offset
}


function align4(n: u32) -> u32 {
    return (n + (3 as u32)) & (~(3 as u32))
}

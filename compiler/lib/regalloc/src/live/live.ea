
module regalloc.live.live

import std.mem.alloc
import std.collections.vec

import ir.lir.tree.body as lir_body_mod
import ir.lir.tree.reg as lir_reg_mod
import local.live.defuse.bits as bits_mod
import local.live.defuse.defuse as defuse_mod
import local.live.solve.solve as solve_mod


spec std.collections.vec.Vec(u64)
spec std.collections.vec.Vec(lir_reg_mod.LirVReg)
spec std.collections.vec.Vec(lir_body_mod.LirBlock)


public type Liveness {
    n_vregs: usize
    n_blocks: usize
    live_in: Vec_u64.Vec
    live_out: Vec_u64.Vec
}


public function compute(
    out: init Liveness,
    body: lir_body_mod.LirBody,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n_vregs = Vec_LirVReg.len(body.vregs)
    let n_blocks = Vec_LirBlock.len(body.blocks)

    uninit def_set: Vec_u64.Vec
    bits_mod.new_flat(init def_set, n_blocks, n_vregs, allocator)?
    uninit use_set: Vec_u64.Vec
    bits_mod.new_flat(init use_set, n_blocks, n_vregs, allocator)?
    uninit live_in: Vec_u64.Vec
    bits_mod.new_flat(init live_in, n_blocks, n_vregs, allocator)?
    uninit live_out: Vec_u64.Vec
    bits_mod.new_flat(init live_out, n_blocks, n_vregs, allocator)?

    defuse_mod.compute(mutable def_set, mutable use_set, body, n_blocks, n_vregs, allocator)?
    solve_mod.run(mutable live_in, mutable live_out, def_set, use_set, body, n_blocks, n_vregs, allocator)?

    out = Liveness {
        n_vregs: n_vregs,
        n_blocks: n_blocks,
        live_in: live_in,
        live_out: live_out,
    }
}


public function live_in_at(l: Liveness, b: usize, v: usize) -> bool {
    if b >= l.n_blocks { return false }
    if v >= l.n_vregs { return false }
    return bits_mod.bget(l.live_in, b, v, l.n_vregs)
}


public function live_out_at(l: Liveness, b: usize, v: usize) -> bool {
    if b >= l.n_blocks { return false }
    if v >= l.n_vregs { return false }
    return bits_mod.bget(l.live_out, b, v, l.n_vregs)
}


public function n_blocks_of(l: Liveness) -> usize {
    return l.n_blocks
}


public function n_vregs_of(l: Liveness) -> usize {
    return l.n_vregs
}

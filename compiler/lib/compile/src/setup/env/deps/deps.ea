
module compile.setup.env.deps.deps

import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.mem.alloc
import std.os.fs
import std.text.string
import diagnostics.emit.collection as diags_mod
import source.map as source_map_mod
import manifest.manifest as manifest_mod
import manifest.model.dependency.dependency as dep_mod
import manifest.model.workspace.workspace as ws_mod
import local.setup.env.load.load as load_mod
import local.setup.env.discover as discover_mod


spec std.collections.vec.Vec(String)
spec std.collections.hashmap.StringMap(bool)
spec std.core.option.Option(String)
spec std.core.option.Option(manifest_mod.LoadedManifest)
spec std.core.option.Option(dep_mod.Dependency)


public function append_dependency_sources(
    rfs: ReadOnlyFilesystem,
    workspace_root: String,
    manifest: manifest_mod.LoadedManifest,
    current_member: Option_String.Option,
    results: mutable Vec_String.Vec,
    allocator: Allocator,
) -> ()
    with {rfs, allocator, err: fs.FsError, err: alloc.AllocError, divergence}
{
    let pkg_root = package_root_of(workspace_root, manifest, current_member, allocator)?
    var visited = StringMap_bool.new(allocator)?
    uninit worklist: Vec_String.Vec
    Vec_String.new(init worklist, allocator)?

    match load_manifest_at(rfs, pkg_root, allocator)? {
        case .some(let root_m) => seed_path_deps(root_m, pkg_root, mutable worklist, allocator)?
        case .none => ()
    }

    var idx: usize = 0
    loop {
        let wn = Vec_String.len(worklist)
        if idx >= wn { break }
        let dep_root = Vec_String.at(worklist, idx)
        idx = idx + 1
        if StringMap_bool.contains(visited, dep_root) {
            continue
        }
        let _ = StringMap_bool.insert(mutable visited, dep_root, true, allocator)?
        let src_dir = string.concat(dep_root, "/src", allocator)?
        if fs.path_exists(rfs, src_dir) {
            discover_mod.walk_dir(rfs, src_dir, mutable results, allocator)?
        }
        match load_manifest_at(rfs, dep_root, allocator)? {
            case .some(let dep_m) => seed_path_deps(dep_m, dep_root, mutable worklist, allocator)?
            case .none => ()
        }
    }
}


function package_root_of(
    workspace_root: String,
    manifest: manifest_mod.LoadedManifest,
    current_member: Option_String.Option,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    match current_member {
        case .some(let member) => {
            if manifest_mod.has_workspace(manifest) {
                let root_segment = match load_mod.workspace_of(manifest) {
                    case .some(let ws) => ws_mod.discover_root_of(ws)
                    case .none => ""
                }
                let a = string.concat(workspace_root, "/", allocator)?
                let b = string.concat(a, root_segment, allocator)?
                let c = string.concat(b, "/", allocator)?
                return string.concat(c, member, allocator)?
            }
            return string.clone(workspace_root, allocator)?
        }
        case .none => return string.clone(workspace_root, allocator)?
    }
}


function seed_path_deps(
    m: manifest_mod.LoadedManifest,
    base_dir: String,
    worklist: mutable Vec_String.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = manifest_mod.dependency_count_of(m)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        match manifest_mod.dependency_at(m, i) {
            case .some(let dep) => match dep_mod.source(dep) {
                case .path(let rel) => {
                    let dep_root = normalize_join(base_dir, rel, allocator)?
                    Vec_String.push(mutable worklist, take dep_root, allocator)?
                }
                case _ => ()
            }
            case .none => ()
        }
        i = i + 1
    }
}


function load_manifest_at(rfs: ReadOnlyFilesystem, package_root: String, allocator: Allocator) -> Option_LoadedManifest.Option
    with {rfs, allocator, err: fs.FsError, err: alloc.AllocError}
{
    let manifest_path = string.concat(package_root, "/package.toml", allocator)?
    if !fs.path_exists(rfs, manifest_path) {
        return Option_LoadedManifest.none
    }
    uninit scratch_map: source_map_mod.SourceMap
    source_map_mod.new_map(init scratch_map, allocator)?
    uninit scratch_diags: diags_mod.Diagnostics
    diags_mod.new_diagnostics(init scratch_diags, allocator)?
    return load_mod.manifest_load(rfs, mutable scratch_map, package_root, mutable scratch_diags, allocator)?
}


function normalize_join(base: String, rel: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let joined_a = string.concat(base, "/", allocator)?
    let joined = string.concat(joined_a, rel, allocator)?
    let parts = string.split(joined, "/", allocator)?
    uninit segs: Vec_String.Vec
    Vec_String.new(init segs, allocator)?
    let n = parts.len()
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let part = parts[i]
        if string.equals(part, "..") {
            let depth = Vec_String.len(segs)
            if depth > 0 {
                let _ = Vec_String.remove(mutable segs, depth - 1)
            }
        } else {
            if !string.equals(part, ".") && !string.is_empty(part) {
                let owned = string.clone(part, allocator)?
                Vec_String.push(mutable segs, take owned, allocator)?
            }
        }
        i = i + 1
    }
    var acc: String = if string.starts_with(joined, "/") { "/" } else { "" }
    let m = Vec_String.len(segs)
    var k: usize = 0
    loop decreases (m - k) {
        if k >= m { break }
        if k > 0 {
            acc = string.concat(acc, "/", allocator)?
        }
        acc = string.concat(acc, Vec_String.at(segs, k), allocator)?
        k = k + 1
    }
    return acc
}

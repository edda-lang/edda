
module compile.phase.pipeline.lower

import std.mem.alloc
import std.collections.vec
import hir.build.file as hir_file_mod
import hir.build.walk.lower as hir_lower_mod
import intern.interner as interner_mod
import resolve.ctx as resolve_ctx_mod
import syntax.ast.file as ast_file_mod


spec std.collections.vec.Vec(ast_file_mod.File)
spec std.collections.vec.Vec(hir_file_mod.HirFile)


public function lower_to_hir(
    files: take Vec_File.Vec,
    output: resolve_ctx_mod.ResolveOutput,
    start_def_id: u32,
    interner: mutable interner_mod.Interner,
    sym_alloc: Allocator,
    allocator: Allocator,
) -> Vec_HirFile.Vec
    with {sym_alloc, allocator, err: alloc.AllocError, divergence}
{
    uninit hir_files: Vec_HirFile.Vec
    Vec_HirFile.new(init hir_files, allocator)?
    loop decreases (Vec_File.len(files) + 1) as usize {
        if Vec_File.is_empty(files) {
            break
        }
        let ast = Vec_File.remove(mutable files, 0 as usize)
        let hir = hir_lower_mod.lower_file(take ast, output, start_def_id, mutable interner, sym_alloc, allocator)?
        Vec_HirFile.push(mutable hir_files, take hir, allocator)?
    }
    return hir_files
}

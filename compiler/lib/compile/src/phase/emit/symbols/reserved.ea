
module compile.phase.emit.symbols.reserved

import std.mem.alloc
import std.collections.hashmap

import resolve.build.builtins as builtins_mod


spec std.collections.hashmap.IntMap(String)


public function insert_reserved_symbols(
    map: mutable IntMap_String.IntMap,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let concat_def = builtins_mod.seed(1).builtins.string_concat
    let concat_sym: String = "__edda_string_concat"
    let _ = IntMap_String.insert(mutable map, concat_def.raw as i64, take concat_sym, allocator)?
    let fmt_i64_def = builtins_mod.seed(1).builtins.format_i64
    let fmt_i64_sym: String = "__edda_format_i64"
    let _ = IntMap_String.insert(mutable map, fmt_i64_def.raw as i64, take fmt_i64_sym, allocator)?
    let fmt_u64_def = builtins_mod.seed(1).builtins.format_u64
    let fmt_u64_sym: String = "__edda_format_u64"
    let _ = IntMap_String.insert(mutable map, fmt_u64_def.raw as i64, take fmt_u64_sym, allocator)?
    let fmt_f64_def = builtins_mod.seed(1).builtins.format_f64
    let fmt_f64_sym: String = "__edda_format_f64"
    let _ = IntMap_String.insert(mutable map, fmt_f64_def.raw as i64, take fmt_f64_sym, allocator)?
    let fmt_bool_def = builtins_mod.seed(1).builtins.format_bool
    let fmt_bool_sym: String = "__edda_format_bool"
    let _ = IntMap_String.insert(mutable map, fmt_bool_def.raw as i64, take fmt_bool_sym, allocator)?
    let fmt_str_def = builtins_mod.seed(1).builtins.format_str
    let fmt_str_sym: String = "__edda_format_str"
    let _ = IntMap_String.insert(mutable map, fmt_str_def.raw as i64, take fmt_str_sym, allocator)?
    let spawn_def = builtins_mod.seed(1).builtins.task_spawn
    let spawn_sym: String = "__edda_task_spawn"
    let _ = IntMap_String.insert(mutable map, spawn_def.raw as i64, take spawn_sym, allocator)?
    let await_def = builtins_mod.seed(1).builtins.task_await
    let await_sym: String = "__edda_task_await"
    let _ = IntMap_String.insert(mutable map, await_def.raw as i64, take await_sym, allocator)?
    let group_open_def = builtins_mod.seed(1).builtins.task_group_open
    let group_open_sym: String = "__edda_task_group_open"
    let _ = IntMap_String.insert(mutable map, group_open_def.raw as i64, take group_open_sym, allocator)?
    let group_join_def = builtins_mod.seed(1).builtins.task_group_join
    let group_join_sym: String = "__edda_task_group_join"
    let _ = IntMap_String.insert(mutable map, group_join_def.raw as i64, take group_join_sym, allocator)?
    let slice_new_def = builtins_mod.seed(1).builtins.slice_iter_new
    let slice_new_sym: String = "__edda_slice_iter_new"
    let _ = IntMap_String.insert(mutable map, slice_new_def.raw as i64, take slice_new_sym, allocator)?
    let slice_next_def = builtins_mod.seed(1).builtins.slice_iter_next
    let slice_next_sym: String = "__edda_slice_iter_next"
    let _ = IntMap_String.insert(mutable map, slice_next_def.raw as i64, take slice_next_sym, allocator)?
    let range_new_def = builtins_mod.seed(1).builtins.range_iter_new
    let range_new_sym: String = "__edda_range_iter_new"
    let _ = IntMap_String.insert(mutable map, range_new_def.raw as i64, take range_new_sym, allocator)?
    let range_next_def = builtins_mod.seed(1).builtins.range_iter_next
    let range_next_sym: String = "__edda_range_iter_next"
    let _ = IntMap_String.insert(mutable map, range_next_def.raw as i64, take range_next_sym, allocator)?
    let alloc_array_def = builtins_mod.seed(1).builtins.alloc_array
    let alloc_array_sym: String = "__edda_alloc_array_raw"
    let _ = IntMap_String.insert(mutable map, alloc_array_def.raw as i64, take alloc_array_sym, allocator)?
    let alloc_raw_def = builtins_mod.seed(1).builtins.alloc_raw
    let alloc_raw_sym: String = "__edda_alloc_raw"
    let _ = IntMap_String.insert(mutable map, alloc_raw_def.raw as i64, take alloc_raw_sym, allocator)?
    let box_read_raw_def = builtins_mod.seed(1).builtins.box_read_raw
    let box_read_raw_sym: String = "__edda_box_read_raw"
    let _ = IntMap_String.insert(mutable map, box_read_raw_def.raw as i64, take box_read_raw_sym, allocator)?
    let box_unbox_raw_def = builtins_mod.seed(1).builtins.box_unbox_raw
    let box_unbox_raw_sym: String = "__edda_box_unbox_raw"
    let _ = IntMap_String.insert(mutable map, box_unbox_raw_def.raw as i64, take box_unbox_raw_sym, allocator)?
    let free_raw_def = builtins_mod.seed(1).builtins.free_raw
    let free_raw_sym: String = "__edda_free_raw"
    let _ = IntMap_String.insert(mutable map, free_raw_def.raw as i64, take free_raw_sym, allocator)?
    let realloc_array_raw_def = builtins_mod.seed(1).builtins.realloc_array_raw
    let realloc_array_raw_sym: String = "__edda_realloc_array_raw"
    let _ = IntMap_String.insert(mutable map, realloc_array_raw_def.raw as i64, take realloc_array_raw_sym, allocator)?
    let copy_array_raw_def = builtins_mod.seed(1).builtins.copy_array_raw
    let copy_array_raw_sym: String = "__edda_copy_array_raw"
    let _ = IntMap_String.insert(mutable map, copy_array_raw_def.raw as i64, take copy_array_raw_sym, allocator)?
    let floattidf_def = builtins_mod.seed(1).builtins.floattidf
    let floattidf_sym: String = "__floattidf"
    let _ = IntMap_String.insert(mutable map, floattidf_def.raw as i64, take floattidf_sym, allocator)?
    let floattisf_def = builtins_mod.seed(1).builtins.floattisf
    let floattisf_sym: String = "__floattisf"
    let _ = IntMap_String.insert(mutable map, floattisf_def.raw as i64, take floattisf_sym, allocator)?
    let floatuntidf_def = builtins_mod.seed(1).builtins.floatuntidf
    let floatuntidf_sym: String = "__floatuntidf"
    let _ = IntMap_String.insert(mutable map, floatuntidf_def.raw as i64, take floatuntidf_sym, allocator)?
    let floatuntisf_def = builtins_mod.seed(1).builtins.floatuntisf
    let floatuntisf_sym: String = "__floatuntisf"
    let _ = IntMap_String.insert(mutable map, floatuntisf_def.raw as i64, take floatuntisf_sym, allocator)?
    let fixdfti_def = builtins_mod.seed(1).builtins.fixdfti
    let fixdfti_sym: String = "__fixdfti"
    let _ = IntMap_String.insert(mutable map, fixdfti_def.raw as i64, take fixdfti_sym, allocator)?
    let fixsfti_def = builtins_mod.seed(1).builtins.fixsfti
    let fixsfti_sym: String = "__fixsfti"
    let _ = IntMap_String.insert(mutable map, fixsfti_def.raw as i64, take fixsfti_sym, allocator)?
    let fixunsdfti_def = builtins_mod.seed(1).builtins.fixunsdfti
    let fixunsdfti_sym: String = "__fixunsdfti"
    let _ = IntMap_String.insert(mutable map, fixunsdfti_def.raw as i64, take fixunsdfti_sym, allocator)?
    let fixunssfti_def = builtins_mod.seed(1).builtins.fixunssfti
    let fixunssfti_sym: String = "__fixunssfti"
    let _ = IntMap_String.insert(mutable map, fixunssfti_def.raw as i64, take fixunssfti_sym, allocator)?
    let fixwrapdfti_def = builtins_mod.seed(1).builtins.fixwrapdfti
    let fixwrapdfti_sym: String = "__edda_fixwrapdfti"
    let _ = IntMap_String.insert(mutable map, fixwrapdfti_def.raw as i64, take fixwrapdfti_sym, allocator)?
    let fixwrapsfti_def = builtins_mod.seed(1).builtins.fixwrapsfti
    let fixwrapsfti_sym: String = "__edda_fixwrapsfti"
    let _ = IntMap_String.insert(mutable map, fixwrapsfti_def.raw as i64, take fixwrapsfti_sym, allocator)?
}

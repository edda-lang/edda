import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.os.fs
import std.text.string
import std.core.fmt as fmt_mod

import target.triple as triple_mod
import cache.addr.hash as hash_mod
import intern.interner as interner_mod
import types.ty.interner as ty_interner_mod
import source.map as source_map_mod
import span.loc.pos.span as span_mod
import mir.file.store as mir_file_mod
import mir.body.model as body_mod
import hir.def as def_mod
import object.coff.codeview.typetable.table as debug_table_mod
import object.lib as object_mod
import ir.hlir.error as hlir_error_mod
import ir.lir.error as lir_error_mod
import object.coff.wrap.wrap as coff_wrap_mod
import object.sym.coff.multisym as multisym_mod

import diagnostics.emit.collection as diags_mod

import local.phase.emit.link.link as link_phase_mod
import local.phase.emit.codegen.codegen as codegen_mod
import local.phase.emit.write.aggregate as aggregate_mod
import local.phase.emit.write.name as name_mod
import local.member.cache.object as objcache_mod
import local.member.cache.objindex as objindex_mod
import local.member.cache.store.blob as store_mod

public type SeedAnalysis {
    hir_files: Vec_HirFile.Vec
    dep_ast: Vec_File.Vec
    dep_decl_types: Vec_TypeOutput.Vec
    dep_def_base: u32
    dep_fmt: fmt_targets_mod.FmtTargets
    dep_eq_def: def_mod.DefId
    exp: instloop_mod.ExpandResult
    type_outputs: Vec_TypeOutput.Vec
    prims: primitives_mod.PrimitiveDefs
    caps: capabilities_mod.CapabilityDefs
    builtin_registry: cbi_registry_mod.BuiltinRegistry
    eq_pairs: Vec_EqPair.Vec
    debug_pairs: Vec_EqPair.Vec
    coll_eq_pairs: Vec_CollEqPair.Vec
    tmpl: fntable_mod.TemplateTable
    ty_paths: typaths_mod.TyPathMap
}


public type InstanceLowering {
    mir_files: Vec_MirFile.Vec
    type_outputs: Vec_TypeOutput.Vec
    inst_types: Vec_TypeOutput.Vec
}


public type BuildLowering {
    mir_files: Vec_MirFile.Vec
    type_outputs: Vec_TypeOutput.Vec
    inst_types: Vec_TypeOutput.Vec
    stream: depstream_mod.DepStream
}


public function analyze_seed(
    primary_files: take Vec_HirFile.Vec,
    dep_files: take Vec_HirFile.Vec,
    dep_ast: take Vec_File.Vec,
    dep_def_base: u32,
    dep_alloc: Allocator,
    output: take resolve_ctx_mod.ResolveOutput,
    cat: resolve_specsurface_mod.SpecCatalogue,
    triple: triple_mod.TargetTriple,
    check_instances: bool,
    rfs: ReadOnlyFilesystem,
    wfs: Filesystem,
    trace: trace_mod.TraceConfig,
    clock: MonotonicClock,
    errout: Stderr,
    cache_ctx: mutable cachectx_mod.SpecCacheCtx,
    interner: mutable interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    map: mutable source_map_mod.SourceMap,
    allocator: Allocator,
) -> SeedAnalysis
    with {rfs, wfs, clock, errout, dep_alloc, allocator, divergence, err: alloc.AllocError, err: fs.FsError, panic}
{
    validate_mod.check_capabilities(primary_files, triple, interner, mutable diags, allocator)?
    validate_mod.check_capabilities(dep_files, triple, interner, mutable diags, allocator)?

    let prims = resolve_ctx_mod.output_primitives(output)
    let caps = resolve_ctx_mod.output_capabilities(output)
    let comptime_builtins = resolve_ctx_mod.output_comptime_builtins(output)
    let builtin_registry = cbi_registry_mod.new(comptime_builtins)

    uninit scratch: diags_mod.Diagnostics
    diags_mod.new_diagnostics(init scratch, allocator)?

    let primary = primary_files
    let deps = dep_files

    let s_feed = trace_mod.phase_begin(trace, clock, errout, "seed.feed", allocator)?
    let feed = typecheck_feed_mod.typecheck_files_feed(
        primary, deps, triple, prims, caps,
        interner, mutable ty_interner, mutable effect_interner, mutable scratch, allocator,
    )?
    trace_mod.phase_end(s_feed, clock, errout, allocator)?
    let s_elide = trace_mod.phase_begin(trace, clock, errout, "seed.elide", allocator)?
    let elided = unroll_mod.elide_comptime_if_files(
        primary, feed.primary_types, ty_interner, effect_interner,
        builtin_registry, triple, mutable interner, allocator,
    )?
    let primary_hir = elided.files
    let elided_deps = unroll_mod.elide_comptime_if_files(
        deps, feed.dep_decl_types, ty_interner, effect_interner,
        builtin_registry, triple, mutable interner, dep_alloc,
    )?
    let deps_hir = elided_deps.files
    trace_mod.phase_end(s_elide, clock, errout, allocator)?
    let s_cteval = trace_mod.phase_begin(trace, clock, errout, "seed.cteval", allocator)?
    let ct_primary = cteval_phase_mod.evaluate_files(
        primary_hir, feed.primary_types, ty_interner, effect_interner,
        builtin_registry, triple, mutable interner, mutable diags, allocator,
    )?
    let ct_deps = cteval_phase_mod.evaluate_files(
        deps_hir, feed.dep_decl_types, ty_interner, effect_interner,
        builtin_registry, triple, mutable interner, mutable diags, allocator,
    )?
    trace_mod.phase_end(s_cteval, clock, errout, allocator)?
    let s_mono = trace_mod.phase_begin(trace, clock, errout, "seed.mono", allocator)?
    let spec_map = specs_phase_mod.build_spec_map(primary_hir, deps_hir, output.module_tree, interner, allocator)?
    var ty_paths = tybuild_mod.build_ty_paths(primary_hir, feed.primary_types, deps_hir, feed.dep_decl_types, mutable ty_interner, allocator)?
    tybuild_mod.extend_ty_paths_synthetic(mutable ty_paths, output.registry, mutable ty_interner, allocator)?
    var seed = specs_phase_mod.monomorphise_files_with_map(
        primary_hir, ct_primary, output.registry, output.module_tree, spec_map, feed.primary_types, ty_paths, rfs, wfs, mutable cache_ctx,
        mutable interner, ty_interner, effect_interner, mutable diags, mutable map, allocator,
    )?
    var seed_deps = specs_phase_mod.monomorphise_files_with_map(
        deps_hir, ct_deps, output.registry, output.module_tree, spec_map, feed.dep_decl_types, ty_paths, rfs, wfs, mutable cache_ctx,
        mutable interner, ty_interner, effect_interner, mutable diags, mutable map, allocator,
    )?
    append_spec(mutable seed, mutable seed_deps, allocator)?
    trace_mod.phase_end(s_mono, clock, errout, allocator)?
    let s_fninst = trace_mod.phase_begin(trace, clock, errout, "seed.fninst", allocator)?
    var tmpl = fntable_mod.new_table(allocator)?
    fntable_mod.extend(mutable tmpl, deps_hir, output.module_tree, interner, allocator)?
    fnbuild_mod.expand_round(
        primary_hir, feed.primary_types, mutable tmpl, ty_paths, output.registry, output.module_tree,
        mutable interner, ty_interner, mutable map, mutable seed, allocator,
    )?
    trace_mod.phase_end(s_fninst, clock, errout, allocator)?
    let eq_pairs = eqwire_mod.drain_eq_pairs(seed, allocator)?
    let debug_pairs = eqwire_mod.drain_debug_pairs(seed, allocator)?
    let coll_eq_pairs = eqwire_mod.drain_coll_eq_pairs(seed, allocator)?
    let seed_resolve_diag_count = Vec_Diagnostic.len(output.diags.items)
    let s_instloop = trace_mod.phase_begin(trace, clock, errout, "seed.instloop", allocator)?
    let exp = instloop_mod.expand(
        seed, primary_hir, deps_hir, take output, cat, spec_map, triple, prims, caps, builtin_registry,
        mutable tmpl, mutable ty_paths, rfs, wfs, trace, clock, errout, mutable cache_ctx,
        mutable interner, mutable ty_interner, mutable effect_interner, mutable diags, mutable scratch, mutable map, allocator,
    )?
    trace_mod.phase_end_n(s_instloop, clock, errout, Vec_HirFile.len(exp.hir), "instances", allocator)?
    drain_instance_diags(mutable diags, exp.output.diags.items, seed_resolve_diag_count, allocator)?
    if check_instances {
        let s_tc_inst = trace_mod.phase_begin(trace, clock, errout, "seed.tc-inst", allocator)?
        let _ = typecheck_mod.typecheck_files(
            exp.hir, deps_hir, primary_hir, triple, prims, caps, exp.nominals,
            false, exp.output,
            interner, mutable ty_interner, mutable effect_interner, mutable diags, allocator,
        )?
        trace_mod.phase_end(s_tc_inst, clock, errout, allocator)?
    }
    let s_tc_primary = trace_mod.phase_begin(trace, clock, errout, "seed.tc-primary", allocator)?
    let type_outputs = typecheck_mod.typecheck_files_with_nominals(
        primary_hir, deps_hir, exp.hir, triple, prims, caps, feed.nominals, exp.nominals,
        true, exp.output,
        interner, mutable ty_interner, mutable effect_interner, mutable diags, allocator,
    )?
    trace_mod.phase_end(s_tc_primary, clock, errout, allocator)?
    unaligned_mod.check_unaligned_field_access_files(primary_hir, type_outputs, ty_interner, triple, mutable diags, allocator)?
    var dep_fmt = fmt_targets_mod.none_targets(allocator)?
    fmt_targets_mod.extend_fmt_targets(mutable dep_fmt, deps_hir, interner)
    let dep_eq_def = stringeq_mod.find_string_eq_def(deps_hir, mutable interner, allocator)?
    return SeedAnalysis {
        hir_files: take primary_hir,
        dep_ast: take dep_ast,
        dep_decl_types: take feed.dep_decl_types,
        dep_def_base: dep_def_base,
        dep_fmt: take dep_fmt,
        dep_eq_def: dep_eq_def,
        exp: take exp,
        type_outputs: take type_outputs,
        prims: prims,
        caps: caps,
        builtin_registry: builtin_registry,
        eq_pairs: take eq_pairs,
        debug_pairs: take debug_pairs,
        coll_eq_pairs: take coll_eq_pairs,
        tmpl: take tmpl,
        ty_paths: ty_paths,
    }
}


public function lower_instances(
    analysis: take SeedAnalysis,
    triple: triple_mod.TargetTriple,
    interner: mutable interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> InstanceLowering
    with {allocator, divergence, err: alloc.AllocError, panic}
{
    let seed_hir = analysis.hir_files
    let exp = analysis.exp
    let type_outputs = analysis.type_outputs
    let builtin_registry = analysis.builtin_registry

    let seed_body_cteval_only = cteval_phase_mod.evaluate_files_bodies(
        seed_hir, type_outputs, ty_interner, effect_interner,
        builtin_registry, triple, mutable interner, true, mutable diags, allocator,
    )?
    let bridge_map = mir_bridge_mod.build_bridge_map(seed_hir, interner, allocator)?
    let extern_defs = mir_bridge_mod.build_extern_defs_map(seed_hir, allocator)?
    let box_elem_ty_map = mir_bridge_mod.build_box_elem_ty_map(seed_hir, type_outputs, interner, allocator)?
    var fmt_targets = fmt_targets_mod.build_fmt_targets(seed_hir, interner, allocator)?
    fmt_targets_mod.extend_fmt_targets(mutable fmt_targets, exp.hir, interner)
    fmt_targets_mod.merge_fmt_targets(mutable fmt_targets, analysis.dep_fmt)
    var eq_targets = eqwire_mod.build_eq_targets(analysis.eq_pairs, exp.hir, mutable interner, mutable ty_interner, allocator)?
    stringeq_mod.add_string_eq_target(mutable eq_targets, seed_hir, mutable interner, mutable ty_interner, allocator)?
    stringeq_mod.add_string_eq_target_def(mutable eq_targets, analysis.dep_eq_def, mutable ty_interner, allocator)?
    let debug_targets = eqwire_mod.build_debug_targets(analysis.debug_pairs, exp.hir, mutable interner, mutable ty_interner, allocator)?
    fmt_targets_mod.set_debug_targets(mutable fmt_targets, take debug_targets)
    var layout_cache = mir_layout_mod.new_cache(allocator)?
    var primary_mir = mir_phase_mod.lower_to_mir(take seed_hir, type_outputs, seed_body_cteval_only, mutable ty_interner, effect_interner, triple, true, interner, bridge_map, extern_defs, box_elem_ty_map, fmt_targets, eq_targets, mutable layout_cache, mutable diags, allocator, allocator)?
    mir_phase_mod.finalize_agg_layouts(mutable primary_mir, layout_cache.table)
    uninit empty_inst_types: Vec_TypeOutput.Vec
    Vec_TypeOutput.new(init empty_inst_types, allocator)?
    return InstanceLowering {
        mir_files: take primary_mir,
        type_outputs: take type_outputs,
        inst_types: take empty_inst_types,
    }
}


public function lower_instances_build(
    analysis: take SeedAnalysis,
    triple: triple_mod.TargetTriple,
    trace: trace_mod.TraceConfig,
    clock: MonotonicClock,
    errout: Stderr,
    interner: mutable interner_mod.Interner,
    ty_interner: mutable ty_interner_mod.Interner,
    effect_interner: mutable effect_interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> BuildLowering
    with {clock, errout, allocator, divergence, err: alloc.AllocError, panic}
{
    let seed_hir = analysis.hir_files
    let exp = analysis.exp
    var type_outputs = analysis.type_outputs
    let prims = analysis.prims
    let caps = analysis.caps
    let builtin_registry = analysis.builtin_registry
    let dep_ast_pass2 = depjit_mod.copy_ast_files(analysis.dep_ast, allocator)?

        let s_jit = trace_mod.phase_begin(trace, clock, errout, "mir.jit-dep", allocator)?
        let dep_scratch = alloc.fork(allocator)
        let dep_ast_files = analysis.dep_ast
        let dep_hir = depjit_mod.relower_dep_hir(
            take dep_ast_files, exp.output, analysis.dep_def_base, analysis.dep_decl_types,
            ty_interner, effect_interner, builtin_registry, triple,
            mutable interner, allocator, dep_scratch,
        )?
        trace_mod.phase_end_n(s_jit, clock, errout, Vec_HirFile.len(dep_hir), "files", allocator)?

        let s_proj = trace_mod.phase_begin(trace, clock, errout, "mir.decl-proj", allocator)?
        let seed_decl = project_to_decl(seed_hir, dep_scratch)?
        let dep_decl = project_to_decl(dep_hir, dep_scratch)?
        let exp_decl = project_to_decl(exp.hir, dep_scratch)?
        trace_mod.phase_end(s_proj, clock, errout, allocator)?

        let s_tc_inst = trace_mod.phase_begin(trace, clock, errout, "mir.tc-inst", allocator)?
        var inst_types = typecheck_fully_lean_mod.typecheck_files_fully_lean(
            exp.hir, dep_decl, seed_decl, triple, prims, caps, exp.nominals,
            false, exp.output,
            interner, mutable ty_interner, mutable effect_interner, mutable diags, allocator,
        )?
        trace_mod.phase_end_n(s_tc_inst, clock, errout, Vec_HirFile.len(exp.hir), "files", allocator)?

        let s_tc_dep = trace_mod.phase_begin(trace, clock, errout, "mir.tc-dep", allocator)?
        var dep_types = typecheck_fully_lean_mod.typecheck_files_fully_lean(
            dep_hir, seed_decl, exp_decl, triple, prims, caps, exp.nominals,
            true, exp.output,
            interner, mutable ty_interner, mutable effect_interner, mutable diags, allocator,
        )?
        trace_mod.phase_end_n(s_tc_dep, clock, errout, Vec_HirFile.len(dep_hir), "files", allocator)?

        let inst_fn_index = fnredirect_mod.build_instance_fn_index(exp.hir, allocator)?
        fnredirect_mod.apply(
            seed_hir, mutable type_outputs, analysis.tmpl, inst_fn_index,
            analysis.ty_paths, ty_interner, mutable interner, allocator,
        )?
        fnredirect_mod.apply(
            exp.hir, mutable inst_types, analysis.tmpl, inst_fn_index,
            analysis.ty_paths, ty_interner, mutable interner, allocator,
        )?
        fnredirect_mod.apply(
            dep_hir, mutable dep_types, analysis.tmpl, inst_fn_index,
            analysis.ty_paths, ty_interner, mutable interner, allocator,
        )?

        let s_prep = trace_mod.phase_begin(trace, clock, errout, "mir.prep", allocator)?
        let seed_body_cteval = cteval_phase_mod.evaluate_files_bodies(
            seed_hir, type_outputs, ty_interner, effect_interner,
            builtin_registry, triple, mutable interner, true, mutable diags, allocator,
        )?
        var bridge_map = mir_bridge_mod.build_bridge_map(seed_hir, interner, allocator)?
        mir_bridge_mod.extend_bridge_map(mutable bridge_map, exp.hir, interner, allocator)?
        mir_bridge_mod.extend_bridge_map(mutable bridge_map, dep_hir, interner, allocator)?
        var extern_defs = mir_bridge_mod.build_extern_defs_map(seed_hir, allocator)?
        mir_bridge_mod.extend_extern_defs_map(mutable extern_defs, exp.hir, allocator)?
        mir_bridge_mod.extend_extern_defs_map(mutable extern_defs, dep_hir, allocator)?
        var box_elem_ty_map = mir_bridge_mod.build_box_elem_ty_map(seed_hir, type_outputs, interner, allocator)?
        mir_bridge_mod.extend_box_elem_ty_map(mutable box_elem_ty_map, exp.hir, inst_types, interner, allocator)?
        mir_bridge_mod.extend_box_elem_ty_map(mutable box_elem_ty_map, dep_hir, dep_types, interner, allocator)?
        var fmt_targets = fmt_targets_mod.build_fmt_targets(seed_hir, interner, allocator)?
        fmt_targets_mod.extend_fmt_targets(mutable fmt_targets, exp.hir, interner)
        fmt_targets_mod.merge_fmt_targets(mutable fmt_targets, analysis.dep_fmt)
        var eq_targets = eqwire_mod.build_eq_targets(analysis.eq_pairs, exp.hir, mutable interner, mutable ty_interner, allocator)?
        eqwire_mod.add_collection_eq_targets(mutable eq_targets, analysis.coll_eq_pairs, exp.hir, inst_types, mutable interner, mutable ty_interner, allocator)?
        stringeq_mod.add_string_eq_target(mutable eq_targets, seed_hir, mutable interner, mutable ty_interner, allocator)?
        stringeq_mod.add_string_eq_target_def(mutable eq_targets, analysis.dep_eq_def, mutable ty_interner, allocator)?
        let debug_targets = eqwire_mod.build_debug_targets(analysis.debug_pairs, exp.hir, mutable interner, mutable ty_interner, allocator)?
        fmt_targets_mod.set_debug_targets(mutable fmt_targets, take debug_targets)
        var layout_cache = mir_layout_mod.new_cache(allocator)?
        trace_mod.phase_end(s_prep, clock, errout, allocator)?

        let s_ct_dep = trace_mod.phase_begin(trace, clock, errout, "mir.cteval-dep", allocator)?
        uninit pass1_diags: diags_mod.Diagnostics
        diags_mod.new_diagnostics(init pass1_diags, allocator)?
        let dep_body_cteval = cteval_phase_mod.evaluate_files_bodies(
            dep_hir, dep_types, ty_interner, effect_interner,
            builtin_registry, triple, mutable interner, true, mutable pass1_diags, allocator,
        )?
        trace_mod.phase_end(s_ct_dep, clock, errout, allocator)?
        let s_low_dep = trace_mod.phase_begin(trace, clock, errout, "mir.lower-dep", allocator)?
        let dep_mir_fork = alloc.fork(allocator)
        let dep_mir = mir_phase_mod.lower_to_mir(take dep_hir, dep_types, dep_body_cteval, mutable ty_interner, effect_interner, triple, true, interner, bridge_map, extern_defs, box_elem_ty_map, fmt_targets, eq_targets, mutable layout_cache, mutable pass1_diags, allocator, dep_mir_fork)?
        let dep_refs = reach_mod.collect_file_refs(dep_mir, interner, allocator)?
        alloc.close(take dep_mir_fork)
        alloc.close(take dep_scratch)
        trace_mod.phase_end(s_low_dep, clock, errout, allocator)?

        let s_seed = trace_mod.phase_begin(trace, clock, errout, "mir.lower-seed", allocator)?
        var mir_files = mir_phase_mod.lower_to_mir(take seed_hir, type_outputs, seed_body_cteval, mutable ty_interner, effect_interner, triple, true, interner, bridge_map, extern_defs, box_elem_ty_map, fmt_targets, eq_targets, mutable layout_cache, mutable diags, allocator, allocator)?
        trace_mod.phase_end(s_seed, clock, errout, allocator)?

        let s_ct_inst = trace_mod.phase_begin(trace, clock, errout, "mir.cteval-inst", allocator)?
        let inst_body_cteval = cteval_phase_mod.evaluate_files_bodies(
            exp.hir, inst_types, ty_interner, effect_interner,
            builtin_registry, triple, mutable interner, false, mutable diags, allocator,
        )?
        trace_mod.phase_end(s_ct_inst, clock, errout, allocator)?
        let s_low_inst = trace_mod.phase_begin(trace, clock, errout, "mir.lower-inst", allocator)?
        var inst_mir = mir_phase_mod.lower_to_mir(take exp.hir, inst_types, inst_body_cteval, mutable ty_interner, effect_interner, triple, false, interner, bridge_map, extern_defs, box_elem_ty_map, fmt_targets, eq_targets, mutable layout_cache, mutable diags, allocator, allocator)?
        trace_mod.phase_end(s_low_inst, clock, errout, allocator)?

        append_mir(mutable mir_files, mutable inst_mir, allocator)?
        mir_phase_mod.finalize_agg_layouts(mutable mir_files, layout_cache.table)
        let dep_types_stream = copy_type_outputs(dep_types, allocator)?
        append_type_outputs(mutable type_outputs, mutable inst_types, allocator)?
        append_type_outputs(mutable type_outputs, mutable dep_types, allocator)?
        let stream = depstream_mod.DepStream {
            dep_ast: take dep_ast_pass2,
            dep_refs: take dep_refs,
            dep_types: take dep_types_stream,
            dep_decl_types: analysis.dep_decl_types,
            dep_def_base: analysis.dep_def_base,
            output: exp.output,
            builtin_registry: builtin_registry,
            bridge_map: take bridge_map,
            extern_defs: take extern_defs,
            box_elem_ty_map: take box_elem_ty_map,
            fmt_targets: take fmt_targets,
            eq_targets: take eq_targets,
            layout_cache: take layout_cache,
        }
        return BuildLowering {
            mir_files: take mir_files,
            type_outputs: take type_outputs,
            inst_types: take inst_types,
            stream: take stream,
        }
}


function project_to_decl(
    files: Vec_HirFile.Vec,
    allocator: Allocator,
) -> Vec_HirFileDecl.Vec
    with {allocator, divergence, err: alloc.AllocError}
{
    uninit out: Vec_HirFileDecl.Vec
    Vec_HirFileDecl.new(init out, allocator)?
    let n = Vec_HirFile.len(files)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let f = Vec_HirFile.at(files, i)
        let decl = hir_file_mod.to_decl_file(f, allocator)?
        Vec_HirFileDecl.push(mutable out, take decl, allocator)?
        i = i + 1
    }
    return out
}


function append_mir(
    all_mir: mutable Vec_MirFile.Vec,
    batch: mutable Vec_MirFile.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, divergence, err: alloc.AllocError}
{
    let n = Vec_MirFile.len(batch)
    var i: usize = 0
    loop decreases (n - i + 1) as usize {
        if i >= n { break }
        let m = Vec_MirFile.at(batch, i)
        Vec_MirFile.push(mutable all_mir, take m, allocator)?
        i = i + 1 as usize
    }
    Vec_MirFile.clear(mutable batch)
}



public type AstPartition {
    primary: Vec_File.Vec
    deps: Vec_File.Vec
}


function copy_type_outputs(
    batch: Vec_TypeOutput.Vec,
    allocator: Allocator,
) -> Vec_TypeOutput.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit out: Vec_TypeOutput.Vec
    Vec_TypeOutput.new(init out, allocator)?
    let n = Vec_TypeOutput.len(batch)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        Vec_TypeOutput.push(mutable out, Vec_TypeOutput.at(batch, i), allocator)?
        i = i + 1 as usize
    }
    return out
}


public function partition_files(
    all: mutable Vec_File.Vec,
    primary_member: Option_String.Option,
    interner: mutable interner_mod.Interner,
    allocator: Allocator,
) -> AstPartition
    with {allocator, divergence, err: alloc.AllocError}
{
    uninit primary: Vec_File.Vec
    Vec_File.new(init primary, allocator)?
    uninit deps: Vec_File.Vec
    Vec_File.new(init deps, allocator)?
    var has_primary = false
    var root_sym = sym_mod.empty()
    match primary_member {
        case .none => ()
        case .some(let name) => {
            has_primary = true
            root_sym = interner_mod.intern(mutable interner, name, allocator)?
        }
    }
    let n = Vec_File.len(all)
    var i: usize = 0
    loop decreases (n - i + 1) as usize {
        if i >= n { break }
        let f = Vec_File.at(all, i)
        if has_primary {
            let froot = module_root_of(f)
            if froot.raw == root_sym.raw {
                Vec_File.push(mutable primary, take f, allocator)?
            } else {
                Vec_File.push(mutable deps, take f, allocator)?
            }
        } else {
            Vec_File.push(mutable primary, take f, allocator)?
        }
        i = i + 1 as usize
    }
    Vec_File.clear(mutable all)
    return AstPartition { primary: take primary, deps: take deps }
}


function module_root_of(file: ast_file_mod.File) -> sym_mod.Symbol {
    let n = Vec_Item.len(file.items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        match Vec_Item.at(file.items, i).kind {
            case .module_(let decl) => {
                let segs = decl.path.segments
                let sn = Vec_Ident.len(segs)
                if sn == 0 { return sym_mod.empty() }
                return Vec_Ident.at(segs, 0 as usize).name
            }
            case _ => ()
        }
        i = i + 1
    }
    return sym_mod.empty()
}


function drain_instance_diags(
    diags: mutable diags_mod.Diagnostics,
    source: Vec_Diagnostic.Vec,
    start: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_Diagnostic.len(source)
    var i: usize = start
    loop decreases (n - i) {
        if i >= n { break }
        let d = Vec_Diagnostic.at(source, i)
        diags_mod.emit(mutable diags, take d, allocator)?
        i = i + 1
    }
}

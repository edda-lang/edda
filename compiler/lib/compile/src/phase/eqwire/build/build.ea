
module compile.phase.eqwire.build.build

import std.collections.hashmap
import std.collections.vec
import std.core.option
import std.mem.alloc
import hir.build.file as hir_file_mod
import hir.def as def_mod
import hir.item as hir_item_mod
import intern.interner as interner_mod
import intern.symbol as sym_mod
import mir.lower.eqmap.targets as eqmap_mod
import specs.gen.build.output as spec_output_mod
import syntax.ast.ident as ast_ident_mod
import types.pass.ty as ty_mod
import types.pass.effect as effect_pass_mod
import types.ty.interner as ty_interner_mod
import types.ty.kind as ty_kind_mod
import types.check as types_check_mod


spec std.mem.alloc.Box(hir_item_mod.HFnSignature)

spec std.collections.vec.Vec(hir_file_mod.HirFile)
spec std.collections.vec.Vec(hir_item_mod.HItem)
spec std.collections.vec.Vec(hir_item_mod.HParam)
spec std.collections.vec.Vec(spec_output_mod.SpecOutput)
spec std.collections.vec.Vec(spec_output_mod.EqPair)
spec std.collections.vec.Vec(spec_output_mod.CollEqPair)
spec std.collections.vec.Vec(types_check_mod.TypeOutput)
spec std.collections.vec.Vec(ast_ident_mod.Ident)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(u32)

spec std.collections.hashmap.IntMap(Vec_u32)
spec std.core.option.Option(Vec_u32)
spec std.core.option.Option(ty_mod.TyId)


public function drain_eq_pairs(
    outs: Vec_SpecOutput.Vec,
    allocator: Allocator,
) -> Vec_EqPair.Vec
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit pairs: Vec_EqPair.Vec
    Vec_EqPair.new(init pairs, allocator)?
    let n = Vec_SpecOutput.len(outs)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let out = Vec_SpecOutput.at(outs, i)
        let pn = Vec_EqPair.len(out.eq_pairs)
        var pi: usize = 0
        loop decreases (pn - pi) {
            if pi >= pn { break }
            Vec_EqPair.push(mutable pairs, Vec_EqPair.at(out.eq_pairs, pi), allocator)?
            pi = pi + 1
        }
        i = i + 1
    }
    return pairs
}



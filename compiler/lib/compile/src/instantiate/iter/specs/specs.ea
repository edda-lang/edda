
module compile.instantiate.iter.specs.specs

import std.mem.alloc
import std.collections.vec
import std.os.fs
import cteval.res.output as cteval_output_mod
import diagnostics.emit.collection as diags_mod
import hir.build.file as hir_file_mod
import intern.interner as sym_interner_mod
import resolve.paths.modules as mt_mod
import resolve.build.drive.surface.registry as registry_mod
import source.map as source_map_mod
import specs.error as spec_error_mod
import specs.gen.typaths as typaths_mod
import specs.gen.monomorphise.monomorphise as specs_mono_mod
import specs.gen.build.output as spec_output_mod
import specs.specdefs as specdefs_mod
import specs.cachectx as cachectx_mod
import types.check as types_check_mod
import types.effect.interner as row_interner_mod
import types.ty.interner as ty_interner_mod


spec std.collections.vec.Vec(hir_file_mod.HirFile)
spec std.collections.vec.Vec(cteval_output_mod.ComptimeOutput)
spec std.collections.vec.Vec(spec_output_mod.SpecOutput)
spec std.collections.vec.Vec(spec_error_mod.SpecError)
spec std.collections.vec.Vec(types_check_mod.TypeOutput)


public function build_spec_map(
    hir_files: Vec_HirFile.Vec,
    dep_files: Vec_HirFile.Vec,
    mt: mt_mod.ModuleTree,
    interner: sym_interner_mod.Interner,
    allocator: Allocator,
) -> specdefs_mod.SpecDefMap
    with {allocator, divergence, err: alloc.AllocError}
{
    return specdefs_mod.collect_all_pair(hir_files, dep_files, mt, interner, allocator)?
}


public function monomorphise_files(
    hir_files: Vec_HirFile.Vec,
    cteval_outputs: Vec_ComptimeOutput.Vec,
    registry: registry_mod.Registry,
    mt: mt_mod.ModuleTree,
    type_outputs: Vec_TypeOutput.Vec,
    ty_paths: typaths_mod.TyPathMap,
    rfs: ReadOnlyFilesystem,
    wfs: Filesystem,
    cache_ctx: mutable cachectx_mod.SpecCacheCtx,
    sym_interner: mutable sym_interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    row_interner: row_interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    map: mutable source_map_mod.SourceMap,
    allocator: Allocator,
) -> Vec_SpecOutput.Vec
    with {rfs, wfs, allocator, divergence, err: alloc.AllocError, err: fs.FsError}
{
    let spec_map = specdefs_mod.collect_all(hir_files, mt, sym_interner, allocator)?
    return monomorphise_files_with_map(
        hir_files, cteval_outputs, registry, mt, spec_map, type_outputs, ty_paths, rfs, wfs, mutable cache_ctx,
        mutable sym_interner, ty_interner, row_interner, mutable diags, mutable map, allocator,
    )?
}


public function monomorphise_files_with_map(
    hir_files: Vec_HirFile.Vec,
    cteval_outputs: Vec_ComptimeOutput.Vec,
    registry: registry_mod.Registry,
    mt: mt_mod.ModuleTree,
    spec_map: specdefs_mod.SpecDefMap,
    type_outputs: Vec_TypeOutput.Vec,
    ty_paths: typaths_mod.TyPathMap,
    rfs: ReadOnlyFilesystem,
    wfs: Filesystem,
    cache_ctx: mutable cachectx_mod.SpecCacheCtx,
    sym_interner: mutable sym_interner_mod.Interner,
    ty_interner: ty_interner_mod.Interner,
    row_interner: row_interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    map: mutable source_map_mod.SourceMap,
    allocator: Allocator,
) -> Vec_SpecOutput.Vec
    with {rfs, wfs, allocator, divergence, err: alloc.AllocError, err: fs.FsError}
{
    uninit results: Vec_SpecOutput.Vec
    Vec_SpecOutput.new(init results, allocator)?
    let n = Vec_HirFile.len(hir_files)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let hir = Vec_HirFile.at(hir_files, i)
        let cteval_out = Vec_ComptimeOutput.at(cteval_outputs, i)
        let types_out = Vec_TypeOutput.at(type_outputs, i)
        let spec_out = specs_mono_mod.monomorphise_file(
            hir, cteval_out, registry, mt, spec_map, types_out, ty_paths, rfs, wfs, mutable cache_ctx,
            mutable sym_interner, ty_interner, row_interner,
            mutable map, allocator,
        )?
        emit_failures(mutable diags, spec_out, allocator)?
        Vec_SpecOutput.push(mutable results, take spec_out, allocator)?
        i = i + 1
    }
    return results
}


function emit_failures(
    diags: mutable diags_mod.Diagnostics,
    output: spec_output_mod.SpecOutput,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_SpecError.len(output.failures)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let e = Vec_SpecError.at(output.failures, i)
        let d = spec_error_mod.to_diagnostic(e, allocator)?
        diags_mod.emit(mutable diags, take d, allocator)?
        i = i + 1
    }
}

module compile.instantiate.fninst.discover.discover

import std.collections.vec
import std.core.option
import std.mem.alloc
import hir.build.file as hir_file_mod
import hir.item as hir_item_mod
import hir.tree as hir_tree
import intern.symbol as sym_mod
import local.instantiate.fninst.typearg.typearg as typearg_mod
import syntax.ast.ident as ast_ident_mod
import syntax.ast.item as ast_item_mod
import syntax.ast.tree as ast_tree_mod
import types.check as check_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import local.instantiate.fninst.table.table as table_mod


spec std.core.option.Option(u32)
spec std.mem.alloc.Box(hir_item_mod.HFnSignature)
spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_tree.HClosure)
spec std.mem.alloc.Box(hir_tree.HSpawn)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_file_mod.HirFile)
spec std.collections.vec.Vec(hir_item_mod.HItem)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HExpr)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HSpawnArg)
spec std.collections.vec.Vec(ast_item_mod.GenericParam)
spec std.collections.vec.Vec(ast_tree_mod.Param)
spec std.collections.vec.Vec(ast_ident_mod.Ident)
spec std.collections.vec.Vec(sym_mod.Symbol)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.core.option.Option(ty_mod.TyId)
spec std.core.option.Option(Vec_TyId)
spec std.collections.vec.Vec(TemplateCall)
spec std.collections.vec.Vec(table_mod.TemplateEntry)


public type TemplateCall {
    node_raw: u32
    entry_idx: u32
    bound: Vec_TyId.Vec
}


public function collect_calls(
    file: hir_file_mod.HirFile,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> Vec_TemplateCall.Vec
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit out: Vec_TemplateCall.Vec
    Vec_TemplateCall.new(init out, allocator)?
    var i: usize = 0
    loop
        decreases Vec_HItem.len(file.items) - i
    {
        if i >= Vec_HItem.len(file.items) { break }
        let item = Vec_HItem.at(file.items, i)
        match item.kind {
            case .function_(let sig_box, let body) => {
                let sig = Box_HFnSignature.get(sig_box)
                if Vec_GenericParam.len(sig.outbound_generics) == 0
                    && Vec_GenericParam.len(sig.generics) == 0 {
                    walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
                }
            }
            case .let_decl(_, _, let init_) => {
                walk_expr(init_, types_out, t, ty_interner, mutable out, allocator)?
            }
            case _ => ()
        }
        i += 1
    }
    return out
}


function walk_block(
    b: hir_tree.HBlock,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    var i: usize = 0
    loop
        decreases Vec_HStmt.len(b.stmts) - i
    {
        if i >= Vec_HStmt.len(b.stmts) { break }
        walk_stmt(Vec_HStmt.at(b.stmts, i), types_out, t, ty_interner, mutable out, allocator)?
        i += 1
    }
    match b.trailing {
        case .some(let e) => walk_expr(Box_HExpr.get(e), types_out, t, ty_interner, mutable out, allocator)?
        case .none => ()
    }
}


function walk_stmt(
    s: hir_tree.HStmt,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match s.kind {
        case .let_(_, _, _, _, let init_) => walk_expr(init_, types_out, t, ty_interner, mutable out, allocator)?
        case .uninit_(_, _, _) => ()
        case .assign(let target, _, let rhs) => {
            walk_expr(target, types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(rhs, types_out, t, ty_interner, mutable out, allocator)?
        }
    }
}


function walk_args(
    args: Vec_HArg.Vec,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    var i: usize = 0
    loop
        decreases Vec_HArg.len(args) - i
    {
        if i >= Vec_HArg.len(args) { break }
        walk_expr(Vec_HArg.at(args, i).expr, types_out, t, ty_interner, mutable out, allocator)?
        i += 1
    }
}


function walk_arms(
    arms: Vec_HArm.Vec,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    var i: usize = 0
    loop
        decreases Vec_HArm.len(arms) - i
    {
        if i >= Vec_HArm.len(arms) { break }
        let arm = Vec_HArm.at(arms, i)
        match arm.guard {
            case .some(let g) => walk_expr(g, types_out, t, ty_interner, mutable out, allocator)?
            case .none => ()
        }
        walk_expr(arm.body, types_out, t, ty_interner, mutable out, allocator)?
        i += 1
    }
}


function walk_opt_box(
    opt: Option_Box_HExpr.Option,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match opt {
        case .some(let b) => walk_expr(Box_HExpr.get(b), types_out, t, ty_interner, mutable out, allocator)?
        case .none => ()
    }
}


function walk_expr(
    e: hir_tree.HExpr,
    types_out: check_mod.TypeOutput,
    t: table_mod.TemplateTable,
    ty_interner: ty_interner_mod.Interner,
    out: mutable Vec_TemplateCall.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match e.kind {
        case .binary(_, let lhs, let rhs) => {
            walk_expr(Box_HExpr.get(lhs), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(rhs), types_out, t, ty_interner, mutable out, allocator)?
        }
        case .unary(_, let inner) => walk_expr(Box_HExpr.get(inner), types_out, t, ty_interner, mutable out, allocator)?
        case .call(let callee, let args) => {
            walk_args(args, types_out, t, ty_interner, mutable out, allocator)?
            match table_mod.lookup(t, callee) {
                case .some(let idx) => {
                    let entry = Vec_TemplateEntry.at(t.entries, idx as usize)
                    match bind_call(entry, args, types_out, ty_interner, allocator)? {
                        case .some(let bound) => {
                            Vec_TemplateCall.push(mutable out, TemplateCall {
                                node_raw: e.node_id.raw,
                                entry_idx: idx,
                                bound: bound,
                            }, allocator)?
                        }
                        case .none => ()
                    }
                }
                case .none => ()
            }
        }
        case .variant_ctor(_, _, let args) => walk_args(args, types_out, t, ty_interner, mutable out, allocator)?
        case .dyn_call(let callee, let args) => {
            walk_expr(Box_HExpr.get(callee), types_out, t, ty_interner, mutable out, allocator)?
            walk_args(args, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .method_call(_, let args) => walk_args(args, types_out, t, ty_interner, mutable out, allocator)?
        case .field(let recv, _) => walk_expr(Box_HExpr.get(recv), types_out, t, ty_interner, mutable out, allocator)?
        case .positional(let recv, let idx) => {
            walk_expr(Box_HExpr.get(recv), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(idx), types_out, t, ty_interner, mutable out, allocator)?
        }
        case .index(let recv, let idx) => {
            walk_expr(Box_HExpr.get(recv), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(idx), types_out, t, ty_interner, mutable out, allocator)?
        }
        case .subrange(let recv, let lo, let hi, _) => {
            walk_expr(Box_HExpr.get(recv), types_out, t, ty_interner, mutable out, allocator)?
            walk_opt_box(lo, types_out, t, ty_interner, mutable out, allocator)?
            walk_opt_box(hi, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .range(let lo, let hi, _) => {
            walk_expr(Box_HExpr.get(lo), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(hi), types_out, t, ty_interner, mutable out, allocator)?
        }
        case .if_(let cond, let then_block, let else_block) => {
            walk_expr(Box_HExpr.get(cond), types_out, t, ty_interner, mutable out, allocator)?
            walk_block(then_block, types_out, t, ty_interner, mutable out, allocator)?
            match else_block {
                case .some(let eb) => walk_block(eb, types_out, t, ty_interner, mutable out, allocator)?
                case .none => ()
            }
        }
        case .match_(let scrutinee, let arms) => {
            walk_expr(Box_HExpr.get(scrutinee), types_out, t, ty_interner, mutable out, allocator)?
            walk_arms(arms, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .block_(let body) => walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
        case .loop_(let body, _, let dec) => {
            walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
            walk_opt_box(dec, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .cast(let inner, _, _) => walk_expr(Box_HExpr.get(inner), types_out, t, ty_interner, mutable out, allocator)?
        case .tuple(let elements) => {
            var i: usize = 0
            loop
                decreases Vec_HExpr.len(elements) - i
            {
                if i >= Vec_HExpr.len(elements) { break }
                walk_expr(Vec_HExpr.at(elements, i), types_out, t, ty_interner, mutable out, allocator)?
                i += 1
            }
        }
        case .struct_lit(_, let fields) => walk_args(fields, types_out, t, ty_interner, mutable out, allocator)?
        case .raise_(let inner) => walk_expr(Box_HExpr.get(inner), types_out, t, ty_interner, mutable out, allocator)?
        case .panic_(let inner) => walk_expr(Box_HExpr.get(inner), types_out, t, ty_interner, mutable out, allocator)?
        case .return_(let value) => walk_opt_box(value, types_out, t, ty_interner, mutable out, allocator)?
        case .break_(_, let value) => walk_opt_box(value, types_out, t, ty_interner, mutable out, allocator)?
        case .comptime_(let inner) => walk_expr(Box_HExpr.get(inner), types_out, t, ty_interner, mutable out, allocator)?
        case .comptime_block(let body) => walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
        case .comptime_for(_, let lo, let hi, _, let body) => {
            walk_expr(Box_HExpr.get(lo), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(hi), types_out, t, ty_interner, mutable out, allocator)?
            walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .scope_(_, _, let body) => walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
        case .handle_(_, _, let recovery, let body) => {
            walk_expr(Box_HExpr.get(recovery), types_out, t, ty_interner, mutable out, allocator)?
            walk_block(body, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .closure(let c) => walk_block(Box_HClosure.get(c).body, types_out, t, ty_interner, mutable out, allocator)?
        case .spawn_(let sp) => {
            let spawn = Box_HSpawn.get(sp)
            var i: usize = 0
            loop
                decreases Vec_HSpawnArg.len(spawn.args) - i
            {
                if i >= Vec_HSpawnArg.len(spawn.args) { break }
                walk_expr(Vec_HSpawnArg.at(spawn.args, i).init_, types_out, t, ty_interner, mutable out, allocator)?
                i += 1
            }
            walk_block(spawn.body, types_out, t, ty_interner, mutable out, allocator)?
        }
        case .forall_(_, let iter, let body) => {
            walk_expr(Box_HExpr.get(iter), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(body), types_out, t, ty_interner, mutable out, allocator)?
        }
        case .exists_(_, let iter, let body) => {
            walk_expr(Box_HExpr.get(iter), types_out, t, ty_interner, mutable out, allocator)?
            walk_expr(Box_HExpr.get(body), types_out, t, ty_interner, mutable out, allocator)?
        }
        case _ => ()
    }
}


function param_index_for(params: Vec_Param.Vec, gname: sym_mod.Symbol) -> usize
    with {divergence}
{
    var j: usize = 0
    loop
        decreases Vec_Param.len(params) - j
    {
        if j >= Vec_Param.len(params) { break }
        let p = Vec_Param.at(params, j)
        match p.ty.kind {
            case .path(let pp) => {
                if Vec_Ident.len(pp.segments) == 1 {
                    if Vec_Ident.at(pp.segments, 0 as usize).name.raw == gname.raw {
                        return j
                    }
                }
            }
            case _ => ()
        }
        j += 1
    }
    return Vec_Param.len(params)
}


function returns_generic(decl: ast_item_mod.FnDecl) -> bool
    with {divergence}
{
    match decl.return_ty {
        case .some(let rt) => {
            match rt.kind {
                case .path(let pp) => {
                    if Vec_Ident.len(pp.segments) != 1 { return false }
                    let head = Vec_Ident.at(pp.segments, 0 as usize).name
                    var k: usize = 0
                    loop
                        decreases Vec_GenericParam.len(decl.outbound_generics) - k
                    {
                        if k >= Vec_GenericParam.len(decl.outbound_generics) { break }
                        if Vec_GenericParam.at(decl.outbound_generics, k).name.name.raw == head.raw {
                            return true
                        }
                        k += 1
                    }
                    return false
                }
                case _ => return false
            }
        }
        case .none => return false
    }
}


public function bind_call(
    entry: table_mod.TemplateEntry,
    args: Vec_HArg.Vec,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> Option_Vec_TyId.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    let n_inline = Vec_GenericParam.len(entry.decl.generics)
    if Vec_Param.len(entry.decl.params) + n_inline != Vec_HArg.len(args) {
        return Option_Vec_TyId.none
    }
    if Vec_GenericParam.len(entry.decl.outbound_generics) > 0 && returns_generic(entry.decl) {
        return Option_Vec_TyId.none
    }
    uninit bound: Vec_TyId.Vec
    Vec_TyId.new(init bound, allocator)?
    var k: usize = 0
    loop
        decreases Vec_GenericParam.len(entry.decl.outbound_generics) - k
    {
        if k >= Vec_GenericParam.len(entry.decl.outbound_generics) { break }
        let g = Vec_GenericParam.at(entry.decl.outbound_generics, k)
        let j = param_index_for(entry.decl.params, g.name.name)
        if j >= Vec_Param.len(entry.decl.params) {
            return Option_Vec_TyId.none
        }
        let arg_ty = check_mod.type_of_node(types_out, Vec_HArg.at(args, n_inline + j).expr.node_id)
        if !supported_binding(arg_ty, ty_interner) {
            return Option_Vec_TyId.none
        }
        Vec_TyId.push(mutable bound, arg_ty, allocator)?
        k += 1
    }
    var m: usize = 0
    loop decreases (n_inline - m) {
        if m >= n_inline { break }
        let dt = typearg_mod.evaluate(Vec_HArg.at(args, m).expr, types_out, ty_interner, 8 as usize, allocator)?
        if !supported_binding(dt, ty_interner) {
            return Option_Vec_TyId.none
        }
        Vec_TyId.push(mutable bound, dt, allocator)?
        m += 1
    }
    return Option_Vec_TyId.some(value: bound)
}


function supported_binding(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool {
    if ty_mod.is_error(t) { return false }
    if ty_mod.index(t) >= ty_interner_mod.slot_count(ty_interner) { return false }
    return match ty_interner_mod.lookup(ty_interner, t) {
        case .primitive(let p) => match p {
            case .type_meta => false
            case .heap_ptr => false
            case .unit_ => true
            case .never_ => false
            case _ => true
        }
        case .string_ => true
        case .record(_) => true
        case .sum_(_) => true
        case .tuple_(_) => true
        case _ => false
    }
}



module compile.instantiate.fninst.build.build

import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.mem.alloc
import cteval.state.value as value_mod
import hir.build.file as hir_file_mod
import types.check as check_mod
import intern.interner as interner_mod
import intern.symbol as sym_mod
import resolve.build.drive.surface.registry as registry_mod
import resolve.paths.modules as mt_mod
import source.map as source_map_mod
import span.loc.pos.span as span_mod
import specs.address.id as id_mod
import specs.error as spec_err_mod
import specs.gen.build.output as output_mod
import specs.gen.monomorphise.address.address as addr_mod
import specs.gen.respan.respan as respan_mod
import specs.gen.typaths as typaths_mod
import specs.subst.item as item_subst_mod
import specs.subst.walk.map as map_mod
import syntax.ast.ident as ast_ident_mod
import syntax.ast.item as ast_item_mod
import syntax.ast.literal as ast_literal_mod
import syntax.ast.tree as ast_tree_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.ty.kind as ty_kind_mod
import local.instantiate.fninst.table.table as table_mod
import local.instantiate.fninst.discover.discover as discover_mod

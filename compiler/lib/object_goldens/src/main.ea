
module object_goldens.main

import std.mem.alloc
import std.collections.vec
import std.core.fmt as fmt_mod
import std.io.stream
import std.text.string
import object.coff as coff_mod
import object.coff.serialize as serialize_mod


spec std.collections.vec.Vec(u8)


public function main(errout: Stderr, allocator: Allocator) -> i32
    with {errout, allocator, divergence, panic}
{
    let code = handle err: alloc.AllocError as ae -> fail_alloc(errout, ae) {
        run(errout, allocator)?
    }
    return code
}


function run(errout: Stderr, allocator: Allocator) -> i32
    with {errout, allocator, err: alloc.AllocError, divergence}
{
    var total: usize = 0
    var passed: usize = 0

    total = total + 1
    let r1 = check_section_name(errout, "coff string_table_ref base64 (offset 10000000)", 10000000 as u32, "//AAmJaA", allocator)?
    if r1 { passed = passed + 1 }

    total = total + 1
    let r2 = check_section_name(errout, "coff string_table_ref base64 (alphabet coverage)", 4278144383 as u32, "//D+/01/", allocator)?
    if r2 { passed = passed + 1 }

    total = total + 1
    let r3 = check_section_name(errout, "coff string_table_ref decimal (offset 9999999)", 9999999 as u32, "/9999999", allocator)?
    if r3 { passed = passed + 1 }

    let summary = build_summary(passed, total, allocator)?
    stream.eprint_line(errout, summary)
    return if passed == total { 0 } else { 1 }
}


function check_section_name(
    errout: Stderr,
    label: String,
    off: u32,
    expected: String,
    allocator: Allocator,
) -> bool
    with {errout, allocator, err: alloc.AllocError}
{
    uninit out: Vec_u8.Vec
    Vec_u8.new(init out, allocator)?
    let name = coff_mod.CoffSectionName.string_table_ref(offset: off)
    serialize_mod.serialize_section_name(mutable out, name, allocator)?
    let ok = vec_matches(out, expected)
    report(errout, ok, label, expected, allocator)?
    return ok
}


function vec_matches(v: Vec_u8.Vec, expected: String) -> bool {
    let eb = expected.bytes()
    let n = Vec_u8.len(v)
    if n != eb.len() {
        return false
    }
    var i: usize = 0
    var ok: bool = true
    loop decreases (n - i) {
        if i >= n { break }
        if Vec_u8.at(v, i) != eb[i] {
            ok = false
        }
        i = i + 1
    }
    return ok
}


function report(
    errout: Stderr,
    ok: bool,
    label: String,
    expected: String,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError}
{
    let tag = if ok { "pass: " } else { "fail: " }
    let s1 = string.concat(tag, label, allocator)?
    let s2 = string.concat(s1, " -> ", allocator)?
    let line = string.concat(s2, expected, allocator)?
    stream.eprint_line(errout, line)
}


function build_summary(passed: usize, total: usize, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p = fmt_mod.usize_to_string(passed, allocator)?
    let t = fmt_mod.usize_to_string(total, allocator)?
    let s1 = string.concat("objtest: ", p, allocator)?
    let s2 = string.concat(s1, "/", allocator)?
    let s3 = string.concat(s2, t, allocator)?
    return string.concat(s3, " coff goldens passed", allocator)?
}


function fail_alloc(errout: Stderr, e: alloc.AllocError) -> i32
    with {errout}
{
    match e {
        case .out_of_memory => errout.eprint_line("object-goldens: out of memory")
    }
    return 70
}

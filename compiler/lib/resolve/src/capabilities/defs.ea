
module resolve.capabilities.defs

import std.core.option
import intern.interner as interner_mod
import intern.symbol
import hir.def as def_mod
import target.capability as cap_mod


spec std.core.option.Option(cap_mod.Capability)


public type CapabilityDefs {
    filesystem: def_mod.DefId
    read_only_filesystem: def_mod.DefId
    sandboxed_filesystem: def_mod.DefId
    network: def_mod.DefId
    localhost_network: def_mod.DefId
    restricted_network: def_mod.DefId
    clock: def_mod.DefId
    monotonic_clock: def_mod.DefId
    random: def_mod.DefId
    deterministic_random: def_mod.DefId
    allocator: def_mod.DefId
    bounded_allocator: def_mod.DefId
    executor: def_mod.DefId
    stdin: def_mod.DefId
    stdout: def_mod.DefId
    stderr: def_mod.DefId
    subprocess: def_mod.DefId
    dom: def_mod.DefId
    window: def_mod.DefId
    extension_content: def_mod.DefId
    extension_worker: def_mod.DefId
    debugger: def_mod.DefId
}


public type Seeded {
    capabilities: CapabilityDefs
    next_def_id: u32
}

public function seed(start: u32) -> Seeded
    requires start < 4294967274
{
    return Seeded {
        capabilities: CapabilityDefs {
            filesystem: def_mod.DefId { raw: start },
            read_only_filesystem: def_mod.DefId { raw: start + 1 },
            sandboxed_filesystem: def_mod.DefId { raw: start + 2 },
            network: def_mod.DefId { raw: start + 3 },
            localhost_network: def_mod.DefId { raw: start + 4 },
            restricted_network: def_mod.DefId { raw: start + 5 },
            clock: def_mod.DefId { raw: start + 6 },
            monotonic_clock: def_mod.DefId { raw: start + 7 },
            random: def_mod.DefId { raw: start + 8 },
            deterministic_random: def_mod.DefId { raw: start + 9 },
            allocator: def_mod.DefId { raw: start + 10 },
            bounded_allocator: def_mod.DefId { raw: start + 11 },
            executor: def_mod.DefId { raw: start + 12 },
            stdin: def_mod.DefId { raw: start + 13 },
            stdout: def_mod.DefId { raw: start + 14 },
            stderr: def_mod.DefId { raw: start + 15 },
            subprocess: def_mod.DefId { raw: start + 16 },
            dom: def_mod.DefId { raw: start + 17 },
            window: def_mod.DefId { raw: start + 18 },
            extension_content: def_mod.DefId { raw: start + 19 },
            extension_worker: def_mod.DefId { raw: start + 20 },
            debugger: def_mod.DefId { raw: start + 21 },
        },
        next_def_id: start + 22,
    }
}


public function lookup(cd: CapabilityDefs, name: symbol.Symbol, interner: interner_mod.Interner) -> def_mod.DefId {
    let bytes = interner_mod.lookup(interner, name)
    return match cap_mod.from_name_bytes(bytes) {
        case .some(let cap) => def_for(cd, cap)
        case .none => def_mod.error()
    }
}


function def_for(cd: CapabilityDefs, cap: cap_mod.Capability) -> def_mod.DefId {
    return match cap {
        case .filesystem            => cd.filesystem
        case .read_only_filesystem  => cd.read_only_filesystem
        case .sandboxed_filesystem  => cd.sandboxed_filesystem
        case .network               => cd.network
        case .localhost_network     => cd.localhost_network
        case .restricted_network    => cd.restricted_network
        case .clock                 => cd.clock
        case .monotonic_clock       => cd.monotonic_clock
        case .random                => cd.random
        case .deterministic_random  => cd.deterministic_random
        case .allocator             => cd.allocator
        case .bounded_allocator     => cd.bounded_allocator
        case .executor              => cd.executor
        case .stdin                 => cd.stdin
        case .stdout                => cd.stdout
        case .stderr                => cd.stderr
        case .subprocess            => cd.subprocess
        case .dom                   => cd.dom
        case .window                => cd.window
        case .extension_content     => cd.extension_content
        case .extension_worker      => cd.extension_worker
        case .debugger              => cd.debugger
    }
}


public stable function cap_of(cd: CapabilityDefs, def_id: def_mod.DefId) -> Option_Capability.Option {
    let r = def_id.raw
    if r == cd.filesystem.raw           { return Option_Capability.some(value: cap_mod.Capability.filesystem) }
    if r == cd.read_only_filesystem.raw { return Option_Capability.some(value: cap_mod.Capability.read_only_filesystem) }
    if r == cd.sandboxed_filesystem.raw { return Option_Capability.some(value: cap_mod.Capability.sandboxed_filesystem) }
    if r == cd.network.raw              { return Option_Capability.some(value: cap_mod.Capability.network) }
    if r == cd.localhost_network.raw    { return Option_Capability.some(value: cap_mod.Capability.localhost_network) }
    if r == cd.restricted_network.raw   { return Option_Capability.some(value: cap_mod.Capability.restricted_network) }
    if r == cd.clock.raw                { return Option_Capability.some(value: cap_mod.Capability.clock) }
    if r == cd.monotonic_clock.raw      { return Option_Capability.some(value: cap_mod.Capability.monotonic_clock) }
    if r == cd.random.raw               { return Option_Capability.some(value: cap_mod.Capability.random) }
    if r == cd.deterministic_random.raw { return Option_Capability.some(value: cap_mod.Capability.deterministic_random) }
    if r == cd.allocator.raw            { return Option_Capability.some(value: cap_mod.Capability.allocator) }
    if r == cd.bounded_allocator.raw    { return Option_Capability.some(value: cap_mod.Capability.bounded_allocator) }
    if r == cd.executor.raw             { return Option_Capability.some(value: cap_mod.Capability.executor) }
    if r == cd.stdin.raw                { return Option_Capability.some(value: cap_mod.Capability.stdin) }
    if r == cd.stdout.raw               { return Option_Capability.some(value: cap_mod.Capability.stdout) }
    if r == cd.stderr.raw               { return Option_Capability.some(value: cap_mod.Capability.stderr) }
    if r == cd.subprocess.raw           { return Option_Capability.some(value: cap_mod.Capability.subprocess) }
    if r == cd.dom.raw                  { return Option_Capability.some(value: cap_mod.Capability.dom) }
    if r == cd.window.raw               { return Option_Capability.some(value: cap_mod.Capability.window) }
    if r == cd.extension_content.raw    { return Option_Capability.some(value: cap_mod.Capability.extension_content) }
    if r == cd.extension_worker.raw     { return Option_Capability.some(value: cap_mod.Capability.extension_worker) }
    if r == cd.debugger.raw             { return Option_Capability.some(value: cap_mod.Capability.debugger) }
    return Option_Capability.none
}

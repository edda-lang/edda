
module resolve.paths.path

import std.collections.vec
import std.core.option
import syntax.ast.ident as ast_ident
import intern.symbol

spec std.collections.vec.Vec(symbol.Symbol)
spec std.collections.vec.Vec(ast_ident.Ident)
spec std.core.option.Option(ast_ident.Ident)

derive eq, debug for ResolvedPathKind


public type ResolvedPathKind {
    case stdlib

    case local_pkg

    case rune(dep_name: symbol.Symbol)

    case workspace(member_root: symbol.Symbol)

    case unresolved
}

public type RoutingTable {
    std_sym: symbol.Symbol
    local_sym: symbol.Symbol
    dep_syms: Vec_Symbol.Vec
    member_syms: Vec_Symbol.Vec
}


public function new_routing_table(
    out: init RoutingTable,
    std_sym: symbol.Symbol,
    local_sym: symbol.Symbol,
    dep_syms: take Vec_Symbol.Vec,
    member_syms: take Vec_Symbol.Vec,
) -> () {
    out = RoutingTable {
        std_sym: std_sym,
        local_sym: local_sym,
        dep_syms: dep_syms,
        member_syms: member_syms,
    }
}


public stable function classify(path: ast_ident.Path, table: RoutingTable) -> ResolvedPathKind {
    let n = Vec_Ident.len(path.segments)
    if n == 0 {
        return ResolvedPathKind.unresolved
    }
    let first = Vec_Ident.at(path.segments, 0).name
    if first.raw == table.std_sym.raw {
        return ResolvedPathKind.stdlib
    }
    if first.raw == table.local_sym.raw {
        return ResolvedPathKind.local_pkg
    }
    if matches_any(first, table.member_syms) {
        return ResolvedPathKind.workspace(member_root: first)
    }
    if matches_any(first, table.dep_syms) {
        return ResolvedPathKind.rune(dep_name: first)
    }
    return ResolvedPathKind.unresolved
}


public stable function leaf(p: ast_ident.Path) -> symbol.Symbol {
    let n = Vec_Ident.len(p.segments)
    if n == 0 {
        return symbol.empty()
    }
    return Vec_Ident.at(p.segments, n - 1).name
}

public stable function path_len(p: ast_ident.Path) -> usize {
    return Vec_Ident.len(p.segments)
}

public stable function first_seg_ident(p: ast_ident.Path) -> Option_Ident.Option {
    if Vec_Ident.len(p.segments) == 0 {
        return Option_Ident.none
    }
    return Option_Ident.some(value: Vec_Ident.at(p.segments, 0))
}


stable function matches_any(needle: symbol.Symbol, haystack: Vec_Symbol.Vec) -> bool {
    let n = Vec_Symbol.len(haystack)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n {
            return false
        }
        let s = Vec_Symbol.at(haystack, i)
        if s.raw == needle.raw {
            return true
        }
        i = i + 1
    }
    return false
}


module resolve.primitives.defs

import std.collections.slice
import intern.interner as interner_mod
import intern.symbol
import hir.def as def_mod


public type PrimitiveDefs {
    i8_: def_mod.DefId
    i16_: def_mod.DefId
    i32_: def_mod.DefId
    i64_: def_mod.DefId
    i128_: def_mod.DefId
    u8_: def_mod.DefId
    u16_: def_mod.DefId
    u32_: def_mod.DefId
    u64_: def_mod.DefId
    u128_: def_mod.DefId
    isize_: def_mod.DefId
    usize_: def_mod.DefId
    f32_: def_mod.DefId
    f64_: def_mod.DefId
    bool_: def_mod.DefId
    never_: def_mod.DefId
    codepoint_: def_mod.DefId
    type_meta: def_mod.DefId
    string_: def_mod.DefId
}


public type Seeded {
    primitives: PrimitiveDefs
    next_def_id: u32
}

public function seed(start: u32) -> Seeded
    requires start < 4294967277
{
    return Seeded {
        primitives: PrimitiveDefs {
            i8_: def_mod.DefId { raw: start },
            i16_: def_mod.DefId { raw: start + 1 },
            i32_: def_mod.DefId { raw: start + 2 },
            i64_: def_mod.DefId { raw: start + 3 },
            i128_: def_mod.DefId { raw: start + 4 },
            u8_: def_mod.DefId { raw: start + 5 },
            u16_: def_mod.DefId { raw: start + 6 },
            u32_: def_mod.DefId { raw: start + 7 },
            u64_: def_mod.DefId { raw: start + 8 },
            u128_: def_mod.DefId { raw: start + 9 },
            isize_: def_mod.DefId { raw: start + 10 },
            usize_: def_mod.DefId { raw: start + 11 },
            f32_: def_mod.DefId { raw: start + 12 },
            f64_: def_mod.DefId { raw: start + 13 },
            bool_: def_mod.DefId { raw: start + 14 },
            never_: def_mod.DefId { raw: start + 15 },
            codepoint_: def_mod.DefId { raw: start + 16 },
            type_meta: def_mod.DefId { raw: start + 17 },
            string_: def_mod.DefId { raw: start + 18 },
        },
        next_def_id: start + 19,
    }
}


public function lookup(pd: PrimitiveDefs, name: symbol.Symbol, interner: interner_mod.Interner) -> def_mod.DefId {
    let bytes = interner_mod.lookup(interner, name)
    if slice.eq_u8(bytes, "i8".bytes())        { return pd.i8_ }
    if slice.eq_u8(bytes, "i16".bytes())       { return pd.i16_ }
    if slice.eq_u8(bytes, "i32".bytes())       { return pd.i32_ }
    if slice.eq_u8(bytes, "i64".bytes())       { return pd.i64_ }
    if slice.eq_u8(bytes, "i128".bytes())      { return pd.i128_ }
    if slice.eq_u8(bytes, "u8".bytes())        { return pd.u8_ }
    if slice.eq_u8(bytes, "u16".bytes())       { return pd.u16_ }
    if slice.eq_u8(bytes, "u32".bytes())       { return pd.u32_ }
    if slice.eq_u8(bytes, "u64".bytes())       { return pd.u64_ }
    if slice.eq_u8(bytes, "u128".bytes())      { return pd.u128_ }
    if slice.eq_u8(bytes, "isize".bytes())     { return pd.isize_ }
    if slice.eq_u8(bytes, "usize".bytes())     { return pd.usize_ }
    if slice.eq_u8(bytes, "f32".bytes())       { return pd.f32_ }
    if slice.eq_u8(bytes, "f64".bytes())       { return pd.f64_ }
    if slice.eq_u8(bytes, "bool".bytes())      { return pd.bool_ }
    if slice.eq_u8(bytes, "never".bytes())     { return pd.never_ }
    if slice.eq_u8(bytes, "Codepoint".bytes()) { return pd.codepoint_ }
    if slice.eq_u8(bytes, "Type".bytes())      { return pd.type_meta }
    if slice.eq_u8(bytes, "String".bytes())    { return pd.string_ }
    return def_mod.error()
}


public stable function i8_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.i8_ }

public stable function i16_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.i16_ }

public stable function i32_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.i32_ }

public stable function i64_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.i64_ }

public stable function i128_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.i128_ }

public stable function u8_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.u8_ }

public stable function u16_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.u16_ }

public stable function u32_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.u32_ }

public stable function u64_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.u64_ }

public stable function u128_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.u128_ }

public stable function isize_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.isize_ }

public stable function usize_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.usize_ }

public stable function f32_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.f32_ }

public stable function f64_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.f64_ }

public stable function bool_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.bool_ }

public stable function never_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.never_ }

public stable function codepoint_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.codepoint_ }

public stable function type_meta(pd: PrimitiveDefs) -> def_mod.DefId { return pd.type_meta }

public stable function string_(pd: PrimitiveDefs) -> def_mod.DefId { return pd.string_ }

public type Seeded {
    builtins: BuiltinDefs
    next_def_id: u32
}

public function seed(start: u32) -> Seeded
    requires start < 4294967236
{
    return Seeded {
        builtins: BuiltinDefs {
            string_concat: def_mod.DefId { raw: start },
            task_await: def_mod.DefId { raw: start + 1 },
            slice_iter_new: def_mod.DefId { raw: start + 2 },
            slice_iter_next: def_mod.DefId { raw: start + 3 },
            range_iter_new: def_mod.DefId { raw: start + 4 },
            range_iter_next: def_mod.DefId { raw: start + 5 },
            syscall6: def_mod.DefId { raw: start + 6 },
            slice_addr: def_mod.DefId { raw: start + 7 },
            slice_from_raw: def_mod.DefId { raw: start + 8 },
            load_u8: def_mod.DefId { raw: start + 9 },
            load_u16: def_mod.DefId { raw: start + 10 },
            load_u32: def_mod.DefId { raw: start + 11 },
            load_u64: def_mod.DefId { raw: start + 12 },
            load_usize: def_mod.DefId { raw: start + 13 },
            store_u8: def_mod.DefId { raw: start + 14 },
            store_u16: def_mod.DefId { raw: start + 15 },
            store_u32: def_mod.DefId { raw: start + 16 },
            store_u64: def_mod.DefId { raw: start + 17 },
            store_usize: def_mod.DefId { raw: start + 18 },
            sqrt_f64: def_mod.DefId { raw: start + 19 },
            floor_f64: def_mod.DefId { raw: start + 20 },
            ceil_f64: def_mod.DefId { raw: start + 21 },
            trunc_f64: def_mod.DefId { raw: start + 22 },
            task_spawn: def_mod.DefId { raw: start + 23 },
            alloc_array: def_mod.DefId { raw: start + 24 },
            string_from_raw: def_mod.DefId { raw: start + 25 },
            f64_to_bits: def_mod.DefId { raw: start + 26 },
            f64_from_bits: def_mod.DefId { raw: start + 27 },
            f32_to_bits: def_mod.DefId { raw: start + 28 },
            f32_from_bits: def_mod.DefId { raw: start + 29 },
            slice_from_raw_string: def_mod.DefId { raw: start + 30 },
            codepoint_to_u32: def_mod.DefId { raw: start + 31 },
            codepoint_from_u32: def_mod.DefId { raw: start + 32 },
            alloc_raw: def_mod.DefId { raw: start + 33 },
            box_read_raw: def_mod.DefId { raw: start + 34 },
            box_unbox_raw: def_mod.DefId { raw: start + 35 },
            free_raw: def_mod.DefId { raw: start + 36 },
            realloc_array_raw: def_mod.DefId { raw: start + 37 },
            fstring_format: def_mod.DefId { raw: start + 38 },
            format_i64: def_mod.DefId { raw: start + 39 },
            format_u64: def_mod.DefId { raw: start + 40 },
            format_f64: def_mod.DefId { raw: start + 41 },
            format_bool: def_mod.DefId { raw: start + 42 },
            format_str: def_mod.DefId { raw: start + 43 },
            task_wake: def_mod.DefId { raw: start + 44 },
            task_dispatch_event: def_mod.DefId { raw: start + 45 },
            floattidf: def_mod.DefId { raw: start + 46 },
            floattisf: def_mod.DefId { raw: start + 47 },
            floatuntidf: def_mod.DefId { raw: start + 48 },
            floatuntisf: def_mod.DefId { raw: start + 49 },
            fixdfti: def_mod.DefId { raw: start + 50 },
            fixsfti: def_mod.DefId { raw: start + 51 },
            fixunsdfti: def_mod.DefId { raw: start + 52 },
            fixunssfti: def_mod.DefId { raw: start + 53 },
            fixwrapdfti: def_mod.DefId { raw: start + 54 },
            fixwrapsfti: def_mod.DefId { raw: start + 55 },
            task_group_open: def_mod.DefId { raw: start + 56 },
            task_group_join: def_mod.DefId { raw: start + 57 },
            discriminant_of: def_mod.DefId { raw: start + 58 },
            copy_array_raw: def_mod.DefId { raw: start + 59 },
        },
        next_def_id: start + 60,
    }
}


public function lookup(b: BuiltinDefs, name: symbol.Symbol, interner: interner_mod.Interner) -> def_mod.DefId {
    let bytes = interner_mod.lookup(interner, name)
    if slice.eq_u8(bytes, "discriminant_of".bytes()) { return b.discriminant_of }
    return def_mod.error()
}


public function is_inline_intrinsic_def(def: def_mod.DefId) -> bool {
    let s = seed(1)
    if def.raw == s.builtins.string_from_raw.raw { return true }
    if def.raw == s.builtins.slice_from_raw_string.raw { return true }
    if def.raw >= s.builtins.codepoint_to_u32.raw && def.raw <= s.builtins.codepoint_from_u32.raw { return true }
    if def.raw >= s.builtins.f64_to_bits.raw && def.raw <= s.builtins.f32_from_bits.raw { return true }
    return def.raw >= s.builtins.syscall6.raw && def.raw <= s.builtins.trunc_f64.raw
}



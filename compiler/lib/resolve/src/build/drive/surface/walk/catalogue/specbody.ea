
module resolve.build.drive.surface.walk.catalogue.specbody

import std.collections.vec
import std.mem.alloc
import intern.symbol
import syntax.ast.item as ast_item

spec std.mem.alloc.Box(ast_item.FnDecl)
spec std.mem.alloc.Box(ast_item.TypeDecl)
spec std.mem.alloc.Box(ast_item.Spec)
spec std.mem.alloc.Box(ast_item.LetDecl)
spec std.collections.vec.Vec(ast_item.Item)
spec std.collections.vec.Vec(symbol.Symbol)
spec std.collections.vec.Vec(ast_item.Variant)


public type VariantInfo {
    name: symbol.Symbol
    owner: symbol.Symbol
}

spec std.collections.vec.Vec(VariantInfo)


public function spec_body_names(body: Vec_Item.Vec, allocator: Allocator) -> Vec_Symbol.Vec
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit out: Vec_Symbol.Vec
    Vec_Symbol.new(init out, allocator)?
    let n = Vec_Item.len(body)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let nm = item_name(Vec_Item.at(body, i))
        if nm.raw != symbol.empty().raw {
            Vec_Symbol.push(mutable out, nm, allocator)?
        }
        i = i + 1
    }
    return out
}


public function spec_body_variants(body: Vec_Item.Vec, allocator: Allocator) -> Vec_VariantInfo.Vec
    with {allocator, err: alloc.AllocError, divergence}
{
    uninit out: Vec_VariantInfo.Vec
    Vec_VariantInfo.new(init out, allocator)?
    let n = Vec_Item.len(body)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        match Vec_Item.at(body, i).kind {
            case .type_decl(let decl) => {
                let d = Box_TypeDecl.get(decl)
                match d.kind {
                    case .sum(let variants) => {
                        let vn = Vec_Variant.len(variants)
                        var vi: usize = 0
                        loop decreases (vn - vi) {
                            if vi >= vn { break }
                            let v = Vec_Variant.at(variants, vi)
                            Vec_VariantInfo.push(mutable out, VariantInfo { name: v.name.name, owner: d.name.name }, allocator)?
                            vi = vi + 1
                        }
                    }
                    case _ => ()
                }
            }
            case _ => ()
        }
        i = i + 1
    }
    return out
}


function item_name(item: ast_item.Item) -> symbol.Symbol {
    return match item.kind {
        case .function_(let d) => Box_FnDecl.get(d).name.name
        case .type_decl(let d) => Box_TypeDecl.get(d).name.name
        case .spec_(let d) => Box_Spec.get(d).name.name
        case .let_(let d) => Box_LetDecl.get(d).name.name
        case _ => symbol.empty()
    }
}

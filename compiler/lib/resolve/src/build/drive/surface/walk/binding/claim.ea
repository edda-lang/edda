
module resolve.build.drive.surface.walk.binding.claim

import std.collections.vec
import std.collections.slice
import std.core.option
import intern.interner as intern_mod
import syntax.ast.item as ast_item
import syntax.ast.ident as ast_ident
import hir.def as def_mod
import local.build.builtins as builtins_mod


spec std.collections.vec.Vec(ast_item.Item)
spec std.collections.vec.Vec(ast_ident.Ident)
spec std.core.option.Option(def_mod.DefId)


public function module_path_is_std_task(items: Vec_Item.Vec, interner: intern_mod.Interner) -> bool {
    let n = Vec_Item.len(items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_Item.at(items, i)
        match item.kind {
            case .module_(let decl) => return path_is_std_task(decl.path, interner)
            case _ => ()
        }
        i = i + 1
    }
    return false
}

function path_is_std_task(path: ast_ident.Path, interner: intern_mod.Interner) -> bool {
    if Vec_Ident.len(path.segments) != (2 as usize) {
        return false
    }
    let s0 = Vec_Ident.at(path.segments, 0 as usize)
    let s1 = Vec_Ident.at(path.segments, 1 as usize)
    if !slice.eq_u8(intern_mod.lookup(interner, s0.name), "std".bytes()) {
        return false
    }
    return slice.eq_u8(intern_mod.lookup(interner, s1.name), "task".bytes())
}

public function reserved_task_body_def(name: ast_ident.Ident, in_task_mod: bool, interner: intern_mod.Interner) -> Option_DefId.Option {
    if !in_task_mod {
        return Option_DefId.none
    }
    let nb = intern_mod.lookup(interner, name.name)
    if slice.eq_u8(nb, "wake".bytes()) {
        return Option_DefId.some(value: builtins_mod.task_wake_reserved())
    }
    if slice.eq_u8(nb, "dispatch_event".bytes()) {
        return Option_DefId.some(value: builtins_mod.task_dispatch_event_reserved())
    }
    return Option_DefId.none
}


module resolve.lints.run

import std.collections.vec
import std.mem.alloc
import intern.interner as interner_mod
import source.map as source_map_mod
import syntax.ast.file as ast_file
import local.ctx as ctx_mod
import local.lints.cycles as cycles_mod
import local.lints.dead as dead_mod
import local.lints.duplicate as duplicate_mod
import local.lints.trust as trust_mod
import local.lints.unresolved as unresolved_mod
import local.lints.cohesion.lint.lint as cohesion_mod

spec std.collections.vec.Vec(ast_file.File)


public function run_all(ctx: mutable ctx_mod.ResolveCtx, files: Vec_File.Vec, source_map: source_map_mod.SourceMap, interner: interner_mod.Interner, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    unresolved_mod.check_unresolved_imports(mutable ctx, files, interner, allocator)?
    duplicate_mod.check_duplicate_imports(mutable ctx, files, interner, allocator)?
    duplicate_mod.check_duplicate_spec_invocations(mutable ctx, files, allocator)?
    cycles_mod.check_import_cycles(mutable ctx, files, interner, allocator)?
    dead_mod.check_dead_private_functions(mutable ctx, files, interner, allocator)?
    trust_mod.check_trust_hatch_density(mutable ctx, files, interner, allocator)?
    cohesion_mod.check_file_cohesion(mutable ctx, files, source_map, interner, allocator)?
}

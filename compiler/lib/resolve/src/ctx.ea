public function output_module_id_of(output: ResolveOutput, segments: Vec_Symbol.Vec) -> mt_mod.ModuleId {
    return match mt_mod.find_longest_prefix(output.module_tree, segments) {
        case .some(let pm) => if pm.segments_consumed == Vec_Symbol.len(segments) {
            pm.mod_id
        } else {
            mt_mod.ModuleId { raw: 0 }
        }
        case .none => mt_mod.ModuleId { raw: 0 }
    }
}

public function lookup_single(ctx: ResolveCtx, name: symbol.Symbol, interner: interner_mod.Interner) -> def_mod.DefId {
    return registry_mod.lookup_single_segment(ctx.registry, name, interner)
}


public function emit_diagnostic(ctx: mutable ResolveCtx, d: take diag_mod.Diagnostic, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    diag_collection.emit(mutable ctx.diags, d, allocator)?
}


public function record_use(ctx: mutable ResolveCtx, at: span_mod.Span, def: def_mod.DefId, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    resmap_mod.record(mutable ctx.uses, at, def, allocator)?
    bump_use_count(mutable ctx, def, allocator)?
    record_call_edge(mutable ctx, def, allocator)?
}

public stable function lookup_use(output: ResolveOutput, at: span_mod.Span) -> def_mod.DefId {
    return resmap_mod.lookup(output.uses, at)
}


public function record_local_use(ctx: mutable ResolveCtx, at: span_mod.Span, def: def_mod.DefId, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    resmap_mod.record(mutable ctx.local_uses, at, def, allocator)?
    bump_use_count(mutable ctx, def, allocator)?
}

public stable function lookup_local_use(output: ResolveOutput, at: span_mod.Span) -> def_mod.DefId {
    return resmap_mod.lookup(output.local_uses, at)
}


function bump_use_count(ctx: mutable ResolveCtx, def: def_mod.DefId, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let cur = use_count_of(ctx, def)
    let _ = IntMap_usize.insert(mutable ctx.use_counts, def.raw as i64, cur + 1, allocator)?
}

public stable function use_count_of(ctx: ResolveCtx, def: def_mod.DefId) -> usize {
    return match IntMap_usize.get(ctx.use_counts, def.raw as i64) {
        case .some(let v) => v
        case .none => 0
    }
}


public function add_self_uses(ctx: mutable ResolveCtx, def: def_mod.DefId, delta: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let cur = self_use_count_of(ctx, def)
    let _ = IntMap_usize.insert(mutable ctx.self_use_counts, def.raw as i64, cur + delta, allocator)?
}

public stable function self_use_count_of(ctx: ResolveCtx, def: def_mod.DefId) -> usize {
    return match IntMap_usize.get(ctx.self_use_counts, def.raw as i64) {
        case .some(let v) => v
        case .none => 0
    }
}


public function set_current_def(ctx: mutable ResolveCtx, def: def_mod.DefId) -> () {
    ctx.current_def = def
}

public function clear_current_def(ctx: mutable ResolveCtx) -> () {
    ctx.current_def = def_mod.DefId { raw: 0 }
}

public function enter_spec(ctx: mutable ResolveCtx) -> () {
    ctx.spec_depth = ctx.spec_depth + 1
}

public function exit_spec(ctx: mutable ResolveCtx) -> () {
    if ctx.spec_depth > 0 as usize {
        ctx.spec_depth = ctx.spec_depth - 1
    }
}

public function set_track_edges(ctx: mutable ResolveCtx, v: bool) -> () {
    ctx.track_edges = v
}

function record_call_edge(ctx: mutable ResolveCtx, callee: def_mod.DefId, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if !ctx.track_edges {
        return
    }
    if ctx.current_def.raw != 0 && ctx.spec_depth == 0 as usize {
        let caller_key = ctx.current_def.raw as i64
        match IntMap_Vec_DefId.get(ctx.call_edges, caller_key) {
            case .some(let existing) => {
                var lst = existing
                Vec_DefId.push(mutable lst, callee, allocator)?
                let _ = IntMap_Vec_DefId.insert(mutable ctx.call_edges, caller_key, lst, allocator)?
            }
            case .none => {
                uninit lst: Vec_DefId.Vec
                Vec_DefId.new(init lst, allocator)?
                Vec_DefId.push(mutable lst, callee, allocator)?
                let _ = IntMap_Vec_DefId.insert(mutable ctx.call_edges, caller_key, lst, allocator)?
            }
        }
    } else {
        Vec_DefId.push(mutable ctx.extra_roots, callee, allocator)?
    }
}

public stable function callees_of(ctx: ResolveCtx, def: def_mod.DefId) -> Option_Vec_DefId.Option {
    return IntMap_Vec_DefId.get(ctx.call_edges, def.raw as i64)
}

public function extra_roots_of(ctx: ResolveCtx) -> Vec_DefId.Vec {
    return ctx.extra_roots
}

public stable function def_id_bound(ctx: ResolveCtx) -> usize {
    return ctx.next_def_id as usize
}


public function finish(ctx: take ResolveCtx) -> ResolveOutput {
    return ResolveOutput {
        registry: ctx.registry,
        module_tree: ctx.module_tree,
        diags: ctx.diags,
        next_def_id: ctx.next_def_id,
        next_module_id: ctx.next_module_id,
        uses: ctx.uses,
        local_uses: ctx.local_uses,
    }
}


public function reopen(output: take ResolveOutput, allocator: Allocator) -> ResolveCtx
    with {allocator, err: alloc.AllocError}
{
    uninit empty_imports: imports_mod.ImportScope
    imports_mod.new_scope(init empty_imports, allocator)?
    uninit empty_mod_path: Vec_Symbol.Vec
    Vec_Symbol.new(init empty_mod_path, allocator)?
    let use_counts_map = IntMap_usize.new(allocator)?
    let self_use_counts_map = IntMap_usize.new(allocator)?
    let call_edges_map = IntMap_Vec_DefId.new(allocator)?
    uninit extra_roots_vec: Vec_DefId.Vec
    Vec_DefId.new(init extra_roots_vec, allocator)?
    return ResolveCtx {
        next_def_id: output.next_def_id,
        next_module_id: output.next_module_id,
        registry: output.registry,
        module_tree: output.module_tree,
        diags: output.diags,
        uses: output.uses,
        local_uses: output.local_uses,
        use_counts: use_counts_map,
        self_use_counts: self_use_counts_map,
        current_module: mt_mod.ModuleId { raw: 0 },
        current_module_path: empty_mod_path,
        current_imports: empty_imports,
        quiet: false,
        instance_mode: false,
        current_def: def_mod.DefId { raw: 0 },
        spec_depth: 0 as usize,
        call_edges: call_edges_map,
        extra_roots: extra_roots_vec,
        track_edges: false,
    }
}


public stable function output_builtins(output: ResolveOutput) -> builtins_mod.BuiltinDefs {
    return registry_mod.builtins(output.registry)
}

public stable function output_primitives(output: ResolveOutput) -> primitives_mod.PrimitiveDefs {
    return registry_mod.primitives(output.registry)
}

public stable function output_comptime_builtins(output: ResolveOutput) -> cbi_mod.ComptimeBuiltinDefs {
    return registry_mod.comptime_builtins(output.registry)
}

public stable function output_capabilities(output: ResolveOutput) -> capabilities_mod.CapabilityDefs {
    return registry_mod.capabilities(output.registry)
}

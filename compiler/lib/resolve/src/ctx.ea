
module resolve.ctx

import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.mem.alloc
import diagnostics.emit.collection as diag_collection
import diagnostics.emit.diagnostic as diag_mod
import intern.symbol
import intern.interner as interner_mod
import span.loc.pos.span as span_mod
import hir.def as def_mod
import local.bind.bindings as bindings_mod
import local.build.builtins as builtins_mod
import local.cteval.builtins as cbi_mod
import local.paths.modules as mt_mod
import local.primitives.defs as primitives_mod
import local.capabilities.defs as capabilities_mod
import local.build.drive.surface.registry as registry_mod
import local.map.resmap as resmap_mod
import local.paths.imports as imports_mod

spec std.collections.vec.Vec(symbol.Symbol)
spec std.collections.vec.Vec(def_mod.DefId)
spec std.collections.hashmap.IntMap(usize)
spec std.collections.hashmap.IntMap(Vec_DefId)
spec std.core.option.Option(mt_mod.PrefixMatch)
spec std.core.option.Option(usize)
spec std.core.option.Option(Vec_DefId)


public linear type ResolveCtx {
    next_def_id: u32
    next_module_id: u32
    registry: registry_mod.Registry
    module_tree: mt_mod.ModuleTree
    diags: diag_collection.Diagnostics
    uses: resmap_mod.ResolveMap
    local_uses: resmap_mod.ResolveMap
    use_counts: IntMap_usize.IntMap
    self_use_counts: IntMap_usize.IntMap
    current_module: mt_mod.ModuleId
    current_module_path: Vec_Symbol.Vec
    current_imports: imports_mod.ImportScope
    quiet: bool
    instance_mode: bool
    current_def: def_mod.DefId
    spec_depth: usize
    call_edges: IntMap_Vec_DefId.IntMap
    extra_roots: Vec_DefId.Vec
    track_edges: bool
}

public type ResolveOutput {
    registry: registry_mod.Registry
    module_tree: mt_mod.ModuleTree
    diags: diag_collection.Diagnostics
    next_def_id: u32
    next_module_id: u32
    uses: resmap_mod.ResolveMap
    local_uses: resmap_mod.ResolveMap
}


public function new_ctx(out: init ResolveCtx, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let builtins_seed = builtins_mod.seed(1)
    let prims_seed = primitives_mod.seed(builtins_seed.next_def_id)
    let cbi_seed = cbi_mod.seed(prims_seed.next_def_id)
    let caps_seed = capabilities_mod.seed(cbi_seed.next_def_id)
    uninit reg: registry_mod.Registry
    registry_mod.new_registry(
        init reg,
        builtins_seed.builtins,
        prims_seed.primitives,
        cbi_seed.comptime_builtins,
        caps_seed.capabilities,
        allocator,
    )?
    uninit mt: mt_mod.ModuleTree
    mt_mod.new_tree(init mt, allocator)?
    uninit diags_buf: diag_collection.Diagnostics
    diag_collection.new_diagnostics(init diags_buf, allocator)?
    let uses_map = resmap_mod.new_map(allocator)?
    let local_uses_map = resmap_mod.new_map(allocator)?
    let use_counts_map = IntMap_usize.new(allocator)?
    let self_use_counts_map = IntMap_usize.new(allocator)?
    let call_edges_map = IntMap_Vec_DefId.new(allocator)?
    uninit extra_roots_vec: Vec_DefId.Vec
    Vec_DefId.new(init extra_roots_vec, allocator)?
    uninit empty_imports: imports_mod.ImportScope
    imports_mod.new_scope(init empty_imports, allocator)?
    uninit empty_mod_path: Vec_Symbol.Vec
    Vec_Symbol.new(init empty_mod_path, allocator)?
    out = ResolveCtx {
        next_def_id: caps_seed.next_def_id,
        next_module_id: 1,
        registry: reg,
        module_tree: mt,
        diags: diags_buf,
        uses: uses_map,
        local_uses: local_uses_map,
        use_counts: use_counts_map,
        self_use_counts: self_use_counts_map,
        current_module: mt_mod.ModuleId { raw: 0 },
        current_module_path: empty_mod_path,
        current_imports: empty_imports,
        quiet: false,
        instance_mode: false,
        current_def: def_mod.DefId { raw: 0 },
        spec_depth: 0 as usize,
        call_edges: call_edges_map,
        extra_roots: extra_roots_vec,
        track_edges: false,
    }
}


public function alloc_def(ctx: mutable ResolveCtx) -> def_mod.DefId
    requires ctx.next_def_id < 4294967295
{
    let id = def_mod.DefId { raw: ctx.next_def_id }
    ctx.next_def_id = ctx.next_def_id + 1
    return id
}

public function alloc_module_id(ctx: mutable ResolveCtx) -> mt_mod.ModuleId
    requires ctx.next_module_id < 4294967295
{
    let id = mt_mod.ModuleId { raw: ctx.next_module_id }
    ctx.next_module_id = ctx.next_module_id + 1
    return id
}



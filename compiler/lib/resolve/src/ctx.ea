public stable function lookup_path(ctx: ResolveCtx, segments: Vec_Symbol.Vec) -> def_mod.DefId {
    return registry_mod.lookup_path(ctx.registry, segments, ctx.module_tree)
}

public stable function module_id_of(ctx: ResolveCtx, segments: Vec_Symbol.Vec) -> mt_mod.ModuleId {
    return match mt_mod.find_longest_prefix(ctx.module_tree, segments) {
        case .some(let pm) => if pm.segments_consumed == Vec_Symbol.len(segments) {
            pm.mod_id
        } else {
            mt_mod.ModuleId { raw: 0 }
        }
        case .none => mt_mod.ModuleId { raw: 0 }
    }
}



module cache.blob.mir.expr.leaf.codec

import std.mem.alloc
import std.collections.vec
import std.core.option
import intern.interner as interner_mod
import syntax.ast.tree as ast_tree_mod
import syntax.ast.ident as ident_mod
import syntax.ast.ops as ops_mod
import local.error as error_mod
import local.blob.mir.prim as prim_mod
import local.blob.mir.ast.codec as ast_codec_mod
import local.blob.mir.ast.ops as ast_ops_mod
import local.blob.mir.pat.codec as pat_codec_mod
import local.blob.mir.ty.write.codec as ty_codec_mod
import local.blob.mir.ty.read.codec as ty_read_mod


spec std.mem.alloc.Box(ast_tree_mod.Pat)
spec std.mem.alloc.Box(ast_tree_mod.Ty)


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(ast_tree_mod.Param)
spec std.collections.vec.Vec(ast_tree_mod.Capture)


spec std.core.option.Option(ast_tree_mod.Ty)
spec std.core.option.Option(ident_mod.Ident)
spec std.core.option.Option(ops_mod.CallMode)
spec std.core.option.Option(Vec_Capture)


public function write_box_ty(
    it: interner_mod.Interner,
    b: Box_Ty,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
    write_expr_fn: function(it: interner_mod.Interner, expr: ast_tree_mod.Expr, out: mutable Vec_u8.Vec, allocator: Allocator) -> () with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ()
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    ty_codec_mod.write_ty(it, Box_Ty.get(b), mutable out, allocator, write_expr_fn)?
}

public function read_box_ty(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
    read_expr_fn: function(bytes: [u8], cur: mutable prim_mod.Reader, it: mutable interner_mod.Interner, allocator: Allocator) -> ast_tree_mod.Expr with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> Box_Ty
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let t = ty_read_mod.read_ty(bytes, mutable cur, mutable it, allocator, read_expr_fn)?
    return Box_Ty.new(take t, allocator)?
}

public function write_box_pat(
    it: interner_mod.Interner,
    b: Box_Pat,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
    write_expr_fn: function(it: interner_mod.Interner, expr: ast_tree_mod.Expr, out: mutable Vec_u8.Vec, allocator: Allocator) -> () with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ()
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    pat_codec_mod.write_pat(it, Box_Pat.get(b), mutable out, allocator, write_expr_fn)?
}

public function read_box_pat(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
    read_expr_fn: function(bytes: [u8], cur: mutable prim_mod.Reader, it: mutable interner_mod.Interner, allocator: Allocator) -> ast_tree_mod.Expr with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> Box_Pat
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let p = pat_codec_mod.read_pat(bytes, mutable cur, mutable it, allocator, read_expr_fn)?
    return Box_Pat.new(take p, allocator)?
}

public function write_option_ty(
    opt: Option_Ty,
    it: interner_mod.Interner,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
    write_expr_fn: function(it: interner_mod.Interner, expr: ast_tree_mod.Expr, out: mutable Vec_u8.Vec, allocator: Allocator) -> () with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ()
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    match opt {
        case .some(let t) => {
            prim_mod.push_bool(mutable out, true, allocator)?
            ty_codec_mod.write_ty(it, t, mutable out, allocator, write_expr_fn)?
        }
        case .none => prim_mod.push_bool(mutable out, false, allocator)?
    }
}

public function read_option_ty(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
    read_expr_fn: function(bytes: [u8], cur: mutable prim_mod.Reader, it: mutable interner_mod.Interner, allocator: Allocator) -> ast_tree_mod.Expr with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> Option_Ty
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let present = prim_mod.read_bool(bytes, mutable cur)?
    if present {
        return Option_Ty.some(value: ty_read_mod.read_ty(bytes, mutable cur, mutable it, allocator, read_expr_fn)?)
    }
    return Option_Ty.none
}

public function write_param(
    it: interner_mod.Interner,
    param: ast_tree_mod.Param,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
    write_expr_fn: function(it: interner_mod.Interner, expr: ast_tree_mod.Expr, out: mutable Vec_u8.Vec, allocator: Allocator) -> () with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ()
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    ast_codec_mod.write_span(param.span, mutable out, allocator)?
    ast_codec_mod.write_ident(it, param.name, mutable out, allocator)?
    ast_ops_mod.write_param_mode(param.mode, mutable out, allocator)?
    ty_codec_mod.write_ty(it, param.ty, mutable out, allocator, write_expr_fn)?
}

public function read_param(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
    read_expr_fn: function(bytes: [u8], cur: mutable prim_mod.Reader, it: mutable interner_mod.Interner, allocator: Allocator) -> ast_tree_mod.Expr with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ast_tree_mod.Param
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let span = ast_codec_mod.read_span(bytes, mutable cur)?
    let name = ast_codec_mod.read_ident(bytes, mutable cur, mutable it, allocator)?
    let mode = ast_ops_mod.read_param_mode(bytes, mutable cur)?
    let ty = ty_read_mod.read_ty(bytes, mutable cur, mutable it, allocator, read_expr_fn)?
    return ast_tree_mod.Param { span: span, name: name, mode: mode, ty: ty }
}

public function write_param_vec(
    params: Vec_Param.Vec,
    it: interner_mod.Interner,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
    write_expr_fn: function(it: interner_mod.Interner, expr: ast_tree_mod.Expr, out: mutable Vec_u8.Vec, allocator: Allocator) -> () with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> ()
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let n = Vec_Param.len(params)
    prim_mod.push_u32_le(mutable out, n as u32 wrapping, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        write_param(it, Vec_Param.at(params, i), mutable out, allocator, write_expr_fn)?
        i += 1
    }
}

public function read_param_vec(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
    read_expr_fn: function(bytes: [u8], cur: mutable prim_mod.Reader, it: mutable interner_mod.Interner, allocator: Allocator) -> ast_tree_mod.Expr with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence},
) -> Vec_Param.Vec
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let n = prim_mod.read_u32_le(bytes, mutable cur)? as usize
    uninit params: Vec_Param.Vec
    Vec_Param.new(init params, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let p = read_param(bytes, mutable cur, mutable it, allocator, read_expr_fn)?
        Vec_Param.push(mutable params, take p, allocator)?
        i += 1
    }
    return params
}

public function write_capture(
    it: interner_mod.Interner,
    capture: ast_tree_mod.Capture,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    ast_codec_mod.write_span(capture.span, mutable out, allocator)?
    ast_codec_mod.write_ident(it, capture.name, mutable out, allocator)?
    ast_ops_mod.write_capture_mode(capture.mode, mutable out, allocator)?
}

public function read_capture(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> ast_tree_mod.Capture
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError}
{
    let span = ast_codec_mod.read_span(bytes, mutable cur)?
    let name = ast_codec_mod.read_ident(bytes, mutable cur, mutable it, allocator)?
    let mode = ast_ops_mod.read_capture_mode(bytes, mutable cur)?
    return ast_tree_mod.Capture { span: span, name: name, mode: mode }
}

public function write_capture_vec(
    captures: Vec_Capture.Vec,
    it: interner_mod.Interner,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_Capture.len(captures)
    prim_mod.push_u32_le(mutable out, n as u32 wrapping, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        write_capture(it, Vec_Capture.at(captures, i), mutable out, allocator)?
        i += 1
    }
}

public function read_capture_vec(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> Vec_Capture.Vec
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError}
{
    let n = prim_mod.read_u32_le(bytes, mutable cur)? as usize
    uninit captures: Vec_Capture.Vec
    Vec_Capture.new(init captures, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let c = read_capture(bytes, mutable cur, mutable it, allocator)?
        Vec_Capture.push(mutable captures, take c, allocator)?
        i += 1
    }
    return captures
}

public function write_option_vec_capture(
    opt: Option_Vec_Capture,
    it: interner_mod.Interner,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match opt {
        case .some(let captures) => {
            prim_mod.push_bool(mutable out, true, allocator)?
            write_capture_vec(captures, it, mutable out, allocator)?
        }
        case .none => prim_mod.push_bool(mutable out, false, allocator)?
    }
}

public function read_option_vec_capture(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> Option_Vec_Capture
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError}
{
    let present = prim_mod.read_bool(bytes, mutable cur)?
    if present {
        return Option_Vec_Capture.some(value: read_capture_vec(bytes, mutable cur, mutable it, allocator)?)
    }
    return Option_Vec_Capture.none
}

public function write_option_ident(
    name: Option_Ident,
    it: interner_mod.Interner,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match name {
        case .some(let value) => {
            prim_mod.push_bool(mutable out, true, allocator)?
            ast_codec_mod.write_ident(it, value, mutable out, allocator)?
        }
        case .none => prim_mod.push_bool(mutable out, false, allocator)?
    }
}

public function read_option_ident(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> Option_Ident
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError}
{
    let present = prim_mod.read_bool(bytes, mutable cur)?
    if present {
        return Option_Ident.some(value: ast_codec_mod.read_ident(bytes, mutable cur, mutable it, allocator)?)
    }
    return Option_Ident.none
}

public function write_option_call_mode(
    mode: Option_CallMode,
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match mode {
        case .some(let m) => {
            prim_mod.push_bool(mutable out, true, allocator)?
            ast_ops_mod.write_call_mode(m, mutable out, allocator)?
        }
        case .none => prim_mod.push_bool(mutable out, false, allocator)?
    }
}

public function read_option_call_mode(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
) -> Option_CallMode
    with {err: error_mod.CacheError}
{
    let present = prim_mod.read_bool(bytes, mutable cur)?
    if present {
        return Option_CallMode.some(value: ast_ops_mod.read_call_mode(bytes, mutable cur)?)
    }
    return Option_CallMode.none
}

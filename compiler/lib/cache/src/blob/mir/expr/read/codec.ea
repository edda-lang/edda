    let n = prim_mod.read_u32_le(bytes, mutable cur)? as usize
    uninit args: Vec_SpawnArg.Vec
    Vec_SpawnArg.new(init args, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let a = read_spawn_arg(bytes, mutable cur, mutable it, allocator)?
        Vec_SpawnArg.push(mutable args, take a, allocator)?
        i += 1

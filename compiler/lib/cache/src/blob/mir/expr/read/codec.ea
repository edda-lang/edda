    return args
}

public function read_fstring_seg(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> ast_tree_mod.FStringSeg
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ast_tree_mod.FStringSeg.text(sym: symbol_codec_mod.read_symbol(bytes, mutable cur, mutable it, allocator)?)
        case 1 => ast_tree_mod.FStringSeg.interp(expr: read_box_expr(bytes, mutable cur, mutable it, allocator)?)
        case _ => raise error_mod.CacheError.body_parse(message: "unknown FStringSeg tag")
    }
}

public function read_fstring_seg_vec(
    bytes: [u8],
    cur: mutable prim_mod.Reader,
    it: mutable interner_mod.Interner,
    allocator: Allocator,
) -> Vec_FStringSeg.Vec
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError, divergence}
{
    let n = prim_mod.read_u32_le(bytes, mutable cur)? as usize
    uninit segments: Vec_FStringSeg.Vec
    Vec_FStringSeg.new(init segments, allocator)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let s = read_fstring_seg(bytes, mutable cur, mutable it, allocator)?
        Vec_FStringSeg.push(mutable segments, take s, allocator)?
        i += 1
    }
    return segments
}

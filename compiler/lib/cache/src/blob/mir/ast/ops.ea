public function write_return_mode(m: ops_mod.ReturnMode, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match m {
        case .by_value => 0
        case .let_     => 1
        case .mutable_ => 2
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_return_mode(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.ReturnMode
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ops_mod.ReturnMode.by_value
        case 1 => ops_mod.ReturnMode.let_
        case 2 => ops_mod.ReturnMode.mutable_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown ReturnMode tag")
    }
}


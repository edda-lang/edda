public function write_assign_op(op: ops_mod.AssignOp, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match op {
        case .plain   => 0
        case .add     => 1
        case .sub     => 2
        case .mul     => 3
        case .div     => 4
        case .mod     => 5
        case .bit_and => 6
        case .bit_or  => 7
        case .bit_xor => 8
        case .shl     => 9
        case .shr     => 10
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_assign_op(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.AssignOp
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0  => ops_mod.AssignOp.plain
        case 1  => ops_mod.AssignOp.add
        case 2  => ops_mod.AssignOp.sub
        case 3  => ops_mod.AssignOp.mul
        case 4  => ops_mod.AssignOp.div
        case 5  => ops_mod.AssignOp.mod
        case 6  => ops_mod.AssignOp.bit_and
        case 7  => ops_mod.AssignOp.bit_or
        case 8  => ops_mod.AssignOp.bit_xor
        case 9  => ops_mod.AssignOp.shl
        case 10 => ops_mod.AssignOp.shr
        case _  => raise error_mod.CacheError.body_parse(message: "unknown AssignOp tag")
    }
}

public function write_refinement_kind(k: ops_mod.RefinementKind, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match k {
        case .where_     => 0
        case .requires_  => 1
        case .ensures_   => 2
        case .decreases_ => 3
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_refinement_kind(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.RefinementKind
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ops_mod.RefinementKind.where_
        case 1 => ops_mod.RefinementKind.requires_
        case 2 => ops_mod.RefinementKind.ensures_
        case 3 => ops_mod.RefinementKind.decreases_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown RefinementKind tag")
    }
}

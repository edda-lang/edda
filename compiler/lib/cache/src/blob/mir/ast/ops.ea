public function write_cast_mode(m: ops_mod.CastMode, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match m {
        case .trap        => 0
        case .wrapping_    => 1
        case .saturating_  => 2
        case .checked_     => 3
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_cast_mode(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.CastMode
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ops_mod.CastMode.trap
        case 1 => ops_mod.CastMode.wrapping_
        case 2 => ops_mod.CastMode.saturating_
        case 3 => ops_mod.CastMode.checked_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown CastMode tag")
    }
}



module cache.blob.mir.ast.ops

import std.mem.alloc
import std.collections.vec
import syntax.ast.ops as ops_mod
import local.error as error_mod
import local.blob.mir.prim as prim_mod


spec std.collections.vec.Vec(u8)


public function write_bin_op(op: ops_mod.BinOp, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match op {
        case .add       => 0
        case .sub       => 1
        case .mul       => 2
        case .div       => 3
        case .mod       => 4
        case .wrap_add  => 5
        case .wrap_sub  => 6
        case .wrap_mul  => 7
        case .sat_add   => 8
        case .sat_sub   => 9
        case .sat_mul   => 10
        case .check_add => 11
        case .check_sub => 12
        case .check_mul => 13
        case .check_mod => 14
        case .eq        => 15
        case .ne        => 16
        case .lt        => 17
        case .le        => 18
        case .gt        => 19
        case .ge        => 20
        case .and       => 21
        case .or        => 22
        case .bit_and   => 23
        case .bit_or    => 24
        case .bit_xor   => 25
        case .shl       => 26
        case .shr       => 27
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_bin_op(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.BinOp
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0  => ops_mod.BinOp.add
        case 1  => ops_mod.BinOp.sub
        case 2  => ops_mod.BinOp.mul
        case 3  => ops_mod.BinOp.div
        case 4  => ops_mod.BinOp.mod
        case 5  => ops_mod.BinOp.wrap_add
        case 6  => ops_mod.BinOp.wrap_sub
        case 7  => ops_mod.BinOp.wrap_mul
        case 8  => ops_mod.BinOp.sat_add
        case 9  => ops_mod.BinOp.sat_sub
        case 10 => ops_mod.BinOp.sat_mul
        case 11 => ops_mod.BinOp.check_add
        case 12 => ops_mod.BinOp.check_sub
        case 13 => ops_mod.BinOp.check_mul
        case 14 => ops_mod.BinOp.check_mod
        case 15 => ops_mod.BinOp.eq
        case 16 => ops_mod.BinOp.ne
        case 17 => ops_mod.BinOp.lt
        case 18 => ops_mod.BinOp.le
        case 19 => ops_mod.BinOp.gt
        case 20 => ops_mod.BinOp.ge
        case 21 => ops_mod.BinOp.and
        case 22 => ops_mod.BinOp.or
        case 23 => ops_mod.BinOp.bit_and
        case 24 => ops_mod.BinOp.bit_or
        case 25 => ops_mod.BinOp.bit_xor
        case 26 => ops_mod.BinOp.shl
        case 27 => ops_mod.BinOp.shr
        case _  => raise error_mod.CacheError.body_parse(message: "unknown BinOp tag")
    }
}

public function write_un_op(op: ops_mod.UnOp, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match op {
        case .neg     => 0
        case .not     => 1
        case .bit_not => 2
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_un_op(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.UnOp
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ops_mod.UnOp.neg
        case 1 => ops_mod.UnOp.not
        case 2 => ops_mod.UnOp.bit_not
        case _ => raise error_mod.CacheError.body_parse(message: "unknown UnOp tag")
    }
}

public function write_range_kind(k: ops_mod.RangeKind, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match k {
        case .half_open => 0
        case .closed    => 1
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_range_kind(bytes: [u8], cur: mutable prim_mod.Reader) -> ops_mod.RangeKind
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => ops_mod.RangeKind.half_open
        case 1 => ops_mod.RangeKind.closed
        case _ => raise error_mod.CacheError.body_parse(message: "unknown RangeKind tag")
    }
}


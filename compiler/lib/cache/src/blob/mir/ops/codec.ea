
module cache.blob.mir.ops.codec

import std.mem.alloc
import std.collections.vec
import hir.def as def_mod
import mir.id.block as block_mod
import mir.rvalue as rvalue_mod
import mir.term as term_mod
import mir.body.model as body_model_mod
import local.error as error_mod
import local.blob.mir.prim as prim_mod


spec std.collections.vec.Vec(u8)


public function write_mutability(m: body_model_mod.Mutability, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match m {
        case .immutable_ => 0
        case .mutable_   => 1
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_mutability(bytes: [u8], cur: mutable prim_mod.Reader) -> body_model_mod.Mutability
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => body_model_mod.Mutability.immutable_
        case 1 => body_model_mod.Mutability.mutable_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown Mutability tag")
    }
}

public function write_consumption(c: body_model_mod.Consumption, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match c {
        case .copy_   => 0
        case .move_   => 1
        case .linear_ => 2
        case .affine_ => 3
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_consumption(bytes: [u8], cur: mutable prim_mod.Reader) -> body_model_mod.Consumption
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => body_model_mod.Consumption.copy_
        case 1 => body_model_mod.Consumption.move_
        case 2 => body_model_mod.Consumption.linear_
        case 3 => body_model_mod.Consumption.affine_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown Consumption tag")
    }
}

public function write_float_width(w: rvalue_mod.FloatWidth, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match w {
        case .f32_ => 0
        case .f64_ => 1
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_float_width(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.FloatWidth
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.FloatWidth.f32_
        case 1 => rvalue_mod.FloatWidth.f64_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown FloatWidth tag")
    }
}

public function write_overflow_mode(m: rvalue_mod.OverflowMode, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match m {
        case .trapping    => 0
        case .wrapping_   => 1
        case .saturating_ => 2
        case .checked_    => 3
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_overflow_mode(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.OverflowMode
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.OverflowMode.trapping
        case 1 => rvalue_mod.OverflowMode.wrapping_
        case 2 => rvalue_mod.OverflowMode.saturating_
        case 3 => rvalue_mod.OverflowMode.checked_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown OverflowMode tag")
    }
}

public function write_un_op(op: rvalue_mod.MUnOp, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match op {
        case .neg     => 0
        case .not_    => 1
        case .bit_not => 2
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_un_op(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.MUnOp
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.MUnOp.neg
        case 1 => rvalue_mod.MUnOp.not_
        case 2 => rvalue_mod.MUnOp.bit_not
        case _ => raise error_mod.CacheError.body_parse(message: "unknown MUnOp tag")
    }
}

public function write_borrow_kind(k: rvalue_mod.BorrowKind, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let tag: u8 = match k {
        case .shared   => 0
        case .mutable_ => 1
    }
    prim_mod.push_u8(mutable out, tag, allocator)?
}

public function read_borrow_kind(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.BorrowKind
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.BorrowKind.shared
        case 1 => rvalue_mod.BorrowKind.mutable_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown BorrowKind tag")
    }
}

public function write_cast_kind(k: rvalue_mod.CastKind, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    match k {
        case .int_to_int(let mode) => {
            prim_mod.push_u8(mutable out, 0, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
        }
        case .int_to_float => prim_mod.push_u8(mutable out, 1, allocator)?
        case .float_to_int(let mode) => {
            prim_mod.push_u8(mutable out, 2, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
        }
        case .float_to_float => prim_mod.push_u8(mutable out, 3, allocator)?
        case .bool_to_int    => prim_mod.push_u8(mutable out, 4, allocator)?
    }
}

public function read_cast_kind(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.CastKind
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.CastKind.int_to_int(mode: read_overflow_mode(bytes, mutable cur)?)
        case 1 => rvalue_mod.CastKind.int_to_float
        case 2 => rvalue_mod.CastKind.float_to_int(mode: read_overflow_mode(bytes, mutable cur)?)
        case 3 => rvalue_mod.CastKind.float_to_float
        case 4 => rvalue_mod.CastKind.bool_to_int
        case _ => raise error_mod.CacheError.body_parse(message: "unknown CastKind tag")
    }
}

public function write_aggregate_kind(k: rvalue_mod.AggregateKind, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    match k {
        case .tuple => prim_mod.push_u8(mutable out, 0, allocator)?
        case .record(let def) => {
            prim_mod.push_u8(mutable out, 1, allocator)?
            prim_mod.push_u32_le(mutable out, def.raw, allocator)?
        }
        case .variant(let def, let variant_idx) => {
            prim_mod.push_u8(mutable out, 2, allocator)?
            prim_mod.push_u32_le(mutable out, def.raw, allocator)?
            prim_mod.push_u32_le(mutable out, variant_idx, allocator)?
        }
        case .array => prim_mod.push_u8(mutable out, 3, allocator)?
    }
}

public function read_aggregate_kind(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.AggregateKind
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.AggregateKind.tuple
        case 1 => rvalue_mod.AggregateKind.record(def: def_mod.DefId { raw: prim_mod.read_u32_le(bytes, mutable cur)? })
        case 2 => {
            let def = def_mod.DefId { raw: prim_mod.read_u32_le(bytes, mutable cur)? }
            let variant_idx = prim_mod.read_u32_le(bytes, mutable cur)?
            rvalue_mod.AggregateKind.variant(def: def, variant_idx: variant_idx)
        }
        case 3 => rvalue_mod.AggregateKind.array
        case _ => raise error_mod.CacheError.body_parse(message: "unknown AggregateKind tag")
    }
}

public function write_unwind_action(a: term_mod.UnwindAction, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    match a {
        case .propagate => prim_mod.push_u8(mutable out, 0, allocator)?
        case .handler(let block) => {
            prim_mod.push_u8(mutable out, 1, allocator)?
            prim_mod.push_u32_le(mutable out, block.raw, allocator)?
        }
        case .unreachable_ => prim_mod.push_u8(mutable out, 2, allocator)?
    }
}

public function read_unwind_action(bytes: [u8], cur: mutable prim_mod.Reader) -> term_mod.UnwindAction
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => term_mod.UnwindAction.propagate
        case 1 => term_mod.UnwindAction.handler(block: block_mod.BlockId { raw: prim_mod.read_u32_le(bytes, mutable cur)? })
        case 2 => term_mod.UnwindAction.unreachable_
        case _ => raise error_mod.CacheError.body_parse(message: "unknown UnwindAction tag")
    }
}

public function write_bin_op(op: rvalue_mod.MBinOp, out: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    match op {
        case .add(let mode) => {
            prim_mod.push_u8(mutable out, 0, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
        }
        case .sub(let mode) => {
            prim_mod.push_u8(mutable out, 1, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
        }
        case .mul(let mode) => {
            prim_mod.push_u8(mutable out, 2, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
        }
        case .div(let mode, let proven_nonzero, let proven_no_overflow) => {
            prim_mod.push_u8(mutable out, 3, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
            prim_mod.push_bool(mutable out, proven_nonzero, allocator)?
            prim_mod.push_bool(mutable out, proven_no_overflow, allocator)?
        }
        case .mod_(let mode, let proven_nonzero, let proven_no_overflow) => {
            prim_mod.push_u8(mutable out, 4, allocator)?
            write_overflow_mode(mode, mutable out, allocator)?
            prim_mod.push_bool(mutable out, proven_nonzero, allocator)?
            prim_mod.push_bool(mutable out, proven_no_overflow, allocator)?
        }
        case .bit_and     => prim_mod.push_u8(mutable out, 5, allocator)?
        case .bit_or      => prim_mod.push_u8(mutable out, 6, allocator)?
        case .bit_xor     => prim_mod.push_u8(mutable out, 7, allocator)?
        case .shl         => prim_mod.push_u8(mutable out, 8, allocator)?
        case .shr         => prim_mod.push_u8(mutable out, 9, allocator)?
        case .eq          => prim_mod.push_u8(mutable out, 10, allocator)?
        case .ne          => prim_mod.push_u8(mutable out, 11, allocator)?
        case .lt          => prim_mod.push_u8(mutable out, 12, allocator)?
        case .le          => prim_mod.push_u8(mutable out, 13, allocator)?
        case .gt          => prim_mod.push_u8(mutable out, 14, allocator)?
        case .ge          => prim_mod.push_u8(mutable out, 15, allocator)?
        case .logical_and => prim_mod.push_u8(mutable out, 16, allocator)?
        case .logical_or  => prim_mod.push_u8(mutable out, 17, allocator)?
    }
}

public function read_bin_op(bytes: [u8], cur: mutable prim_mod.Reader) -> rvalue_mod.MBinOp
    with {err: error_mod.CacheError}
{
    let tag = prim_mod.read_u8(bytes, mutable cur)?
    return match tag {
        case 0 => rvalue_mod.MBinOp.add(mode: read_overflow_mode(bytes, mutable cur)?)
        case 1 => rvalue_mod.MBinOp.sub(mode: read_overflow_mode(bytes, mutable cur)?)
        case 2 => rvalue_mod.MBinOp.mul(mode: read_overflow_mode(bytes, mutable cur)?)
        case 3 => {
            let mode = read_overflow_mode(bytes, mutable cur)?
            let proven_nonzero = prim_mod.read_bool(bytes, mutable cur)?
            let proven_no_overflow = prim_mod.read_bool(bytes, mutable cur)?
            rvalue_mod.MBinOp.div(mode: mode, proven_nonzero: proven_nonzero, proven_no_overflow: proven_no_overflow)
        }
        case 4 => {
            let mode = read_overflow_mode(bytes, mutable cur)?
            let proven_nonzero = prim_mod.read_bool(bytes, mutable cur)?
            let proven_no_overflow = prim_mod.read_bool(bytes, mutable cur)?
            rvalue_mod.MBinOp.mod_(mode: mode, proven_nonzero: proven_nonzero, proven_no_overflow: proven_no_overflow)
        }
        case 5  => rvalue_mod.MBinOp.bit_and
        case 6  => rvalue_mod.MBinOp.bit_or
        case 7  => rvalue_mod.MBinOp.bit_xor
        case 8  => rvalue_mod.MBinOp.shl
        case 9  => rvalue_mod.MBinOp.shr
        case 10 => rvalue_mod.MBinOp.eq
        case 11 => rvalue_mod.MBinOp.ne
        case 12 => rvalue_mod.MBinOp.lt
        case 13 => rvalue_mod.MBinOp.le
        case 14 => rvalue_mod.MBinOp.gt
        case 15 => rvalue_mod.MBinOp.ge
        case 16 => rvalue_mod.MBinOp.logical_and
        case 17 => rvalue_mod.MBinOp.logical_or
        case _  => raise error_mod.CacheError.body_parse(message: "unknown MBinOp tag")
    }
}

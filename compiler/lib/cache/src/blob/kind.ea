
module cache.blob.kind

import std.core.option

spec std.core.option.Option(BlobKind)

derive eq, hash, ord, clone, debug for BlobKind


public type BlobKind {
    case ast
    case typecheck
    case proofs
    case ir
    case obj
}


public stable function tag(k: BlobKind) -> u8 {
    return match k {
        case .ast       => 0
        case .typecheck => 1
        case .proofs    => 2
        case .ir        => 3
        case .obj       => 4
    }
}

public function from_tag(t: u8) -> Option_BlobKind {
    return match t {
        case 0 => Option_BlobKind.some(value: BlobKind.ast)
        case 1 => Option_BlobKind.some(value: BlobKind.typecheck)
        case 2 => Option_BlobKind.some(value: BlobKind.proofs)
        case 3 => Option_BlobKind.some(value: BlobKind.ir)
        case 4 => Option_BlobKind.some(value: BlobKind.obj)
        case _ => Option_BlobKind.none
    }
}


module cache.toon.emit.write

import std.collections.vec
import std.core.fmt
import std.core.option
import std.mem.alloc
import std.text.string

spec std.collections.vec.Vec(u8)
spec std.core.option.Option(String)


public type Writer {
    out: Vec_u8
    indent: usize
    commented_mode: bool
}


public function new(out: init Writer, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit buf: Vec_u8.Vec
    Vec_u8.new(init buf, allocator)?
    out = Writer { out: buf, indent: 0, commented_mode: false }
}

public function commented(out: init Writer, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit buf: Vec_u8.Vec
    Vec_u8.new(init buf, allocator)?
    out = Writer { out: buf, indent: 0, commented_mode: true }
}


public function comment(w: mutable Writer, text: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if w.commented_mode {
        panic("toon.write.comment: cannot emit \\ comment in commented mode (use bare)")
    }
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    Vec_u8.push(mutable w.out, 92, allocator)?
    Vec_u8.push(mutable w.out, 32, allocator)?
    push_str(mutable w.out, text, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
}

public function bare(w: mutable Writer, text: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    push_str(mutable w.out, text, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
}

public function blank_line(w: mutable Writer, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if w.commented_mode {
        Vec_u8.push(mutable w.out, 47, allocator)?
        Vec_u8.push(mutable w.out, 47, allocator)?
    }
    Vec_u8.push(mutable w.out, 10, allocator)?
}


public function scalar(w: mutable Writer, key: String, value: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    push_str(mutable w.out, key, allocator)?
    Vec_u8.push(mutable w.out, 58, allocator)?
    Vec_u8.push(mutable w.out, 32, allocator)?
    write_scalar_value(mutable w.out, value, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
}

public function empty_list(w: mutable Writer, key: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    push_str(mutable w.out, key, allocator)?
    push_str(mutable w.out, ": []", allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
}

public function block_open(w: mutable Writer, key: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    push_str(mutable w.out, key, allocator)?
    Vec_u8.push(mutable w.out, 58, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
    w.indent = w.indent + 1
}

public function block_close(w: mutable Writer) -> () {
    w.indent = w.indent -| 1
}


public function list_with_schema_open(
    w: mutable Writer,
    key: String,
    field_names_joined: String,
    count: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    push_str(mutable w.out, key, allocator)?
    Vec_u8.push(mutable w.out, 91, allocator)?
    push_str(mutable w.out, fmt.usize_to_string(count, allocator)?, allocator)?
    Vec_u8.push(mutable w.out, 93, allocator)?
    Vec_u8.push(mutable w.out, 123, allocator)?
    push_str(mutable w.out, field_names_joined, allocator)?
    Vec_u8.push(mutable w.out, 125, allocator)?
    Vec_u8.push(mutable w.out, 58, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
    w.indent = w.indent + 1
}

public function list_with_schema_close(w: mutable Writer) -> () {
    w.indent = w.indent -| 1
}


public function list_item_open(
    w: mutable Writer,
    first_key: String,
    first_value: String,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    Vec_u8.push(mutable w.out, 45, allocator)?
    Vec_u8.push(mutable w.out, 32, allocator)?
    push_str(mutable w.out, first_key, allocator)?
    Vec_u8.push(mutable w.out, 58, allocator)?
    Vec_u8.push(mutable w.out, 32, allocator)?
    write_scalar_value(mutable w.out, first_value, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
    w.indent = w.indent + 1
}

public function list_item_close(w: mutable Writer) -> () {
    w.indent = w.indent -| 1
}

public function list_item_scalar(w: mutable Writer, value: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_prefix_and_indent(mutable w.out, w.commented_mode, w.indent, allocator)?
    Vec_u8.push(mutable w.out, 45, allocator)?
    Vec_u8.push(mutable w.out, 32, allocator)?
    write_scalar_value(mutable w.out, value, allocator)?
    Vec_u8.push(mutable w.out, 10, allocator)?
}


public function finish(w: take Writer, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let buf: [u8] = Vec_u8.into_array(take w.out, allocator)?
    return string.from_owned_utf8(take buf)
}


function write_prefix_and_indent(
    out: mutable Vec_u8.Vec,
    commented_mode: bool,
    indent: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if commented_mode {
        Vec_u8.push(mutable out, 47, allocator)?
        Vec_u8.push(mutable out, 47, allocator)?
        Vec_u8.push(mutable out, 32, allocator)?
    }
    push_spaces(mutable out, indent * 2, allocator)?
}

function push_spaces(out: mutable Vec_u8.Vec, n: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        Vec_u8.push(mutable out, 32, allocator)?
        i += 1
    }
}

function push_str(out: mutable Vec_u8.Vec, s: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.extend_from_slice(mutable out, s.bytes(), allocator)?
}


function write_scalar_value(out: mutable Vec_u8.Vec, value: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    if value_needs_quoting(value) {
        Vec_u8.push(mutable out, 34, allocator)?
        write_quoted_body(mutable out, value.bytes(), 0, allocator)?
        Vec_u8.push(mutable out, 34, allocator)?
    } else {
        push_str(mutable out, value, allocator)?
    }
}

function write_quoted_body(
    out: mutable Vec_u8.Vec,
    bytes: [u8],
    i: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires i <= bytes.len()
    decreases bytes.len() - i
{
    if i >= bytes.len() { return () }
    let b = bytes[i]
    if b == 34 || b == 92 {
        Vec_u8.push(mutable out, 92, allocator)?
    }
    Vec_u8.push(mutable out, b, allocator)?
    return write_quoted_body(mutable out, bytes, i + 1, allocator)?
}

function value_needs_quoting(s: String) -> bool {
    let bytes = s.bytes()
    if bytes.len() == 0 { return true }
    return scan_for_special(bytes, 0)
}

function scan_for_special(bytes: [u8], i: usize) -> bool
    requires i <= bytes.len()
    decreases bytes.len() - i
{
    if i >= bytes.len() { return false }
    if is_special_scalar_byte(bytes[i]) { return true }
    return scan_for_special(bytes, i + 1)
}

function is_special_scalar_byte(b: u8) -> bool {
    if b == 9 || b == 10 || b == 13 || b == 32 { return true }
    if b == 34 || b == 35 || b == 44 || b == 58 { return true }
    if b == 91 || b == 92 || b == 93 || b == 123 || b == 125 { return true }
    return false
}

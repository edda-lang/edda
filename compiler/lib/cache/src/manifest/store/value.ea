
module cache.manifest.store.value

import std.collections.vec
import std.core.option
import std.mem.alloc
import std.text.string
import std.time.calendar
import local.addr.hash as hash_mod
import local.tier.tier as tier_mod

spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(ArtifactEntry)
spec std.collections.vec.Vec(ArgumentEntry)
spec std.core.option.Option(ArgumentKind)
spec std.core.option.Option(calendar.DateTime)

derive eq, hash, ord, clone, debug for ArgumentKind


public stable function schema_version() -> u32 {
    return 1
}

public stable function artifact_field_count() -> usize {
    return 7
}


public type ArgumentKind {
    case type_
    case effect_row
    case primitive_value
    case user_value
}

public type ArgumentEntry {
    kind: ArgumentKind
    value: String
}

public type ArtifactInputs {
    body_version: hash_mod.BodyVersion
    spec_qualified_name: String
    argument_tuple: Vec_ArgumentEntry
    nested_deps: Vec_String
}

public type ReachableFrom {
    sources: Vec_String
    artifacts: Vec_String
}

public type ArtifactEntry {
    path: String
    hash: hash_mod.ArtifactHash
    short_name: String
    tier: tier_mod.Tier
    inputs: ArtifactInputs
    reachable_from: ReachableFrom
    generated_at: calendar.DateTime
}

public type Manifest {
    schema_version: u32
    project: String
    generated_at: calendar.DateTime
    last_gc_run: Option_DateTime
    artifacts: Vec_ArtifactEntry
}


public stable function argument_kind_name(k: ArgumentKind) -> String {
    return match k {
        case .type_           => "type"
        case .effect_row      => "effect_row"
        case .primitive_value => "primitive_value"
        case .user_value      => "user_value"
    }
}

public function argument_kind_from_name(s: String) -> Option_ArgumentKind {
    if string.equals(s, "type") {
        return Option_ArgumentKind.some(value: ArgumentKind.type_)
    }
    if string.equals(s, "effect_row") {
        return Option_ArgumentKind.some(value: ArgumentKind.effect_row)
    }
    if string.equals(s, "primitive_value") {
        return Option_ArgumentKind.some(value: ArgumentKind.primitive_value)
    }
    if string.equals(s, "user_value") {
        return Option_ArgumentKind.some(value: ArgumentKind.user_value)
    }
    return Option_ArgumentKind.none
}


public function empty_manifest(project: take String, now: calendar.DateTime, allocator: Allocator) -> Manifest
    with {allocator, err: alloc.AllocError}
{
    uninit artifacts: Vec_ArtifactEntry.Vec
    Vec_ArtifactEntry.new(init artifacts, allocator)?
    return Manifest {
        schema_version: schema_version(),
        project: project,
        generated_at: now,
        last_gc_run: Option_DateTime.none,
        artifacts: artifacts,
    }
}

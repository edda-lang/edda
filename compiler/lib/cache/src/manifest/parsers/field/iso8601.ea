
module cache.manifest.parsers.field.iso8601

import std.mem.alloc
import std.core.option
import std.text.string
import std.time.calendar
import std.time.iso8601
import local.error as error_mod

spec std.core.option.Option(iso8601.ParsedDateTime)

public function parse_iso8601_utc(
    s: String,
    source_path: String,
    allocator: Allocator,
) -> calendar.DateTime
    with {allocator, err: alloc.AllocError, err: error_mod.CacheError}
{
    let bytes = s.bytes()
    let parsed: iso8601.ParsedDateTime = match parse_iso8601_into_option(bytes, allocator)? {
        case .some(let dt) => dt
        case .none => raise error_mod.CacheError.manifest_parse(
            path: source_path,
            line: 0,
            message: string.clone("invalid ISO-8601 timestamp", allocator)?,
        )
    }
    if parsed.value.offset_minutes != 0 {
        raise error_mod.CacheError.manifest_parse(
            path: source_path,
            line: 0,
            message: string.clone("timestamp is not UTC", allocator)?,
        )
    }
    return parsed.value
}

function parse_iso8601_into_option(
    bytes: [u8],
    allocator: Allocator,
) -> Option_ParsedDateTime
    with {allocator, err: alloc.AllocError}
{
    let h = handle err: iso8601.Iso8601Error as _e ->
        Option_ParsedDateTime.none
    {
        Option_ParsedDateTime.some(value: iso8601.parse(bytes, 0)?)
    }
    return h
}

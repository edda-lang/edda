
module cache.manifest.parsers.bodyversion

import local.error as error_mod

public function parse_body_version_byte(s: String, source_path: String) -> u8
    with {err: error_mod.CacheError}
{
    let bytes = s.bytes()
    if bytes.len() != 4 { raise_parse_err(source_path, "malformed body_version")? }
    if bytes[0] != 48 { raise_parse_err(source_path, "malformed body_version")? }
    if bytes[1] != 120 && bytes[1] != 88 { raise_parse_err(source_path, "malformed body_version")? }
    let hi = parse_hex_nibble(bytes[2], source_path)?
    let lo = parse_hex_nibble(bytes[3], source_path)?
    return (hi << 4) | lo
}

function parse_hex_nibble(b: u8, source_path: String) -> u8
    with {err: error_mod.CacheError}
{
    if b >= 48 && b <= 57  { return b - 48 }
    if b >= 97 && b <= 102 { return (b - 97) + 10 }
    if b >= 65 && b <= 70  { return (b - 65) + 10 }
    raise_parse_err(source_path, "malformed hex digit")?
    return 0
}

function raise_parse_err(source_path: String, msg: String) -> ()
    with {err: error_mod.CacheError}
{
    raise error_mod.CacheError.manifest_parse(
        path: source_path,
        line: 0,
        message: msg,
    )
}

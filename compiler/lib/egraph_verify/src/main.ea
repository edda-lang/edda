
module egraph_verify.main

import std.mem.alloc
import std.io.stream
import local.scenario.scenario as scenario_mod


public function main(out: Stdout, errout: Stderr, allocator: Allocator) -> i32
    with {out, errout, allocator, panic}
{
    let code = handle err: alloc.AllocError as ae -> fail_alloc(errout, ae) {
        run(out, errout, allocator)?
    }
    return code
}


function run(out: Stdout, errout: Stderr, allocator: Allocator) -> i32
    with {out, errout, allocator, err: alloc.AllocError, panic}
{
    if scenario_mod.run_all(out, errout, allocator)? {
        return 0
    }
    return 1
}


function fail_alloc(errout: Stderr, e: alloc.AllocError) -> i32
    with {errout}
{
    match e {
        case .out_of_memory => errout.eprint_line("egraph-verify: out of memory")
    }
    return 70
}


module target.capability

import std.core.option
import std.collections.slice
import target.os as os_mod
import target.triple as triple_mod

spec std.core.option.Option(Capability)

derive eq, hash, ord, clone, debug for Capability


public type Capability {
    case filesystem
    case read_only_filesystem
    case sandboxed_filesystem
    case network
    case localhost_network
    case restricted_network
    case clock
    case monotonic_clock
    case random
    case deterministic_random
    case allocator
    case bounded_allocator
    case executor
    case stdin
    case stdout
    case stderr
    case subprocess
    case dom
    case window
    case extension_content
    case extension_worker
    case debugger
}


public stable function name(c: Capability) -> String {
    return match c {
        case .filesystem            => "Filesystem"
        case .read_only_filesystem  => "ReadOnlyFilesystem"
        case .sandboxed_filesystem  => "SandboxedFilesystem"
        case .network               => "Network"
        case .localhost_network     => "LocalhostNetwork"
        case .restricted_network    => "RestrictedNetwork"
        case .clock                 => "Clock"
        case .monotonic_clock       => "MonotonicClock"
        case .random                => "Random"
        case .deterministic_random  => "DeterministicRandom"
        case .allocator             => "Allocator"
        case .bounded_allocator     => "BoundedAllocator"
        case .executor              => "Executor"
        case .stdin                 => "Stdin"
        case .stdout                => "Stdout"
        case .stderr                => "Stderr"
        case .subprocess            => "Subprocess"
        case .dom                   => "Dom"
        case .window                => "Window"
        case .extension_content     => "ExtensionContent"
        case .extension_worker      => "ExtensionWorker"
        case .debugger              => "Debugger"
    }
}


public function ordinal(c: Capability) -> u32 {
    return match c {
        case .filesystem            => 0 as u32
        case .read_only_filesystem  => 1 as u32
        case .sandboxed_filesystem  => 2 as u32
        case .network               => 3 as u32
        case .localhost_network     => 4 as u32
        case .restricted_network    => 5 as u32
        case .clock                 => 6 as u32
        case .monotonic_clock       => 7 as u32
        case .random                => 8 as u32
        case .deterministic_random  => 9 as u32
        case .allocator             => 10 as u32
        case .bounded_allocator     => 11 as u32
        case .executor              => 12 as u32
        case .stdin                 => 13 as u32
        case .stdout                => 14 as u32
        case .stderr                => 15 as u32
        case .subprocess            => 16 as u32
        case .dom                   => 17 as u32
        case .window                => 18 as u32
        case .extension_content     => 19 as u32
        case .extension_worker      => 20 as u32
        case .debugger              => 21 as u32
    }
}


public function from_name_bytes(name: [u8]) -> Option_Capability.Option {
    if slice.eq_u8(name, "Filesystem".bytes())          { return Option_Capability.some(value: Capability.filesystem) }
    if slice.eq_u8(name, "ReadOnlyFilesystem".bytes())  { return Option_Capability.some(value: Capability.read_only_filesystem) }
    if slice.eq_u8(name, "SandboxedFilesystem".bytes()) { return Option_Capability.some(value: Capability.sandboxed_filesystem) }
    if slice.eq_u8(name, "Network".bytes())             { return Option_Capability.some(value: Capability.network) }
    if slice.eq_u8(name, "LocalhostNetwork".bytes())    { return Option_Capability.some(value: Capability.localhost_network) }
    if slice.eq_u8(name, "RestrictedNetwork".bytes())   { return Option_Capability.some(value: Capability.restricted_network) }
    if slice.eq_u8(name, "Clock".bytes())               { return Option_Capability.some(value: Capability.clock) }
    if slice.eq_u8(name, "MonotonicClock".bytes())      { return Option_Capability.some(value: Capability.monotonic_clock) }
    if slice.eq_u8(name, "Random".bytes())              { return Option_Capability.some(value: Capability.random) }
    if slice.eq_u8(name, "DeterministicRandom".bytes()) { return Option_Capability.some(value: Capability.deterministic_random) }
    if slice.eq_u8(name, "Allocator".bytes())           { return Option_Capability.some(value: Capability.allocator) }
    if slice.eq_u8(name, "BoundedAllocator".bytes())    { return Option_Capability.some(value: Capability.bounded_allocator) }
    if slice.eq_u8(name, "Executor".bytes())            { return Option_Capability.some(value: Capability.executor) }
    if slice.eq_u8(name, "Stdin".bytes())               { return Option_Capability.some(value: Capability.stdin) }
    if slice.eq_u8(name, "Stdout".bytes())              { return Option_Capability.some(value: Capability.stdout) }
    if slice.eq_u8(name, "Stderr".bytes())              { return Option_Capability.some(value: Capability.stderr) }
    if slice.eq_u8(name, "Subprocess".bytes())          { return Option_Capability.some(value: Capability.subprocess) }
    if slice.eq_u8(name, "Dom".bytes())                 { return Option_Capability.some(value: Capability.dom) }
    if slice.eq_u8(name, "Window".bytes())              { return Option_Capability.some(value: Capability.window) }
    if slice.eq_u8(name, "ExtensionContent".bytes())    { return Option_Capability.some(value: Capability.extension_content) }
    if slice.eq_u8(name, "ExtensionWorker".bytes())     { return Option_Capability.some(value: Capability.extension_worker) }
    if slice.eq_u8(name, "Debugger".bytes())            { return Option_Capability.some(value: Capability.debugger) }
    return Option_Capability.none
}


public stable function supports(triple: triple_mod.TargetTriple, cap: Capability) -> bool {
    let target_os = triple_mod.os(triple)
    return match target_os {
        case .browser => browser_supports(cap)
        case _        => match cap {
            case .subprocess        => is_hosted_os(target_os)
            case .debugger          => is_hosted_os(target_os)
            case .executor          => true
            case .dom               => false
            case .window            => false
            case .extension_content => false
            case .extension_worker  => false
            case _                  => is_not_bare_metal(target_os)
        }
    }
}


stable function browser_supports(cap: Capability) -> bool {
    return match cap {
        case .filesystem           => false
        case .read_only_filesystem => false
        case .sandboxed_filesystem => false
        case .network              => false
        case .localhost_network    => false
        case .restricted_network   => false
        case .subprocess           => false
        case .debugger             => false
        case _                     => true
    }
}


stable function is_hosted_os(o: os_mod.Os) -> bool {
    return match o {
        case .linux      => true
        case .windows    => true
        case .macos      => true
        case .freebsd    => true
        case .wasi       => false
        case .bare_metal => false
        case .browser    => false
    }
}

stable function is_not_bare_metal(o: os_mod.Os) -> bool {
    return match o {
        case .bare_metal => false
        case _           => true
    }
}


module target.abi

import std.core.option
import std.text.string

spec std.core.option.Option(AbiVariant)

derive eq, hash, ord, clone, debug for AbiVariant

public type AbiVariant {
    case gnu
    case musl
    case msvc
    case darwin
    case none
    case wasi_preview1
}

public stable function name(a: AbiVariant) -> String {
    return match a {
        case .gnu           => "gnu"
        case .musl          => "musl"
        case .msvc          => "msvc"
        case .darwin        => "darwin"
        case .none          => "none"
        case .wasi_preview1 => "wasi-preview1"
    }
}

public function from_name(s: String) -> Option_AbiVariant {
    if string.equals(s, "gnu")           { return Option_AbiVariant.some(value: AbiVariant.gnu) }
    if string.equals(s, "musl")          { return Option_AbiVariant.some(value: AbiVariant.musl) }
    if string.equals(s, "msvc")          { return Option_AbiVariant.some(value: AbiVariant.msvc) }
    if string.equals(s, "darwin")        { return Option_AbiVariant.some(value: AbiVariant.darwin) }
    if string.equals(s, "none")          { return Option_AbiVariant.some(value: AbiVariant.none) }
    if string.equals(s, "wasi-preview1") { return Option_AbiVariant.some(value: AbiVariant.wasi_preview1) }
    return Option_AbiVariant.none
}

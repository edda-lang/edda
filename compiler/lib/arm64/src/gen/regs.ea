
module arm64.gen.regs

import std.core.option
import ir.lir.tree.reg as lir_reg_mod


spec std.core.option.Option(GpReg)


derive eq, hash, debug for GpReg


public type GpReg {
    case x0
    case x1
    case x2
    case x3
    case x4
    case x5
    case x6
    case x7
    case x8
    case x9
    case x10
    case x11
    case x12
    case x13
    case x14
    case x15
    case x16
    case x17
    case x18
    case x19
    case x20
    case x21
    case x22
    case x23
    case x24
    case x25
    case x26
    case x27
    case x28
    case x29
    case x30
}

public stable function gp_reg_num(r: GpReg) -> u8 {
    return match r {
        case .x0  => 0 as u8
        case .x1  => 1 as u8
        case .x2  => 2 as u8
        case .x3  => 3 as u8
        case .x4  => 4 as u8
        case .x5  => 5 as u8
        case .x6  => 6 as u8
        case .x7  => 7 as u8
        case .x8  => 8 as u8
        case .x9  => 9 as u8
        case .x10 => 10 as u8
        case .x11 => 11 as u8
        case .x12 => 12 as u8
        case .x13 => 13 as u8
        case .x14 => 14 as u8
        case .x15 => 15 as u8
        case .x16 => 16 as u8
        case .x17 => 17 as u8
        case .x18 => 18 as u8
        case .x19 => 19 as u8
        case .x20 => 20 as u8
        case .x21 => 21 as u8
        case .x22 => 22 as u8
        case .x23 => 23 as u8
        case .x24 => 24 as u8
        case .x25 => 25 as u8
        case .x26 => 26 as u8
        case .x27 => 27 as u8
        case .x28 => 28 as u8
        case .x29 => 29 as u8
        case .x30 => 30 as u8
    }
}


public stable function preg_of(r: GpReg) -> lir_reg_mod.PReg
    ensures result.raw == (gp_reg_num(r) as u32)
{
    return lir_reg_mod.PReg { raw: gp_reg_num(r) as u32 }
}

public stable function gp_of_preg(p: lir_reg_mod.PReg) -> Option_GpReg.Option {
    if p.raw == 0  { return Option_GpReg.some(value: GpReg.x0) }
    if p.raw == 1  { return Option_GpReg.some(value: GpReg.x1) }
    if p.raw == 2  { return Option_GpReg.some(value: GpReg.x2) }
    if p.raw == 3  { return Option_GpReg.some(value: GpReg.x3) }
    if p.raw == 4  { return Option_GpReg.some(value: GpReg.x4) }
    if p.raw == 5  { return Option_GpReg.some(value: GpReg.x5) }
    if p.raw == 6  { return Option_GpReg.some(value: GpReg.x6) }
    if p.raw == 7  { return Option_GpReg.some(value: GpReg.x7) }
    if p.raw == 8  { return Option_GpReg.some(value: GpReg.x8) }
    if p.raw == 9  { return Option_GpReg.some(value: GpReg.x9) }
    if p.raw == 10 { return Option_GpReg.some(value: GpReg.x10) }
    if p.raw == 11 { return Option_GpReg.some(value: GpReg.x11) }
    if p.raw == 12 { return Option_GpReg.some(value: GpReg.x12) }
    if p.raw == 13 { return Option_GpReg.some(value: GpReg.x13) }
    if p.raw == 14 { return Option_GpReg.some(value: GpReg.x14) }
    if p.raw == 15 { return Option_GpReg.some(value: GpReg.x15) }
    if p.raw == 16 { return Option_GpReg.some(value: GpReg.x16) }
    if p.raw == 17 { return Option_GpReg.some(value: GpReg.x17) }
    if p.raw == 18 { return Option_GpReg.some(value: GpReg.x18) }
    if p.raw == 19 { return Option_GpReg.some(value: GpReg.x19) }
    if p.raw == 20 { return Option_GpReg.some(value: GpReg.x20) }
    if p.raw == 21 { return Option_GpReg.some(value: GpReg.x21) }
    if p.raw == 22 { return Option_GpReg.some(value: GpReg.x22) }
    if p.raw == 23 { return Option_GpReg.some(value: GpReg.x23) }
    if p.raw == 24 { return Option_GpReg.some(value: GpReg.x24) }
    if p.raw == 25 { return Option_GpReg.some(value: GpReg.x25) }
    if p.raw == 26 { return Option_GpReg.some(value: GpReg.x26) }
    if p.raw == 27 { return Option_GpReg.some(value: GpReg.x27) }
    if p.raw == 28 { return Option_GpReg.some(value: GpReg.x28) }
    if p.raw == 29 { return Option_GpReg.some(value: GpReg.x29) }
    if p.raw == 30 { return Option_GpReg.some(value: GpReg.x30) }
    return Option_GpReg.none
}


module arm64.abi.shared

import std.collections.vec
import std.core.option

import span.loc.pos.span as span_mod
import types.pass.ty as ty_mod

import ir.lir.tree.body as lir_body_mod
import ir.lir.tree.reg as lir_reg_mod
import ir.lir.error as lir_error_mod
import ir.hlir.op as hlir_op_mod


spec std.collections.vec.Vec(lir_reg_mod.LirVReg)


spec std.core.option.Option(lir_reg_mod.PReg)


public function pin_vreg_at(
    body: mutable lir_body_mod.LirBody,
    idx: usize,
    preg: lir_reg_mod.PReg,
) -> ()
    with {err: lir_error_mod.LirError}
    requires idx < Vec_LirVReg.len(body.vregs)
{
    let current = Vec_LirVReg.at(body.vregs, idx)
    match current.pin {
        case .none => {
            let updated = lir_reg_mod.LirVReg {
                class_: current.class_,
                pin: Option_PReg.some(value: preg),
                ty: current.ty,
                size: current.size,
                int_width: current.int_width,
                int_signed: current.int_signed,
                is_ref: current.is_ref,
            }
            Vec_LirVReg.set_at(mutable body.vregs, idx, take updated)
        }
        case .some(let existing) => {
            if existing.raw != preg.raw {
                raise lir_error_mod.LirError.internal_lowering_invariant(
                    at: span_mod.dummy(),
                    message: "arm64.abi: pin conflict — vreg already pinned to a different PReg (copy-insertion not yet implemented)",
                )
            }
        }
    }
}


public function pinned_vreg(class_: lir_reg_mod.RegClass, preg: lir_reg_mod.PReg) -> lir_reg_mod.LirVReg {
    return lir_reg_mod.LirVReg {
        class_: class_,
        pin: Option_PReg.some(value: preg),
        ty: ty_mod.error(),
        size: lir_reg_mod.register_width(),
        int_width: lir_reg_mod.register_width(),
        int_signed: false,
        is_ref: false,
    }
}


public function unpinned_vreg(class_: lir_reg_mod.RegClass) -> lir_reg_mod.LirVReg {
    return lir_reg_mod.LirVReg {
        class_: class_,
        pin: Option_PReg.none,
        ty: ty_mod.error(),
        size: lir_reg_mod.register_width(),
        int_width: lir_reg_mod.register_width(),
        int_signed: false,
        is_ref: false,
    }
}


public function stack_flags() -> hlir_op_mod.OpFlags {
    return hlir_op_mod.OpFlags {
        overflow_safe: false,
        in_bounds: true,
        nonzero_divisor: false,
        range_safe: true,
        intrinsic: hlir_op_mod.Intrinsic.none,
        div_overflow: hlir_op_mod.DivOverflow.trap,
        div_overflow_safe: false,
        extern_call: false,
        extern_ret_size: 0 as u32,
    }
}


public function vreg_size_at(body: lir_body_mod.LirBody, idx: usize) -> u32 {
    if idx == 0 { return lir_reg_mod.register_width() }
    if idx >= Vec_LirVReg.len(body.vregs) { return lir_reg_mod.register_width() }
    return Vec_LirVReg.at(body.vregs, idx).size
}


public function align8_u32(value: u32) -> u32 {
    let rem = value % (8 as u32)
    if rem == (0 as u32) { return value }
    return (value - rem) + (8 as u32)
}

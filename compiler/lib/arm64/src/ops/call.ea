
module arm64.ops.call

import std.mem.alloc
import std.collections.vec

import ir.lir.tree.body as lir_body_mod
import ir.lir.tree.reg as lir_reg_mod
import ir.lir.error as lir_error_mod

import local.encoding.branch as branch_mod
import local.abi.misc.regutil as regutil_mod


spec std.collections.vec.Vec(u8)


public function emit_call(
    code: mutable Vec_u8.Vec,
    body: lir_body_mod.LirBody,
    callee: lir_reg_mod.Operand,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, err: lir_error_mod.LirError}
{
    match callee {
        case .vreg(let id) => branch_mod.encode_blr(mutable code, regutil_mod.gp_of_pinned_vreg(body, id)?, allocator)?
        case .preg(let p) => branch_mod.encode_blr(mutable code, regutil_mod.gp_of_preg(p)?, allocator)?
        case .imm(_) => raise regutil_mod.unsupported()
    }
}

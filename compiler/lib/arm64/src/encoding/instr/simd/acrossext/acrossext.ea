    sz: bool,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    fp_across_impl(mutable out, q, 0 as u32, sz, 0x0F as u32, vd, vn, allocator)?
}



module arm64.encoding.instr.simd.acrossext

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.encoding.instr.simd.threesame.threesame as threesame_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function q30(q: bool) -> u32 {
    return if q { (1 as u32) << 30 } else { 0 as u32 }
}

stable function sz22(sz: bool) -> u32 {
    return if sz { (1 as u32) << 22 } else { 0 as u32 }
}


function across_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    u: u32,
    size: u32,
    opcode: u32,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("across_impl: size out of range (admits 0..3)")
    }
    if vd > 31 {
        panic("across_impl: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("across_impl: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E300800 as u32) | q30(q) | ((u & 0x1) << 29) | ((size & 0x3) << 22) | ((opcode & 0x1F) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_smaxv(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    across_impl(mutable out, q, 0 as u32, size as u32, 0x0A as u32, vd, vn, allocator)?
}

public function encode_umaxv(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    across_impl(mutable out, q, 1 as u32, size as u32, 0x0A as u32, vd, vn, allocator)?
}


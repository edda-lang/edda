    across_impl(mutable out, q, 1 as u32, size as u32, 0x1A as u32, vd, vn, allocator)?
}


function fp_across_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    o1: u32,
    sz: bool,
    opcode: u32,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if vd > 31 {
        panic("fp_across_impl: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("fp_across_impl: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x2E300800 as u32) | q30(q) | ((o1 & 0x1) << 23) | sz22(sz) | ((opcode & 0x1F) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


public function encode_ext(
    out: mutable Vec_u8.Vec,
    q: bool,
    index: u8,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if q {
        if index > 15 {
            panic("encode_ext: index out of range (admits 0..15 when q)")
        }
    } else {
        if index > 7 {
            panic("encode_ext: index out of range (admits 0..7 when !q)")
        }
    }
    if vd > 31 {
        panic("encode_ext: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_ext: vn out of range (admits 0..31)")
    }
    if vm > 31 {
        panic("encode_ext: vm out of range (admits 0..31)")
    }
    let instr: u32 = (0x2E000000 as u32) | q30(q) | (vreg5(vm) << 16) | (((index as u32) & 0xF) << 11) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


function pairwise_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    u: u32,
    size: u32,
    opcode: u32,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if vd > 31 {
        panic("pairwise_impl: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("pairwise_impl: vn out of range (admits 0..31)")
    }
    if vm > 31 {
        panic("pairwise_impl: vm out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E200400 as u32) | q30(q) | ((u & 0x1) << 29) | ((size & 0x3) << 22) | (vreg5(vm) << 16) | ((opcode & 0x1F) << 11) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_addp_vec(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let q: bool = threesame_mod.vec_arr_q(arr) == (1 as u32)
    pairwise_impl(mutable out, q, 0 as u32, threesame_mod.vec_arr_size(arr), 0x17 as u32, vd, vn, vm, allocator)?
}

public function encode_faddp_vec(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let q: bool = threesame_mod.vec_arr_q(arr) == (1 as u32)
    let size: u32 = if threesame_mod.vec_arr_size(arr) == (3 as u32) { 1 as u32 } else { 0 as u32 }
    pairwise_impl(mutable out, q, 1 as u32, size, 0x1A as u32, vd, vn, vm, allocator)?
}

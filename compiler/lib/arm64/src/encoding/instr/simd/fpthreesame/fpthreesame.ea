
module arm64.encoding.instr.simd.fpthreesame

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.encoding.instr.simd.threesame.threesame as threesame_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function qbit(q: u32) -> u32 {
    return (q & 0x1) << 30
}

stable function fp_arr_sz(a: threesame_mod.VecArr) -> u32 {
    return match a {
        case .b8 => 0 as u32
        case .b16 => 0 as u32
        case .h4 => 0 as u32
        case .h8 => 0 as u32
        case .s2 => 0 as u32
        case .s4 => 0 as u32
        case .d1 => 1 as u32
        case .d2 => 1 as u32
    }
}


function fp_three_same_impl(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    a: u32,
    u: u32,
    opcode: u32,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let is_legal = match arr {
        case .s2 => true
        case .s4 => true
        case .d2 => true
        case _ => false
    }
    if !is_legal {
        panic("fp_three_same_impl: arrangement out of range (admits s2, s4, d2)")
    }
    if rd > 31 {
        panic("fp_three_same_impl: rd out of range (admits 0..31)")
    }
    if rn > 31 {
        panic("fp_three_same_impl: rn out of range (admits 0..31)")
    }
    if rm > 31 {
        panic("fp_three_same_impl: rm out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E200400 as u32) | qbit(threesame_mod.vec_arr_q(arr)) | ((u & 0x1) << 29) | ((a & 0x1) << 23) | (fp_arr_sz(arr) << 22) | (vreg5(rm) << 16) | ((opcode & 0x1F) << 11) | (vreg5(rn) << 5) | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_fadd_vec(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    fp_three_same_impl(mutable out, arr, 0 as u32, 0 as u32, 0x1A as u32, rd, rn, rm, allocator)?
}


public function encode_st1_lane_s(
    out: mutable Vec_u8.Vec,
    q: bool,
    vt: u8,
    qss: u8,
    rn_base: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if vt > 31 {
        panic("encode_st1_lane_s: vt out of range (admits 0..31)")
    }
    if qss > 7 {
        panic("encode_st1_lane_s: qss out of range (admits 0..7: Q at bit 2, S at bit 1, size at bit 0)")
    }
    let q_field = (((qss as u32) >> 2) & 0x1) << 30
    let s_field = (((qss as u32) >> 1) & 0x1) << 12
    let size_field = ((qss as u32) & 0x1) << 10
    let instr: u32 = (0x0D008000 as u32) | q30(q) | q_field | s_field | size_field | (dp_mod.reg5(rn_base) << 5) | vreg5(vt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ld1_lane_s(
    out: mutable Vec_u8.Vec,
    q: bool,
    vt: u8,
    qss: u8,
    rn_base: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if vt > 31 {
        panic("encode_ld1_lane_s: vt out of range (admits 0..31)")
    }
    if qss > 7 {
        panic("encode_ld1_lane_s: qss out of range (admits 0..7: Q at bit 2, S at bit 1, size at bit 0)")
    }
    let q_field = (((qss as u32) >> 2) & 0x1) << 30
    let s_field = (((qss as u32) >> 1) & 0x1) << 12
    let size_field = ((qss as u32) & 0x1) << 10
    let instr: u32 = (0x0D408000 as u32) | q30(q) | q_field | s_field | size_field | (dp_mod.reg5(rn_base) << 5) | vreg5(vt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


    }
    if size > 3 {
        panic("encode_ld1_multi: size out of range (admits 0..3)")
    }
    let instr: u32 = (0x0C407000 as u32) | q30(q) | size1110(size) | (dp_mod.reg5(rn_base) << 5) | vreg5(vt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


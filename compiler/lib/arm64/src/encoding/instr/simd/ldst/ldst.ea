
module arm64.encoding.instr.simd.ldst

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function q30(q: bool) -> u32 {
    return if q { (1 as u32) << 30 } else { 0 as u32 }
}

stable function size1110(size: u8) -> u32 {
    return ((size as u32) & 0x3) << 10
}


public function encode_st1_multi(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vt: u8,
    rn_base: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if vt > 31 {
        panic("encode_st1_multi: vt out of range (admits 0..31)")
    }
    if size > 3 {
        panic("encode_st1_multi: size out of range (admits 0..3)")
    }
    let instr: u32 = (0x0C007000 as u32) | q30(q) | size1110(size) | (dp_mod.reg5(rn_base) << 5) | vreg5(vt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ld1_multi(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vt: u8,
    rn_base: regs_mod.GpReg,

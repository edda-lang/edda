
module arm64.encoding.instr.simd.lane

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function q30(q: bool) -> u32 {
    return if q { (1 as u32) << 30 } else { 0 as u32 }
}


public function encode_dup_elt(
    out: mutable Vec_u8.Vec,
    q: bool,
    imm5: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm5 > 31 {
        panic("encode_dup_elt: imm5 out of range (admits 0..31)")
    }
    if vd > 31 {
        panic("encode_dup_elt: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_dup_elt: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E000400 as u32) | q30(q) | ((imm5 as u32) << 16) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_dup_gp(
    out: mutable Vec_u8.Vec,
    q: bool,
    imm5: u8,
    vd: u8,
    rn_gp: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm5 > 31 {
        panic("encode_dup_gp: imm5 out of range (admits 0..31)")
    }
    if vd > 31 {
        panic("encode_dup_gp: vd out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E000400 as u32) | q30(q) | ((imm5 as u32) << 16) | ((1 as u32) << 11) | (dp_mod.reg5(rn_gp) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ins_elt(
    out: mutable Vec_u8.Vec,
    imm5: u8,
    imm4: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm5 > 31 {
        panic("encode_ins_elt: imm5 out of range (admits 0..31)")
    }
    if imm4 > 15 {
        panic("encode_ins_elt: imm4 out of range (admits 0..15)")
    }
    if vd > 31 {
        panic("encode_ins_elt: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_ins_elt: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x6E000400 as u32) | ((imm5 as u32) << 16) | ((imm4 as u32) << 11) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ins_gp(
    out: mutable Vec_u8.Vec,
    imm5: u8,

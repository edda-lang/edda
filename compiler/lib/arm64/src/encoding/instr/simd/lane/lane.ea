public function encode_addv(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("encode_addv: size out of range (admits 0..3)")
    }
    if vd > 31 {
        panic("encode_addv: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_addv: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E300800 as u32) | q30(q) | ((size as u32) << 22) | ((0x1B as u32) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_uaddlv(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vd: u8,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("encode_uaddlv: size out of range (admits 0..3)")
    }
    if vd > 31 {
        panic("encode_uaddlv: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_uaddlv: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E300800 as u32) | q30(q) | ((1 as u32) << 29) | ((size as u32) << 22) | ((0x03 as u32) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_saddlv(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,

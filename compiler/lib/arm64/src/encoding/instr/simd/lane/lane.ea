    }
    if vd > 31 {
        panic("encode_saddlv: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_saddlv: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E300800 as u32) | q30(q) | ((size as u32) << 22) | ((0x03 as u32) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


function simd_permute(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    opcode: u8,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("simd_permute: size out of range (admits 0..3)")
    }
    if opcode > 7 {
        panic("simd_permute: opcode out of range (admits 0..7)")
    }
    if vd > 31 {
        panic("simd_permute: vd out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("simd_permute: vn out of range (admits 0..31)")
    }
    if vm > 31 {
        panic("simd_permute: vm out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E000800 as u32) | q30(q) | ((size as u32) << 22) | (vreg5(vm) << 16) | ((opcode as u32) << 12) | (vreg5(vn) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_zip1(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    vd: u8,
    vn: u8,
    vm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    simd_permute(mutable out, q, size, 3 as u8, vd, vn, vm, allocator)?
}


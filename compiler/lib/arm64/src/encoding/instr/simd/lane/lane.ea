    }
    if vd > 31 {
        panic("encode_ins_gp: vd out of range (admits 0..31)")
    }
    let instr: u32 = (0x4E001C00 as u32) | ((imm5 as u32) << 16) | (dp_mod.reg5(rn_gp) << 5) | vreg5(vd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_umov(
    out: mutable Vec_u8.Vec,
    q: bool,
    imm5: u8,
    rd_gp: regs_mod.GpReg,
    vn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm5 > 31 {
        panic("encode_umov: imm5 out of range (admits 0..31)")
    }
    if vn > 31 {
        panic("encode_umov: vn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E000400 as u32) | q30(q) | ((imm5 as u32) << 16) | ((7 as u32) << 11) | (vreg5(vn) << 5) | dp_mod.reg5(rd_gp)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


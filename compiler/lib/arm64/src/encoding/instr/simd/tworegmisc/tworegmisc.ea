function narrow_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    u: u32,
    size: u8,
    opcode: u32,
    rd: u8,
    rn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 2 {
        panic("narrow_impl: size out of range (admits 0..2)")
    }
    two_reg_misc_impl(mutable out, qbit_to_q(q), u, size as u32, opcode, rd, rn, allocator)?
}

stable function qbit_to_q(q: bool) -> u32 {
    return if q { 1 as u32 } else { 0 as u32 }
}


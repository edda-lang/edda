function fp_q(a: threesame_mod.VecArr) -> u32 {
    return match a {
        case .b8 => 0 as u32
        case .b16 => 0 as u32
        case .h4 => 0 as u32
        case .h8 => 0 as u32
        case .s2 => 0 as u32
        case .s4 => 1 as u32
        case .d1 => 0 as u32
        case .d2 => 1 as u32
    }
}

function fp_sz(a: threesame_mod.VecArr) -> u32 {
    return match a {
        case .b8 => 0 as u32
        case .b16 => 0 as u32
        case .h4 => 0 as u32
        case .h8 => 0 as u32
        case .s2 => 0 as u32
        case .s4 => 0 as u32
        case .d1 => 1 as u32
        case .d2 => 1 as u32
    }
}

function fp_arr_legal(a: threesame_mod.VecArr) -> bool {
    return match a {
        case .b8 => false
        case .b16 => false
        case .h4 => false
        case .h8 => false
        case .s2 => true
        case .s4 => true
        case .d1 => false
        case .d2 => true
    }
}

function fp_two_reg_misc(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    u: u32,
    size_hi: u32,
    opcode: u32,
    rd: u8,
    rn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if !fp_arr_legal(arr) {
        panic("fp_two_reg_misc: arrangement out of range (admits s2 s4 d2)")
    }
    let size: u32 = ((size_hi & 0x1) << 1) | fp_sz(arr)
    two_reg_misc_impl(mutable out, fp_q(arr), u, size, opcode, rd, rn, allocator)?
}



module arm64.encoding.instr.simd.tworegmisc

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.encoding.instr.simd.threesame.threesame as threesame_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

function two_reg_misc_impl(
    out: mutable Vec_u8.Vec,
    q: u32,
    u: u32,
    size: u32,
    opcode: u32,
    rd: u8,
    rn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if rd > 31 {
        panic("two_reg_misc_impl: rd out of range (admits 0..31)")
    }
    if rn > 31 {
        panic("two_reg_misc_impl: rn out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E200800 as u32) | ((q & 0x1) << 30) | ((u & 0x1) << 29) | ((size & 0x3) << 22) | ((opcode & 0x1F) << 12) | (vreg5(rn) << 5) | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


public function encode_neg_vec(
    out: mutable Vec_u8.Vec,
    arr: threesame_mod.VecArr,
    rd: u8,
    rn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    two_reg_misc_impl(mutable out, threesame_mod.vec_arr_q(arr), 1 as u32, threesame_mod.vec_arr_size(arr), 0x0B as u32, rd, rn, allocator)?
}


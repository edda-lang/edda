
module arm64.encoding.instr.simd.threediff

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function qbit(q: bool) -> u32 {
    return if q { (1 as u32) << 30 } else { 0 as u32 }
}


function three_diff_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    u: u32,
    size: u8,
    opcode: u32,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if rd > 31 {
        panic("three_diff_impl: rd out of range (admits 0..31)")
    }
    if rn > 31 {
        panic("three_diff_impl: rn out of range (admits 0..31)")
    }
    if rm > 31 {
        panic("three_diff_impl: rm out of range (admits 0..31)")
    }
    if size > 2 {
        panic("three_diff_impl: size out of range (admits 0..2, no 128-bit result)")
    }
    let instr: u32 = (0x0E200000 as u32) | qbit(q) | ((u & 0x1) << 29) | (((size as u32) & 0x3) << 22) | (vreg5(rm) << 16) | ((opcode & 0xF) << 12) | (vreg5(rn) << 5) | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_saddl(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_diff_impl(mutable out, q, 0 as u32, size, 0x0 as u32, rd, rn, rm, allocator)?
}

public function encode_uaddl(
    out: mutable Vec_u8.Vec,
    q: bool,
    size: u8,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_diff_impl(mutable out, q, 1 as u32, size, 0x0 as u32, rd, rn, rm, allocator)?
}


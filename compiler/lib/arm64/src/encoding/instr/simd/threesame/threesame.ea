
module arm64.encoding.instr.simd.threesame

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod


spec std.collections.vec.Vec(u8)


public type VecArr {
    case b8
    case b16
    case h4
    case h8
    case s2
    case s4
    case d1
    case d2
}

derive eq, hash, debug for VecArr

public stable function vec_arr_q(a: VecArr) -> u32 {
    return match a {
        case .b8 => 0 as u32
        case .b16 => 1 as u32
        case .h4 => 0 as u32
        case .h8 => 1 as u32
        case .s2 => 0 as u32
        case .s4 => 1 as u32
        case .d1 => 0 as u32
        case .d2 => 1 as u32
    }
}

public stable function vec_arr_size(a: VecArr) -> u32 {
    return match a {
        case .b8 => 0 as u32
        case .b16 => 0 as u32
        case .h4 => 1 as u32
        case .h8 => 1 as u32
        case .s2 => 2 as u32
        case .s4 => 2 as u32
        case .d1 => 3 as u32
        case .d2 => 3 as u32
    }
}


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function qbit(q: bool) -> u32 {
    return if q { (1 as u32) << 30 } else { 0 as u32 }
}


function three_same_impl(
    out: mutable Vec_u8.Vec,
    q: u32,
    u: u32,
    size: u32,
    opcode: u32,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if rd > 31 {
        panic("three_same_impl: rd out of range (admits 0..31)")
    }
    if rn > 31 {
        panic("three_same_impl: rn out of range (admits 0..31)")
    }
    if rm > 31 {
        panic("three_same_impl: rm out of range (admits 0..31)")
    }
    let instr: u32 = (0x0E200400 as u32) | ((q & 0x1) << 30) | ((u & 0x1) << 29) | ((size & 0x3) << 22) | (vreg5(rm) << 16) | ((opcode & 0x1F) << 11) | (vreg5(rn) << 5) | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_add_vec(
    out: mutable Vec_u8.Vec,
    arr: VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 0 as u32, vec_arr_size(arr), 0x10 as u32, rd, rn, rm, allocator)?
}

public function encode_sub_vec(
    out: mutable Vec_u8.Vec,
    arr: VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 1 as u32, vec_arr_size(arr), 0x10 as u32, rd, rn, rm, allocator)?
}


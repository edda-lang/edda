    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 1 as u32, 0 as u32, 0x03 as u32, rd, rn, rm, allocator)?
}

public function encode_cmeq_vec(
    out: mutable Vec_u8.Vec,
    arr: VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 1 as u32, vec_arr_size(arr), 0x11 as u32, rd, rn, rm, allocator)?
}

public function encode_cmgt_vec(
    out: mutable Vec_u8.Vec,
    arr: VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 0 as u32, vec_arr_size(arr), 0x06 as u32, rd, rn, rm, allocator)?
}

function modified_imm_impl(
    out: mutable Vec_u8.Vec,
    q: bool,
    op: u32,
    abc: u8,
    cmode: u8,
    defgh: u8,
    rd: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if rd > 31 {
        panic("modified_imm_impl: rd out of range (admits 0..31)")
    }
    if cmode > 15 {
        panic("modified_imm_impl: cmode out of range (admits 0..15)")
    }
    if abc > 7 {
        panic("modified_imm_impl: abc out of range (admits 0..7)")
    }
    if defgh > 31 {
        panic("modified_imm_impl: defgh out of range (admits 0..31)")
    }
    let instr: u32 = (0x0F000400 as u32) | qbit(q) | ((op & 0x1) << 29) | (((abc as u32) & 0x7) << 16) | (((cmode as u32) & 0xF) << 12) | (((defgh as u32) & 0x1F) << 5) | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_movi(
    out: mutable Vec_u8.Vec,
    q: bool,
    abc: u8,
    cmode: u8,
    defgh: u8,
    rd: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    modified_imm_impl(mutable out, q, 0 as u32, abc, cmode, defgh, rd, allocator)?
}

public function encode_mvni(
    out: mutable Vec_u8.Vec,
    q: bool,
    abc: u8,
    cmode: u8,
    defgh: u8,
    rd: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    modified_imm_impl(mutable out, q, 1 as u32, abc, cmode, defgh, rd, allocator)?
}

    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 0 as u32, 2 as u32, 0x03 as u32, rd, rn, rm, allocator)?
}


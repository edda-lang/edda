    out: mutable Vec_u8.Vec,
    arr: VecArr,
    rd: u8,
    rn: u8,
    rm: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    three_same_impl(mutable out, vec_arr_q(arr), 0 as u32, vec_arr_size(arr), 0x13 as u32, rd, rn, rm, allocator)?
}


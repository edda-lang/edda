
module arm64.encoding.instr.sys.syscall

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


public function encode_sys(
    out: mutable Vec_u8.Vec,
    op1: u8,
    crn: u8,
    crm: u8,
    op2: u8,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if op1 > 7 {
        panic("encode_sys: op1 out of range (admits 0..7)")
    }
    if crn > 15 {
        panic("encode_sys: crn out of range (admits 0..15)")
    }
    if crm > 15 {
        panic("encode_sys: crm out of range (admits 0..15)")
    }
    if op2 > 7 {
        panic("encode_sys: op2 out of range (admits 0..7)")
    }
    let instr: u32 = (0xD5080000 as u32) | (((op1 as u32) & 0x7) << 16) | (((crn as u32) & 0xF) << 12) | (((crm as u32) & 0xF) << 8) | (((op2 as u32) & 0x7) << 5) | dp_mod.reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_sysl(
    out: mutable Vec_u8.Vec,
    op1: u8,
    crn: u8,
    crm: u8,
    op2: u8,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if op1 > 7 {
        panic("encode_sysl: op1 out of range (admits 0..7)")
    }
    if crn > 15 {
        panic("encode_sysl: crn out of range (admits 0..15)")
    }
    if crm > 15 {
        panic("encode_sysl: crm out of range (admits 0..15)")
    }
    if op2 > 7 {
        panic("encode_sysl: op2 out of range (admits 0..7)")
    }
    let instr: u32 = (0xD5280000 as u32) | (((op1 as u32) & 0x7) << 16) | (((crn as u32) & 0xF) << 12) | (((crm as u32) & 0xF) << 8) | (((op2 as u32) & 0x7) << 5) | dp_mod.reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_paciasp(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD503201F as u32) | (((3 as u32) & 0xF) << 8) | (((1 as u32) & 0x7) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_autiasp(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD503201F as u32) | (((3 as u32) & 0xF) << 8) | (((5 as u32) & 0x7) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_xpaclri(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD503201F as u32) | (((0 as u32) & 0xF) << 8) | (((7 as u32) & 0x7) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_bti(
    out: mutable Vec_u8.Vec,
    targets: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if targets > 3 {
        panic("encode_bti: targets out of range (admits 0..3)")
    }
    let op2: u32 = ((targets as u32) & 0x3) << 1
    let instr: u32 = (0xD503201F as u32) | (((4 as u32) & 0xF) << 8) | ((op2 & 0x7) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_esb(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD503201F as u32) | (((2 as u32) & 0xF) << 8) | (((0 as u32) & 0x7) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

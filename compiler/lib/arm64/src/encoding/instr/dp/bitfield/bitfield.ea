
module arm64.encoding.instr.dp.bitfield

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


function bf(
    out: mutable Vec_u8.Vec,
    base: u32,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    immr: u8,
    imms: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if immr > 63 {
        panic("bf: immr out of range (admits 0..63)")
    }
    if imms > 63 {
        panic("bf: imms out of range (admits 0..63)")
    }
    let nbit: u32 = if is64 { (1 as u32) << 22 } else { 0 as u32 }
    let instr: u32 = base | dp_mod.sf31(is64) | nbit | (((immr as u32) & 0x3F) << 16) | (((imms as u32) & 0x3F) << 10) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_sbfm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    immr: u8,
    imms: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    bf(mutable out, 0x13000000 as u32, is64, rd, rn, immr, imms, allocator)?
}

public function encode_bfm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    immr: u8,
    imms: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    bf(mutable out, 0x33000000 as u32, is64, rd, rn, immr, imms, allocator)?
}

public function encode_ubfm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,

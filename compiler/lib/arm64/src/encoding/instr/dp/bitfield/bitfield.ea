public function encode_sbfiz(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    lsb: u8,
    width: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let datasize = if is64 { 64 as u8 } else { 32 as u8 }
    if width == 0 {
        panic("encode_sbfiz: width out of range (admits 1..datasize)")
    }
    if (lsb as u32) + (width as u32) > (datasize as u32) {
        panic("encode_sbfiz: lsb + width out of range (admits lsb + width <= datasize)")
    }
    let ds = datasize as u32
    let immr = ((ds - (lsb as u32)) % ds) as u8
    let imms = width - 1
    bf(mutable out, 0x13000000 as u32, is64, rd, rn, immr, imms, allocator)?
}


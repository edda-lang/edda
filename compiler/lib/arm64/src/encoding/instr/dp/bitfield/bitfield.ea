}

public function encode_lsl_imm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    shift: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let datasize = if is64 { 64 as u8 } else { 32 as u8 }
    if shift >= datasize {
        panic("encode_lsl_imm: shift out of range (admits 0..datasize-1)")
    }
    let ds = datasize as u32
    let immr = ((ds - (shift as u32)) % ds) as u8
    let imms = (datasize - 1) - shift
    bf(mutable out, 0x53000000 as u32, is64, rd, rn, immr, imms, allocator)?
}

public function encode_lsr_imm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    shift: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let datasize = if is64 { 64 as u8 } else { 32 as u8 }
    if shift >= datasize {
        panic("encode_lsr_imm: shift out of range (admits 0..datasize-1)")
    }
    let imms = datasize - 1
    bf(mutable out, 0x53000000 as u32, is64, rd, rn, shift, imms, allocator)?
}


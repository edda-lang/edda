
module arm64.encoding.instr.dp.dp

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod


spec std.collections.vec.Vec(u8)


public stable function reg5(r: regs_mod.GpReg) -> u32 {
    return (regs_mod.gp_reg_num(r) as u32) & 0x1F
}

public stable function sf31(is64: bool) -> u32 {
    return if is64 { (1 as u32) << 31 } else { 0 as u32 }
}


public function encode_movz_w(
    out: mutable Vec_u8.Vec,
    rd: regs_mod.GpReg,
    imm16: u16,
    hw: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if hw > 1 {
        panic("encode_movz_w: hw out of range (32-bit MOVZ admits hw in {0, 1})")
    }
    let base: u32 = 0x52800000
    let hw_field = (hw as u32) << 21
    let imm_field = (imm16 as u32) << 5
    let rd_field = (regs_mod.gp_reg_num(rd) as u32) & 0x1F
    let instr: u32 = base | hw_field | imm_field | rd_field
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_movz_x(
    out: mutable Vec_u8.Vec,
    rd: regs_mod.GpReg,
    imm16: u16,
    hw: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if hw > 3 {
        panic("encode_movz_x: hw out of range (64-bit MOVZ admits hw in {0, 1, 2, 3})")
    }
    let base: u32 = 0xD2800000
    let hw_field = (hw as u32) << 21
    let imm_field = (imm16 as u32) << 5
    let rd_field = (regs_mod.gp_reg_num(rd) as u32) & 0x1F
    let instr: u32 = base | hw_field | imm_field | rd_field
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_movn(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    imm16: u16,
    hw: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let max_hw = if is64 { 3 as u8 } else { 1 as u8 }
    if hw > max_hw {
        panic("encode_movn: hw out of range")
    }
    let instr: u32 = (0x12800000 as u32) | sf31(is64) | ((hw as u32) << 21) | ((imm16 as u32) << 5) | reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_movk(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    imm16: u16,
    hw: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let max_hw = if is64 { 3 as u8 } else { 1 as u8 }
    if hw > max_hw {
        panic("encode_movk: hw out of range")
    }
    let instr: u32 = (0x72800000 as u32) | sf31(is64) | ((hw as u32) << 21) | ((imm16 as u32) << 5) | reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

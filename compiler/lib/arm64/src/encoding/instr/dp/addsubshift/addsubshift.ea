    with {allocator, err: alloc.AllocError, panic}
{
    addsub_shifted(mutable out, 0x2B000000 as u32, is64, rd, rn, rm, shift, amount, allocator)?
}

public function encode_subs_reg_shift(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    shift: ShiftKind,
    amount: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    addsub_shifted(mutable out, 0x6B000000 as u32, is64, rd, rn, rm, shift, amount, allocator)?
}

public function encode_neg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    shift: ShiftKind,
    amount: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let width: u8 = if is64 { 64 as u8 } else { 32 as u8 }
    if amount >= width {
        panic("encode_neg: shift amount out of range (admits 0..width-1)")
    }
    let instr: u32 = (0x4B000000 as u32) | dp_mod.sf31(is64) | (shift_code(shift) << 22) | (dp_mod.reg5(rm) << 16) | (((amount as u32) & 0x3F) << 10) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_negs(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    shift: ShiftKind,
    amount: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let width: u8 = if is64 { 64 as u8 } else { 32 as u8 }
    if amount >= width {
        panic("encode_negs: shift amount out of range (admits 0..width-1)")
    }
    let instr: u32 = (0x6B000000 as u32) | dp_mod.sf31(is64) | (shift_code(shift) << 22) | (dp_mod.reg5(rm) << 16) | (((amount as u32) & 0x3F) << 10) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

{
    let instr: u32 = (0x9B200000 as u32) | (dp_mod.reg5(rm) << 16) | ((0 as u32) << 15) | (dp_mod.reg5(ra) << 10) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}



module arm64.encoding.instr.dp.addsubext

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


public type ExtendKind {
    case uxtb
    case uxth
    case uxtw
    case uxtx
    case sxtb
    case sxth
    case sxtw
    case sxtx
}

derive eq, hash, debug for ExtendKind

public stable function extend_code(e: ExtendKind) -> u32 {
    return match e {
        case .uxtb => 0 as u32
        case .uxth => 1 as u32
        case .uxtw => 2 as u32
        case .uxtx => 3 as u32
        case .sxtb => 4 as u32
        case .sxth => 5 as u32
        case .sxtw => 6 as u32
        case .sxtx => 7 as u32
    }
}


function addsub_ext(
    out: mutable Vec_u8.Vec,
    base: u32,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm3 > 4 {
        panic("addsub_ext: imm3 out of range (admits 0..4)")
    }
    let instr: u32 = base | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (extend_code(ext) << 13) | (((imm3 as u32) & 0x7) << 10) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_add_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    addsub_ext(mutable out, 0x0B200000 as u32, is64, rd, rn, rm, ext, imm3, allocator)?
}

public function encode_sub_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    addsub_ext(mutable out, 0x4B200000 as u32, is64, rd, rn, rm, ext, imm3, allocator)?
}

public function encode_adds_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    addsub_ext(mutable out, 0x2B200000 as u32, is64, rd, rn, rm, ext, imm3, allocator)?
}

public function encode_subs_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    addsub_ext(mutable out, 0x6B200000 as u32, is64, rd, rn, rm, ext, imm3, allocator)?
}

public function encode_cmp_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm3 > 4 {
        panic("encode_cmp_ext: imm3 out of range (admits 0..4)")
    }
    let instr: u32 = (0x6B200000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (extend_code(ext) << 13) | (((imm3 as u32) & 0x7) << 10) | (dp_mod.reg5(rn) << 5) | (31 as u32)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_cmn_ext(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: ExtendKind,
    imm3: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm3 > 4 {
        panic("encode_cmn_ext: imm3 out of range (admits 0..4)")
    }
    let instr: u32 = (0x2B200000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (extend_code(ext) << 13) | (((imm3 as u32) & 0x7) << 10) | (dp_mod.reg5(rn) << 5) | (31 as u32)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


module arm64.encoding.instr.dp.condcmp

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod
import local.encoding.branch as branch_mod


spec std.collections.vec.Vec(u8)


function ccmp_reg_impl(
    out: mutable Vec_u8.Vec,
    base: u32,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if nzcv > 15 {
        panic("ccmp_reg_impl: nzcv out of range (admits 0..15)")
    }
    let instr: u32 = base
        | dp_mod.sf31(is64)
        | (dp_mod.reg5(rm) << 16)
        | (branch_mod.arm_cond_code(cond) << 12)
        | (dp_mod.reg5(rn) << 5)
        | ((nzcv as u32) & 0xF)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

function ccmp_imm_impl(
    out: mutable Vec_u8.Vec,
    base: u32,
    is64: bool,
    rn: regs_mod.GpReg,
    imm5: u8,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if imm5 > 31 {
        panic("ccmp_imm_impl: imm5 out of range (admits 0..31)")
    }
    if nzcv > 15 {
        panic("ccmp_imm_impl: nzcv out of range (admits 0..15)")
    }
    let instr: u32 = base
        | dp_mod.sf31(is64)
        | (((imm5 as u32) & 0x1F) << 16)
        | (branch_mod.arm_cond_code(cond) << 12)
        | ((1 as u32) << 11)
        | (dp_mod.reg5(rn) << 5)
        | ((nzcv as u32) & 0xF)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ccmp_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    ccmp_reg_impl(mutable out, 0x7A400000 as u32, is64, rn, rm, nzcv, cond, allocator)?
}

public function encode_ccmn_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    ccmp_reg_impl(mutable out, 0x3A400000 as u32, is64, rn, rm, nzcv, cond, allocator)?
}

public function encode_ccmp_imm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    imm5: u8,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    ccmp_imm_impl(mutable out, 0x7A400800 as u32, is64, rn, imm5, nzcv, cond, allocator)?
}

public function encode_ccmn_imm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    imm5: u8,
    nzcv: u8,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    ccmp_imm_impl(mutable out, 0x3A400800 as u32, is64, rn, imm5, nzcv, cond, allocator)?
}

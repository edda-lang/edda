
module arm64.encoding.instr.dp.pcrel

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod


spec std.collections.vec.Vec(u8)


stable function reg5(r: regs_mod.GpReg) -> u32 {
    return (regs_mod.gp_reg_num(r) as u32) & 0x1F
}


function pcrel(
    out: mutable Vec_u8.Vec,
    op_bit: u32,
    rd: regs_mod.GpReg,
    imm21: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let bits = imm21 as u32 wrapping
    let immlo = (bits & 0x3) << 29
    let immhi = ((bits >> 2) & 0x7FFFF) << 5
    let instr: u32 = op_bit | immlo | immhi | reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_adr(
    out: mutable Vec_u8.Vec,
    rd: regs_mod.GpReg,
    imm21: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    pcrel(mutable out, 0x10000000 as u32, rd, imm21, allocator)?
}

public function encode_adrp(
    out: mutable Vec_u8.Vec,
    rd: regs_mod.GpReg,
    imm21: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    pcrel(mutable out, 0x90000000 as u32, rd, imm21, allocator)?
}


module arm64.encoding.instr.dp.condsel

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod
import local.encoding.branch as branch_mod


spec std.collections.vec.Vec(u8)


function invert_cond(c: branch_mod.ArmCond) -> branch_mod.ArmCond {
    return match c {
        case .eq_ => branch_mod.ArmCond.ne_
        case .ne_ => branch_mod.ArmCond.eq_
        case .hs_ => branch_mod.ArmCond.lo_
        case .lo_ => branch_mod.ArmCond.hs_
        case .mi_ => branch_mod.ArmCond.pl_
        case .pl_ => branch_mod.ArmCond.mi_
        case .vs_ => branch_mod.ArmCond.vc_
        case .vc_ => branch_mod.ArmCond.vs_
        case .hi_ => branch_mod.ArmCond.ls_
        case .ls_ => branch_mod.ArmCond.hi_
        case .ge_ => branch_mod.ArmCond.lt_
        case .lt_ => branch_mod.ArmCond.ge_
        case .gt_ => branch_mod.ArmCond.le_
        case .le_ => branch_mod.ArmCond.gt_
        case .al_ => branch_mod.ArmCond.al_
    }
}

function condsel(
    out: mutable Vec_u8.Vec,
    base: u32,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = base | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (branch_mod.arm_cond_code(cond) << 12) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_csel(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    condsel(mutable out, 0x1A800000 as u32, is64, rd, rn, rm, cond, allocator)?
}

public function encode_csinc(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    condsel(mutable out, 0x1A800400 as u32, is64, rd, rn, rm, cond, allocator)?
}

public function encode_csinv(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    condsel(mutable out, 0x5A800000 as u32, is64, rd, rn, rm, cond, allocator)?
}

public function encode_csneg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    condsel(mutable out, 0x5A800400 as u32, is64, rd, rn, rm, cond, allocator)?
}

public function encode_cset(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let inv = invert_cond(cond)
    let instr: u32 = (0x1A800400 as u32) | dp_mod.sf31(is64) | ((31 as u32) << 16) | (branch_mod.arm_cond_code(inv) << 12) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_csetm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let inv = invert_cond(cond)
    let instr: u32 = (0x5A800000 as u32) | dp_mod.sf31(is64) | ((31 as u32) << 16) | (branch_mod.arm_cond_code(inv) << 12) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_cinc(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let inv = invert_cond(cond)
    condsel(mutable out, 0x1A800400 as u32, is64, rd, rn, rn, inv, allocator)?
}

public function encode_cinv(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,

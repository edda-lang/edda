    with {allocator, err: alloc.AllocError}
{
    let inv = invert_cond(cond)
    condsel(mutable out, 0x5A800000 as u32, is64, rd, rn, rn, inv, allocator)?
}

public function encode_cneg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    cond: branch_mod.ArmCond,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let inv = invert_cond(cond)
    condsel(mutable out, 0x5A800400 as u32, is64, rd, rn, rn, inv, allocator)?
}

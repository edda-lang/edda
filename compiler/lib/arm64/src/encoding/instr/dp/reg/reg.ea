public function encode_ands_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    dp_shifted_reg(mutable out, 0x6A000000 as u32, is64, rd, rn, rm, allocator)?
}

public function encode_cmp_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x6B000000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (dp_mod.reg5(rn) << 5) | (31 as u32)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_cmn_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x2B000000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | (dp_mod.reg5(rn) << 5) | (31 as u32)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_mov_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x2A000000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_mvn_reg(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x2A200000 as u32) | dp_mod.sf31(is64) | (dp_mod.reg5(rm) << 16) | ((31 as u32) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

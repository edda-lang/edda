
module arm64.encoding.instr.dp.extr

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod
import local.encoding.instr.dp.dp as dp_mod


spec std.collections.vec.Vec(u8)


public function encode_extr(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    lsb: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let width = if is64 { 64 as u8 } else { 32 as u8 }
    if lsb >= width {
        panic("encode_extr: lsb out of range (admits 0..width-1)")
    }
    let nbit = if is64 { (1 as u32) << 22 } else { 0 as u32 }
    let instr: u32 = (0x13800000 as u32) | dp_mod.sf31(is64) | nbit | (dp_mod.reg5(rm) << 16) | (((lsb as u32) & 0x3F) << 10) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_ror_imm(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rd: regs_mod.GpReg,
    rs: regs_mod.GpReg,
    shift: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    encode_extr(mutable out, is64, rd, rs, rs, shift, allocator)?
}

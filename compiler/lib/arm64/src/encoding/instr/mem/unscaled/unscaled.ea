public function encode_ldursb(
    out: mutable Vec_u8.Vec,
    is64dst: bool,
    rt: regs_mod.GpReg,
    base_reg: regs_mod.GpReg,
    imm9: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let base: u32 = if is64dst { 0x38800000 as u32 } else { 0x38C00000 as u32 }
    ldst_unscaled(mutable out, base, 0 as u32, rt, base_reg, imm9, allocator)?
}

public function encode_ldursh(
    out: mutable Vec_u8.Vec,
    is64dst: bool,
    rt: regs_mod.GpReg,
    base_reg: regs_mod.GpReg,
    imm9: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let base: u32 = if is64dst { 0x78800000 as u32 } else { 0x78C00000 as u32 }
    ldst_unscaled(mutable out, base, 1 as u32, rt, base_reg, imm9, allocator)?
}

public function encode_ldursw(
    out: mutable Vec_u8.Vec,
    rt: regs_mod.GpReg,
    base_reg: regs_mod.GpReg,
    imm9: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    ldst_unscaled(mutable out, 0xB8800000 as u32, 2 as u32, rt, base_reg, imm9, allocator)?
}

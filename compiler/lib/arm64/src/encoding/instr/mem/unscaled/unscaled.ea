    with {allocator, err: alloc.AllocError, panic}
{
    ldst_unscaled(mutable out, 0x78000000 as u32, 1 as u32, rt, base_reg, imm9, allocator)?
}

public function encode_ldurh(
    out: mutable Vec_u8.Vec,
    rt: regs_mod.GpReg,
    base_reg: regs_mod.GpReg,
    imm9: i32,
    allocator: Allocator,

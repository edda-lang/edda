public function encode_ldrsw_reg(
    out: mutable Vec_u8.Vec,
    rt: regs_mod.GpReg,
    base_reg: regs_mod.GpReg,
    rm: regs_mod.GpReg,
    ext: IndexExtend,
    s_bit: bool,
    allocator: Allocator,


module arm64.encoding.instr.mem.atomics.exclusive

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod


spec std.collections.vec.Vec(u8)


stable function reg5(r: regs_mod.GpReg) -> u32 {
    return (regs_mod.gp_reg_num(r) as u32) & 0x1F
}


function excl_impl(
    out: mutable Vec_u8.Vec,
    base: u32,
    size: u32,
    rs: regs_mod.GpReg,
    rt2: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("excl_impl: size out of range (admits 0..3)")
    }
    let instr: u32 = base | (size << 30) | (reg5(rs) << 16) | (reg5(rt2) << 10) | (reg5(rn) << 5) | reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


public function encode_stxr(
    out: mutable Vec_u8.Vec,
    size: u32,
    rs: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    excl_impl(mutable out, 0x08000000 as u32, size, rs, regs_mod.GpReg.x0, rn, rt, allocator)?
}

public function encode_stlxr(
    out: mutable Vec_u8.Vec,
    size: u32,
    rs: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    excl_impl(mutable out, 0x08008000 as u32, size, rs, regs_mod.GpReg.x0, rn, rt, allocator)?
}

public function encode_ldxr(
    out: mutable Vec_u8.Vec,
    size: u32,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("encode_ldxr: size out of range (admits 0..3)")
    }
    let instr: u32 = (0x085F7C00 as u32) | (size << 30) | (reg5(rn) << 5) | reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


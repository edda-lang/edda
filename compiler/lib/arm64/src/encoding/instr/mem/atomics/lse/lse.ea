public function encode_swp(
    out: mutable Vec_u8.Vec,
    size: u32,
    a: bool,
    r: bool,
    rs: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("encode_swp: size out of range (admits 0..3)")
    }
    let a_bit = if a { (1 as u32) << 23 } else { 0 as u32 }
    let r_bit = if r { (1 as u32) << 22 } else { 0 as u32 }
    let instr: u32 = (0x38208000 as u32) | (size << 30) | a_bit | r_bit | (dp_mod.reg5(rs) << 16) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?

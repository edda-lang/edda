public function encode_cas(
    out: mutable Vec_u8.Vec,
    size: u32,
    acquire: bool,
    release: bool,
    rs: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if size > 3 {
        panic("encode_cas: size out of range (admits 0..3)")
    }
    let l_bit = if acquire { (1 as u32) << 22 } else { 0 as u32 }
    let o0_bit = if release { (1 as u32) << 15 } else { 0 as u32 }
    let instr: u32 = (0x08A07C00 as u32) | (size << 30) | l_bit | o0_bit | (dp_mod.reg5(rs) << 16) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_casp(
    out: mutable Vec_u8.Vec,
    is64: bool,
    acquire: bool,
    release: bool,
    rs: regs_mod.GpReg,
    rn: regs_mod.GpReg,
    rt: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    let sz_bit = if is64 { (1 as u32) << 30 } else { 0 as u32 }
    let l_bit = if acquire { (1 as u32) << 22 } else { 0 as u32 }
    let o0_bit = if release { (1 as u32) << 15 } else { 0 as u32 }
    let instr: u32 = (0x08207C00 as u32) | sz_bit | l_bit | o0_bit | (dp_mod.reg5(rs) << 16) | (dp_mod.reg5(rn) << 5) | dp_mod.reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

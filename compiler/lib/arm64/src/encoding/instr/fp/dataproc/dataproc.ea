    }
    if ra > 31 {
        panic("encode_fmadd: ra out of range (admits 0..31)")
    }
    let instr: u32 = (0x1F000000 as u32)
        | ftype22(ftype)
        | (vreg5(rm) << 16)
        | (vreg5(ra) << 10)
        | (vreg5(rn) << 5)
        | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


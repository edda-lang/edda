
module arm64.encoding.instr.fp.dataproc

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function ftype22(ftype: u8) -> u32 {
    return ((ftype as u32) & 0x3) << 22
}


public function encode_fmov_reg(
    out: mutable Vec_u8.Vec,
    ftype: u8,
    rd: u8,
    rn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if ftype > 1 {
        panic("encode_fmov_reg: ftype out of range (admits 0=S, 1=D)")
    }
    if rd > 31 {
        panic("encode_fmov_reg: rd out of range (admits 0..31)")
    }
    if rn > 31 {
        panic("encode_fmov_reg: rn out of range (admits 0..31)")
    }
    let instr: u32 = (0x1E204000 as u32)
        | ftype22(ftype)
        | (vreg5(rn) << 5)
        | vreg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}



module arm64.encoding.instr.fp.pair

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod


spec std.collections.vec.Vec(u8)


stable function vreg5(v: u8) -> u32 {
    return (v as u32) & 0x1F
}

stable function reg5(r: regs_mod.GpReg) -> u32 {
    return (regs_mod.gp_reg_num(r) as u32) & 0x1F
}


function stp_ldp(
    out: mutable Vec_u8.Vec,
    op: u32,
    ft: u8,
    ft2: u8,
    base: regs_mod.GpReg,
    imm7: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if ft > 31 {
        panic("stp_ldp: ft out of range (admits 0..31)")
    }
    if ft2 > 31 {
        panic("stp_ldp: ft2 out of range (admits 0..31)")
    }
    if imm7 < -64 {
        panic("stp_ldp: imm7 out of range (admits -64..63)")
    }
    if imm7 > 63 {
        panic("stp_ldp: imm7 out of range (admits -64..63)")
    }
    let instr: u32 = op | (((imm7 as u32 wrapping) & 0x7F) << 15) | (vreg5(ft2) << 10) | (reg5(base) << 5) | vreg5(ft)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


public function encode_stp_s(
    out: mutable Vec_u8.Vec,
    ft: u8,
    ft2: u8,
    base: regs_mod.GpReg,
    imm7: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    stp_ldp(mutable out, 0x2D000000 as u32, ft, ft2, base, imm7, allocator)?
}

public function encode_ldp_s(
    out: mutable Vec_u8.Vec,
    ft: u8,
    ft2: u8,
    base: regs_mod.GpReg,
    imm7: i32,
    allocator: Allocator,

    }
    let instr: u32 = (0x1E200000 as u32) | dp_mod.sf31(is64) | ftype22(ftype) | ((0x03 as u32) << 16) | (dp_mod.reg5(rn) << 5) | vreg5(fd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_fcvtzs_fp_to_gp(
    out: mutable Vec_u8.Vec,
    is64: bool,
    ftype: u8,
    rd: regs_mod.GpReg,
    fn: u8,
    allocator: Allocator,

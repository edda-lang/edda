    }
    if fn > 31 {
        panic("encode_fcvtzs_fp_to_gp: fn out of range (admits 0..31)")
    }
    let instr: u32 = (0x1E200000 as u32) | dp_mod.sf31(is64) | ftype22(ftype) | ((3 as u32) << 19) | (vreg5(fn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_fcvtzu_fp_to_gp(
    out: mutable Vec_u8.Vec,
    is64: bool,
    ftype: u8,
    rd: regs_mod.GpReg,
    fn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if ftype > 1 {
        panic("encode_fcvtzu_fp_to_gp: ftype out of range (admits 0..1)")
    }
    if fn > 31 {
        panic("encode_fcvtzu_fp_to_gp: fn out of range (admits 0..31)")
    }
    let instr: u32 = (0x1E200000 as u32) | dp_mod.sf31(is64) | ftype22(ftype) | ((3 as u32) << 19) | ((1 as u32) << 16) | (vreg5(fn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


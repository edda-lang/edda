    let instr: u32 = (0x1E200000 as u32) | dp_mod.sf31(is64) | ftype22(ftype) | ((0x06 as u32) << 16) | (vreg5(fn) << 5) | dp_mod.reg5(rd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?

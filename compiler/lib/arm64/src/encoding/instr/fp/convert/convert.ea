    }
    let instr: u32 = (0x1E200000 as u32) | dp_mod.sf31(is64) | ftype22(ftype) | ((0x07 as u32) << 16) | (dp_mod.reg5(rn) << 5) | vreg5(fd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?

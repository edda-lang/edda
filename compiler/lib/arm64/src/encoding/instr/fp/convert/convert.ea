public function encode_fcvt(
    out: mutable Vec_u8.Vec,
    ftype_src: u8,
    ftype_dst: u8,
    fd: u8,
    fn: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic}
{
    if ftype_src > 1 {
        panic("encode_fcvt: ftype_src out of range (admits 0..1)")
    }
    if ftype_dst > 1 {
        panic("encode_fcvt: ftype_dst out of range (admits 0..1)")
    }
    if fd > 31 {
        panic("encode_fcvt: fd out of range (admits 0..31)")
    }
    if fn > 31 {
        panic("encode_fcvt: fn out of range (admits 0..31)")
    }
    let instr: u32 = (0x1E224000 as u32) | ftype22(ftype_src) | (((ftype_dst as u32) & 0x3) << 17) | (vreg5(fn) << 5) | vreg5(fd)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

    if ft > 31 {
        panic("encode_ldr_s: ft out of range (admits 0..31)")
    }
    if imm12 > 4095 {
        panic("encode_ldr_s: imm12 out of range (admits 0..4095)")
    }
    let instr: u32 = (0xBD400000 as u32) | (((imm12 as u32) & 0xFFF) << 10) | (dp_mod.reg5(base) << 5) | vreg5(ft)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}


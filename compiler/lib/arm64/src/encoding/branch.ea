
module arm64.encoding.branch

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.regs as regs_mod


spec std.collections.vec.Vec(u8)


public type ArmCond {
    case eq_
    case ne_
    case hs_
    case lo_
    case mi_
    case pl_
    case vs_
    case vc_
    case hi_
    case ls_
    case ge_
    case lt_
    case gt_
    case le_
    case al_
}

derive eq, hash, debug for ArmCond

public stable function arm_cond_code(c: ArmCond) -> u32 {
    return match c {
        case .eq_ => 0 as u32
        case .ne_ => 1 as u32
        case .hs_ => 2 as u32
        case .lo_ => 3 as u32
        case .mi_ => 4 as u32
        case .pl_ => 5 as u32
        case .vs_ => 6 as u32
        case .vc_ => 7 as u32
        case .hi_ => 8 as u32
        case .ls_ => 9 as u32
        case .ge_ => 10 as u32
        case .lt_ => 11 as u32
        case .gt_ => 12 as u32
        case .le_ => 13 as u32
        case .al_ => 14 as u32
    }
}


stable function reg5(r: regs_mod.GpReg) -> u32 {
    return (regs_mod.gp_reg_num(r) as u32) & 0x1F
}

stable function sf31(is64: bool) -> u32 {
    return if is64 { (1 as u32) << 31 } else { 0 as u32 }
}


public function encode_ret(
    out: mutable Vec_u8.Vec,
    rn: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let rn_field = regs_mod.gp_reg_num(rn) as u32
    let instr: u32 = 0xD65F0000 | (rn_field << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_br(
    out: mutable Vec_u8.Vec,
    rn: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD61F0000 as u32) | (reg5(rn) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_blr(
    out: mutable Vec_u8.Vec,
    rn: regs_mod.GpReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0xD63F0000 as u32) | (reg5(rn) << 5)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_b(
    out: mutable Vec_u8.Vec,
    imm26: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x14000000 as u32) | ((imm26 as u32 wrapping) & 0x03FFFFFF)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_bl(
    out: mutable Vec_u8.Vec,
    imm26: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x94000000 as u32) | ((imm26 as u32 wrapping) & 0x03FFFFFF)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_b_cond(
    out: mutable Vec_u8.Vec,
    c: ArmCond,
    imm19: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x54000000 as u32) | (((imm19 as u32 wrapping) & 0x7FFFF) << 5) | arm_cond_code(c)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_cbz(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rt: regs_mod.GpReg,
    imm19: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x34000000 as u32) | sf31(is64) | (((imm19 as u32 wrapping) & 0x7FFFF) << 5) | reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

public function encode_cbnz(
    out: mutable Vec_u8.Vec,
    is64: bool,
    rt: regs_mod.GpReg,
    imm19: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let instr: u32 = (0x35000000 as u32) | sf31(is64) | (((imm19 as u32 wrapping) & 0x7FFFF) << 5) | reg5(rt)
    bytes_mod.push_u32_le(mutable out, instr, allocator)?
}

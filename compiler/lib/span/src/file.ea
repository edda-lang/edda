
module span.file

derive eq, hash, ord, clone for FileId

public type FileId {
    raw: u32
}

public stable function unknown() -> FileId
    ensures result.raw == 4294967295
{
    return FileId { raw: 4294967295 }
}

public stable function is_unknown(f: FileId) -> bool
    ensures result == (f.raw == 4294967295)
{
    return f.raw == 4294967295
}

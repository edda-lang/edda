
module syntax.parse.util

import std.mem.alloc
import span.loc.pos.span as span_mod
import diagnostics.emit.collection as diags_mod
import diagnostics.emit.diagnostic as diag_mod
import diagnostics.code
import syntax.tokens.kind as kind_mod
import syntax.tokens.lexed as lexed_mod
import syntax.ast.tree as tree_mod
import syntax.ast.item as item_mod


public type ParserTable {
    parse_expr: function(table: ParserTable, tokens: [lexed_mod.Lexed], pos: usize, diags: mutable diags_mod.Diagnostics, allocator: Allocator, depth: usize) -> (tree_mod.Expr, usize) with {allocator, err: alloc.AllocError, divergence}
    parse_stmt: function(table: ParserTable, tokens: [lexed_mod.Lexed], pos: usize, diags: mutable diags_mod.Diagnostics, allocator: Allocator, depth: usize) -> (tree_mod.Stmt, usize) with {allocator, err: alloc.AllocError, divergence}
    parse_pat: function(table: ParserTable, tokens: [lexed_mod.Lexed], pos: usize, diags: mutable diags_mod.Diagnostics, allocator: Allocator, depth: usize) -> (tree_mod.Pat, usize) with {allocator, err: alloc.AllocError, divergence}
    parse_ty: function(table: ParserTable, tokens: [lexed_mod.Lexed], pos: usize, diags: mutable diags_mod.Diagnostics, allocator: Allocator, depth: usize) -> (tree_mod.Ty, usize) with {allocator, err: alloc.AllocError, divergence}
    parse_item: function(table: ParserTable, tokens: [lexed_mod.Lexed], pos: usize, diags: mutable diags_mod.Diagnostics, allocator: Allocator, depth: usize) -> (item_mod.Item, usize) with {allocator, err: alloc.AllocError, divergence}
}


public function max_parse_depth() -> usize {
    return 256
}


public function peek(tokens: [lexed_mod.Lexed], pos: usize) -> kind_mod.Token {
    if pos >= tokens.len() {
        return kind_mod.Token.eof
    }
    return tokens[pos].kind
}

public function peek_at(tokens: [lexed_mod.Lexed], pos: usize, offset: usize) -> kind_mod.Token {
    if pos + offset >= tokens.len() {
        return kind_mod.Token.eof
    }
    return tokens[pos + offset].kind
}

public function span_at(tokens: [lexed_mod.Lexed], pos: usize) -> span_mod.Span {
    if pos >= tokens.len() {
        return span_mod.dummy()
    }
    return tokens[pos].span
}

public function at_eof(tokens: [lexed_mod.Lexed], pos: usize) -> bool {
    return match peek(tokens, pos) {
        case .eof => true
        case _ => false
    }
}

public function peek_newline(tokens: [lexed_mod.Lexed], pos: usize) -> bool {
    if pos >= tokens.len() {
        return false
    }
    return tokens[pos].leading_newline
}

public function skip_doc_trivia(tokens: [lexed_mod.Lexed], pos: usize) -> usize {
    let _ = tokens
    return pos
}


public function emit_error(
    diags: mutable diags_mod.Diagnostics,
    span: span_mod.Span,
    message: String,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let d = diag_mod.error_at(code.parse_error(), span, message)
    diags_mod.emit(mutable diags, take d, allocator)?
}


module syntax.ast.attr

import std.mem.alloc
import std.collections.vec
import span.loc.pos.span as span_mod
import intern.symbol
import syntax.tokens.kind as kind_mod
import local.ast.ident as ident_mod

spec std.mem.alloc.Box(AttrArg)
spec std.collections.vec.Vec(AttrArg)

derive eq, clone, debug for Attribute
derive eq, clone, debug for AttrArg
derive eq, hash, clone, debug for AttrLit

public type Attribute {
    span: span_mod.Span
    name: ident_mod.Ident
    args: Vec_AttrArg
}

public type AttrArg {
    case ident(ident_mod.Ident)
    case lit(span: span_mod.Span, value: AttrLit)
    case named(span: span_mod.Span, key: ident_mod.Ident, value: Box_AttrArg)
}

public type AttrLit {
    case str(sym: symbol.Symbol)
    case int(value: u128, base: kind_mod.IntBase)
    case bool(value: bool)
}


module syntax.ast.ident

import std.collections.vec
import span.loc.pos.span as span_mod
import intern.symbol

spec std.collections.vec.Vec(Ident)

derive eq, hash, clone, debug for Ident
derive eq, clone, debug for Path

public type Ident {
    name: symbol.Symbol
    span: span_mod.Span
}

public type Path {
    segments: Vec_Ident
    span: span_mod.Span
}

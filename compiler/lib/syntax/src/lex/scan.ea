
module syntax.lex.scan

import std.mem.alloc
import std.collections.slice
import std.core.option
import span.file as file_mod
import intern.interner as interner_mod
import diagnostics.emit.collection as diags_mod
import syntax.tokens.kind as kind_mod
import syntax.tokens.keyword as keyword_mod
import local.lex.util.util as util_mod
import local.lex.util.literals as literals_mod

spec std.core.option.Option(kind_mod.Token)


public function skip_trivia(bytes: [u8], start: usize) -> (usize, bool)
    requires start <= bytes.len()
    ensures result.0 >= start
    ensures result.0 <= bytes.len()
{
    let n = bytes.len()
    var p = start
    var saw_newline = false
    loop decreases (n - p) {
        if p >= n { return (p, saw_newline) }
        let b = bytes[p]
        if b == 0x20 || b == 0x09 || b == 0x0D {
            p = p + 1
            continue
        }
        if b == 0x0A {
            saw_newline = true
            p = p + 1
            continue
        }
        return (p, saw_newline)
    }
    return (p, saw_newline)
}


public function next_token(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    interner: mutable interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start < bytes.len()
    ensures result.1 > start
{
    let b = bytes[start]
    let n = bytes.len()
    if b == 0x21 && start + 2 < n && bytes[start + 1] == 0x21 && bytes[start + 2] == 0x21 {
        return reject_comment(mutable diags, file, start, 3, allocator)?
    }
    if b == 0x2F && start + 2 < n && bytes[start + 1] == 0x21 && bytes[start + 2] == 0x21 {
        return reject_comment(mutable diags, file, start, 3, allocator)?
    }
    if b == 0x2F && start + 1 < n && bytes[start + 1] == 0x2F {
        return reject_comment(mutable diags, file, start, 2, allocator)?
    }
    if util_mod.is_ident_start(b) {
        return lex_ident_or_underscore(bytes, start, mutable interner, allocator)?
    }
    if util_mod.is_digit(b) {
        return literals_mod.lex_number(bytes, file, start, mutable interner, mutable diags, allocator)?
    }
    if b == 0x22 && start + 2 < n && bytes[start + 1] == 0x22 && bytes[start + 2] == 0x22 {
        return literals_mod.lex_block_string(bytes, file, start, mutable interner, mutable diags, allocator)?
    }
    if b == 0x22 {
        return literals_mod.lex_string(bytes, file, start, mutable interner, mutable diags, allocator)?
    }
    return lex_punct_or_op(bytes, file, start, mutable diags, allocator)?
}


function lex_ident_or_underscore(
    bytes: [u8],
    start: usize,
    interner: mutable interner_mod.Interner,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start < bytes.len()
    ensures result.1 > start
{
    let n = bytes.len()
    var p = start + 1
    loop decreases (n - p) {
        if p >= n { break }
        if !util_mod.is_ident_continue(bytes[p]) { break }
        p = p + 1
    }
    let text_bytes = bytes[start..<p]
    if text_bytes.len() == 1 && text_bytes[0] == 0x5F {
        return (kind_mod.Token.underscore, p)
    }
    let kw = keyword_mod.keyword_token(text_bytes)
    return match kw {
        case .some(let tok) => (tok, p)
        case .none => {
            let sym = interner_mod.intern_bytes(mutable interner, text_bytes, allocator)?
            if slice.eq_u8(text_bytes, "result".bytes()) {
                (kind_mod.Token.kw_result(sym: sym), p)
            } else {
                (kind_mod.Token.ident(sym: sym), p)
            }
        }
    }
}


function reject_comment(
    diags: mutable diags_mod.Diagnostics,
    file: file_mod.FileId,
    start: usize,
    marker_len: usize,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError}
{
    let end = start + marker_len
    util_mod.emit_comment_not_admitted(mutable diags, util_mod.sp(file, start, end), "comments are not admitted in Edda source", allocator)?
    return (kind_mod.Token.eof, end)
}


function lex_punct_or_op(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start < bytes.len()
    ensures result.1 > start
{
    let n = bytes.len()
    if start + 2 < n {
        let t3 = try_match3(bytes[start], bytes[start + 1], bytes[start + 2])
        match t3 {
            case .some(let tok) => return (tok, start + 3)
            case .none => ()
        }
    }
    if start + 1 < n {
        let t2 = try_match2(bytes[start], bytes[start + 1])
        match t2 {
            case .some(let tok) => return (tok, start + 2)
            case .none => ()
        }
    }
    let b = bytes[start]
    let single = try_match1(b)
    match single {
        case .some(let tok) => return (tok, start + 1)
        case .none => ()
    }
    let width = util_mod.utf8_width(b)
    var end = start + width
    if end > n { end = n }
    util_mod.emit_error(mutable diags, util_mod.sp(file, start, end), "unexpected character in source", allocator)?
    return (kind_mod.Token.eof, end)
}

function try_match3(a: u8, b: u8, c: u8) -> Option_Token {
    if a == 0x2E && b == 0x2E && c == 0x3C { return Option_Token.some(value: kind_mod.Token.dot_dot_lt) }
    if a == 0x2E && b == 0x2E && c == 0x3D { return Option_Token.some(value: kind_mod.Token.dot_dot_eq) }
    if a == 0x2E && b == 0x2E && c == 0x2E { return Option_Token.some(value: kind_mod.Token.dot_dot_dot) }
    if a == 0x3C && b == 0x3C && c == 0x3D { return Option_Token.some(value: kind_mod.Token.lt_lt_eq) }
    if a == 0x3E && b == 0x3E && c == 0x3D { return Option_Token.some(value: kind_mod.Token.gt_gt_eq) }
    return Option_Token.none
}

function try_match2(a: u8, b: u8) -> Option_Token {
    if a == 0x2D && b == 0x3E { return Option_Token.some(value: kind_mod.Token.arrow) }
    if a == 0x3D && b == 0x3E { return Option_Token.some(value: kind_mod.Token.fat_arrow) }
    if a == 0x3D && b == 0x3D { return Option_Token.some(value: kind_mod.Token.eq_eq) }
    if a == 0x21 && b == 0x3D { return Option_Token.some(value: kind_mod.Token.bang_eq) }
    if a == 0x3C && b == 0x3D { return Option_Token.some(value: kind_mod.Token.lt_eq) }
    if a == 0x3E && b == 0x3D { return Option_Token.some(value: kind_mod.Token.gt_eq) }
    if a == 0x3C && b == 0x3C { return Option_Token.some(value: kind_mod.Token.lt_lt) }
    if a == 0x3E && b == 0x3E { return Option_Token.some(value: kind_mod.Token.gt_gt) }
    if a == 0x26 && b == 0x26 { return Option_Token.some(value: kind_mod.Token.amp_amp) }
    if a == 0x7C && b == 0x7C { return Option_Token.some(value: kind_mod.Token.pipe_pipe) }
    if a == 0x2B && b == 0x3D { return Option_Token.some(value: kind_mod.Token.plus_eq) }
    if a == 0x2D && b == 0x3D { return Option_Token.some(value: kind_mod.Token.minus_eq) }
    if a == 0x2A && b == 0x3D { return Option_Token.some(value: kind_mod.Token.star_eq) }
    if a == 0x2F && b == 0x3D { return Option_Token.some(value: kind_mod.Token.slash_eq) }
    if a == 0x25 && b == 0x3D { return Option_Token.some(value: kind_mod.Token.percent_eq) }
    if a == 0x2B && b == 0x25 { return Option_Token.some(value: kind_mod.Token.plus_pct) }
    if a == 0x2D && b == 0x25 { return Option_Token.some(value: kind_mod.Token.minus_pct) }
    if a == 0x2A && b == 0x25 { return Option_Token.some(value: kind_mod.Token.star_pct) }
    if a == 0x2B && b == 0x7C { return Option_Token.some(value: kind_mod.Token.plus_sat) }
    if a == 0x2D && b == 0x7C { return Option_Token.some(value: kind_mod.Token.minus_sat) }
    if a == 0x2A && b == 0x7C { return Option_Token.some(value: kind_mod.Token.star_sat) }
    if a == 0x2B && b == 0x3F { return Option_Token.some(value: kind_mod.Token.plus_question) }
    if a == 0x2D && b == 0x3F { return Option_Token.some(value: kind_mod.Token.minus_question) }
    if a == 0x2A && b == 0x3F { return Option_Token.some(value: kind_mod.Token.star_question) }
    if a == 0x25 && b == 0x3F { return Option_Token.some(value: kind_mod.Token.percent_question) }
    if a == 0x26 && b == 0x3D { return Option_Token.some(value: kind_mod.Token.amp_eq) }
    if a == 0x7C && b == 0x3D { return Option_Token.some(value: kind_mod.Token.pipe_eq) }
    if a == 0x5E && b == 0x3D { return Option_Token.some(value: kind_mod.Token.caret_eq) }
    if a == 0x2E && b == 0x2E { return Option_Token.some(value: kind_mod.Token.dot_dot) }
    return Option_Token.none
}

function try_match1(b: u8) -> Option_Token {
    if b == 0x28 { return Option_Token.some(value: kind_mod.Token.l_paren) }
    if b == 0x29 { return Option_Token.some(value: kind_mod.Token.r_paren) }
    if b == 0x5B { return Option_Token.some(value: kind_mod.Token.l_bracket) }
    if b == 0x5D { return Option_Token.some(value: kind_mod.Token.r_bracket) }
    if b == 0x7B { return Option_Token.some(value: kind_mod.Token.l_brace) }
    if b == 0x7D { return Option_Token.some(value: kind_mod.Token.r_brace) }
    if b == 0x2C { return Option_Token.some(value: kind_mod.Token.comma) }
    if b == 0x2E { return Option_Token.some(value: kind_mod.Token.dot) }
    if b == 0x3A { return Option_Token.some(value: kind_mod.Token.colon) }
    if b == 0x3B { return Option_Token.some(value: kind_mod.Token.semicolon) }
    if b == 0x2B { return Option_Token.some(value: kind_mod.Token.plus) }
    if b == 0x2D { return Option_Token.some(value: kind_mod.Token.minus) }
    if b == 0x2A { return Option_Token.some(value: kind_mod.Token.star) }
    if b == 0x2F { return Option_Token.some(value: kind_mod.Token.slash) }
    if b == 0x25 { return Option_Token.some(value: kind_mod.Token.percent) }
    if b == 0x3C { return Option_Token.some(value: kind_mod.Token.lt) }
    if b == 0x3E { return Option_Token.some(value: kind_mod.Token.gt) }
    if b == 0x3D { return Option_Token.some(value: kind_mod.Token.eq) }
    if b == 0x21 { return Option_Token.some(value: kind_mod.Token.bang) }
    if b == 0x26 { return Option_Token.some(value: kind_mod.Token.amp) }
    if b == 0x7C { return Option_Token.some(value: kind_mod.Token.pipe) }
    if b == 0x5E { return Option_Token.some(value: kind_mod.Token.caret) }
    if b == 0x7E { return Option_Token.some(value: kind_mod.Token.tilde) }
    if b == 0x3F { return Option_Token.some(value: kind_mod.Token.question) }
    if b == 0x40 { return Option_Token.some(value: kind_mod.Token.at) }
    return Option_Token.none
}

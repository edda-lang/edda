
module syntax.lex.util.literals

import std.mem.alloc
import std.text.string
import span.file as file_mod
import span.loc.pos.span as span_mod
import intern.interner as interner_mod
import intern.symbol
import diagnostics.emit.collection as diags_mod
import syntax.tokens.kind as kind_mod
import local.lex.util.util as util_mod


function intern_bytes(
    bytes: [u8],
    interner: mutable interner_mod.Interner,
    allocator: Allocator,
) -> symbol.Symbol
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = bytes.len()
    let buf: [u8] = allocator.alloc_array(u8, n)?
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        buf[i] = bytes[i]
        i = i + 1
    }
    let s = string.from_owned_utf8(take buf)
    return interner_mod.intern(mutable interner, s, allocator)?
}

function intern_unescaped(
    content: [u8],
    interner: mutable interner_mod.Interner,
    allocator: Allocator,
) -> symbol.Symbol
    with {allocator, err: alloc.AllocError, divergence}
{
    let n = content.len()
    var out_len: usize = 0
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        if content[i] == 0x5C && i + 1 < n {
            out_len = out_len + 1
            i = i + 2
        } else {
            out_len = out_len + 1
            i = i + 1
        }
    }
    let buf: [u8] = allocator.alloc_array(u8, out_len)?
    var src_i: usize = 0
    var dst_i: usize = 0
    loop decreases (n - src_i) {
        if src_i >= n { break }
        let b = content[src_i]
        if b == 0x5C && src_i + 1 < n {
            let esc = content[src_i + 1]
            let decoded: u8 = match esc {
                case 0x6E => 0x0A as u8
                case 0x74 => 0x09 as u8
                case 0x72 => 0x0D as u8
                case 0x5C => 0x5C as u8
                case 0x22 => 0x22 as u8
                case 0x30 => 0x00 as u8
                case _    => esc
            }
            if dst_i < out_len { buf[dst_i] = decoded }
            src_i = src_i + 2
            dst_i = dst_i + 1
        } else {
            if dst_i < out_len { buf[dst_i] = b }
            src_i = src_i + 1
            dst_i = dst_i + 1
        }
    }
    let s = string.from_owned_utf8(take buf)
    return interner_mod.intern(mutable interner, s, allocator)?
}


public function lex_number(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    interner: mutable interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start < bytes.len()
    ensures result.1 > start
{
    let n = bytes.len()
    let first = bytes[start]
    var p = start + 1
    if first == 0x30 && p < n {
        let prefix = bytes[p]
        if prefix == 0x78 || prefix == 0x58 {
            p = p + 1
            return finish_based_int(bytes, file, start, p, kind_mod.IntBase.hex, mutable diags, allocator)?
        }
        if prefix == 0x62 || prefix == 0x42 {
            p = p + 1
            return finish_based_int(bytes, file, start, p, kind_mod.IntBase.bin, mutable diags, allocator)?
        }
        if prefix == 0x6F || prefix == 0x4F {
            p = p + 1
            return finish_based_int(bytes, file, start, p, kind_mod.IntBase.oct, mutable diags, allocator)?
        }
    }
    p = consume_digits(bytes, p, 10)
    var is_float = false
    if p < n && bytes[p] == 0x2E && p + 1 < n && util_mod.is_digit(bytes[p + 1]) {
        is_float = true
        p = p + 1
        p = consume_digits(bytes, p, 10)
    }
    if p < n && (bytes[p] == 0x65 || bytes[p] == 0x45) {
        is_float = true
        p = p + 1
        if p < n && (bytes[p] == 0x2B || bytes[p] == 0x2D) {
            p = p + 1
        }
        let exp_start = p
        p = consume_digits(bytes, p, 10)
        if p == exp_start {
            util_mod.emit_error(mutable diags, util_mod.sp(file, start, p), "float literal missing exponent digits", allocator)?
        }
    }
    if is_float {
        let sym = intern_bytes(bytes[start..<p], mutable interner, allocator)?
        return (kind_mod.Token.float(sym: sym), p)
    }
    let value = parse_int_text(bytes[start..<p], kind_mod.IntBase.dec, util_mod.sp(file, start, p), mutable diags, allocator)?
    return (kind_mod.Token.int(value: value, base: kind_mod.IntBase.dec), p)
}

function finish_based_int(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    digits_start: usize,
    base: kind_mod.IntBase,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires digits_start <= bytes.len()
    requires start <= digits_start
    ensures result.1 >= digits_start
{
    let radix = base_radix(base)
    let end = consume_digits(bytes, digits_start, radix)
    if end == digits_start {
        util_mod.emit_error(mutable diags, util_mod.sp(file, start, end), "numeric literal has base prefix but no digits", allocator)?
        return (kind_mod.Token.int(value: 0, base: base), end)
    }
    let value = parse_int_text(bytes[digits_start..<end], base, util_mod.sp(file, start, end), mutable diags, allocator)?
    return (kind_mod.Token.int(value: value, base: base), end)
}

function consume_digits(bytes: [u8], start: usize, radix: u32) -> usize
    requires start <= bytes.len()
    ensures result >= start
    ensures result <= bytes.len()
{
    let n = bytes.len()
    var p = start
    loop decreases (n - p) {
        if p >= n { return p }
        let b = bytes[p]
        if b == 0x5F || digit_in_radix(b, radix) {
            p = p + 1
        } else {
            return p
        }
    }
    return p
}

function parse_int_text(
    text: [u8],
    base: kind_mod.IntBase,
    span: span_mod.Span,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> u128
    with {allocator, err: alloc.AllocError, divergence}
{
    let radix = base_radix(base)
    let n = text.len()
    var value: u128 = 0
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { return value }
        let b = text[i]
        if b == 0x5F {
            i = i + 1
            continue
        }
        let d = digit_value(b, radix)
        if d == 0xFFFFFFFF {
            util_mod.emit_error(mutable diags, span, "invalid digit for integer literal", allocator)?
            return 0
        }
        let radix128 = radix as u128
        let max_pre = (0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF as u128) / radix128
        if value > max_pre {
            util_mod.emit_error(mutable diags, span, "integer literal overflows u128", allocator)?
            return 0
        }
        let scaled = value * radix128
        let next = scaled + (d as u128)
        if next < scaled {
            util_mod.emit_error(mutable diags, span, "integer literal overflows u128", allocator)?
            return 0
        }
        value = next
        i = i + 1
    }
    return value
}

function digit_value(b: u8, radix: u32) -> u32 {
    var d: u32 = 0xFFFFFFFF
    if b >= 0x30 && b <= 0x39 {
        d = (b - 0x30) as u32
    } else if b >= 0x61 && b <= 0x7A {
        d = ((b - 0x61) as u32) + 10
    } else if b >= 0x41 && b <= 0x5A {
        d = ((b - 0x41) as u32) + 10
    }
    if d >= radix { return 0xFFFFFFFF }
    return d
}

function digit_in_radix(b: u8, radix: u32) -> bool {
    return digit_value(b, radix) != 0xFFFFFFFF
}

function base_radix(base: kind_mod.IntBase) -> u32
    ensures result >= 2
    ensures result <= 16
{
    return match base {
        case .dec => 10
        case .hex => 16
        case .bin => 2
        case .oct => 8
    }
}


public function lex_string(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    interner: mutable interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start < bytes.len()
    ensures result.1 > start
{
    let n = bytes.len()
    let content_start = start + 1
    var p = content_start
    loop decreases (n - p) {
        if p >= n {
            util_mod.emit_error(mutable diags, util_mod.sp(file, start, n), "unterminated string literal", allocator)?
            let sym = intern_unescaped(bytes[content_start..<n], mutable interner, allocator)?
            return (kind_mod.Token.str(sym: sym), n)
        }
        let b = bytes[p]
        if b == 0x22 {
            let sym = intern_unescaped(bytes[content_start..<p], mutable interner, allocator)?
            return (kind_mod.Token.str(sym: sym), p + 1)
        }
        if b == 0x0A {
            util_mod.emit_error(mutable diags, util_mod.sp(file, start, p), "unterminated string literal at end of line", allocator)?
            let sym = intern_unescaped(bytes[content_start..<p], mutable interner, allocator)?
            return (kind_mod.Token.str(sym: sym), p)
        }
        if b == 0x5C {
            p = p + 1
            if p < n {
                p = p + util_mod.utf8_width(bytes[p])
                if p > n { p = n }
            }
            continue
        }
        p = p + util_mod.utf8_width(b)
        if p > n { p = n }
    }
    let sym = intern_unescaped(bytes[content_start..<n], mutable interner, allocator)?
    return (kind_mod.Token.str(sym: sym), n)
}


public function lex_block_string(
    bytes: [u8],
    file: file_mod.FileId,
    start: usize,
    interner: mutable interner_mod.Interner,
    diags: mutable diags_mod.Diagnostics,
    allocator: Allocator,
) -> (kind_mod.Token, usize)
    with {allocator, err: alloc.AllocError, divergence}
    requires start + 2 < bytes.len()
    ensures result.1 > start
{
    let n = bytes.len()
    let content_start = start + 3
    var p = content_start
    loop decreases (n - p) {
        if p + 3 > n {
            util_mod.emit_error(mutable diags, util_mod.sp(file, start, n), "unterminated block string literal", allocator)?
            let sym = intern_block(bytes[content_start..<n], mutable interner, allocator)?
            return (kind_mod.Token.str(sym: sym), n)
        }
        if bytes[p] == 0x22 && bytes[p + 1] == 0x22 && bytes[p + 2] == 0x22 {
            let sym = intern_block(bytes[content_start..<p], mutable interner, allocator)?
            return (kind_mod.Token.str(sym: sym), p + 3)
        }
        p = p + 1
    }
    let sym = intern_block(bytes[content_start..<n], mutable interner, allocator)?
    return (kind_mod.Token.str(sym: sym), n)
}


function ws_prefix_len(content: [u8], lo: usize, hi: usize) -> usize
    requires lo <= hi
    requires hi <= content.len()
    ensures result <= (hi - lo)
{
    var i = lo
    loop decreases (hi - i) {
        if i >= hi { break }
        let c = content[i]
        if c != 0x20 && c != 0x09 { break }
        i = i + 1
    }
    return i - lo
}


function block_strip(content: [u8]) -> (usize, usize, usize) {
    let m = content.len()
    var last_nl = m
    var i: usize = 0
    loop decreases (m - i) {
        if i >= m { break }
        if content[i] == 0x0A { last_nl = i }
        i = i + 1
    }
    if last_nl >= m { return (0, m, 0) }
    let fl_start = last_nl + 1
    let fl_ws = ws_prefix_len(content, fl_start, m)
    if fl_ws != m - fl_start { return (0, m, 0) }
    var bs: usize = 0
    if m > 0 && content[0] == 0x0A { bs = 1 }
    return (bs, last_nl, fl_ws)
}


function intern_block(
    content: [u8],
    interner: mutable interner_mod.Interner,
    allocator: Allocator,
) -> symbol.Symbol
    with {allocator, err: alloc.AllocError, divergence}
{
    let m = content.len()
    let region = block_strip(content)
    let body_end = region.1
    let strip = region.2
    let buf: [u8] = allocator.alloc_array(u8, m)?
    let blen = buf.len()
    var j: usize = 0
    var k = region.0
    var at_line_start = true
    var stripped: usize = 0
    loop decreases (m - k) {
        if k >= body_end { break }
        if k >= m { break }
        let c = content[k]
        if at_line_start && stripped < strip && (c == 0x20 || c == 0x09) {
            stripped = stripped + 1
            k = k + 1
            continue
        }
        at_line_start = false
        if j >= blen { break }
        buf[j] = c
        j = j + 1
        if c == 0x0A {
            at_line_start = true
            stripped = 0
        }
        k = k + 1
    }
    return intern_bytes(buf[0..<j], mutable interner, allocator)?
}


module diagnostics.emit.note

import span.loc.pos.span as span_mod

derive eq, clone for Note

public type Note {
    at: span_mod.Span
    message: String
}

public stable function note_of(at: span_mod.Span, message: String) -> Note
    ensures result.at == at
    ensures result.message == message
{
    return Note { at: at, message: message }
}

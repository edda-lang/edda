
module diagnostics.emit.severity

derive eq, ord, clone for Severity

public type Severity {
    case fatal
    case error
    case warn
    case note
}

public stable function is_fatal(s: Severity) -> bool {
    return match s {
        case .fatal => true
        case _      => false
    }
}

public stable function is_error(s: Severity) -> bool {
    return match s {
        case .error => true
        case _      => false
    }
}

public stable function is_warn(s: Severity) -> bool {
    return match s {
        case .warn => true
        case _      => false
    }
}

public stable function is_note(s: Severity) -> bool {
    return match s {
        case .note => true
        case _      => false
    }
}

public stable function worse_of(a: Severity, b: Severity) -> Severity {
    if is_fatal(a) || is_fatal(b) {
        return Severity.fatal
    }
    if is_error(a) || is_error(b) {
        return Severity.error
    }
    if is_warn(a) || is_warn(b) {
        return Severity.warn
    }
    return Severity.note
}

public stable function exit_code(s: Severity) -> i32 {
    return match s {
        case .warn  => 0 as i32
        case .note  => 0 as i32
        case .error => 1 as i32
        case .fatal => 2 as i32
    }
}

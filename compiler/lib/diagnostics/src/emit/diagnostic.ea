
module diagnostics.emit.diagnostic

import std.core.option
import diagnostics.emit.lint.config as lint_config_mod
import diagnostics.emit.severity as severity_mod
import span.loc.pos.span as span_mod

derive eq, clone for Diagnostic

spec std.core.option.Option(Diagnostic)
spec std.core.option.Option(severity_mod.Severity)

public type Diagnostic {
    severity: severity_mod.Severity
    code: String
    span: span_mod.Span
    message: String
}

public stable function error_at(code: String, at: span_mod.Span, message: String) -> Diagnostic {
    return Diagnostic {
        severity: severity_mod.Severity.error,
        code: code,
        span: at,
        message: message,
    }
}

public stable function warn_at(code: String, at: span_mod.Span, message: String) -> Diagnostic {
    return Diagnostic {
        severity: severity_mod.Severity.warn,
        code: code,
        span: at,
        message: message,
    }
}

public stable function note_at(code: String, at: span_mod.Span, message: String) -> Diagnostic {
    return Diagnostic {
        severity: severity_mod.Severity.note,
        code: code,
        span: at,
        message: message,
    }
}

public stable function fatal_at(code: String, at: span_mod.Span, message: String) -> Diagnostic {
    return Diagnostic {
        severity: severity_mod.Severity.fatal,
        code: code,
        span: at,
        message: message,
    }
}

public stable function is_error(d: Diagnostic) -> bool {
    return severity_mod.is_error(d.severity)
}

public stable function is_warn(d: Diagnostic) -> bool {
    return severity_mod.is_warn(d.severity)
}

public stable function is_fatal(d: Diagnostic) -> bool {
    return severity_mod.is_fatal(d.severity)
}

public stable function with_severity(d: Diagnostic, s: severity_mod.Severity) -> Diagnostic
    ensures result.code == d.code
    ensures result.span == d.span
    ensures result.message == d.message
    ensures result.severity == s
{
    return Diagnostic {
        severity: s,
        code: d.code,
        span: d.span,
        message: d.message,
    }
}

public function lint_at(config: lint_config_mod.LintConfig, class_code: String, at: span_mod.Span, message: String, default: severity_mod.Severity) -> Option_Diagnostic.Option {
    return match lint_config_mod.effective_severity(config, class_code, default) {
        case .some(let sev) => Option_Diagnostic.some(value: Diagnostic { severity: sev, code: class_code, span: at, message: message })
        case .none          => Option_Diagnostic.none
    }
}


module egraph.eclass

derive eq, hash, ord, debug for EClassId


public type EClassId {
    raw: u32
}


public stable function error() -> EClassId
    ensures result.raw == 0
{
    return EClassId { raw: 0 }
}

public stable function is_error(c: EClassId) -> bool
    ensures result == (c.raw == 0)
{
    return c.raw == 0
}


public stable function index(c: EClassId) -> usize
    ensures result == (c.raw as usize)
{
    return c.raw as usize
}


module egraph.graph.graph

import std.mem.alloc
import std.collections.vec
import local.eclass as eclass_mod
import local.graph.unionfind as uf_mod
import local.graph.enode as enode_mod


spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(enode_mod.ENode)
spec std.collections.vec.Vec(EClass)


derive eq, hash, debug for EClass
derive debug for EGraph


public type EClass {
    nodes: Vec_ENode.Vec
}


public type EGraph {
    uf: uf_mod.UnionFind
    classes: Vec_EClass.Vec
}


public function new(out: init EGraph, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit uf: uf_mod.UnionFind
    uf_mod.new(init uf, allocator)?
    uninit classes: Vec_EClass.Vec
    Vec_EClass.new(init classes, allocator)?
    Vec_EClass.push(mutable classes, take sentinel_class(allocator)?, allocator)?
    out = EGraph {
        uf: uf,
        classes: classes,
    }
}


function sentinel_class(allocator: Allocator) -> EClass
    with {allocator, err: alloc.AllocError}
{
    uninit nodes: Vec_ENode.Vec
    Vec_ENode.new(init nodes, allocator)?
    return EClass {
        nodes: nodes,
    }
}


public stable function class_count(egraph: EGraph) -> usize
    requires Vec_EClass.len(egraph.classes) >= 1
{
    return Vec_EClass.len(egraph.classes) - 1
}


public function add_class(
    egraph: mutable EGraph,
    node: take enode_mod.ENode,
    allocator: Allocator,
) -> eclass_mod.EClassId
    with {allocator, err: alloc.AllocError}
    requires Vec_u32.len(egraph.uf.parent) < 4294967295
    requires Vec_u32.len(egraph.uf.rank) < 4294967295
{
    let id = uf_mod.new_class(mutable egraph.uf, allocator)?
    uninit nodes: Vec_ENode.Vec
    Vec_ENode.new(init nodes, allocator)?
    Vec_ENode.push(mutable nodes, take node, allocator)?
    let cls = EClass {
        nodes: nodes,
    }
    Vec_EClass.push(mutable egraph.classes, take cls, allocator)?
    return id
}


module specs.encode.prim

import std.mem.alloc
import std.collections.vec
import std.math.scalar
import cteval.state.value as value_mod
import types.ty.kind as ty_kind_mod
import intern.symbol as sym_mod
import intern.interner as sym_interner_mod
import local.encode.bytes as bytes_mod


spec std.collections.vec.Vec(u8)


public function kind_primitive() -> u8 { return 0x03 as u8 }


public function encode_bool(buf: mutable Vec_u8.Vec, b: bool, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, prim_subtag_bool(), allocator)?
    let byte: u8 = if b { 1 as u8 } else { 0 as u8 }
    bytes_mod.put_u8(mutable buf, byte, allocator)?
}

public function encode_int_signed(
    buf: mutable Vec_u8.Vec,
    n: i64,
    w: value_mod.IntWidth,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, int_signed_subtag(w), allocator)?
    bytes_mod.put_i64_le(mutable buf, n, allocator)?
}

public function encode_int_unsigned(
    buf: mutable Vec_u8.Vec,
    n: u64,
    w: value_mod.IntWidth,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, int_unsigned_subtag(w), allocator)?
    bytes_mod.put_u64_le(mutable buf, n, allocator)?
}

public function encode_f32(buf: mutable Vec_u8.Vec, f: f32, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, prim_subtag_f32(), allocator)?
    bytes_mod.put_u32_le(mutable buf, scalar.f32_to_bits(f), allocator)?
}

public function encode_f64(buf: mutable Vec_u8.Vec, f: f64, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, prim_subtag_f64(), allocator)?
    bytes_mod.put_u64_le(mutable buf, scalar.f64_to_bits(f), allocator)?
}

public function encode_string(
    buf: mutable Vec_u8.Vec,
    s: sym_mod.Symbol,
    sym_interner: sym_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, prim_subtag_string(), allocator)?
    let bytes = sym_interner_mod.lookup(sym_interner, s)
    let len_u32 = bytes.len() as u32
    bytes_mod.put_u32_le(mutable buf, len_u32, allocator)?
    bytes_mod.put_bytes(mutable buf, bytes, allocator)?
}

public function encode_unit(buf: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.put_u8(mutable buf, kind_primitive(), allocator)?
    bytes_mod.put_u8(mutable buf, prim_subtag_unit(), allocator)?
}


public function prim_subtag(pk: ty_kind_mod.PrimKind) -> u8 {
    return match pk {
        case .i8_       => 0x10 as u8
        case .i16_      => 0x11 as u8
        case .i32_      => 0x12 as u8
        case .i64_      => 0x13 as u8
        case .i128_     => 0x14 as u8
        case .u8_       => 0x15 as u8
        case .u16_      => 0x16 as u8
        case .u32_      => 0x17 as u8
        case .u64_      => 0x18 as u8
        case .u128_     => 0x19 as u8
        case .isize_    => 0x1A as u8
        case .usize_    => 0x1B as u8
        case .f32_      => 0x1C as u8
        case .f64_      => 0x1D as u8
        case .bool_     => 0x1E as u8
        case .unit_     => 0x1F as u8
        case .never_    => 0x20 as u8
        case .codepoint_ => 0x21 as u8
        case .type_meta => 0x22 as u8
        case .heap_ptr  => 0x23 as u8
    }
}

public function prim_subtag_bool() -> u8 { return 0x1E as u8 }

public function prim_subtag_unit() -> u8 { return 0x1F as u8 }

public function prim_subtag_f32() -> u8 { return 0x1C as u8 }

public function prim_subtag_f64() -> u8 { return 0x1D as u8 }

public function prim_subtag_string() -> u8 { return 0x24 as u8 }

public function int_signed_subtag(w: value_mod.IntWidth) -> u8 {
    return match w {
        case .w8    => 0x10 as u8
        case .w16   => 0x11 as u8
        case .w32   => 0x12 as u8
        case .w64   => 0x13 as u8
        case .wsize => 0x1A as u8
    }
}

public function int_unsigned_subtag(w: value_mod.IntWidth) -> u8 {
    return match w {
        case .w8    => 0x15 as u8
        case .w16   => 0x16 as u8
        case .w32   => 0x17 as u8
        case .w64   => 0x18 as u8
        case .wsize => 0x1B as u8
    }
}

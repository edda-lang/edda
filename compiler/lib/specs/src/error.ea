
module specs.error

import std.core.fmt
import std.mem.alloc
import std.text.string
import diagnostics.code as code_mod
import diagnostics.emit.diagnostic as diag_mod
import span.loc.pos.span as span_mod


derive eq, debug for SpecError


public type SpecError {
    case unresolved_spec(
        at: span_mod.Span,
        path: String,
    )

    case arity_mismatch(
        at: span_mod.Span,
        spec_name: String,
        expected: u32,
        actual: u32,
    )

    case provides_violation(
        at: span_mod.Span,
        spec_name: String,
        type_name: String,
        missing: String,
    )

    case where_clause_violation(
        at: span_mod.Span,
        spec_name: String,
        predicate: String,
    )

    case short_name_collision(
        at: span_mod.Span,
        short_name: String,
        this_prefix: String,
        other_prefix: String,
    )

    case encoding_failed(
        at: span_mod.Span,
        kind: String,
        message: String,
    )
}


public function to_diagnostic(e: SpecError, allocator: Allocator) -> diag_mod.Diagnostic
    with {allocator, err: alloc.AllocError}
{
    let at = span_of(e)
    let msg = format_message(e, allocator)?
    return match e {
        case .unresolved_spec(_, _) =>
            diag_mod.error_at(code_mod.spec_unresolved_spec(), at, msg)
        case .arity_mismatch(_, _, _, _) =>
            diag_mod.error_at(code_mod.spec_arity_mismatch(), at, msg)
        case .provides_violation(_, _, _, _) =>
            diag_mod.error_at(code_mod.spec_provides_violation(), at, msg)
        case .where_clause_violation(_, _, _) =>
            diag_mod.error_at(code_mod.spec_where_clause_violation(), at, msg)
        case .short_name_collision(_, _, _, _) =>
            diag_mod.error_at(code_mod.spec_short_name_collision(), at, msg)
        case .encoding_failed(_, _, _) =>
            diag_mod.error_at(code_mod.spec_encoding_failed(), at, msg)
    }
}


public stable function span_of(e: SpecError) -> span_mod.Span {
    return match e {
        case .unresolved_spec(let at, _) => at
        case .arity_mismatch(let at, _, _, _) => at
        case .provides_violation(let at, _, _, _) => at
        case .where_clause_violation(let at, _, _) => at
        case .short_name_collision(let at, _, _, _) => at
        case .encoding_failed(let at, _, _) => at
    }
}


function format_message(e: SpecError, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return match e {
        case .unresolved_spec(_, let path) =>
            fmt_unresolved_spec(path, allocator)?
        case .arity_mismatch(_, let spec_name, let expected, let actual) =>
            fmt_arity_mismatch(spec_name, expected, actual, allocator)?
        case .provides_violation(_, let spec_name, let type_name, let missing) =>
            fmt_provides_violation(spec_name, type_name, missing, allocator)?
        case .where_clause_violation(_, let spec_name, let predicate) =>
            fmt_where_clause_violation(spec_name, predicate, allocator)?
        case .short_name_collision(_, let short_name, let this_prefix, let other_prefix) =>
            fmt_short_name_collision(short_name, this_prefix, other_prefix, allocator)?
        case .encoding_failed(_, let kind, let message) =>
            fmt_encoding_failed(kind, message, allocator)?
    }
}

function fmt_unresolved_spec(path: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("unresolved spec path `", path, allocator)?
    return string.concat(
        p1,
        "` — no spec by that name in scope at this invocation site",
        allocator,
    )?
}

function fmt_arity_mismatch(
    spec_name: String,
    expected: u32,
    actual: u32,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("spec `", spec_name, allocator)?
    let p2 = string.concat(p1, "` takes ", allocator)?
    let expected_str = fmt.u32_to_string(expected, allocator)?
    let p3 = string.concat(p2, expected_str, allocator)?
    let p4 = string.concat(p3, " comptime argument(s), got ", allocator)?
    let actual_str = fmt.u32_to_string(actual, allocator)?
    return string.concat(p4, actual_str, allocator)?
}

function fmt_provides_violation(
    spec_name: String,
    type_name: String,
    missing: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("spec `", spec_name, allocator)?
    let p2 = string.concat(p1, "` requires `", allocator)?
    let p3 = string.concat(p2, type_name, allocator)?
    let p4 = string.concat(p3, "` to provide `", allocator)?
    let p5 = string.concat(p4, missing, allocator)?
    return string.concat(
        p5,
        "` — the structural-provides check (§2.5) found no matching item on the type's surface",
        allocator,
    )?
}

function fmt_where_clause_violation(
    spec_name: String,
    predicate: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("spec `", spec_name, allocator)?
    let p2 = string.concat(p1, "` requires `", allocator)?
    let p3 = string.concat(p2, predicate, allocator)?
    return string.concat(
        p3,
        "` but the predicate evaluated to false at this invocation",
        allocator,
    )?
}

function fmt_short_name_collision(
    short_name: String,
    this_prefix: String,
    other_prefix: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("spec short-name collision on `", short_name, allocator)?
    let p2 = string.concat(p1, "` — this invocation hashes to `", allocator)?
    let p3 = string.concat(p2, this_prefix, allocator)?
    let p4 = string.concat(p3, "`, another in the build hashes to `", allocator)?
    let p5 = string.concat(p4, other_prefix, allocator)?
    return string.concat(
        p5,
        "`. Lift one into a sibling-spec wrapper or align the spec body bytes (§2.10).",
        allocator,
    )?
}

function fmt_encoding_failed(
    kind: String,
    message: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("canonical-encoder rejected `", kind, allocator)?
    let p2 = string.concat(p1, "` argument: ", allocator)?
    return string.concat(p2, message, allocator)?
}

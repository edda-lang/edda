
module specs.gen.typaths

import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.mem.alloc
import intern.symbol as sym_mod
import types.pass.ty as ty_mod


spec std.collections.vec.Vec(sym_mod.Symbol)
spec std.collections.vec.Vec(TyPath)

spec std.collections.hashmap.IntMap(u32)

spec std.core.option.Option(TyPath)


public type TyPath {
    segs: Vec_Symbol.Vec
}

public type TyPathMap {
    index_by_ty: IntMap_u32.IntMap
    rows: Vec_TyPath.Vec
}


public function empty_ty_paths(allocator: Allocator) -> TyPathMap
    with {allocator, err: alloc.AllocError}
{
    uninit rows: Vec_TyPath.Vec
    Vec_TyPath.new(init rows, allocator)?
    return TyPathMap { index_by_ty: IntMap_u32.new(allocator)?, rows: rows }
}


public function add_ty_path(m: mutable TyPathMap, t: ty_mod.TyId, segs: take Vec_Symbol.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let row = Vec_TyPath.len(m.rows) as u32
    let _ = IntMap_u32.insert(mutable m.index_by_ty, t.raw as i64, take row, allocator)?
    Vec_TyPath.push(mutable m.rows, TyPath { segs: take segs }, allocator)?
}


public function has_ty_path(m: TyPathMap, t: ty_mod.TyId) -> bool {
    return match IntMap_u32.get(m.index_by_ty, t.raw as i64) {
        case .some(_) => true
        case .none => false
    }
}


public function ty_path_of(m: TyPathMap, t: ty_mod.TyId) -> Option_TyPath.Option {
    return match IntMap_u32.get(m.index_by_ty, t.raw as i64) {
        case .some(let row) => {
            if (row as usize) >= Vec_TyPath.len(m.rows) {
                return Option_TyPath.none
            }
            return Option_TyPath.some(value: Vec_TyPath.at(m.rows, row as usize))
        }
        case .none => Option_TyPath.none
    }
}

spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(value_mod.ComptimeValue)
spec std.collections.vec.Vec(ast_ident_mod.Ident)
spec std.collections.vec.Vec(sym_mod.Symbol)
spec std.collections.vec.Vec(tree_mod.Expr)
spec std.collections.vec.Vec(ty_mod.TyId)


spec std.core.option.Option(ty_mod.TyId)


public function is_alloc_box_path(
    path: ast_ident_mod.Path,
    sym_interner: sym_interner_mod.Interner,
    allocator: Allocator,
) -> bool
    with {allocator, divergence, err: alloc.AllocError}
{
    let rendered = render_path_bytes(path, sym_interner, allocator)?
    return slice.eq_u8(rendered, "std.mem.alloc.Box".bytes())
}


public function is_compare_eq_path(
    path: ast_ident_mod.Path,
    sym_interner: sym_interner_mod.Interner,
    allocator: Allocator,

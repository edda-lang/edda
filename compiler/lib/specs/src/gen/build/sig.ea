
module specs.gen.build.sig

import std.mem.alloc
import std.collections.vec
import span.loc.pos.span as span_mod
import intern.symbol as sym_mod
import intern.interner as sym_interner_mod
import types.check.env.sig as check_sig_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.effect.interner as row_interner_mod
import local.address.hash as hash_mod
import local.error as spec_err_mod
import local.address.finalize as finalize_mod
import local.encode.ty as ty_enc_mod
import local.encode.row as row_enc_mod
import local.encode.prim as prim_enc_mod
import local.encode.bytes as bytes_mod


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(ty_mod.TyId)


public function surface_of(
    sig: check_sig_mod.FnSig,
    name: sym_mod.Symbol,
    at: span_mod.Span,
    ty_interner: ty_interner_mod.Interner,
    row_interner: row_interner_mod.Interner,
    sym_interner: sym_interner_mod.Interner,
    allocator: Allocator,
) -> hash_mod.SpecHash
    with {allocator, err: alloc.AllocError, err: spec_err_mod.SpecError}
{
    uninit buf: Vec_u8.Vec
    Vec_u8.new(init buf, allocator)?

    prim_enc_mod.encode_string(mutable buf, name, sym_interner, allocator)?

    let pn = Vec_TyId.len(sig.params)
    bytes_mod.put_u32_le(mutable buf, pn as u32, allocator)?
    var i: usize = 0
    loop decreases (pn - i) {
        if i >= pn { break }
        let pty = Vec_TyId.at(sig.params, i)
        ty_enc_mod.encode_type_defid(mutable buf, pty, at, ty_interner, allocator)?
        i = i + 1
    }

    ty_enc_mod.encode_type_defid(mutable buf, sig.ret, at, ty_interner, allocator)?

    row_enc_mod.encode_effect_row(mutable buf, sig.effects, at, row_interner, sym_interner, allocator)?

    let bytes = Vec_u8.into_array(take buf, allocator)?
    return finalize_mod.finalize(bytes, allocator)?
}

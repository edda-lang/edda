
module specs.address.finalize

import std.mem.alloc
import std.crypto.hash.blake3
import local.address.hash as hash_mod


public function finalize(bytes: [u8], allocator: Allocator) -> hash_mod.SpecHash
    with {allocator, err: alloc.AllocError}
{
    var scratch: [u8] = allocator.alloc_array(u8, 32)?
    blake3.blake3(bytes, mutable scratch, 0)
    return hash_mod.SpecHash {
        w0: u64_from_le_bytes(scratch, 0),
        w1: u64_from_le_bytes(scratch, 8),
        w2: u64_from_le_bytes(scratch, 16),
        w3: u64_from_le_bytes(scratch, 24),
    }
}


function u64_from_le_bytes(bytes: [u8], offset: usize) -> u64
    requires offset + 8 <= bytes.len()
{
    return  (bytes[offset]         as u64)
          | ((bytes[offset + 1] as u64) <<  8)
          | ((bytes[offset + 2] as u64) << 16)
          | ((bytes[offset + 3] as u64) << 24)
          | ((bytes[offset + 4] as u64) << 32)
          | ((bytes[offset + 5] as u64) << 40)
          | ((bytes[offset + 6] as u64) << 48)
          | ((bytes[offset + 7] as u64) << 56)
}

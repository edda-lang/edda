
module specs.address.key

import std.collections.vec
import hir.def as def_mod


spec std.collections.vec.Vec(u8)


derive eq, debug for SpecKey


public type SpecKey {
    spec_def: def_mod.DefId
    arg_bytes: Vec_u8.Vec
}


public function new(spec_def: def_mod.DefId, arg_bytes: take Vec_u8.Vec) -> SpecKey {
    return SpecKey {
        spec_def: spec_def,
        arg_bytes: arg_bytes,
    }
}


module specs.address.id

derive eq, hash, ord, debug for ModuleId

public type ModuleId {
    raw: u32
}


public stable function error() -> ModuleId
    ensures result.raw == 0
{
    return ModuleId { raw: 0 }
}

public stable function is_error(m: ModuleId) -> bool
    ensures result == (m.raw == 0)
{
    return m.raw == 0
}


public stable function index(m: ModuleId) -> usize
    ensures result == (m.raw as usize)
{
    return m.raw as usize
}

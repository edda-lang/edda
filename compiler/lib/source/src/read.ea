
module source.read

import std.mem.alloc
import std.os.fs
import span.file as file_mod
import local.map as src_map_mod

public function read_file(rfs: ReadOnlyFilesystem, map: mutable src_map_mod.SourceMap, path: take String, allocator: Allocator) -> file_mod.FileId
    with {rfs, allocator, err: fs.FsError, err: alloc.AllocError}
{
    let content = rfs.read_to_string(path, allocator)?
    return src_map_mod.add_file(mutable map, take path, content, allocator)?
}


module source.map

import std.collections.vec
import std.mem.alloc
import span.file as file_mod
import span.loc.loc as loc_mod
import span.loc.pos.span as span_mod
import local.file as src_file_mod

spec std.collections.vec.Vec(src_file_mod.SourceFile)


public type SourceMap {
    files: Vec_SourceFile.Vec
}

public function new_map(out: init SourceMap, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit files: Vec_SourceFile.Vec
    Vec_SourceFile.new(init files, allocator)?
    out = SourceMap { files: files }
}

public function file_count(map: SourceMap) -> usize {
    return Vec_SourceFile.len(map.files)
}

public function add_file(map: mutable SourceMap, name: take String, content: take String, allocator: Allocator) -> file_mod.FileId
    with {allocator, err: alloc.AllocError}
{
    let next_raw = Vec_SourceFile.len(map.files) as u32
    let next_id = file_mod.FileId { raw: next_raw }
    let entry = src_file_mod.source_file_of(next_id, name, content)
    Vec_SourceFile.push(mutable map.files, entry, allocator)?
    return next_id
}


public function file_at(map: SourceMap, idx: usize where idx < file_count(map)) -> src_file_mod.SourceFile {
    return Vec_SourceFile.at(map.files, idx)
}

public function file_of(map: SourceMap, id: file_mod.FileId where (id.raw as usize) < file_count(map)) -> src_file_mod.SourceFile {
    return Vec_SourceFile.at(map.files, id.raw as usize)
}

public function file_name_of(map: SourceMap, id: file_mod.FileId where (id.raw as usize) < file_count(map)) -> String {
    return src_file_mod.name(Vec_SourceFile.at(map.files, id.raw as usize))
}

public function file_content_of(map: SourceMap, id: file_mod.FileId where (id.raw as usize) < file_count(map)) -> String {
    return src_file_mod.content(Vec_SourceFile.at(map.files, id.raw as usize))
}


public function byte_to_linecol(map: SourceMap, loc: loc_mod.Loc where (loc.file.raw as usize) < file_count(map)) -> loc_mod.LineCol {
    let file = Vec_SourceFile.at(map.files, loc.file.raw as usize)
    let bytes = src_file_mod.content(file).bytes()
    let stop = if loc.byte <= bytes.len() { loc.byte } else { bytes.len() }
    var line: usize = 1
    var col: usize = 1
    var i: usize = 0
    loop decreases (stop - i) {
        if i >= stop { break }
        if bytes[i] == 0x0A {
            line = line + 1
            col = 1
        } else {
            col = col + 1
        }
        i = i + 1
    }
    return loc_mod.LineCol { line: line, col: col }
}

public function span_text(map: SourceMap, sp: span_mod.Span where (sp.file.raw as usize) < file_count(map) && sp.end <= span_text_len(map, sp.file)) -> [u8] {
    let file = Vec_SourceFile.at(map.files, sp.file.raw as usize)
    let bytes = src_file_mod.content(file).bytes()
    return bytes[sp.start..<sp.end]
}

public function span_text_len(map: SourceMap, id: file_mod.FileId where (id.raw as usize) < file_count(map)) -> usize {
    return src_file_mod.content(Vec_SourceFile.at(map.files, id.raw as usize)).bytes().len()
}


module source.file

import span.file as file_mod

derive eq, hash, ord, clone, debug for SourceFile

public type SourceFile {
    id: file_mod.FileId
    name: String
    content: String
}

public stable function source_file_of(id: file_mod.FileId, name: take String, content: take String) -> SourceFile {
    return SourceFile { id: id, name: name, content: content }
}

public stable function id(f: SourceFile) -> file_mod.FileId {
    return f.id
}

public stable function name(f: SourceFile) -> String {
    return f.name
}

public stable function content(f: SourceFile) -> String {
    return f.content
}

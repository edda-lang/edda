
module mir.rvalue

import std.collections.vec
import types.pass.ty as ty_mod
import intern.symbol as symbol_mod
import hir.def as def_mod
import local.place as place_mod


spec std.collections.vec.Vec(Operand)
spec std.collections.vec.Vec(Constant)


derive eq, hash, debug for Operand
derive eq, hash, debug for Constant
derive eq, hash, debug for ConstantKind
derive eq, hash, debug for FloatWidth
derive eq, hash, debug for Rvalue
derive eq, hash, debug for MBinOp
derive eq, hash, debug for OverflowMode
derive eq, hash, debug for MUnOp
derive eq, hash, debug for CastKind
derive eq, hash, debug for AggregateKind
derive eq, hash, debug for BorrowKind


public type Operand {
    case copy_(place: place_mod.Place, ty: ty_mod.TyId)
    case move_(place: place_mod.Place, ty: ty_mod.TyId)
    case constant(c: Constant)
}


public type Constant {
    ty: ty_mod.TyId
    kind: ConstantKind
}

public type ConstantKind {
    case int_(bits: u128)
    case float_(bits: u64, width: FloatWidth)
    case bool_(value: bool)
    case str_(symbol: symbol_mod.Symbol)
    case unit_
    case zero_init
    case aggregate(elems: Vec_Constant.Vec)
    case fn_ref(def: def_mod.DefId)
}

public type FloatWidth {
    case f32_
    case f64_
}


public type Rvalue {
    case use_(operand: Operand)
    case binary(op: MBinOp, lhs: Operand, rhs: Operand)
    case unary(op: MUnOp, operand: Operand)
    case cast(operand: Operand, from: ty_mod.TyId, to: ty_mod.TyId, kind: CastKind)
    case aggregate(kind: AggregateKind, elems: Vec_Operand.Vec, result_ty: ty_mod.TyId)
    case ref_(kind: BorrowKind, place: place_mod.Place)
    case len(place: place_mod.Place)
    case discriminant(place: place_mod.Place)
    case make_closure(code: def_mod.DefId, env: Operand)
}


public type MBinOp {
    case add(mode: OverflowMode)
    case sub(mode: OverflowMode)
    case mul(mode: OverflowMode)
    case div(mode: OverflowMode, proven_nonzero: bool, proven_no_overflow: bool)
    case mod_(mode: OverflowMode, proven_nonzero: bool, proven_no_overflow: bool)
    case bit_and
    case bit_or
    case bit_xor
    case shl
    case shr
    case eq
    case ne
    case lt
    case le
    case gt
    case ge
    case logical_and
    case logical_or
}

public type OverflowMode {
    case trapping
    case wrapping_
    case saturating_
    case checked_
}


public type MUnOp {
    case neg
    case not_
    case bit_not
}


public type CastKind {
    case int_to_int(mode: OverflowMode)
    case int_to_float
    case float_to_int(mode: OverflowMode)
    case float_to_float
    case bool_to_int
}


public type AggregateKind {
    case tuple
    case record(def: def_mod.DefId)
    case variant(def: def_mod.DefId, variant_idx: u32)
    case array
}


public type BorrowKind {
    case shared
    case mutable_
}

    let alloc_op = Vec_Operand.at(arg_operands, 1)
    let triple = builder_mod.triple(builder)
    let size_op = layout_op(bridge.LayoutField.size_, result_ty, ty_interner, types_out, triple, 0)
    let align_op = layout_op(bridge.LayoutField.align_, result_ty, ty_interner, types_out, triple, 1)
    let out_slot = zero_slot(mutable builder, result_ty, call_node, allocator)?
    let out_ptr = addr_of_local(mutable builder, out_slot, rvalue_mod.BorrowKind.mutable_, types_out, call_node, allocator)?
    let out_ptr_local = addr_operand_local(out_ptr)
    uninit args: Vec_Operand.Vec
    Vec_Operand.new(init args, allocator)?
    Vec_Operand.push(mutable args, alloc_op, allocator)?
    Vec_Operand.push(mutable args, size_op, allocator)?
    Vec_Operand.push(mutable args, align_op, allocator)?
    Vec_Operand.push(mutable args, b_op, allocator)?
    Vec_Operand.push(mutable args, out_ptr, allocator)?
    let _ = emit_raw_bridge_call(mutable builder, call_node, builtins_mod.box_unbox_raw_reserved(), args, types_out.builtins.unit_, false, ty_mod.error(), types_out, allocator)?
    return deref_operand(out_ptr_local, result_ty, allocator)?
}


function build_alloc_array_bridge(
    builder: mutable builder_mod.LowerCtx,
    call_node: node_mod.NodeId,
    ef: effect_row_mod.EffectFacts,
    arg_operands: Vec_Operand.Vec,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let alloc_op = Vec_Operand.at(arg_operands, 0)
    let n_op = Vec_Operand.at(arg_operands, 1)
    let t = slice_elem_ty(result_ty, ty_interner)
    let triple = builder_mod.triple(builder)
    let size_op = layout_op(bridge.LayoutField.size_, t, ty_interner, types_out, triple, 0)
    let align_op = layout_op(bridge.LayoutField.align_, t, ty_interner, types_out, triple, 1)
    uninit args: Vec_Operand.Vec
    Vec_Operand.new(init args, allocator)?
    Vec_Operand.push(mutable args, alloc_op, allocator)?
    Vec_Operand.push(mutable args, size_op, allocator)?
    Vec_Operand.push(mutable args, align_op, allocator)?
    Vec_Operand.push(mutable args, n_op, allocator)?
    return emit_raw_bridge_call(mutable builder, call_node, builtins_mod.alloc_array_reserved(), args, result_ty, ef.raises, ef.err_ty, types_out, allocator)?
}


function build_realloc_array_bridge(
    builder: mutable builder_mod.LowerCtx,
    call_node: node_mod.NodeId,
    ef: effect_row_mod.EffectFacts,
    arg_operands: Vec_Operand.Vec,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let data_op = Vec_Operand.at(arg_operands, 0)
    let n_op = Vec_Operand.at(arg_operands, 1)
    let alloc_op = Vec_Operand.at(arg_operands, 2)
    let t = slice_elem_ty(result_ty, ty_interner)
    let triple = builder_mod.triple(builder)
    let size_op = layout_op(bridge.LayoutField.size_, t, ty_interner, types_out, triple, 0)
    let align_op = layout_op(bridge.LayoutField.align_, t, ty_interner, types_out, triple, 1)
    uninit args: Vec_Operand.Vec
    Vec_Operand.new(init args, allocator)?
    Vec_Operand.push(mutable args, alloc_op, allocator)?
    Vec_Operand.push(mutable args, size_op, allocator)?
    Vec_Operand.push(mutable args, align_op, allocator)?
    Vec_Operand.push(mutable args, data_op, allocator)?
    Vec_Operand.push(mutable args, n_op, allocator)?
    return emit_raw_bridge_call(mutable builder, call_node, builtins_mod.realloc_array_raw_reserved(), args, result_ty, ef.raises, ef.err_ty, types_out, allocator)?
}


function emit_call_preconditions(
    builder: mutable builder_mod.LowerCtx,
    callee_op: rvalue_mod.Operand,
    args: Vec_HArg.Vec,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    match callee_op {
        case .constant(let c) => match c.kind {
            case .fn_ref(let def) => {
                let i = def_mod.index(def)
                if i < Vec_FnSig.len(types_out.fn_signatures) {
                    let sig = Vec_FnSig.at(types_out.fn_signatures, i)
                    obligation_mod.emit_precondition_obligations(
                        mutable builder,
                        sig.param_names,
                        sig.refinements,
                        args,
                        types_out,
                        ty_interner,
                        allocator,
                    )?
                }
            }
            case _ => ()
        }
        case _ => ()
    }
}


function callee_raise_facts(
    callee_op: rvalue_mod.Operand,
    types_out: check_mod.TypeOutput,
) -> effect_row_mod.EffectFacts {
    match callee_op {
        case .constant(let c) => match c.kind {
            case .fn_ref(let def) => {
                let i = def_mod.index(def)
                if i < Vec_FnSig.len(types_out.fn_signatures) {
                    return Vec_FnSig.at(types_out.fn_signatures, i).effect_facts
                }
            }
            case _ => ()
        }
        case _ => ()
    }
    return effect_row_mod.pure_facts()
}


function fill_call_err_edge(
    builder: mutable builder_mod.LowerCtx,
    call_node: node_mod.NodeId,
    err_bb: block_mod.BlockId,
    dest_local: local_mod.LocalId,
    caught_ty: ty_mod.TyId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    builder_mod.switch_to(mutable builder, err_bb)
    let payload_place = builder_mod.local_place(dest_local)
    let payload_op = rvalue_mod.Operand.copy_(place: payload_place, ty: caught_ty)
    match builder_mod.innermost_matching_handler(builder, caught_ty) {
        case .some(let frame) => {
            let binder_place = builder_mod.local_place(frame.binder_local)
            let assign_stmt = stmt_mod.Statement {
                origin: call_node,
                kind: stmt_mod.MStmtKind.assign(
                    dest: binder_place,
                    value: rvalue_mod.Rvalue.use_(operand: payload_op),
                ),
            }
            builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
            let goto_handler = term_mod.Terminator {
                origin: call_node,
                kind: term_mod.TermKind.goto_(target: frame.handler_block),
            }
            builder_mod.seal_block_with(mutable builder, take goto_handler, allocator)?
        }
        case .none => {
            let raise_term = term_mod.Terminator {
                origin: call_node,
                kind: term_mod.TermKind.raise_(
                    value: payload_op,
                    unwind: term_mod.UnwindAction.propagate,
                ),
            }
            builder_mod.seal_block_with(mutable builder, take raise_term, allocator)?
        }
    }
}


function lower_raise_expr(
    builder: mutable builder_mod.LowerCtx,
    raise_node: node_mod.NodeId,
    value_expr: hir_tree.HExpr,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let value_ty = check_mod.type_of_node(types_out, value_expr.node_id)
    let value_op = lower_expr_as_operand(mutable builder, value_expr, value_ty, types_out, ty_interner, allocator)?
    match builder_mod.innermost_matching_handler(builder, value_ty) {
        case .some(let frame) => {
            let binder_place = builder_mod.local_place(frame.binder_local)
            let assign_stmt = stmt_mod.Statement {
                origin: raise_node,
                kind: stmt_mod.MStmtKind.assign(
                    dest: binder_place,
                    value: rvalue_mod.Rvalue.use_(operand: value_op),
                ),
            }
            builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
            let dead_block = builder_mod.alloc_block(mutable builder, raise_node, Option_RegionId.none, allocator)?
            let goto_handler = term_mod.Terminator {
                origin: raise_node,
                kind: term_mod.TermKind.goto_(target: frame.handler_block),
            }
            builder_mod.seal_block_with(mutable builder, take goto_handler, allocator)?
            builder_mod.switch_to(mutable builder, dead_block)
        }
        case .none => {
            let dead_block = builder_mod.alloc_block(mutable builder, raise_node, Option_RegionId.none, allocator)?
            let raise_term = term_mod.Terminator {
                origin: raise_node,
                kind: term_mod.TermKind.raise_(
                    value: value_op,
                    unwind: term_mod.UnwindAction.propagate,
                ),
            }
            builder_mod.seal_block_with(mutable builder, take raise_term, allocator)?
            builder_mod.switch_to(mutable builder, dead_block)
        }
    }
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.zero_init,
        },
    )
}


function lower_handle_expr(
    builder: mutable builder_mod.LowerCtx,
    handle_node: node_mod.NodeId,
    binder: def_mod.DefId,
    recovery: hir_tree.HExpr,
    body: hir_tree.HBlock,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let caught_ty = check_mod.type_of_local(types_out, binder)
    let binder_local = builder_mod.alloc_local(
        mutable builder,
        caught_ty,
        body_mod.Mutability.immutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: handle_node),
        allocator,
    )?
    builder_mod.bind_local(mutable builder, binder, binder_local, allocator)?

    let dest_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: handle_node),
        allocator,
    )?
    let handler_blk = builder_mod.alloc_block(mutable builder, handle_node, Option_RegionId.none, allocator)?
    let join_blk = builder_mod.alloc_block(mutable builder, handle_node, Option_RegionId.none, allocator)?

    let frame = builder_mod.HandlerFrame {
        caught_ty: caught_ty,
        handler_block: handler_blk,
        binder_local: binder_local,
    }
    builder_mod.enter_handler(mutable builder, take frame, allocator)?
    let body_op = lower_block(mutable builder, body, types_out, ty_interner, allocator)?
    let _popped = builder_mod.exit_handler(mutable builder)
    emit_assign_then_goto(mutable builder, handle_node, dest_local, body_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, handler_blk)
    let rec_op = lower_expr_as_operand(mutable builder, recovery, result_ty, types_out, ty_interner, allocator)?
    emit_assign_then_goto(mutable builder, handle_node, dest_local, rec_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, join_blk)
    let read_place = builder_mod.local_place(dest_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}


function lower_panic_expr(
    builder: mutable builder_mod.LowerCtx,
    panic_node: node_mod.NodeId,
    message_expr: hir_tree.HExpr,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let message_ty = check_mod.type_of_node(types_out, message_expr.node_id)
    let message_op = lower_expr_as_operand(mutable builder, message_expr, message_ty, types_out, ty_interner, allocator)?
    let dead_block = builder_mod.alloc_block(
        mutable builder,
        panic_node,
        Option_RegionId.none,
        allocator,
    )?
    let panic_term = term_mod.Terminator {
        origin: panic_node,
        kind: term_mod.TermKind.panic_(message: message_op),
    }
    builder_mod.seal_block_with(mutable builder, take panic_term, allocator)?
    builder_mod.switch_to(mutable builder, dead_block)
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.zero_init,
        },
    )
}


function ret_is_unit(builder: builder_mod.LowerCtx, ty_interner: ty_interner_mod.Interner) -> bool {
    return match ty_interner_mod.lookup(ty_interner, builder_mod.return_value_ty(builder)) {
        case .primitive(let prim) => match prim {
            case .unit_ => true
            case _ => false
        }
        case _ => false
    }
}

function unit_zero_operand(ty: ty_mod.TyId) -> rvalue_mod.Operand {
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: ty,
            kind: rvalue_mod.ConstantKind.int_(bits: 0 as u128),
        },
    )
}

function assign_return_place(
    builder: mutable builder_mod.LowerCtx,
    origin: node_mod.NodeId,
    value_op: rvalue_mod.Operand,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let return_place = builder_mod.local_place(local_mod.LocalId { raw: 1 })
    let assign_stmt = stmt_mod.Statement {
        origin: origin,
        kind: stmt_mod.MStmtKind.assign(
            dest: return_place,
            value: rvalue_mod.Rvalue.use_(operand: value_op),
        ),
    }
    builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
}

function lower_return_expr(
    builder: mutable builder_mod.LowerCtx,
    return_node: node_mod.NodeId,
    value_opt: Option_Box_HExpr.Option,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let is_unit = ret_is_unit(builder, ty_interner)
    match value_opt {
        case .some(let boxed) => {
            let value_expr = Box_HExpr.get(boxed)
            let value_ty = check_mod.type_of_node(types_out, value_expr.node_id)
            let value_op = lower_expr_as_operand(mutable builder, value_expr, value_ty, types_out, ty_interner, allocator)?
            let assigned_op = if is_unit {
                unit_zero_operand(builder_mod.return_value_ty(builder))
            } else {
                value_op
            }
            assign_return_place(mutable builder, return_node, assigned_op, allocator)?
            let return_expr_opt = if is_unit { Option_Box_HExpr.none } else { Option_Box_HExpr.some(value: boxed) }
            obligation_mod.record_return_exit(mutable builder, assigned_op, return_expr_opt, allocator)?
        }
        case .none => {
            if is_unit {
                let unit_op = unit_zero_operand(builder_mod.return_value_ty(builder))
                assign_return_place(mutable builder, return_node, unit_op, allocator)?
                obligation_mod.record_return_exit(mutable builder, unit_op, Option_Box_HExpr.none, allocator)?
            }
        }
    }
    let dead_block = builder_mod.alloc_block(
        mutable builder,
        return_node,
        Option_RegionId.none,
        allocator,
    )?
    let return_term = term_mod.Terminator {
        origin: return_node,
        kind: term_mod.TermKind.return_,
    }
    builder_mod.seal_block_with(mutable builder, take return_term, allocator)?
    builder_mod.switch_to(mutable builder, dead_block)
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.zero_init,
        },
    )
}


public function lower_block(
    builder: mutable builder_mod.LowerCtx,
    block: hir_tree.HBlock,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    return lower_block_impl(mutable builder, block, false, types_out, ty_interner, allocator)?
}


public function lower_fn_body_block(
    builder: mutable builder_mod.LowerCtx,
    block: hir_tree.HBlock,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    return lower_block_impl(mutable builder, block, true, types_out, ty_interner, allocator)?
}


function lower_block_impl(
    builder: mutable builder_mod.LowerCtx,
    block: hir_tree.HBlock,
    retain_exit_negations: bool,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let n: usize = Vec_HStmt.len(block.stmts)
    var i: usize = 0
    var pushed_negations: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let stmt = Vec_HStmt.at(block.stmts, i)
        lower_stmt(mutable builder, stmt, types_out, ty_interner, allocator)?
        match early_exit_negation(builder, stmt, types_out, ty_interner, allocator)? {
            case .some(let neg) => {
                builder_mod.push_guard_fact(mutable builder, take neg, allocator)?
                pushed_negations = pushed_negations + 1
            }
            case .none => {}
        }
        i = i + 1
    }
    let out_op = match block.trailing {
        case .some(let boxed) => {
            let trailing_expr = Box_HExpr.get(boxed)
            let trailing_ty = check_mod.type_of_node(types_out, trailing_expr.node_id)
            lower_expr_as_operand(mutable builder, trailing_expr, trailing_ty, types_out, ty_interner, allocator)?
        }
        case .none => {
            let block_ty = check_mod.type_of_node(types_out, block.node_id)
            rvalue_mod.Operand.constant(
                c: rvalue_mod.Constant {
                    ty: block_ty,
                    kind: rvalue_mod.ConstantKind.unit_,
                },
            )
        }
    }
    if !retain_exit_negations {
        loop
            decreases (pushed_negations)
        {
            if pushed_negations == 0 as usize {
                break
            }
            builder_mod.pop_guard_fact(mutable builder)
            pushed_negations = pushed_negations - 1
        }
    }
    return out_op
}


function early_exit_negation(
    builder: builder_mod.LowerCtx,
    stmt: hir_tree.HStmt,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> Option_Expr.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    return match stmt.kind {
        case .let_(_, _, let bindings, _, let init_) => {
            if Vec_HBinding.len(bindings) != 0 as usize {
                return Option_Expr.none
            }
            match init_.kind {
                case .if_(let cond_box, let then_block, let else_opt) => {
                    let has_else = match else_opt {
                        case .some(_) => true
                        case .none => false
                    }
                    if has_else {
                        return Option_Expr.none
                    }
                    if !block_always_exits(then_block) {
                        return Option_Expr.none
                    }
                    match guard_mod.guard_fact_expr(builder, Box_HExpr.get(cond_box), types_out, ty_interner, allocator)? {
                        case .some(let g) => Option_Expr.some(value: postcond_mod.negated_expr(take g, allocator)?)
                        case .none => Option_Expr.none
                    }
                }
                case _ => Option_Expr.none
            }
        }
        case _ => Option_Expr.none
    }
}


function block_always_exits(b: hir_tree.HBlock) -> bool {
    return match b.trailing {
        case .some(let boxed) => match Box_HExpr.get(boxed).kind {
            case .return_(_) => true
            case .raise_(_) => true
            case .panic_(_) => true
            case _ => false
        }
        case .none => false
    }
}

public function lower_stmt(
    builder: mutable builder_mod.LowerCtx,
    stmt: hir_tree.HStmt,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    match stmt.kind {
        case .assign(let target, let op, let rhs) => {
            match op {
                case .plain => {
                    let target_place = lower_expr_as_place(mutable builder, target, types_out, ty_interner, allocator)?
                    let rhs_ty = check_mod.type_of_node(types_out, rhs.node_id)
                    let rhs_op = lower_expr_as_operand(mutable builder, rhs, rhs_ty, types_out, ty_interner, allocator)?
                    let assign_stmt = stmt_mod.Statement {
                        origin: stmt.node_id,
                        kind: stmt_mod.MStmtKind.assign(
                            dest: target_place,
                            value: rvalue_mod.Rvalue.use_(operand: rhs_op),
                        ),
                    }
                    builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
                }
                case _ => lower_compound_assign(mutable builder, stmt.node_id, target, op, rhs, types_out, ty_interner, allocator)?
            }
        }
        case .let_(let binding, _, let bindings, _, let init_) => {
            lower_let(mutable builder, stmt.node_id, binding, bindings, init_, types_out, ty_interner, allocator)?
        }
        case .uninit_(_, let bindings, _) => {
            lower_uninit(mutable builder, stmt.node_id, bindings, types_out, ty_interner, allocator)?
        }
    }
}


function lower_let(
    builder: mutable builder_mod.LowerCtx,
    stmt_node: node_mod.NodeId,
    binding: ast_ops.BindingMode,
    bindings: Vec_HBinding.Vec,
    init_: hir_tree.HExpr,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let mutability = match binding {
        case .mutable_ => body_mod.Mutability.mutable_
        case _ => body_mod.Mutability.immutable_
    }
    let nb = Vec_HBinding.len(bindings)
    if nb == 1 as usize {
        let b = Vec_HBinding.at(bindings, 0 as usize)
        let bty = check_mod.type_of_local(types_out, b.def_id)
        let blocal = builder_mod.alloc_local(
            mutable builder,
            bty,
            mutability,
            body_mod.Consumption.copy_,
            Option_Symbol.some(value: b.name),
            Option_NodeId.some(value: stmt_node),
            allocator,
        )?
        builder_mod.bind_local(mutable builder, b.def_id, blocal, allocator)?
        let init_op = lower_expr_as_operand(mutable builder, init_, bty, types_out, ty_interner, allocator)?
        let dest_place = builder_mod.local_place(blocal)
        let assign_stmt = stmt_mod.Statement {
            origin: stmt_node,
            kind: stmt_mod.MStmtKind.assign(
                dest: dest_place,
                value: rvalue_mod.Rvalue.use_(operand: init_op),
            ),
        }
        builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
        return ()
    }
    let init_temp = lower_expr_as_temp(mutable builder, init_, types_out, ty_interner, allocator)?
    var j: usize = 0
    loop
        decreases (nb - j)
    {
        if j >= nb {
            break
        }
        let b = Vec_HBinding.at(bindings, j)
        let bty = check_mod.type_of_local(types_out, b.def_id)
        let blocal = builder_mod.alloc_local(
            mutable builder,
            bty,
            mutability,
            body_mod.Consumption.copy_,
            Option_Symbol.some(value: b.name),
            Option_NodeId.some(value: stmt_node),
            allocator,
        )?
        builder_mod.bind_local(mutable builder, b.def_id, blocal, allocator)?
        var src_place = builder_mod.local_place(init_temp)
        place_mod.push_projection(
            mutable src_place,
            place_mod.Projection {
                kind: place_mod.ProjectionKind.field(idx: j as u32),
                result_ty: bty,
            },
            allocator,
        )?
        let dest_place = builder_mod.local_place(blocal)
        let assign_stmt = stmt_mod.Statement {
            origin: stmt_node,
            kind: stmt_mod.MStmtKind.assign(
                dest: dest_place,
                value: rvalue_mod.Rvalue.use_(
                    operand: rvalue_mod.Operand.copy_(place: src_place, ty: bty),
                ),
            ),
        }
        builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
        j = j + 1
    }
}


function lower_uninit(
    builder: mutable builder_mod.LowerCtx,
    stmt_node: node_mod.NodeId,
    bindings: Vec_HBinding.Vec,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let nb = Vec_HBinding.len(bindings)
    var j: usize = 0
    loop
        decreases (nb - j)
    {
        if j >= nb {
            break
        }
        let b = Vec_HBinding.at(bindings, j)
        let bty = check_mod.type_of_local(types_out, b.def_id)
        let blocal = builder_mod.alloc_local(
            mutable builder,
            bty,
            body_mod.Mutability.mutable_,
            body_mod.Consumption.copy_,
            Option_Symbol.some(value: b.name),
            Option_NodeId.some(value: stmt_node),
            allocator,
        )?
        builder_mod.bind_local(mutable builder, b.def_id, blocal, allocator)?
        let seed_stmt = stmt_mod.Statement {
            origin: stmt_node,
            kind: stmt_mod.MStmtKind.assign(
                dest: builder_mod.local_place(blocal),
                value: rvalue_mod.Rvalue.use_(
                    operand: rvalue_mod.Operand.constant(
                        c: rvalue_mod.Constant {
                            ty: bty,
                            kind: rvalue_mod.ConstantKind.zero_init,
                        },
                    ),
                ),
            ),
        }
        builder_mod.push_stmt(mutable builder, take seed_stmt, allocator)?
        j = j + 1
    }
}


function lower_compound_assign(
    builder: mutable builder_mod.LowerCtx,
    stmt_node: node_mod.NodeId,
    target: hir_tree.HExpr,
    op: ast_ops.AssignOp,
    rhs: hir_tree.HExpr,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let target_place = lower_expr_as_place(mutable builder, target, types_out, ty_interner, allocator)?
    let target_ty = check_mod.type_of_node(types_out, target.node_id)
    let rhs_ty = check_mod.type_of_node(types_out, rhs.node_id)
    let rhs_op = lower_expr_as_operand(mutable builder, rhs, rhs_ty, types_out, ty_interner, allocator)?
    let cur_op = rvalue_mod.Operand.copy_(place: target_place, ty: target_ty)
    let mbinop = assign_op_to_mbinop(op)
    let value_rv = rvalue_mod.Rvalue.binary(op: mbinop, lhs: cur_op, rhs: rhs_op)
    maybe_note_div_obligation(mutable builder, value_rv, allocator)?
    maybe_note_overflow_obligation(mutable builder, value_rv, allocator)?
    let assign_stmt = stmt_mod.Statement {
        origin: stmt_node,
        kind: stmt_mod.MStmtKind.assign(
            dest: target_place,
            value: value_rv,
        ),
    }
    builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
}


function assign_op_to_mbinop(op: ast_ops.AssignOp) -> rvalue_mod.MBinOp
    with {panic}
{
    return match op {
        case .add => rvalue_mod.MBinOp.add(mode: rvalue_mod.OverflowMode.trapping)
        case .sub => rvalue_mod.MBinOp.sub(mode: rvalue_mod.OverflowMode.trapping)
        case .mul => rvalue_mod.MBinOp.mul(mode: rvalue_mod.OverflowMode.trapping)
        case .div => rvalue_mod.MBinOp.div(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false)
        case .mod => rvalue_mod.MBinOp.mod_(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false)
        case .bit_and => rvalue_mod.MBinOp.bit_and
        case .bit_or => rvalue_mod.MBinOp.bit_or
        case .bit_xor => rvalue_mod.MBinOp.bit_xor
        case .shl => rvalue_mod.MBinOp.shl
        case .shr => rvalue_mod.MBinOp.shr
        case .plain => panic("walker.assign_op_to_mbinop: plain assign handled in lower_stmt, not a compound op")
    }
}


function lower_if_expr(
    builder: mutable builder_mod.LowerCtx,
    if_node: node_mod.NodeId,
    cond_expr: hir_tree.HExpr,
    then_block: hir_tree.HBlock,
    else_opt: Option_HBlock.Option,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let cond_ty = check_mod.type_of_node(types_out, cond_expr.node_id)
    let cond_op = lower_expr_as_operand(mutable builder, cond_expr, cond_ty, types_out, ty_interner, allocator)?

    let dest_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: if_node),
        allocator,
    )?

    let then_blk = builder_mod.alloc_block(mutable builder, then_block.node_id, Option_RegionId.none, allocator)?
    let else_blk = builder_mod.alloc_block(mutable builder, if_node, Option_RegionId.none, allocator)?
    let join_blk = builder_mod.alloc_block(mutable builder, if_node, Option_RegionId.none, allocator)?

    let branch_term = term_mod.Terminator {
        origin: if_node,
        kind: term_mod.TermKind.branch(
            cond: cond_op,
            true_: then_blk,
            false_: else_blk,
        ),
    }
    builder_mod.seal_block_with(mutable builder, take branch_term, allocator)?

    let guard_fact = guard_mod.guard_fact_expr(builder, cond_expr, types_out, ty_interner, allocator)?
    let has_guard = match guard_fact {
        case .some(_) => true
        case .none => false
    }

    builder_mod.switch_to(mutable builder, then_blk)
    match guard_fact {
        case .some(let g) => builder_mod.push_guard_fact(mutable builder, take g, allocator)?
        case .none => builder_mod.enter_opaque_guards(mutable builder)
    }
    let then_op = lower_block(mutable builder, then_block, types_out, ty_interner, allocator)?
    if has_guard {
        builder_mod.pop_guard_fact(mutable builder)
    } else {
        builder_mod.exit_opaque_guards(mutable builder)
    }
    emit_assign_then_goto(mutable builder, if_node, dest_local, then_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, else_blk)
    match guard_fact {
        case .some(let g) => {
            let ng = postcond_mod.negated_expr(take g, allocator)?
            builder_mod.push_guard_fact(mutable builder, take ng, allocator)?
        }
        case .none => builder_mod.enter_opaque_guards(mutable builder)
    }
    let else_op = match else_opt {
        case .some(let eb) => lower_block(mutable builder, eb, types_out, ty_interner, allocator)?
        case .none => rvalue_mod.Operand.constant(
            c: rvalue_mod.Constant {
                ty: result_ty,
                kind: rvalue_mod.ConstantKind.unit_,
            },
        )
    }
    if has_guard {
        builder_mod.pop_guard_fact(mutable builder)
    } else {
        builder_mod.exit_opaque_guards(mutable builder)
    }
    emit_assign_then_goto(mutable builder, if_node, dest_local, else_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, join_blk)
    let read_place = builder_mod.local_place(dest_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}

function lower_short_circuit(
    builder: mutable builder_mod.LowerCtx,
    node_id: node_mod.NodeId,
    is_and: bool,
    lhs_expr: hir_tree.HExpr,
    rhs_expr: hir_tree.HExpr,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let lhs_ty = check_mod.type_of_node(types_out, lhs_expr.node_id)
    let lhs_op = lower_expr_as_operand(mutable builder, lhs_expr, lhs_ty, types_out, ty_interner, allocator)?

    let dest_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: node_id),
        allocator,
    )?

    let rhs_blk = builder_mod.alloc_block(mutable builder, rhs_expr.node_id, Option_RegionId.none, allocator)?
    let skip_blk = builder_mod.alloc_block(mutable builder, node_id, Option_RegionId.none, allocator)?
    let join_blk = builder_mod.alloc_block(mutable builder, node_id, Option_RegionId.none, allocator)?

    let branch_term = term_mod.Terminator {
        origin: node_id,
        kind: if is_and {
            term_mod.TermKind.branch(cond: lhs_op, true_: rhs_blk, false_: skip_blk)
        } else {
            term_mod.TermKind.branch(cond: lhs_op, true_: skip_blk, false_: rhs_blk)
        },
    }
    builder_mod.seal_block_with(mutable builder, take branch_term, allocator)?

    builder_mod.switch_to(mutable builder, rhs_blk)
    let rhs_ty = check_mod.type_of_node(types_out, rhs_expr.node_id)
    let rhs_op = lower_expr_as_operand(mutable builder, rhs_expr, rhs_ty, types_out, ty_interner, allocator)?
    emit_assign_then_goto(mutable builder, node_id, dest_local, rhs_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, skip_blk)
    let skip_op = rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.bool_(value: !is_and),
        },
    )
    emit_assign_then_goto(mutable builder, node_id, dest_local, skip_op, join_blk, allocator)?

    builder_mod.switch_to(mutable builder, join_blk)
    let read_place = builder_mod.local_place(dest_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}


function emit_assign_then_goto(
    builder: mutable builder_mod.LowerCtx,
    origin: node_mod.NodeId,
    dest_local: local_mod.LocalId,
    value_op: rvalue_mod.Operand,
    join: block_mod.BlockId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let dest_place = builder_mod.local_place(dest_local)
    let assign_stmt = stmt_mod.Statement {
        origin: origin,
        kind: stmt_mod.MStmtKind.assign(
            dest: dest_place,
            value: rvalue_mod.Rvalue.use_(operand: value_op),
        ),
    }
    builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
    let goto_term = term_mod.Terminator {
        origin: origin,
        kind: term_mod.TermKind.goto_(target: join),
    }
    builder_mod.seal_block_with(mutable builder, take goto_term, allocator)?
}


function lower_loop_expr(
    builder: mutable builder_mod.LowerCtx,
    loop_node: node_mod.NodeId,
    body: hir_tree.HBlock,
    label: Option_Symbol.Option,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let break_dest = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: loop_node),
        allocator,
    )?
    let header_block = builder_mod.alloc_block(mutable builder, body.node_id, Option_RegionId.none, allocator)?
    let exit_block = builder_mod.alloc_block(mutable builder, loop_node, Option_RegionId.none, allocator)?

    let frame = builder_mod.LoopFrame {
        break_target: exit_block,
        continue_target: header_block,
        label: label,
        break_dest: break_dest,
    }
    builder_mod.enter_loop(mutable builder, take frame, allocator)?

    let goto_header = term_mod.Terminator {
        origin: loop_node,
        kind: term_mod.TermKind.goto_(target: header_block),
    }
    builder_mod.seal_block_with(mutable builder, take goto_header, allocator)?

    builder_mod.switch_to(mutable builder, header_block)
    let _body_op = lower_block(mutable builder, body, types_out, ty_interner, allocator)?
    let loop_back = term_mod.Terminator {
        origin: loop_node,
        kind: term_mod.TermKind.goto_(target: header_block),
    }
    builder_mod.seal_block_with(mutable builder, take loop_back, allocator)?

    let _popped = builder_mod.exit_loop(mutable builder)

    builder_mod.switch_to(mutable builder, exit_block)
    let read_place = builder_mod.local_place(break_dest)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}

function lower_break_expr(
    builder: mutable builder_mod.LowerCtx,
    break_node: node_mod.NodeId,
    label: Option_Symbol.Option,
    value_opt: Option_Box_HExpr.Option,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let frame_opt = match label {
        case .none => builder_mod.innermost_loop(builder)
        case .some(let lbl) => builder_mod.find_loop_by_label(builder, lbl)
    }
    let frame = match frame_opt {
        case .some(let f) => f
        case .none => panic("walker.lower_break_expr: break outside of any loop — typecheck should have rejected before lowering")
    }
    match value_opt {
        case .some(let boxed) => {
            let value_expr = Box_HExpr.get(boxed)
            let value_ty = check_mod.type_of_node(types_out, value_expr.node_id)
            let value_op = lower_expr_as_operand(mutable builder, value_expr, value_ty, types_out, ty_interner, allocator)?
            let dest_place = builder_mod.local_place(frame.break_dest)
            let assign_stmt = stmt_mod.Statement {
                origin: break_node,
                kind: stmt_mod.MStmtKind.assign(
                    dest: dest_place,
                    value: rvalue_mod.Rvalue.use_(operand: value_op),
                ),
            }
            builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
        }
        case .none => {
            let dest_ty = builder_mod.local_ty(builder, frame.break_dest)
            let value_op = rvalue_mod.Operand.constant(
                c: rvalue_mod.Constant {
                    ty: dest_ty,
                    kind: rvalue_mod.ConstantKind.unit_,
                },
            )
            let dest_place = builder_mod.local_place(frame.break_dest)
            let assign_stmt = stmt_mod.Statement {
                origin: break_node,
                kind: stmt_mod.MStmtKind.assign(
                    dest: dest_place,
                    value: rvalue_mod.Rvalue.use_(operand: value_op),
                ),
            }
            builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?
        }
    }
    let dead_block = builder_mod.alloc_block(mutable builder, break_node, Option_RegionId.none, allocator)?
    let goto_exit = term_mod.Terminator {
        origin: break_node,
        kind: term_mod.TermKind.goto_(target: frame.break_target),
    }
    builder_mod.seal_block_with(mutable builder, take goto_exit, allocator)?
    builder_mod.switch_to(mutable builder, dead_block)
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.zero_init,
        },
    )
}

function lower_scope_expr(
    builder: mutable builder_mod.LowerCtx,
    scope_node: node_mod.NodeId,
    kind: ast_ops.ScopeKind,
    body: hir_tree.HBlock,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    return match kind {
        case .coherence => lower_coherence_scope(
            mutable builder,
            scope_node,
            body,
            result_ty,
            types_out,
            ty_interner,
            allocator,
        )?
        case .exec => lower_exec_scope(
            mutable builder,
            scope_node,
            body,
            result_ty,
            types_out,
            ty_interner,
            allocator,
        )?
    }
}


function lower_exec_scope(
    builder: mutable builder_mod.LowerCtx,
    scope_node: node_mod.NodeId,
    body: hir_tree.HBlock,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let group_local = builder_mod.alloc_local(
        mutable builder,
        builder_mod.task_group_ty_of(builder),
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: scope_node),
        allocator,
    )?
    emit_task_group_call(mutable builder, scope_node, builtins_mod.task_group_open_reserved(), Option_LocalId.none, group_local, allocator)?
    let prev = builder_mod.current_exec_group(builder)
    builder_mod.set_exec_group(mutable builder, Option_LocalId.some(value: group_local))
    let body_op = lower_block(mutable builder, body, types_out, ty_interner, allocator)?
    builder_mod.set_exec_group(mutable builder, prev)
    let join_dest = builder_mod.alloc_local(
        mutable builder,
        builder_mod.task_group_ty_of(builder),
        body_mod.Mutability.immutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: scope_node),
        allocator,
    )?
    emit_task_group_call(mutable builder, scope_node, builtins_mod.task_group_join_reserved(), Option_LocalId.some(value: group_local), join_dest, allocator)?
    return body_op
}


function emit_task_group_call(
    builder: mutable builder_mod.LowerCtx,
    scope_node: node_mod.NodeId,
    callee_def: def_mod.DefId,
    group_arg: Option_LocalId.Option,
    dest_local: local_mod.LocalId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let callee = rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: ty_mod.error(),
            kind: rvalue_mod.ConstantKind.fn_ref(def: callee_def),
        },
    )
    uninit args: Vec_Operand.Vec
    Vec_Operand.new(init args, allocator)?
    match group_arg {
        case .some(let g) => {
            let group_op = rvalue_mod.Operand.move_(place: builder_mod.local_place(g), ty: builder_mod.task_group_ty_of(builder))
            Vec_Operand.push(mutable args, take group_op, allocator)?
        }
        case .none => ()
    }
    let success = builder_mod.alloc_block(mutable builder, scope_node, Option_RegionId.none, allocator)?
    let call_term = term_mod.Terminator {
        origin: scope_node,
        kind: term_mod.TermKind.call_(
            callee: callee,
            args: args,
            dest: builder_mod.local_place(dest_local),
            return_: success,
            unwind: term_mod.UnwindAction.propagate,
        ),
    }
    builder_mod.seal_block_with(mutable builder, take call_term, allocator)?
    builder_mod.switch_to(mutable builder, success)
}


function lower_spawn_expr(
    builder: mutable builder_mod.LowerCtx,
    sp: hir_tree.HSpawn,
    spawn_node: node_mod.NodeId,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let group_local = match builder_mod.current_exec_group(builder) {
        case .some(let g) => g
        case .none => panic("walker.lower_spawn_expr: group.spawn outside any scope(exec) — typecheck should have rejected before lowering")
    }

    let env_ty = builder_mod.closure_env_ty_of(builder, spawn_node)
    if ty_mod.is_error(env_ty) {
        builder_mod.record_unlowered(mutable builder, spawn_node, allocator)?
        return unsupported_closure_operand(result_ty)
    }
    let cap_defs = match builder_mod.spawn_captures_of(builder, spawn_node) {
        case .some(let defs) => defs
        case .none => {
            builder_mod.record_unlowered(mutable builder, spawn_node, allocator)?
            return unsupported_closure_operand(result_ty)
        }
    }

    let unit_ty = types_out.builtins.unit_
    let body_ty = match sp.body.trailing {
        case .some(let box) => check_mod.type_of_node(types_out, Box_HExpr.get(box).node_id)
        case .none => unit_ty
    }
    let slot_ty = if body_ty.raw == unit_ty.raw { types_out.builtins.usize_ } else { body_ty }
    let slot_local = zero_slot(mutable builder, slot_ty, spawn_node, allocator)?
    let slot_ptr = addr_of_local(mutable builder, slot_local, rvalue_mod.BorrowKind.mutable_, types_out, spawn_node, allocator)?

    uninit elems: Vec_Operand.Vec
    Vec_Operand.new(init elems, allocator)?
    Vec_Operand.push(mutable elems, slot_ptr, allocator)?
    uninit captures: Vec_HCapture.Vec
    Vec_HCapture.new(init captures, allocator)?

    let nc = Vec_DefId.len(cap_defs)
    var ci: usize = 0
    loop decreases (nc - ci) {
        if ci >= nc { break }
        let cdef = Vec_DefId.at(cap_defs, ci)
        let cty = check_mod.type_of_local(types_out, cdef)
        let clocal = match builder_mod.lookup_local(builder, cdef) {
            case .some(let l) => l
            case .none => panic("walker.lower_spawn_expr: capture def lost between envscan collection and emission")
        }
        let cplace = builder_mod.local_place(clocal)
        Vec_Operand.push(mutable elems, rvalue_mod.Operand.copy_(place: cplace, ty: cty), allocator)?
        let cap = hir_tree.HCapture {
            def_id: cdef,
            name: symbol_mod.empty(),
            mode: ast_ops.CaptureMode.take_,
        }
        Vec_HCapture.push(mutable captures, take cap, allocator)?
        ci = ci + 1
    }

    let na = Vec_HSpawnArg.len(sp.args)
    var pi: usize = 0
    loop decreases (na - pi) {
        if pi >= na { break }
        let arg = Vec_HSpawnArg.at(sp.args, pi)
        let init_ty = check_mod.type_of_node(types_out, arg.init_.node_id)
        let init_op = lower_expr_as_operand(mutable builder, arg.init_, init_ty, types_out, ty_interner, allocator)?
        Vec_Operand.push(mutable elems, init_op, allocator)?
        let acap = hir_tree.HCapture {
            def_id: arg.def_id,
            name: arg.name,
            mode: ast_ops.CaptureMode.take_,
        }
        Vec_HCapture.push(mutable captures, take acap, allocator)?
        pi = pi + 1
    }

    let env_local = builder_mod.alloc_local(
        mutable builder,
        env_ty,
        body_mod.Mutability.immutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: spawn_node),
        allocator,
    )?
    let agg = rvalue_mod.Rvalue.aggregate(
        kind: rvalue_mod.AggregateKind.tuple,
        elems: elems,
        result_ty: env_ty,
    )
    let agg_stmt = stmt_mod.Statement {
        origin: spawn_node,
        kind: stmt_mod.MStmtKind.assign(dest: builder_mod.local_place(env_local), value: agg),
    }
    builder_mod.push_stmt(mutable builder, take agg_stmt, allocator)?
    let env_ptr = addr_of_local(mutable builder, env_local, rvalue_mod.BorrowKind.shared, types_out, spawn_node, allocator)?
    let triple = builder_mod.triple(builder)
    let env_size = layout_op(bridge.LayoutField.size_, env_ty, ty_interner, types_out, triple, 8)

    uninit args_ops: Vec_Operand.Vec
    Vec_Operand.new(init args_ops, allocator)?
    Vec_Operand.push(mutable args_ops, env_ptr, allocator)?
    Vec_Operand.push(mutable args_ops, env_size, allocator)?

    let base = builder_mod.closure_base(builder)
    let lifted_def = def_mod.DefId { raw: base +% spawn_node.raw }
    uninit params: Vec_HClosureParam.Vec
    Vec_HClosureParam.new(init params, allocator)?
    let pc = builder_mod.PendingClosure {
        def_id: lifted_def,
        name: symbol_mod.empty(),
        params: params,
        body: sp.body,
        return_ty: types_out.builtins.heap_ptr,
        prepend_env: true,
        has_capture: false,
        capture_def: def_mod.error(),
        capture_name: symbol_mod.empty(),
        capture_ty: ty_mod.error(),
        pointer_backed: true,
        env_ty: env_ty,
        captures: captures,
        spawn_result_ty: body_ty,
    }
    builder_mod.record_closure(mutable builder, take pc, allocator)?

    let handle_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.immutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: spawn_node),
        allocator,
    )?
    let handle_place = builder_mod.local_place(handle_local)
    let success = builder_mod.alloc_block(mutable builder, spawn_node, Option_RegionId.none, allocator)?
    let spawn_term = term_mod.Terminator {
        origin: spawn_node,
        kind: term_mod.TermKind.spawn_(
            child: lifted_def,
            args: args_ops,
            group_local: group_local,
            handle_dest: handle_place,
            return_: success,
            unwind: term_mod.UnwindAction.propagate,
        ),
    }
    builder_mod.seal_block_with(mutable builder, take spawn_term, allocator)?
    builder_mod.switch_to(mutable builder, success)
    let read_place = builder_mod.local_place(handle_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}


function lower_coherence_scope(
    builder: mutable builder_mod.LowerCtx,
    scope_node: node_mod.NodeId,
    body: hir_tree.HBlock,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let region = builder_mod.alloc_region(mutable builder)
    let region_opt = Option_RegionId.some(value: region)

    let dest_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: scope_node),
        allocator,
    )?

    let body_blk = builder_mod.alloc_block(mutable builder, body.node_id, region_opt, allocator)?
    let after_blk = builder_mod.alloc_block(mutable builder, scope_node, Option_RegionId.none, allocator)?

    let enter_term = term_mod.Terminator {
        origin: scope_node,
        kind: term_mod.TermKind.coherence_enter(
            body_entry: body_blk,
            exit: after_blk,
        ),
    }
    builder_mod.seal_block_with(mutable builder, take enter_term, allocator)?

    builder_mod.switch_to(mutable builder, body_blk)
    let outer_region = builder_mod.current_region(builder)
    builder_mod.set_coherence_region(mutable builder, region_opt)
    let body_op = lower_block(mutable builder, body, types_out, ty_interner, allocator)?
    builder_mod.set_coherence_region(mutable builder, outer_region)

    let dest_place = builder_mod.local_place(dest_local)
    let assign_stmt = stmt_mod.Statement {
        origin: scope_node,
        kind: stmt_mod.MStmtKind.assign(
            dest: dest_place,
            value: rvalue_mod.Rvalue.use_(operand: body_op),
        ),
    }
    builder_mod.push_stmt(mutable builder, take assign_stmt, allocator)?

    let exit_term = term_mod.Terminator {
        origin: scope_node,
        kind: term_mod.TermKind.coherence_exit(target: after_blk),
    }
    builder_mod.seal_block_with(mutable builder, take exit_term, allocator)?

    builder_mod.switch_to(mutable builder, after_blk)
    let read_place = builder_mod.local_place(dest_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}

function lower_continue_expr(
    builder: mutable builder_mod.LowerCtx,
    cont_node: node_mod.NodeId,
    label: Option_Symbol.Option,
    result_ty: ty_mod.TyId,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    let frame_opt = match label {
        case .none => builder_mod.innermost_loop(builder)
        case .some(let lbl) => builder_mod.find_loop_by_label(builder, lbl)
    }
    let frame = match frame_opt {
        case .some(let f) => f
        case .none => panic("walker.lower_continue_expr: continue outside of any loop — typecheck should have rejected before lowering")
    }
    let dead_block = builder_mod.alloc_block(mutable builder, cont_node, Option_RegionId.none, allocator)?
    let goto_cont = term_mod.Terminator {
        origin: cont_node,
        kind: term_mod.TermKind.goto_(target: frame.continue_target),
    }
    builder_mod.seal_block_with(mutable builder, take goto_cont, allocator)?
    builder_mod.switch_to(mutable builder, dead_block)
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: result_ty,
            kind: rvalue_mod.ConstantKind.zero_init,
        },
    )
}


function lower_match_expr(
    builder: mutable builder_mod.LowerCtx,
    match_node: node_mod.NodeId,
    scrutinee: hir_tree.HExpr,
    arms: Vec_HArm.Vec,
    result_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic, divergence}
{
    let scrut_ty = check_mod.type_of_node(types_out, scrutinee.node_id)
    let scrut_local = lower_expr_as_temp(mutable builder, scrutinee, types_out, ty_interner, allocator)?

    let dest_local = builder_mod.alloc_local(
        mutable builder,
        result_ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: match_node),
        allocator,
    )?
    let join_blk = builder_mod.alloc_block(mutable builder, match_node, Option_RegionId.none, allocator)?
    let bool_ty = types_out.builtins.bool_

    let n = Vec_HArm.len(arms)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let arm = Vec_HArm.at(arms, i)
        let next_blk = builder_mod.alloc_block(mutable builder, match_node, Option_RegionId.none, allocator)?
        let matched_blk = builder_mod.alloc_block(mutable builder, arm.body.node_id, Option_RegionId.none, allocator)?

        pattern_mod.emit_arm_match_and_bind(mutable builder, scrut_local, scrut_ty, bool_ty, arm.pat, arm.bindings, matched_blk, next_blk, types_out, ty_interner, match_node, allocator)?

        builder_mod.switch_to(mutable builder, matched_blk)
        match arm.guard {
            case .some(let g) => {
                let gop = lower_expr_as_operand(mutable builder, g, bool_ty, types_out, ty_interner, allocator)?
                let body_blk = builder_mod.alloc_block(mutable builder, arm.body.node_id, Option_RegionId.none, allocator)?
                let gterm = term_mod.Terminator {
                    origin: match_node,
                    kind: term_mod.TermKind.branch(cond: gop, true_: body_blk, false_: next_blk),
                }
                builder_mod.seal_block_with(mutable builder, take gterm, allocator)?
                builder_mod.switch_to(mutable builder, body_blk)
            }
            case .none => ()
        }

        builder_mod.enter_opaque_guards(mutable builder)
        let arm_op = lower_expr_as_operand(mutable builder, arm.body, result_ty, types_out, ty_interner, allocator)?
        builder_mod.exit_opaque_guards(mutable builder)
        emit_assign_then_goto(mutable builder, match_node, dest_local, arm_op, join_blk, allocator)?

        builder_mod.switch_to(mutable builder, next_blk)
        i = i + 1
    }

    let fallthrough_term = term_mod.Terminator {
        origin: match_node,
        kind: term_mod.TermKind.unreachable_,
    }
    builder_mod.seal_block_with(mutable builder, take fallthrough_term, allocator)?

    builder_mod.switch_to(mutable builder, join_blk)
    let read_place = builder_mod.local_place(dest_local)
    return rvalue_mod.Operand.copy_(place: read_place, ty: result_ty)
}



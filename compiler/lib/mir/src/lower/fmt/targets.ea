
module mir.lower.fmt.targets

import std.mem.alloc
import std.collections.slice as slice
import std.collections.vec
import hir.build.file as hir_file_mod
import hir.item as hir_item
import hir.def as def_mod
import intern.interner as interner_mod
import local.lower.eqmap.targets as eqmap_mod


spec std.mem.alloc.Box(hir_item.HFnSignature)
spec std.collections.vec.Vec(hir_file_mod.HirFile)
spec std.collections.vec.Vec(hir_item.HItem)
spec std.collections.vec.Vec(hir_item.HParam)


public type FmtTargets {
    i64_to_string: def_mod.DefId
    u64_to_string: def_mod.DefId
    bool_to_string: def_mod.DefId
    f64_to_string: def_mod.DefId
    string_concat: def_mod.DefId
    i128_to_string: def_mod.DefId
    u128_to_string: def_mod.DefId
    format_i128: def_mod.DefId
    format_u128: def_mod.DefId
    debug: eqmap_mod.EqTargets
}


public function none_targets(allocator: Allocator) -> FmtTargets
    with {allocator, err: alloc.AllocError}
{
    return FmtTargets {
        i64_to_string: def_mod.error(),
        u64_to_string: def_mod.error(),
        bool_to_string: def_mod.error(),
        f64_to_string: def_mod.error(),
        string_concat: def_mod.error(),
        i128_to_string: def_mod.error(),
        u128_to_string: def_mod.error(),
        format_i128: def_mod.error(),
        format_u128: def_mod.error(),
        debug: eqmap_mod.none_targets(allocator)?,
    }
}


public function build_fmt_targets(
    hir_files: Vec_HirFile.Vec,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> FmtTargets
    with {allocator, err: alloc.AllocError}
{
    var out = none_targets(allocator)?
    extend_fmt_targets(mutable out, hir_files, interner)
    return out
}


public function set_debug_targets(out: mutable FmtTargets, debug: take eqmap_mod.EqTargets) -> () {
    out.debug = debug
}


public function merge_fmt_targets(out: mutable FmtTargets, src: FmtTargets) -> () {
    if !def_mod.is_error(src.i64_to_string) { out.i64_to_string = src.i64_to_string }
    if !def_mod.is_error(src.u64_to_string) { out.u64_to_string = src.u64_to_string }
    if !def_mod.is_error(src.bool_to_string) { out.bool_to_string = src.bool_to_string }
    if !def_mod.is_error(src.f64_to_string) { out.f64_to_string = src.f64_to_string }
    if !def_mod.is_error(src.string_concat) { out.string_concat = src.string_concat }
    if !def_mod.is_error(src.i128_to_string) { out.i128_to_string = src.i128_to_string }
    if !def_mod.is_error(src.u128_to_string) { out.u128_to_string = src.u128_to_string }
    if !def_mod.is_error(src.format_i128) { out.format_i128 = src.format_i128 }
    if !def_mod.is_error(src.format_u128) { out.format_u128 = src.format_u128 }
}


public function extend_fmt_targets(
    out: mutable FmtTargets,
    hir_files: Vec_HirFile.Vec,
    interner: interner_mod.Interner,
) -> ()
{
    let nf: usize = Vec_HirFile.len(hir_files)
    var fi: usize = 0
    loop
        decreases (nf - fi)
    {
        if fi >= nf {
            break
        }
        let file = Vec_HirFile.at(hir_files, fi)
        insert_fmt_target_entries(mutable out, file.items, interner)
        fi = fi + 1
    }
}


function insert_fmt_target_entries(
    out: mutable FmtTargets,
    items: Vec_HItem.Vec,
    interner: interner_mod.Interner,
) -> ()
{
    let n: usize = Vec_HItem.len(items)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let item = Vec_HItem.at(items, i)
        match item.kind {
            case .function_(let sig_box, _) => {
                let sig = Box_HFnSignature.get(sig_box)
                let name_bytes = interner_mod.lookup(interner, sig.name)
                if slice.eq_u8(name_bytes, "i64_to_string".bytes()) {
                    out.i64_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "u64_to_string".bytes()) {
                    out.u64_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "bool_to_string".bytes()) {
                    out.bool_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "f64_to_string".bytes()) {
                    out.f64_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "concat".bytes()) && Vec_HParam.len(sig.params) == 3 as usize {
                    out.string_concat = item.def_id
                } else if slice.eq_u8(name_bytes, "i128_to_string".bytes()) {
                    out.i128_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "u128_to_string".bytes()) {
                    out.u128_to_string = item.def_id
                } else if slice.eq_u8(name_bytes, "format_i128".bytes()) {
                    out.format_i128 = item.def_id
                } else if slice.eq_u8(name_bytes, "format_u128".bytes()) {
                    out.format_u128 = item.def_id
                }
            }
            case _ => ()
        }
        i = i + 1
    }
}

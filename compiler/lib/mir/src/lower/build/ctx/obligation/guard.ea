
module mir.lower.build.ctx.obligation.guard

import std.mem.alloc
import std.collections.vec
import std.core.option
import hir.tree as hir_tree
import syntax.ast.tree as ast_tree_mod
import types.check as check_mod
import types.ty.interner as ty_interner_mod
import local.lower.build.ctx.builder as builder_mod
import local.lower.build.ctx.obligation.obligation as obligation_mod


spec std.collections.vec.Vec(ast_tree_mod.Expr)
spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.core.option.Option(ast_tree_mod.Expr)


public function guard_fact_expr(
    ctx: builder_mod.LowerCtx,
    cond: hir_tree.HExpr,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> Option_Expr.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    if !guard_operands_immutable(ctx, cond) {
        return Option_Expr.none
    }
    uninit scratch: Vec_Expr.Vec
    Vec_Expr.new(init scratch, allocator)?
    return obligation_mod.harg_to_ast_expr(ctx, cond, types_out, ty_interner, mutable scratch, allocator)?
}


function guard_operands_immutable(ctx: builder_mod.LowerCtx, e: hir_tree.HExpr) -> bool
    with {divergence}
{
    return match e.kind {
        case .literal(_) => true
        case .use_(let def) => match builder_mod.by_ref_param_ty(ctx, def) {
            case .some(_) => false
            case .none => true
        }
        case .unary(_, let inner) => guard_operands_immutable(ctx, Box_HExpr.get(inner))
        case .binary(_, let lhs, let rhs) => guard_operands_immutable(ctx, Box_HExpr.get(lhs)) && guard_operands_immutable(ctx, Box_HExpr.get(rhs))
        case _ => false
    }
}

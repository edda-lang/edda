public function push_slice_subrange_in_bounds(
    ctx: mutable LowerCtx,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires Vec_Statement.len(ctx.current_statements) < 4294967295
{
    let predicate = int_literal_expr(0 as u128)
    uninit context: Vec_Expr.Vec
    Vec_Expr.new(init context, allocator)?
    push_obligation(
        mutable ctx,
        body_mod.ObligationKind.slice_subrange_in_bounds,
        take predicate,
        take context,
        body_mod.TrustAnnotation.discharged,
        allocator,
    )?
}


public function push_narrowing_cast_range(
    ctx: mutable LowerCtx,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires Vec_Statement.len(ctx.current_statements) < 4294967295
{
    let predicate = int_literal_expr(0 as u128)
    uninit context: Vec_Expr.Vec
    Vec_Expr.new(init context, allocator)?
    push_obligation(
        mutable ctx,
        body_mod.ObligationKind.narrowing_cast_range,
        take predicate,
        take context,
        body_mod.TrustAnnotation.discharged,
        allocator,
    )?
}


function nonzero_literal_predicate(
    bits: u128,
    allocator: Allocator,
) -> ast_tree_mod.Expr
    with {allocator, err: alloc.AllocError}
{
    let lhs_expr = int_literal_expr(bits)
    let rhs_expr = int_literal_expr(0 as u128)
    let lhs = Box_Expr.new(take lhs_expr, allocator)?
    let rhs = Box_Expr.new(take rhs_expr, allocator)?
    return ast_tree_mod.Expr {
        span: span_mod.dummy(),
        kind: ast_tree_mod.ExprKind.binary(
            op: ast_ops_mod.BinOp.ne,
            lhs: lhs,
            rhs: rhs,
        ),
    }
}


function int_literal_expr(bits: u128) -> ast_tree_mod.Expr {
    return ast_tree_mod.Expr {
        span: span_mod.dummy(),
        kind: ast_tree_mod.ExprKind.literal(
            value: literal_mod.Literal.int(value: bits, base: int_base_mod.IntBase.dec),
        ),
    }
}


function bool_literal_expr(value: bool) -> ast_tree_mod.Expr {
    return ast_tree_mod.Expr {
        span: span_mod.dummy(),
        kind: ast_tree_mod.ExprKind.literal(
            value: literal_mod.Literal.bool(value: value),
        ),
    }
}


public function constant_value_expr(c: rvalue_mod.Constant) -> Option_Expr.Option {
    return match c.kind {
        case .int_(let bits) => Option_Expr.some(value: int_literal_expr(bits))
        case .bool_(let value) => Option_Expr.some(value: bool_literal_expr(value))
        case _ => Option_Expr.none
    }
}


public function set_ensures_clauses(ctx: mutable LowerCtx, clauses: take Vec_RefinementClause.Vec) -> () {
    ctx.ensures_clauses = clauses
}


public function bind_local(
    ctx: mutable LowerCtx,
    def_id: def_mod.DefId,
    local_id: local_mod.LocalId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let raw_value: u32 = local_id.raw
    let _ = IntMap_u32.insert(
        mutable ctx.locals_scope,
        def_id.raw as i64,
        take raw_value,
        allocator,
    )?
}

public function lookup_local(ctx: LowerCtx, def_id: def_mod.DefId) -> Option_LocalId.Option {
    return match IntMap_u32.get(ctx.locals_scope, def_id.raw as i64) {
        case .some(let raw) => Option_LocalId.some(value: local_mod.LocalId { raw: raw })
        case .none          => Option_LocalId.none
    }
}


public function record_closure_env_ty(
    ctx: mutable LowerCtx,
    node_id: node_mod.NodeId,
    env_ty: ty_mod.TyId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let raw_value: u32 = env_ty.raw
    let _ = IntMap_u32.insert(
        mutable ctx.closure_env_tys,
        node_id.raw as i64,
        take raw_value,
        allocator,
    )?
}

public function closure_env_ty_of(ctx: LowerCtx, node_id: node_mod.NodeId) -> ty_mod.TyId {
    return match IntMap_u32.get(ctx.closure_env_tys, node_id.raw as i64) {
        case .some(let raw) => ty_mod.TyId { raw: raw }
        case .none          => ty_mod.error()
    }
}

public function record_spawn_captures(
    ctx: mutable LowerCtx,
    node_id: node_mod.NodeId,
    defs: take Vec_DefId.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let entry = SpawnCaptureSet {
        node_raw: node_id.raw,
        defs: take defs,
    }
    Vec_SpawnCaptureSet.push(mutable ctx.spawn_captures, take entry, allocator)?
}

public function spawn_captures_of(ctx: LowerCtx, node_id: node_mod.NodeId) -> Option_Vec_DefId.Option
    with {divergence}
{
    let n = Vec_SpawnCaptureSet.len(ctx.spawn_captures)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let entry = Vec_SpawnCaptureSet.at(ctx.spawn_captures, i)
        if entry.node_raw == node_id.raw {
            return Option_Vec_DefId.some(value: entry.defs)
        }
        i = i + 1
    }
    return Option_Vec_DefId.none
}

public function record_closure_escapes(
    ctx: mutable LowerCtx,
    node_id: node_mod.NodeId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let marker: u32 = 1
    let _ = IntMap_u32.insert(
        mutable ctx.closure_escapes,
        node_id.raw as i64,
        take marker,
        allocator,
    )?
}

public function closure_escapes_of(ctx: LowerCtx, node_id: node_mod.NodeId) -> bool {
    return match IntMap_u32.get(ctx.closure_escapes, node_id.raw as i64) {
        case .some(_) => true
        case .none    => false
    }
}

public function mark_by_ref_param(
    ctx: mutable LowerCtx,
    def_id: def_mod.DefId,
    value_ty: ty_mod.TyId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let raw_value: u32 = value_ty.raw
    let _ = IntMap_u32.insert(
        mutable ctx.by_ref_param_tys,
        def_id.raw as i64,
        take raw_value,
        allocator,
    )?
}

public function by_ref_param_ty(ctx: LowerCtx, def_id: def_mod.DefId) -> Option_TyId.Option {
    return match IntMap_u32.get(ctx.by_ref_param_tys, def_id.raw as i64) {
        case .some(let raw) => Option_TyId.some(value: ty_mod.TyId { raw: raw })
        case .none          => Option_TyId.none
    }
}


public function enter_loop(
    ctx: mutable LowerCtx,
    frame: take LoopFrame,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_LoopFrame.push(mutable ctx.loop_stack, take frame, allocator)?
}

public function exit_loop(ctx: mutable LowerCtx) -> Option_LoopFrame.Option {
    return Vec_LoopFrame.pop(mutable ctx.loop_stack)
}

public function innermost_loop(ctx: LowerCtx) -> Option_LoopFrame.Option {
    return Vec_LoopFrame.last(ctx.loop_stack)
}

public function find_loop_by_label(ctx: LowerCtx, label: symbol_mod.Symbol) -> Option_LoopFrame.Option {
    let n = Vec_LoopFrame.len(ctx.loop_stack)
    var i: usize = n
    loop
        decreases i
    {
        if i == 0 as usize {
            break
        }
        i = i - 1
        let frame = Vec_LoopFrame.at(ctx.loop_stack, i)
        match frame.label {
            case .some(let l) => {
                if l.raw == label.raw {
                    return Option_LoopFrame.some(value: frame)
                }
            }
            case .none => ()
        }
    }
    return Option_LoopFrame.none
}


public function enter_handler(
    ctx: mutable LowerCtx,
    frame: take HandlerFrame,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_HandlerFrame.push(mutable ctx.handler_stack, take frame, allocator)?
}

public function exit_handler(ctx: mutable LowerCtx) -> Option_HandlerFrame.Option {
    return Vec_HandlerFrame.pop(mutable ctx.handler_stack)
}

public function innermost_matching_handler(ctx: LowerCtx, raised_ty: ty_mod.TyId) -> Option_HandlerFrame.Option {
    let n = Vec_HandlerFrame.len(ctx.handler_stack)
    var i: usize = n
    loop
        decreases i
    {
        if i == 0 as usize {
            break
        }
        i = i - 1
        let frame = Vec_HandlerFrame.at(ctx.handler_stack, i)
        if frame.caught_ty.raw == raised_ty.raw {
            return Option_HandlerFrame.some(value: frame)
        }
    }
    return Option_HandlerFrame.none
}


public function alloc_region(ctx: mutable LowerCtx) -> body_mod.RegionId
    with {panic}
{
    let slot = ctx.next_region_id
    let bumped = ctx.next_region_id +| 1
    if bumped == ctx.next_region_id {
        panic("coherence region id space exhausted")
    }
    ctx.next_region_id = bumped
    return body_mod.RegionId { raw: slot }
}

public function current_region(ctx: LowerCtx) -> Option_RegionId.Option {
    return ctx.current_coherence_region
}

public function set_coherence_region(ctx: mutable LowerCtx, region: Option_RegionId.Option) -> () {
    ctx.current_coherence_region = region
}

public function current_exec_group(ctx: LowerCtx) -> Option_LocalId.Option {
    return ctx.current_exec_group
}

public function set_exec_group(ctx: mutable LowerCtx, group: Option_LocalId.Option) -> () {
    ctx.current_exec_group = group
}


public function local_place(local_id: local_mod.LocalId) -> place_mod.Place {
    return place_mod.Place {
        local: local_id,
        projection: Option_Vec_Projection.none,
    }
}

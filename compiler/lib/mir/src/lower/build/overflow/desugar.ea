module mir.lower.build.overflow.desugar

import std.mem.alloc
import std.collections.vec
import std.core.option
import intern.interner as interner_mod
import intern.symbol as symbol_mod
import hir.node as node_mod
import hir.def as def_mod
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import types.check as check_mod
import types.check.env.fields as fields_mod
import local.rvalue as rvalue_mod
import local.body.model as body_mod
import local.stmt as stmt_mod
import local.term as term_mod
import local.id.local as local_mod
import local.id.block as block_mod
import local.lower.build.ctx.builder as builder_mod


spec std.collections.vec.Vec(rvalue_mod.Operand)
spec std.collections.vec.Vec(symbol_mod.Symbol)
spec std.collections.vec.Vec(fields_mod.VariantNameList)
spec std.collections.vec.Vec(ty_mod.TyId)


spec std.core.option.Option(builder_mod.HandlerFrame)
spec std.core.option.Option(symbol_mod.Symbol)
spec std.core.option.Option(node_mod.NodeId)
spec std.core.option.Option(body_mod.RegionId)


public type CheckedOp {
    case add_
    case sub_
    case mul_
    case mod_
}

public type IntShape {
    is_int: bool
    width: u32
    signed_: bool
}


public function find_overflow_info(
    types_out: check_mod.TypeOutput,
    interner: interner_mod.Interner,
) -> builder_mod.OverflowInfo
{
    let n = Vec_VariantNameList.len(types_out.variant_names)
    let n_tys = Vec_TyId.len(types_out.type_defs)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let list = Vec_VariantNameList.at(types_out.variant_names, i)
        if Vec_Symbol.len(list.names) == (1 as usize) && i < n_tys {
            let sym = Vec_Symbol.at(list.names, 0 as usize)
            if symbol_spells_overflow(interner, sym) {
                let ty = Vec_TyId.at(types_out.type_defs, i)
                if !ty_mod.is_error(ty) {
                    return builder_mod.OverflowInfo {
                        found: true,
                        def_id: def_mod.DefId { raw: i as u32 },
                        ty: ty,
                        variant_idx: 0,
                    }
                }
            }
        }
        i = i + 1
    }
    return builder_mod.missing_overflow_info()
}

function symbol_spells_overflow(
    interner: interner_mod.Interner,
    sym: symbol_mod.Symbol,
) -> bool {
    if (sym.raw as usize) >= interner_mod.slot_count(interner) {
        return false
    }
    let bytes = interner_mod.lookup(interner, sym)
    let expected = "overflow".bytes()
    if bytes.len() != expected.len() {
        return false
    }
    let n = expected.len()
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        if bytes[i] != expected[i] {
            return false
        }
        i = i + 1
    }
    return true
}


public function int_shape(
    ty: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
) -> IntShape {
    var current = ty
    var fuel: u32 = 16
    loop
        decreases fuel
    {
        if fuel == (0 as u32) {
            break
        }
        fuel = fuel - (1 as u32)
        if (current.raw as usize) >= ty_interner_mod.slot_count(ty_interner) {
            break
        }
        match ty_interner_mod.lookup(ty_interner, current) {
            case .primitive(let p) => return prim_shape(p)
            case .refined(let base, _) => { current = base }
            case _ => break
        }
    }
    return IntShape { is_int: false, width: 0, signed_: false }
}

function prim_shape(p: ty_kind_mod.PrimKind) -> IntShape {
    return match p {
        case .i8_ => IntShape { is_int: true, width: 1, signed_: true }
        case .i16_ => IntShape { is_int: true, width: 2, signed_: true }
        case .i32_ => IntShape { is_int: true, width: 4, signed_: true }
        case .i64_ => IntShape { is_int: true, width: 8, signed_: true }
        case .isize_ => IntShape { is_int: true, width: 8, signed_: true }
        case .i128_ => IntShape { is_int: true, width: 16, signed_: true }
        case .u8_ => IntShape { is_int: true, width: 1, signed_: false }
        case .u16_ => IntShape { is_int: true, width: 2, signed_: false }
        case .u32_ => IntShape { is_int: true, width: 4, signed_: false }
        case .u64_ => IntShape { is_int: true, width: 8, signed_: false }
        case .usize_ => IntShape { is_int: true, width: 8, signed_: false }
        case .u128_ => IntShape { is_int: true, width: 16, signed_: false }
        case _ => IntShape { is_int: false, width: 0, signed_: false }
    }
}


function ones_bits(width: u32) -> u128 {
    if width >= (16 as u32) {
        return 340282366920938463463374607431768211455
    }
    let bits: u128 = (1 as u128) << ((8 as u128) * (width as u128))
    return bits - (1 as u128)
}

function min_bits_for(width: u32) -> u128 {
    let shift: u128 = (8 as u128) * (width as u128) - (1 as u128)
    return (1 as u128) << shift
}


function const_int(ty: ty_mod.TyId, bits: u128) -> rvalue_mod.Operand {
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: ty,
            kind: rvalue_mod.ConstantKind.int_(bits: bits),
        },
    )
}

function const_false(ty: ty_mod.TyId) -> rvalue_mod.Operand {
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: ty,
            kind: rvalue_mod.ConstantKind.bool_(value: false),
        },
    )
}


function new_temp(
    ctx: mutable builder_mod.LowerCtx,
    ty: ty_mod.TyId,
    node: node_mod.NodeId,
    allocator: Allocator,
) -> local_mod.LocalId
    with {allocator, err: alloc.AllocError}
{
    return builder_mod.alloc_local(
        mutable ctx,
        ty,
        body_mod.Mutability.mutable_,
        body_mod.Consumption.copy_,
        Option_Symbol.none,
        Option_NodeId.some(value: node),
        allocator,
    )?
}

function assign_rv(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    dest: local_mod.LocalId,
    value: rvalue_mod.Rvalue,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let dest_place = builder_mod.local_place(dest)
    let assign_stmt = stmt_mod.Statement {
        origin: node,
        kind: stmt_mod.MStmtKind.assign(dest: dest_place, value: value),
    }
    builder_mod.push_stmt(mutable ctx, take assign_stmt, allocator)?
}

function copy_of(local: local_mod.LocalId, ty: ty_mod.TyId) -> rvalue_mod.Operand {
    let place = builder_mod.local_place(local)
    return rvalue_mod.Operand.copy_(place: place, ty: ty)
}

function stash_operand(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    op: rvalue_mod.Operand,
    ty: ty_mod.TyId,
    allocator: Allocator,
) -> local_mod.LocalId
    with {allocator, err: alloc.AllocError}
{
    let local = new_temp(mutable ctx, ty, node, allocator)?
    assign_rv(mutable ctx, node, local, rvalue_mod.Rvalue.use_(operand: op), allocator)?
    return local
}

function wrap_cast(
    op: rvalue_mod.Operand,
    from: ty_mod.TyId,
    to: ty_mod.TyId,
) -> rvalue_mod.Rvalue {
    return rvalue_mod.Rvalue.cast(
        operand: op,
        from: from,
        to: to,
        kind: rvalue_mod.CastKind.int_to_int(mode: rvalue_mod.OverflowMode.wrapping_),
    )
}

function wrap_binop(op: CheckedOp) -> rvalue_mod.MBinOp
    with {panic}
{
    return match op {
        case .add_ => rvalue_mod.MBinOp.add(mode: rvalue_mod.OverflowMode.wrapping_)
        case .sub_ => rvalue_mod.MBinOp.sub(mode: rvalue_mod.OverflowMode.wrapping_)
        case .mul_ => rvalue_mod.MBinOp.mul(mode: rvalue_mod.OverflowMode.wrapping_)
        case .mod_ => panic("checked.wrap_binop: checked modulo has no wide wrapping form")
    }
}


function emit_overflow_exit(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    flag_op: rvalue_mod.Operand,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let info = ctx.overflow_info
    let ok_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let err_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let branch_term = term_mod.Terminator {
        origin: node,
        kind: term_mod.TermKind.branch(cond: flag_op, true_: err_bb, false_: ok_bb),
    }
    builder_mod.seal_block_with(mutable ctx, take branch_term, allocator)?
    builder_mod.switch_to(mutable ctx, err_bb)
    uninit elems: Vec_Operand.Vec
    Vec_Operand.new(init elems, allocator)?
    let agg = rvalue_mod.Rvalue.aggregate(
        kind: rvalue_mod.AggregateKind.variant(def: info.def_id, variant_idx: info.variant_idx),
        elems: elems,
        result_ty: info.ty,
    )
    match builder_mod.innermost_matching_handler(ctx, info.ty) {
        case .some(let frame) => {
            assign_rv(mutable ctx, node, frame.binder_local, agg, allocator)?
            let goto_handler = term_mod.Terminator {
                origin: node,
                kind: term_mod.TermKind.goto_(target: frame.handler_block),
            }
            builder_mod.seal_block_with(mutable ctx, take goto_handler, allocator)?
        }
        case .none => {
            let value_local = new_temp(mutable ctx, info.ty, node, allocator)?
            assign_rv(mutable ctx, node, value_local, agg, allocator)?
            let value_place = builder_mod.local_place(value_local)
            let raise_term = term_mod.Terminator {
                origin: node,
                kind: term_mod.TermKind.raise_(
                    value: rvalue_mod.Operand.move_(place: value_place, ty: info.ty),
                    unwind: term_mod.UnwindAction.propagate,
                ),
            }
            builder_mod.seal_block_with(mutable ctx, take raise_term, allocator)?
        }
    }
    builder_mod.switch_to(mutable ctx, ok_bb)
}


public function desugar_checked_binop(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    op: CheckedOp,
    lhs_op: rvalue_mod.Operand,
    rhs_op: rvalue_mod.Operand,
    operand_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    if !ctx.overflow_info.found {
        panic("checked arithmetic requires std.core.overflow.Overflow in the compilation set")
    }
    let shape = int_shape(operand_ty, ty_interner)
    if !shape.is_int {
        panic("checked arithmetic on a non-integer operand type")
    }
    match op {
        case .mod_ => return desugar_checked_mod(
            mutable ctx, node, lhs_op, rhs_op, operand_ty, shape, types_out, allocator,
        )?
        case _ => ()
    }
    if shape.width < (8 as u32) {
        return checked_narrow(
            mutable ctx, node, op, lhs_op, rhs_op, operand_ty, shape, types_out, allocator,
        )?
    }
    let lhs_l = stash_operand(mutable ctx, node, lhs_op, operand_ty, allocator)?
    let rhs_l = stash_operand(mutable ctx, node, rhs_op, operand_ty, allocator)?
    let r = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, r, rvalue_mod.Rvalue.binary(
        op: wrap_binop(op),
        lhs: copy_of(lhs_l, operand_ty),
        rhs: copy_of(rhs_l, operand_ty),
    ), allocator)?
    match op {
        case .mul_ => emit_full_width_mul_check(
            mutable ctx, node, lhs_l, rhs_l, r, operand_ty, shape, types_out, allocator,
        )?
        case _ => emit_full_width_addsub_check(
            mutable ctx, node, op, lhs_l, rhs_l, r, operand_ty, shape, types_out, allocator,
        )?
    }
    return copy_of(r, operand_ty)
}


function checked_narrow(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    op: CheckedOp,
    lhs_op: rvalue_mod.Operand,
    rhs_op: rvalue_mod.Operand,
    operand_ty: ty_mod.TyId,
    shape: IntShape,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    let wide = if shape.signed_ { types_out.builtins.i64_ } else { types_out.builtins.u64_ }
    let lhs_w = new_temp(mutable ctx, wide, node, allocator)?
    assign_rv(mutable ctx, node, lhs_w, wrap_cast(lhs_op, operand_ty, wide), allocator)?
    let rhs_w = new_temp(mutable ctx, wide, node, allocator)?
    assign_rv(mutable ctx, node, rhs_w, wrap_cast(rhs_op, operand_ty, wide), allocator)?
    let r_w = new_temp(mutable ctx, wide, node, allocator)?
    assign_rv(mutable ctx, node, r_w, rvalue_mod.Rvalue.binary(
        op: wrap_binop(op),
        lhs: copy_of(lhs_w, wide),
        rhs: copy_of(rhs_w, wide),
    ), allocator)?
    let r = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, r, wrap_cast(
        copy_of(r_w, wide), wide, operand_ty,
    ), allocator)?
    let back = new_temp(mutable ctx, wide, node, allocator)?
    assign_rv(mutable ctx, node, back, wrap_cast(
        copy_of(r, operand_ty), operand_ty, wide,
    ), allocator)?
    let bool_ty = types_out.builtins.bool_
    let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.ne,
        lhs: copy_of(back, wide),
        rhs: copy_of(r_w, wide),
    ), allocator)?
    emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
    return copy_of(r, operand_ty)
}


function emit_full_width_addsub_check(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    op: CheckedOp,
    lhs_l: local_mod.LocalId,
    rhs_l: local_mod.LocalId,
    r: local_mod.LocalId,
    operand_ty: ty_mod.TyId,
    shape: IntShape,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let bool_ty = types_out.builtins.bool_
    let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
    if shape.signed_ {
        let t1 = new_temp(mutable ctx, operand_ty, node, allocator)?
        let t2 = new_temp(mutable ctx, operand_ty, node, allocator)?
        match op {
            case .sub_ => {
                assign_rv(mutable ctx, node, t1, rvalue_mod.Rvalue.binary(
                    op: rvalue_mod.MBinOp.bit_xor,
                    lhs: copy_of(lhs_l, operand_ty),
                    rhs: copy_of(rhs_l, operand_ty),
                ), allocator)?
                assign_rv(mutable ctx, node, t2, rvalue_mod.Rvalue.binary(
                    op: rvalue_mod.MBinOp.bit_xor,
                    lhs: copy_of(lhs_l, operand_ty),
                    rhs: copy_of(r, operand_ty),
                ), allocator)?
            }
            case _ => {
                assign_rv(mutable ctx, node, t1, rvalue_mod.Rvalue.binary(
                    op: rvalue_mod.MBinOp.bit_xor,
                    lhs: copy_of(r, operand_ty),
                    rhs: copy_of(lhs_l, operand_ty),
                ), allocator)?
                assign_rv(mutable ctx, node, t2, rvalue_mod.Rvalue.binary(
                    op: rvalue_mod.MBinOp.bit_xor,
                    lhs: copy_of(r, operand_ty),
                    rhs: copy_of(rhs_l, operand_ty),
                ), allocator)?
            }
        }
        let t3 = new_temp(mutable ctx, operand_ty, node, allocator)?
        assign_rv(mutable ctx, node, t3, rvalue_mod.Rvalue.binary(
            op: rvalue_mod.MBinOp.bit_and,
            lhs: copy_of(t1, operand_ty),
            rhs: copy_of(t2, operand_ty),
        ), allocator)?
        assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
            op: rvalue_mod.MBinOp.lt,
            lhs: copy_of(t3, operand_ty),
            rhs: const_int(operand_ty, 0),
        ), allocator)?
    } else {
        match op {
            case .sub_ => assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
                op: rvalue_mod.MBinOp.lt,
                lhs: copy_of(lhs_l, operand_ty),
                rhs: copy_of(rhs_l, operand_ty),
            ), allocator)?
            case _ => assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
                op: rvalue_mod.MBinOp.lt,
                lhs: copy_of(r, operand_ty),
                rhs: copy_of(lhs_l, operand_ty),
            ), allocator)?
        }
    }
    emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
}


function emit_full_width_mul_check(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    lhs_l: local_mod.LocalId,
    rhs_l: local_mod.LocalId,
    r: local_mod.LocalId,
    operand_ty: ty_mod.TyId,
    shape: IntShape,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let bool_ty = types_out.builtins.bool_
    let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.use_(operand: const_false(bool_ty)), allocator)?
    let is_zero = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, is_zero, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.eq,
        lhs: copy_of(lhs_l, operand_ty),
        rhs: const_int(operand_ty, 0),
    ), allocator)?
    let join_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let div_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    if shape.signed_ {
        let neg1_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
        let minchk_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
        seal_branch(mutable ctx, node, copy_of(is_zero, bool_ty), join_bb, neg1_bb, allocator)?
        builder_mod.switch_to(mutable ctx, neg1_bb)
        let is_neg1 = new_temp(mutable ctx, bool_ty, node, allocator)?
        assign_rv(mutable ctx, node, is_neg1, rvalue_mod.Rvalue.binary(
            op: rvalue_mod.MBinOp.eq,
            lhs: copy_of(lhs_l, operand_ty),
            rhs: const_int(operand_ty, ones_bits(shape.width)),
        ), allocator)?
        seal_branch(mutable ctx, node, copy_of(is_neg1, bool_ty), minchk_bb, div_bb, allocator)?
        builder_mod.switch_to(mutable ctx, minchk_bb)
        let is_min = new_temp(mutable ctx, bool_ty, node, allocator)?
        assign_rv(mutable ctx, node, is_min, rvalue_mod.Rvalue.binary(
            op: rvalue_mod.MBinOp.eq,
            lhs: copy_of(rhs_l, operand_ty),
            rhs: const_int(operand_ty, min_bits_for(shape.width)),
        ), allocator)?
        assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.use_(
            operand: copy_of(is_min, bool_ty),
        ), allocator)?
        seal_goto(mutable ctx, node, join_bb, allocator)?
    } else {
        seal_branch(mutable ctx, node, copy_of(is_zero, bool_ty), join_bb, div_bb, allocator)?
    }
    builder_mod.switch_to(mutable ctx, div_bb)
    let q = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, q, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.div(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false),
        lhs: copy_of(r, operand_ty),
        rhs: copy_of(lhs_l, operand_ty),
    ), allocator)?
    let mismatch = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, mismatch, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.ne,
        lhs: copy_of(q, operand_ty),
        rhs: copy_of(rhs_l, operand_ty),
    ), allocator)?
    assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.use_(
        operand: copy_of(mismatch, bool_ty),
    ), allocator)?
    seal_goto(mutable ctx, node, join_bb, allocator)?
    builder_mod.switch_to(mutable ctx, join_bb)
    emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
}


function desugar_checked_mod(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    lhs_op: rvalue_mod.Operand,
    rhs_op: rvalue_mod.Operand,
    operand_ty: ty_mod.TyId,
    shape: IntShape,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError}
{
    if !shape.signed_ {
        let r = new_temp(mutable ctx, operand_ty, node, allocator)?
        assign_rv(mutable ctx, node, r, rvalue_mod.Rvalue.binary(
            op: rvalue_mod.MBinOp.mod_(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false),
            lhs: lhs_op,
            rhs: rhs_op,
        ), allocator)?
        return copy_of(r, operand_ty)
    }
    let lhs_l = stash_operand(mutable ctx, node, lhs_op, operand_ty, allocator)?
    let rhs_l = stash_operand(mutable ctx, node, rhs_op, operand_ty, allocator)?
    let bool_ty = types_out.builtins.bool_
    let is_min = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, is_min, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.eq,
        lhs: copy_of(lhs_l, operand_ty),
        rhs: const_int(operand_ty, min_bits_for(shape.width)),
    ), allocator)?
    let is_neg1 = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, is_neg1, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.eq,
        lhs: copy_of(rhs_l, operand_ty),
        rhs: const_int(operand_ty, ones_bits(shape.width)),
    ), allocator)?
    let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.bit_and,
        lhs: copy_of(is_min, bool_ty),
        rhs: copy_of(is_neg1, bool_ty),
    ), allocator)?
    emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
    let r = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, r, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.mod_(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false),
        lhs: copy_of(lhs_l, operand_ty),
        rhs: copy_of(rhs_l, operand_ty),
    ), allocator)?
    let corrected = emit_signed_mod_correction(mutable ctx, node, r, rhs_l, operand_ty, types_out, allocator)?
    return copy_of(corrected, operand_ty)
}


public function desugar_signed_mod(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    lhs_op: rvalue_mod.Operand,
    rhs_op: rvalue_mod.Operand,
    operand_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError}
{
    let rhs_l = stash_operand(mutable ctx, node, rhs_op, operand_ty, allocator)?
    let r = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, r, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.mod_(mode: rvalue_mod.OverflowMode.trapping, proven_nonzero: false, proven_no_overflow: false),
        lhs: lhs_op,
        rhs: copy_of(rhs_l, operand_ty),
    ), allocator)?
    let corrected = emit_signed_mod_correction(mutable ctx, node, r, rhs_l, operand_ty, types_out, allocator)?
    return copy_of(corrected, operand_ty)
}


function emit_signed_mod_correction(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    r0: local_mod.LocalId,
    rhs_l: local_mod.LocalId,
    operand_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> local_mod.LocalId
    with {allocator, err: alloc.AllocError}
{
    let bool_ty = types_out.builtins.bool_
    let abs_rhs = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, abs_rhs, rvalue_mod.Rvalue.use_(
        operand: copy_of(rhs_l, operand_ty),
    ), allocator)?
    let y_neg = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, y_neg, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.lt,
        lhs: copy_of(rhs_l, operand_ty),
        rhs: const_int(operand_ty, 0),
    ), allocator)?
    let neg_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let abs_join_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    seal_branch(mutable ctx, node, copy_of(y_neg, bool_ty), neg_bb, abs_join_bb, allocator)?
    builder_mod.switch_to(mutable ctx, neg_bb)
    assign_rv(mutable ctx, node, abs_rhs, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.sub(mode: rvalue_mod.OverflowMode.wrapping_),
        lhs: const_int(operand_ty, 0),
        rhs: copy_of(rhs_l, operand_ty),
    ), allocator)?
    seal_goto(mutable ctx, node, abs_join_bb, allocator)?
    builder_mod.switch_to(mutable ctx, abs_join_bb)
    let out_val = new_temp(mutable ctx, operand_ty, node, allocator)?
    assign_rv(mutable ctx, node, out_val, rvalue_mod.Rvalue.use_(
        operand: copy_of(r0, operand_ty),
    ), allocator)?
    let r_neg = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, r_neg, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.lt,
        lhs: copy_of(r0, operand_ty),
        rhs: const_int(operand_ty, 0),
    ), allocator)?
    let add_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let join_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    seal_branch(mutable ctx, node, copy_of(r_neg, bool_ty), add_bb, join_bb, allocator)?
    builder_mod.switch_to(mutable ctx, add_bb)
    assign_rv(mutable ctx, node, out_val, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.add(mode: rvalue_mod.OverflowMode.wrapping_),
        lhs: copy_of(r0, operand_ty),
        rhs: copy_of(abs_rhs, operand_ty),
    ), allocator)?
    seal_goto(mutable ctx, node, join_bb, allocator)?
    builder_mod.switch_to(mutable ctx, join_bb)
    return out_val
}


function seal_branch(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    cond: rvalue_mod.Operand,
    true_bb: block_mod.BlockId,
    false_bb: block_mod.BlockId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let branch_term = term_mod.Terminator {
        origin: node,
        kind: term_mod.TermKind.branch(cond: cond, true_: true_bb, false_: false_bb),
    }
    builder_mod.seal_block_with(mutable ctx, take branch_term, allocator)?
}

function seal_goto(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    target: block_mod.BlockId,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let goto_term = term_mod.Terminator {
        origin: node,
        kind: term_mod.TermKind.goto_(target: target),
    }
    builder_mod.seal_block_with(mutable ctx, take goto_term, allocator)?
}


public function desugar_checked_cast(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    src_op: rvalue_mod.Operand,
    from_ty: ty_mod.TyId,
    to_ty: ty_mod.TyId,
    types_out: check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    if !ctx.overflow_info.found {
        panic("checked cast requires std.core.overflow.Overflow in the compilation set")
    }
    let s = int_shape(from_ty, ty_interner)
    let t = int_shape(to_ty, ty_interner)
    if !s.is_int || !t.is_int {
        panic("checked cast desugar on a non-integer type")
    }
    if s.width > (8 as u32) || t.width > (8 as u32) {
        panic("128-bit checked casts are not supported by the native backend")
    }
    if s.width == t.width && s.signed_ == t.signed_ {
        return plain_wrap_cast(mutable ctx, node, src_op, from_ty, to_ty, allocator)?
    }
    let bool_ty = types_out.builtins.bool_
    if t.width == (8 as u32) {
        if s.signed_ && !t.signed_ {
            let src_l = stash_operand(mutable ctx, node, src_op, from_ty, allocator)?
            let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
            assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
                op: rvalue_mod.MBinOp.lt,
                lhs: copy_of(src_l, from_ty),
                rhs: const_int(from_ty, 0),
            ), allocator)?
            emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
            return plain_wrap_cast(
                mutable ctx, node, copy_of(src_l, from_ty), from_ty, to_ty, allocator,
            )?
        }
        if !s.signed_ && t.signed_ && s.width == (8 as u32) {
            let src_l = stash_operand(mutable ctx, node, src_op, from_ty, allocator)?
            let i64_ty = types_out.builtins.i64_
            let src_i = new_temp(mutable ctx, i64_ty, node, allocator)?
            assign_rv(mutable ctx, node, src_i, wrap_cast(
                copy_of(src_l, from_ty), from_ty, i64_ty,
            ), allocator)?
            let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
            assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
                op: rvalue_mod.MBinOp.lt,
                lhs: copy_of(src_i, i64_ty),
                rhs: const_int(i64_ty, 0),
            ), allocator)?
            emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
            return plain_wrap_cast(
                mutable ctx, node, copy_of(src_l, from_ty), from_ty, to_ty, allocator,
            )?
        }
        return plain_wrap_cast(mutable ctx, node, src_op, from_ty, to_ty, allocator)?
    }
    let src_l = stash_operand(mutable ctx, node, src_op, from_ty, allocator)?
    let narrowed = new_temp(mutable ctx, to_ty, node, allocator)?
    assign_rv(mutable ctx, node, narrowed, wrap_cast(
        copy_of(src_l, from_ty), from_ty, to_ty,
    ), allocator)?
    let i64_ty = types_out.builtins.i64_
    let back = new_temp(mutable ctx, i64_ty, node, allocator)?
    assign_rv(mutable ctx, node, back, wrap_cast(
        copy_of(narrowed, to_ty), to_ty, i64_ty,
    ), allocator)?
    let src_w = new_temp(mutable ctx, i64_ty, node, allocator)?
    assign_rv(mutable ctx, node, src_w, wrap_cast(
        copy_of(src_l, from_ty), from_ty, i64_ty,
    ), allocator)?
    let flag = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, flag, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.ne,
        lhs: copy_of(back, i64_ty),
        rhs: copy_of(src_w, i64_ty),
    ), allocator)?
    emit_overflow_exit(mutable ctx, node, copy_of(flag, bool_ty), allocator)?
    return copy_of(narrowed, to_ty)
}

function plain_wrap_cast(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    src_op: rvalue_mod.Operand,
    from_ty: ty_mod.TyId,
    to_ty: ty_mod.TyId,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError}
{
    let r = new_temp(mutable ctx, to_ty, node, allocator)?
    assign_rv(mutable ctx, node, r, wrap_cast(src_op, from_ty, to_ty), allocator)?
    return copy_of(r, to_ty)
}


function const_float(ty: ty_mod.TyId, bits: u64, width: rvalue_mod.FloatWidth) -> rvalue_mod.Operand {
    return rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: ty,
            kind: rvalue_mod.ConstantKind.float_(bits: bits, width: width),
        },
    )
}

function lo_bound_bits(wk_to: u8) -> u64 {
    if wk_to == (1 as u8) {
        let sign: u64 = (1 as u64) << (63 as u64)
        return sign | ((1150 as u64) << (52 as u64))
    }
    return 0 as u64
}

function hi_bound_bits(wk_to: u8) -> u64 {
    if wk_to == (1 as u8) {
        return (1150 as u64) << (52 as u64)
    }
    return (1151 as u64) << (52 as u64)
}


public function checked_float_to_wide_guard(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    src_op: rvalue_mod.Operand,
    from_ty: ty_mod.TyId,
    fw_from: u8,
    wk_to: u8,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    return float_to_wide_range_guard(mutable ctx, node, src_op, from_ty, fw_from, wk_to, false, types_out, allocator)?
}


public function trapping_float_to_wide_guard(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    src_op: rvalue_mod.Operand,
    from_ty: ty_mod.TyId,
    fw_from: u8,
    wk_to: u8,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    return float_to_wide_range_guard(mutable ctx, node, src_op, from_ty, fw_from, wk_to, true, types_out, allocator)?
}


function float_to_wide_range_guard(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    src_op: rvalue_mod.Operand,
    from_ty: ty_mod.TyId,
    fw_from: u8,
    wk_to: u8,
    is_trap: bool,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> rvalue_mod.Operand
    with {allocator, err: alloc.AllocError, panic}
{
    if !is_trap && !ctx.overflow_info.found {
        panic("checked float-to-128-bit cast requires std.core.overflow.Overflow in the compilation set")
    }
    let f64_ty = types_out.builtins.f64_
    let bool_ty = types_out.builtins.bool_
    let src_l = stash_operand(mutable ctx, node, src_op, from_ty, allocator)?
    var chk_l = src_l
    var chk_ty = from_ty
    if fw_from != (2 as u8) {
        let widened = new_temp(mutable ctx, f64_ty, node, allocator)?
        assign_rv(mutable ctx, node, widened, rvalue_mod.Rvalue.cast(
            operand: copy_of(src_l, from_ty),
            from: from_ty,
            to: f64_ty,
            kind: rvalue_mod.CastKind.float_to_float,
        ), allocator)?
        chk_l = widened
        chk_ty = f64_ty
    }
    let lo = const_float(f64_ty, lo_bound_bits(wk_to), rvalue_mod.FloatWidth.f64_)
    let hi = const_float(f64_ty, hi_bound_bits(wk_to), rvalue_mod.FloatWidth.f64_)
    let below = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, below, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.lt,
        lhs: copy_of(chk_l, chk_ty),
        rhs: lo,
    ), allocator)?
    emit_range_exit(mutable ctx, node, copy_of(below, bool_ty), is_trap, types_out, allocator)?
    let above = new_temp(mutable ctx, bool_ty, node, allocator)?
    assign_rv(mutable ctx, node, above, rvalue_mod.Rvalue.binary(
        op: rvalue_mod.MBinOp.ge,
        lhs: copy_of(chk_l, chk_ty),
        rhs: hi,
    ), allocator)?
    emit_range_exit(mutable ctx, node, copy_of(above, bool_ty), is_trap, types_out, allocator)?
    return copy_of(src_l, from_ty)
}


function emit_range_exit(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    flag_op: rvalue_mod.Operand,
    is_trap: bool,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if is_trap {
        emit_trap_exit(mutable ctx, node, flag_op, types_out, allocator)?
        return ()
    }
    emit_overflow_exit(mutable ctx, node, flag_op, allocator)?
}


function emit_trap_exit(
    ctx: mutable builder_mod.LowerCtx,
    node: node_mod.NodeId,
    flag_op: rvalue_mod.Operand,
    types_out: check_mod.TypeOutput,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let ok_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let trap_bb = builder_mod.alloc_block(mutable ctx, node, Option_RegionId.none, allocator)?
    let branch_term = term_mod.Terminator {
        origin: node,
        kind: term_mod.TermKind.branch(cond: flag_op, true_: trap_bb, false_: ok_bb),
    }
    builder_mod.seal_block_with(mutable ctx, take branch_term, allocator)?
    builder_mod.switch_to(mutable ctx, trap_bb)
    let msg = rvalue_mod.Operand.constant(
        c: rvalue_mod.Constant {
            ty: types_out.builtins.string_,
            kind: rvalue_mod.ConstantKind.str_(symbol: symbol_mod.from_raw(symbol_mod.trap_float_to_wide_range_raw())),
        },
    )
    let trap_term = term_mod.Terminator {
        origin: node,
        kind: term_mod.TermKind.panic_(message: msg),
    }
    builder_mod.seal_block_with(mutable ctx, take trap_term, allocator)?
    builder_mod.switch_to(mutable ctx, ok_bb)
}

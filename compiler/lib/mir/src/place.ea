
module mir.place

import std.collections.vec
import std.core.option
import std.mem.alloc
import types.pass.ty as ty_mod
import local.id.local as local_mod


spec std.collections.vec.Vec(Projection)
spec std.core.option.Option(Vec_Projection)


derive eq, hash, debug for Place
derive eq, hash, debug for Projection
derive eq, hash, debug for ProjectionKind


public type Place {
    local: local_mod.LocalId
    projection: Option_Vec_Projection.Option
}

public function bare(local: local_mod.LocalId) -> Place {
    return Place { local: local, projection: Option_Vec_Projection.none }
}

public function proj_len(p: Place) -> usize {
    return match p.projection {
        case .some(let v) => Vec_Projection.len(v)
        case .none        => 0
    }
}

public function proj_at(p: Place, i: usize) -> Projection {
    return match p.projection {
        case .some(let v) => Vec_Projection.at(v, i)
        case .none        => Projection {
            kind: ProjectionKind.deref_,
            result_ty: ty_mod.error(),
        }
    }
}

public function push_projection(
    p: mutable Place,
    proj: take Projection,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    var v: Vec_Projection.Vec = match Option_Vec_Projection.take_out(mutable p.projection) {
        case .some(let existing) => existing
        case .none => {
            uninit fresh: Vec_Projection.Vec
            Vec_Projection.new(init fresh, allocator)?
            fresh
        }
    }
    Vec_Projection.push(mutable v, take proj, allocator)?
    p.projection = Option_Vec_Projection.some(value: v)
}

public type Projection {
    kind: ProjectionKind
    result_ty: ty_mod.TyId
}

public type ProjectionKind {
    case field(idx: u32)
    case index(idx_local: local_mod.LocalId, proven: bool)
    case deref_
    case variant_payload(variant_idx: u32)
    case slice_subrange(lo_local: local_mod.LocalId, hi_local: local_mod.LocalId, proven: bool)
}

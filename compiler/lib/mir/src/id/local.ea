
module mir.id.local

derive eq, hash, ord, debug for LocalId

public type LocalId {
    raw: u32
}


public stable function error() -> LocalId
    ensures result.raw == 0
{
    return LocalId { raw: 0 }
}

public stable function is_error(l: LocalId) -> bool
    ensures result == (l.raw == 0)
{
    return l.raw == 0
}


public stable function index(l: LocalId) -> usize
    ensures result == (l.raw as usize)
{
    return l.raw as usize
}

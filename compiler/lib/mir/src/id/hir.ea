
module mir.id.hir

derive eq, hash, ord, debug for HirFileId

public type HirFileId {
    raw: u32
}


public stable function error() -> HirFileId
    ensures result.raw == 0
{
    return HirFileId { raw: 0 }
}

public stable function is_error(f: HirFileId) -> bool
    ensures result == (f.raw == 0)
{
    return f.raw == 0
}


public stable function index(f: HirFileId) -> usize
    ensures result == (f.raw as usize)
{
    return f.raw as usize
}

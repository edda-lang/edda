
module refine.smt.render.sort

import std.mem.alloc
import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import local.discharge.error as err_mod
import local.smt.term as term_mod


spec std.mem.alloc.Box(term_mod.SmtSort)


derive eq, debug for SortResult


public type SortResult {
    case ok(sort: term_mod.SmtSort)
    case unsupported(fragment: err_mod.UnsupportedFragment)
}


public function sort_of(
    t: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> SortResult
    with {allocator, err: alloc.AllocError, divergence}
{
    if ty_mod.is_error(t) {
        return SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "type-check error sentinel",
            ),
        )
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(let kind) => sort_of_primitive(kind)
        case .string_ => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.string_content,
        )
        case .slice(let elem) => sort_of_indexable(elem, ty_interner, allocator)?
        case .array(let elem, _) => sort_of_indexable(elem, ty_interner, allocator)?
        case .tuple_(_) => {
            let elem_box = Box_SmtSort.new(take term_mod.SmtSort.int_, allocator)?
            SortResult.ok(sort: term_mod.SmtSort.array_(elem: elem_box))
        }
        case .record(_) => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .sum_(_) => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "sum sort lookup not yet wired",
            ),
        )
        case .fn_(_, _, _) => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "function type in refinement",
            ),
        )
        case .spec_instance(_, _) => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "unmonomorphised spec instance — specs pass missed it",
            ),
        )
        case .refined(let base, _) => sort_of(base, ty_interner, allocator)?
        case .capability(_) => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "capability type in refinement",
            ),
        )
        case .opaque(_) => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "opaque type in refinement",
            ),
        )
        case .error_ => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "type-check error sentinel",
            ),
        )
    }
}


function sort_of_primitive(kind: ty_kind_mod.PrimKind) -> SortResult {
    return match kind {
        case .i8_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .i16_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .i32_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .i64_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .i128_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .u8_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .u16_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .u32_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .u64_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .u128_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .isize_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .usize_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .f32_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .f64_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .bool_ => SortResult.ok(sort: term_mod.SmtSort.bool_)
        case .codepoint_ => SortResult.ok(sort: term_mod.SmtSort.int_)
        case .unit_ => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "unit type in refinement",
            ),
        )
        case .never_ => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "never type in refinement",
            ),
        )
        case .type_meta => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "Type meta-type in refinement",
            ),
        )
        case .heap_ptr => SortResult.unsupported(
            fragment: err_mod.UnsupportedFragment.other(
                message: "HeapPtr in refinement",
            ),
        )
    }
}


function sort_of_indexable(
    elem: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> SortResult
    with {allocator, err: alloc.AllocError, divergence}
{
    let inner = sort_of(elem, ty_interner, allocator)?
    return match inner {
        case .ok(let elem_sort) => {
            let elem_box = Box_SmtSort.new(take elem_sort, allocator)?
            SortResult.ok(sort: term_mod.SmtSort.array_(elem: elem_box))
        }
        case .unsupported(let fragment) => SortResult.unsupported(fragment: fragment)
    }
}


module refine.solver.lit.lit


derive eq, hash, debug for Lit
derive eq, debug for LBool


public type Lit {
    code: usize
}


public type LBool {
    case ltrue
    case lfalse
    case lundef
}


public function make_lit(variable: usize, negated: bool) -> Lit {
    let bit: usize = if negated { 1 } else { 0 }
    return Lit { code: variable * 2 + bit }
}


public function lit_var(l: Lit) -> usize {
    return l.code / 2
}


public function lit_negated(l: Lit) -> bool {
    return (l.code & 1) == 1
}


public function lit_negate(l: Lit) -> Lit {
    return Lit { code: l.code ^ 1 }
}


public function lit_code(l: Lit) -> usize {
    return l.code
}


public function lbool_of(b: bool) -> LBool {
    return if b { LBool.ltrue } else { LBool.lfalse }
}


public function lbool_negate(b: LBool) -> LBool {
    return match b {
        case .ltrue => LBool.lfalse
        case .lfalse => LBool.ltrue
        case .lundef => LBool.lundef
    }
}


module refine.solver.rational.wide


derive eq, debug for Wide


public type Wide {
    neg: bool
    mag: u128
}


public type WideResult {
    ok: bool
    value: Wide
}


public function u128_max() -> u128 {
    let p32 = 4294967296 as u128
    let p96 = p32 * p32 * p32
    let p127 = p96 * (2147483648 as u128)
    return (p127 - (1 as u128)) * (2 as u128) + (1 as u128)
}


public function mag_u128(x: i128) -> u128 {
    if x < (0 as i128) {
        return ((((0 - 1) as i128) - x) as u128) + (1 as u128)
    }
    return x as u128
}


public function wide_norm(neg: bool, mag: u128) -> Wide {
    return Wide { neg: if mag == (0 as u128) { false } else { neg }, mag: mag }
}


public function wide_from_i128(v: i128) -> Wide {
    return wide_norm(v < (0 as i128), mag_u128(v))
}


public function wide_zero() -> Wide {
    return Wide { neg: false, mag: 0 as u128 }
}


public function wide_is_zero(w: Wide) -> bool {
    return w.mag == (0 as u128)
}


public function wide_neg(w: Wide) -> Wide {
    return wide_norm(!w.neg, w.mag)
}


public function wide_fail() -> WideResult {
    return WideResult { ok: false, value: wide_zero() }
}


public function wide_add(a: Wide, b: Wide) -> WideResult {
    if a.neg == b.neg {
        if a.mag > u128_max() - b.mag {
            return wide_fail()
        }
        return WideResult { ok: true, value: wide_norm(a.neg, a.mag + b.mag) }
    }
    if a.mag >= b.mag {
        return WideResult { ok: true, value: wide_norm(a.neg, a.mag - b.mag) }
    }
    return WideResult { ok: true, value: wide_norm(b.neg, b.mag - a.mag) }
}


public function wide_sub(a: Wide, b: Wide) -> WideResult {
    return wide_add(a, wide_neg(b))
}


public function wide_mul(a: Wide, b: Wide) -> WideResult {
    if a.mag == (0 as u128) || b.mag == (0 as u128) {
        return WideResult { ok: true, value: wide_zero() }
    }
    if a.mag > u128_max() / b.mag {
        return wide_fail()
    }
    return WideResult { ok: true, value: wide_norm(a.neg != b.neg, a.mag * b.mag) }
}

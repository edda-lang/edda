
module refine.solver.rational.compare

import local.solver.rational.scalar as rat_mod


type Prod320 {
    r0: u128
    r1: u128
    r2: u128
    r3: u128
    r4: u128
}


function mask64() -> u128 {
    let p32 = 4294967296 as u128
    return p32 * p32 - (1 as u128)
}


function prod_320(n: rat_mod.Mag, d: u128) -> Prod320 {
    let m = mask64()
    let n0 = n.lo & m
    let n1 = n.lo >> 64
    let n2 = n.hi as u128
    let d0 = d & m
    let d1 = d >> 64
    let p00 = n0 * d0
    let p01 = n0 * d1
    let p10 = n1 * d0
    let p11 = n1 * d1
    let p20 = n2 * d0
    let p21 = n2 * d1
    let r0 = p00 & m
    let t1 = (p00 >> 64) + (p01 & m) + (p10 & m)
    let r1 = t1 & m
    let t2 = (t1 >> 64) + (p01 >> 64) + (p10 >> 64) + (p11 & m) + (p20 & m)
    let r2 = t2 & m
    let t3 = (t2 >> 64) + (p11 >> 64) + (p20 >> 64) + (p21 & m)
    let r3 = t3 & m
    let r4 = (t3 >> 64) + (p21 >> 64)
    return Prod320 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4 }
}


function cmp_limb(a: u128, b: u128) -> i32 {
    if a > b {
        return 1 as i32
    }
    if a < b {
        return -1 as i32
    }
    return 0 as i32
}


function cmp_prod_320(a: Prod320, b: Prod320) -> i32 {
    let c4 = cmp_limb(a.r4, b.r4)
    if c4 != (0 as i32) {
        return c4
    }
    let c3 = cmp_limb(a.r3, b.r3)
    if c3 != (0 as i32) {
        return c3
    }
    let c2 = cmp_limb(a.r2, b.r2)
    if c2 != (0 as i32) {
        return c2
    }
    let c1 = cmp_limb(a.r1, b.r1)
    if c1 != (0 as i32) {
        return c1
    }
    return cmp_limb(a.r0, b.r0)
}


public function compare(a: rat_mod.Rational, b: rat_mod.Rational) -> i32 {
    if !a.neg && b.neg {
        return 1 as i32
    }
    if a.neg && !b.neg {
        return -1 as i32
    }
    let mag = cmp_prod_320(prod_320(a.num, b.den), prod_320(b.num, a.den))
    if a.neg {
        return (0 as i32) - mag
    }
    return mag
}


public function lt(a: rat_mod.Rational, b: rat_mod.Rational) -> bool {
    return compare(a, b) < 0 as i32
}


public function le(a: rat_mod.Rational, b: rat_mod.Rational) -> bool {
    return compare(a, b) <= 0 as i32
}


public function gt(a: rat_mod.Rational, b: rat_mod.Rational) -> bool {
    return compare(a, b) > 0 as i32
}


public function ge(a: rat_mod.Rational, b: rat_mod.Rational) -> bool {
    return compare(a, b) >= 0 as i32
}


public function eq_val(a: rat_mod.Rational, b: rat_mod.Rational) -> bool {
    return compare(a, b) == 0 as i32
}

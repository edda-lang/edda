
module refine.solver.cdcl.prop.watch

import std.collections.vec
import std.mem.alloc


spec std.collections.vec.Vec(usize)
spec std.collections.vec.Vec(WatchList)


public type WatchList {
    items: Vec_usize.Vec
}


public type Watches {
    lists: Vec_WatchList.Vec
}


public function new_watches(out: init Watches, n_lits: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit lists: Vec_WatchList.Vec
    Vec_WatchList.new(init lists, allocator)?
    var i: usize = 0
    loop
        decreases (n_lits - i)
    {
        if i >= n_lits {
            break
        }
        uninit items: Vec_usize.Vec
        Vec_usize.new(init items, allocator)?
        let wl = WatchList { items: items }
        Vec_WatchList.push(mutable lists, take wl, allocator)?
        i = i + 1
    }
    out = Watches { lists: lists }
}


public function list_len(w: Watches, code: usize) -> usize {
    if code >= Vec_WatchList.len(w.lists) {
        return 0
    }
    let wl = Vec_WatchList.at(w.lists, code)
    return Vec_usize.len(wl.items)
}


public function list_at(w: Watches, code: usize, i: usize) -> usize {
    if code >= Vec_WatchList.len(w.lists) {
        return 0
    }
    let wl = Vec_WatchList.at(w.lists, code)
    if i >= Vec_usize.len(wl.items) {
        return 0
    }
    return Vec_usize.at(wl.items, i)
}


public function add(
    w: mutable Watches,
    code: usize,
    clause: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if code >= Vec_WatchList.len(w.lists) {
        return
    }
    var wl = Vec_WatchList.at(w.lists, code)
    Vec_usize.push(mutable wl.items, take clause, allocator)?
    Vec_WatchList.set_at(mutable w.lists, code, take wl)
}


public function clear(
    w: mutable Watches,
    code: usize,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if code >= Vec_WatchList.len(w.lists) {
        return
    }
    uninit items: Vec_usize.Vec
    Vec_usize.new(init items, allocator)?
    let wl = WatchList { items: items }
    Vec_WatchList.set_at(mutable w.lists, code, take wl)
}

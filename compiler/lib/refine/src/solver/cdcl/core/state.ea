
module refine.solver.cdcl.core.state

import std.collections.vec
import std.mem.alloc
import local.solver.lit.lit as lit_mod
import local.solver.cdcl.core.trail as trail_mod
import local.solver.cdcl.prop.clause as clause_mod
import local.solver.cdcl.prop.watch as watch_mod
import local.solver.theory.theory as theory_mod
import local.solver.atom.atom as atom_mod


spec std.collections.vec.Vec(lit_mod.Lit)
spec std.collections.vec.Vec(usize)


public type SolveResult {
    case sat
    case unsat(core: Vec_Lit.Vec, premise_core: Vec_usize.Vec)
    case unknown
}


public type Solver {
    n_vars: usize
    db: clause_mod.ClauseDb
    watches: watch_mod.Watches
    trail: trail_mod.Trail
    theory: theory_mod.Theory
    atoms: atom_mod.AtomTable
    qhead: usize
    ok: bool
    ok_conflict_origin: Vec_usize.Vec
}


public function new(out: init Solver, atoms: atom_mod.AtomTable, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError, divergence}
{
    let n_vars = atom_mod.atom_count(atoms)
    uninit db: clause_mod.ClauseDb
    clause_mod.new_db(init db, allocator)?
    uninit w: watch_mod.Watches
    watch_mod.new_watches(init w, n_vars * 2, allocator)?
    uninit tr: trail_mod.Trail
    trail_mod.new(init tr, n_vars, allocator)?
    uninit th: theory_mod.Theory
    theory_mod.new(init th, allocator)?
    theory_mod.prepare(mutable th, atoms, allocator)?
    uninit ok_conflict_origin: Vec_usize.Vec
    Vec_usize.new(init ok_conflict_origin, allocator)?
    out = Solver {
        n_vars: n_vars,
        db: db,
        watches: w,
        trail: tr,
        theory: th,
        atoms: atoms,
        qhead: 0,
        ok: true,
        ok_conflict_origin: ok_conflict_origin,
    }
}


public function lit_true(s: Solver, l: lit_mod.Lit) -> bool {
    return trail_mod.lit_value(s.trail, l) == lit_mod.LBool.ltrue
}


public function lit_false(s: Solver, l: lit_mod.Lit) -> bool {
    return trail_mod.lit_value(s.trail, l) == lit_mod.LBool.lfalse
}


public function attach_watches(s: mutable Solver, ci: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = clause_mod.clause_len(s.db, ci)
    if n == 0 {
        return
    }
    let l0 = clause_mod.clause_lit(s.db, ci, 0)
    watch_mod.add(mutable s.watches, lit_mod.lit_code(l0), ci, allocator)?
    if n > 1 {
        let l1 = clause_mod.clause_lit(s.db, ci, 1)
        watch_mod.add(mutable s.watches, lit_mod.lit_code(l1), ci, allocator)?
    }
}

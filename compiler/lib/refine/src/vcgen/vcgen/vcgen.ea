
module refine.vcgen.vcgen.vcgen

import std.core.option
import std.mem.alloc
import intern.symbol as symbol_mod
import mir.body.model as mir_body
import types.ty.interner as ty_interner_mod
import local.smt.term as term_mod
import local.vcgen.div.div as div_mod
import local.vcgen.divoverflow.divoverflow as divoverflow_mod
import local.vcgen.bounds.bounds as bounds_mod
import local.vcgen.cast.cast as cast_mod
import local.vcgen.overflow.overflow as overflow_mod
import local.vcgen.bodyidx.bodyidx as bodyidx_mod


spec std.core.option.Option(term_mod.SmtTerm)
spec std.core.option.Option(symbol_mod.Symbol)


public function vc_for_obligation(
    body: mir_body.MirBody,
    idx: bodyidx_mod.BodyIndex,
    obligation: mir_body.Obligation,
    ty_interner: ty_interner_mod.Interner,
    len_sym: Option_Symbol.Option,
    ptr_width: usize,
    anchor: symbol_mod.Symbol,
    allocator: Allocator,
) -> Option_SmtTerm.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    return match obligation.kind {
        case .int_overflow => overflow_mod.vc_int_overflow(body, idx, obligation, ty_interner, ptr_width, anchor, allocator)?
        case .div_by_zero => div_mod.vc_div_by_zero(body, idx, obligation, allocator)?
        case .div_overflow => divoverflow_mod.vc_div_overflow(body, idx, obligation, ty_interner, ptr_width, anchor, allocator)?
        case .index_in_bounds => bounds_mod.vc_bounds(body, idx, obligation, ty_interner, len_sym, allocator)?
        case .slice_subrange_in_bounds => bounds_mod.vc_bounds(body, idx, obligation, ty_interner, len_sym, allocator)?
        case .narrowing_cast_range => cast_mod.vc_narrowing_cast_range(body, idx, obligation, ty_interner, ptr_width, anchor, allocator)?
        case _ => Option_SmtTerm.none
    }
}


module refine.vcgen.cast.cast

import std.collections.vec
import std.core.option
import std.mem.alloc
import intern.symbol as symbol_mod
import mir.body.model as mir_body
import mir.id.block as block_mod
import mir.rvalue as rvalue_mod
import mir.stmt as stmt_mod
import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.ty.kind as ty_kind_mod
import local.smt.term as term_mod
import local.vcgen.term.term as vterm_mod
import local.vcgen.bodyidx.bodyidx as bodyidx_mod


spec std.collections.vec.Vec(mir_body.BasicBlock)
spec std.collections.vec.Vec(stmt_mod.Statement)
spec std.core.option.Option(term_mod.SmtTerm)
spec std.core.option.Option(ty_kind_mod.PrimKind)


public function vc_narrowing_cast_range(
    body: mir_body.MirBody,
    idx: bodyidx_mod.BodyIndex,
    obligation: mir_body.Obligation,
    ty_interner: ty_interner_mod.Interner,
    ptr_width: usize,
    anchor: symbol_mod.Symbol,
    allocator: Allocator,
) -> Option_SmtTerm.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    let bi = block_mod.index(obligation.block)
    if bi >= Vec_BasicBlock.len(body.blocks) {
        return Option_SmtTerm.none
    }
    let bb = Vec_BasicBlock.at(body.blocks, bi)
    let si = obligation.stmt_index as usize
    if si >= Vec_Statement.len(bb.statements) {
        return Option_SmtTerm.none
    }
    let stmt = Vec_Statement.at(bb.statements, si)
    return match stmt.kind {
        case .assign(_, let value) => vc_from_cast(body, idx, value, ty_interner, ptr_width, anchor, allocator)?
        case _ => Option_SmtTerm.none
    }
}


function vc_from_cast(
    body: mir_body.MirBody,
    idx: bodyidx_mod.BodyIndex,
    value: rvalue_mod.Rvalue,
    ty_interner: ty_interner_mod.Interner,
    ptr_width: usize,
    anchor: symbol_mod.Symbol,
    allocator: Allocator,
) -> Option_SmtTerm.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    return match value {
        case .cast(let operand, _, let to, let kind) => {
            if is_trapping_int_to_int(kind) {
                in_range_term(body, idx, operand, to, ty_interner, ptr_width, anchor, allocator)?
            } else {
                Option_SmtTerm.none
            }
        }
        case _ => Option_SmtTerm.none
    }
}


function is_trapping_int_to_int(kind: rvalue_mod.CastKind) -> bool {
    return match kind {
        case .int_to_int(let mode) => match mode {
            case .trapping => true
            case _ => false
        }
        case _ => false
    }
}


function in_range_term(
    body: mir_body.MirBody,
    idx: bodyidx_mod.BodyIndex,
    operand: rvalue_mod.Operand,
    to: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
    ptr_width: usize,
    anchor: symbol_mod.Symbol,
    allocator: Allocator,
) -> Option_SmtTerm.Option
    with {allocator, err: alloc.AllocError, divergence}
{
    return match resolve_prim(to, ty_interner) {
        case .some(let pk) => build_range(body, idx, operand, pk, ptr_width, anchor, allocator)?
        case .none => Option_SmtTerm.none
    }
}


function build_range(
    body: mir_body.MirBody,
    idx: bodyidx_mod.BodyIndex,
    operand: rvalue_mod.Operand,
    pk: ty_kind_mod.PrimKind,
    ptr_width: usize,
    anchor: symbol_mod.Symbol,
    allocator: Allocator,
) -> Option_SmtTerm.Option
    with {allocator, err: alloc.AllocError}
{
    let s_lo = match vterm_mod.operand_to_int_term(body, idx, operand) {
        case .some(let t) => t
        case .none => return Option_SmtTerm.none
    }
    let s_hi = match vterm_mod.operand_to_int_term(body, idx, operand) {
        case .some(let t) => t
        case .none => return Option_SmtTerm.none
    }
    let lower = vterm_mod.mk_bin(
        term_mod.SmtOp.ge,
        take s_lo,
        vterm_mod.bound_lo_term(pk, ptr_width, anchor, allocator)?,
        allocator,
    )?
    let upper = vterm_mod.mk_bin(
        term_mod.SmtOp.le,
        take s_hi,
        vterm_mod.bound_hi_term(pk, ptr_width, anchor, allocator)?,
        allocator,
    )?
    return Option_SmtTerm.some(value: vterm_mod.mk_bin(term_mod.SmtOp.and_, take lower, take upper, allocator)?)
}


function resolve_prim(
    t: ty_mod.TyId,
    ty_interner: ty_interner_mod.Interner,
) -> Option_PrimKind.Option
    with {divergence}
{
    if ty_mod.is_error(t) {
        return Option_PrimKind.none
    }
    return match ty_interner_mod.lookup(ty_interner, t) {
        case .primitive(let pk) => representable(pk)
        case .refined(let base, _) => resolve_prim(base, ty_interner)
        case _ => Option_PrimKind.none
    }
}


function representable(pk: ty_kind_mod.PrimKind) -> Option_PrimKind.Option {
    return match pk {
        case .i8_ => Option_PrimKind.some(value: pk)
        case .i16_ => Option_PrimKind.some(value: pk)
        case .i32_ => Option_PrimKind.some(value: pk)
        case .i64_ => Option_PrimKind.some(value: pk)
        case .u8_ => Option_PrimKind.some(value: pk)
        case .u16_ => Option_PrimKind.some(value: pk)
        case .u32_ => Option_PrimKind.some(value: pk)
        case .u64_ => Option_PrimKind.some(value: pk)
        case .i128_ => Option_PrimKind.some(value: pk)
        case .u128_ => Option_PrimKind.some(value: pk)
        case .isize_ => Option_PrimKind.some(value: pk)
        case .usize_ => Option_PrimKind.some(value: pk)
        case _ => Option_PrimKind.none
    }
}


module refine.discharge.context

import std.collections.vec
import std.core.option
import intern.symbol as symbol_mod
import types.pass.ty as ty_mod


spec std.collections.vec.Vec(VariableBinding)
spec std.core.option.Option(ty_mod.TyId)


derive eq, debug for VariableBinding


public type VariableBinding {
    name: symbol_mod.Symbol
    ty: ty_mod.TyId
}


public function lookup_variable(
    vars: Vec_VariableBinding.Vec,
    name: symbol_mod.Symbol,
) -> Option_TyId.Option {
    let n = Vec_VariableBinding.len(vars)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let entry = Vec_VariableBinding.at(vars, n - 1 - i)
        if entry.name.raw == name.raw {
            return Option_TyId.some(value: entry.ty)
        }
        i = i + 1
    }
    return Option_TyId.none
}

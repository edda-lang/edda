
module driver.render.render

import std.core.fmt as fmt_mod
import std.io.stream
import std.mem.alloc
import std.text.string
import diagnostics.emit.collection as diags_mod
import diagnostics.emit.diagnostic as diag_mod
import diagnostics.emit.severity as severity_mod
import span.loc.pos.span as span_mod
import span.file as file_mod
import source.map as source_map_mod


public function render_diagnostics(
    errout: Stderr,
    diags: diags_mod.Diagnostics,
    map: source_map_mod.SourceMap,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError}
{
    let n = diags_mod.count(diags)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let d_opt = diags_mod.get(diags, i)
        match d_opt {
            case .some(let d) => render_one(errout, d, map, allocator)?
            case .none => ()
        }
        i = i + 1
    }
}


function render_one(
    errout: Stderr,
    d: diag_mod.Diagnostic,
    map: source_map_mod.SourceMap,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError}
{
    let header = render_header(d, allocator)?
    stream.eprint_line(errout, header)
    let location = render_location(d.span, map, allocator)?
    stream.eprint_line(errout, location)
    stream.eprint_line(errout, "    canonical_form: <none>")
    stream.eprint_line(errout, "    obligation_trace: <none>")
    stream.eprint_line(errout, "    counterexample: <none>")
    stream.eprint_line(errout, "")
}


function render_header(d: diag_mod.Diagnostic, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let sev = severity_label(d.severity)
    let s1 = string.concat(sev, "[", allocator)?
    let s2 = string.concat(s1, d.code, allocator)?
    let s3 = string.concat(s2, "]: ", allocator)?
    return string.concat(s3, d.message, allocator)?
}

function render_location(span: span_mod.Span, map: source_map_mod.SourceMap, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    if file_mod.is_unknown(span.file) {
        return string.concat(" --> ", "<unknown>", allocator)?
    }
    if (span.file.raw as usize) >= source_map_mod.file_count(map) {
        return string.concat(" --> ", "<unknown>", allocator)?
    }
    let path = normalize_path_separators(source_map_mod.file_name_of(map, span.file), allocator)?
    let start_loc = span_mod.start_loc(span)
    let line_col = source_map_mod.byte_to_linecol(map, start_loc)
    let line_str = fmt_mod.usize_to_string(line_col.line, allocator)?
    let col_str = fmt_mod.usize_to_string(line_col.col, allocator)?
    let s1 = string.concat(" --> ", path, allocator)?
    let s2 = string.concat(s1, ":", allocator)?
    let s3 = string.concat(s2, line_str, allocator)?
    let s4 = string.concat(s3, ":", allocator)?
    return string.concat(s4, col_str, allocator)?
}


function normalize_path_separators(path: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    if string.contains(path, "\\") {
        return string.replace(path, "/", "\\", allocator)?
    }
    return path
}


function severity_label(s: severity_mod.Severity) -> String {
    return match s {
        case .fatal => "fatal"
        case .error => "error"
        case .warn => "warn"
        case .note => "note"
    }
}

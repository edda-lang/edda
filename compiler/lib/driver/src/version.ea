
module driver.version

import std.core.option
import std.io.stream
import std.mem.alloc
import std.text.string
import local.build.meta as build_meta_mod


spec std.core.option.Option(String)


public type Identity {
    impl_name: String
    impl_version: String
    source_repo: String
    source_sha: String
    dirty: bool
    runtime_name: String
    runtime_hash: Option_String.Option
    std_hash: String
    target: String
}


public function identity() -> Identity {
    return Identity {
        impl_name: build_meta_mod.impl_name(),
        impl_version: build_meta_mod.impl_version(),
        source_repo: build_meta_mod.source_repo(),
        source_sha: build_meta_mod.source_sha(),
        dirty: build_meta_mod.dirty(),
        runtime_name: build_meta_mod.runtime_name(),
        runtime_hash: build_meta_mod.runtime_hash(),
        std_hash: build_meta_mod.std_hash(),
        target: build_meta_mod.target(),
    }
}


public function render_human(id: Identity, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let impl_name = id.impl_name
    let impl_version = id.impl_version
    let source_repo = id.source_repo
    let source_sha = id.source_sha
    let runtime_name = id.runtime_name
    let std_hash = id.std_hash
    let target = id.target
    let dirty_str = if id.dirty { " (dirty)" } else { "" }
    let head = f"edda ({impl_name}) {impl_version}{dirty_str}\n"
    let l_impl = f"  impl:    {impl_name}\n"
    let l_source = f"  source:  {source_repo} lib@{source_sha}\n"
    let l_runtime = match id.runtime_hash {
        case .some(let h) => f"  runtime: {runtime_name}@{h}\n"
        case .none => f"  runtime: {runtime_name}\n"
    }
    let l_std = f"  std:     {std_hash}\n"
    let l_target = f"  target:  {target}"
    let s1 = string.concat(head, l_impl, allocator)?
    let s2 = string.concat(s1, l_source, allocator)?
    let s3 = string.concat(s2, l_runtime, allocator)?
    let s4 = string.concat(s3, l_std, allocator)?
    return string.concat(s4, l_target, allocator)?
}


public function render_json(id: Identity, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let dirty_str = if id.dirty { "true" } else { "false" }
    var acc: String = "{\"impl\":\""
    acc = string.concat(acc, id.impl_name, allocator)?
    acc = string.concat(acc, "\",\"impl_version\":\"", allocator)?
    acc = string.concat(acc, id.impl_version, allocator)?
    acc = string.concat(acc, "\",\"source\":{\"repo\":\"", allocator)?
    acc = string.concat(acc, id.source_repo, allocator)?
    acc = string.concat(acc, "\",\"sha\":\"", allocator)?
    acc = string.concat(acc, id.source_sha, allocator)?
    acc = string.concat(acc, "\",\"dirty\":", allocator)?
    acc = string.concat(acc, dirty_str, allocator)?
    acc = string.concat(acc, "},\"runtime\":{\"name\":\"", allocator)?
    acc = string.concat(acc, id.runtime_name, allocator)?
    acc = string.concat(acc, "\",\"hash\":", allocator)?
    acc = match id.runtime_hash {
        case .some(let h) => {
            let opened = string.concat(acc, "\"", allocator)?
            let with_hash = string.concat(opened, h, allocator)?
            string.concat(with_hash, "\"", allocator)?
        }
        case .none => string.concat(acc, "null", allocator)?
    }
    acc = string.concat(acc, "},\"std_hash\":\"", allocator)?
    acc = string.concat(acc, id.std_hash, allocator)?
    acc = string.concat(acc, "\",\"target\":\"", allocator)?
    acc = string.concat(acc, id.target, allocator)?
    acc = string.concat(acc, "\"}", allocator)?
    return acc
}


public function banner_line(id: Identity, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let impl_name = id.impl_name
    let impl_version = id.impl_version
    let source_repo = id.source_repo
    let source_sha = id.source_sha
    return f"edda: impl={impl_name} {impl_version} ({source_repo} lib@{source_sha})"
}


public function print_version(out: Stdout, json: bool, allocator: Allocator) -> ()
    with {out, allocator, err: alloc.AllocError}
{
    let id = identity()
    let text = if json { render_json(id, allocator)? } else { render_human(id, allocator)? }
    stream.print_line(out, text)
}


module x64.encoding.integer.shift.shift

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.sel.regs as regs_mod
import local.encoding.encode.prefix as prefix_mod
import local.encoding.encode.modrm as modrm_mod


spec std.collections.vec.Vec(u8)


public type ShiftOp {
    case rol_
    case ror_
    case rcl_
    case rcr_
    case shl_
    case shr_
    case sar_
}

derive eq, hash, debug for ShiftOp

public stable function shift_digit(op: ShiftOp) -> u8 {
    return match op {
        case .rol_ => 0 as u8
        case .ror_ => 1 as u8
        case .rcl_ => 2 as u8
        case .rcr_ => 3 as u8
        case .shl_ => 4 as u8
        case .shr_ => 5 as u8
        case .sar_ => 7 as u8
    }
}


public function encode_shift_imm(
    out: mutable Vec_u8.Vec,
    op: ShiftOp,
    size: regs_mod.OpSize,
    rm: regs_mod.Gp64Reg,
    amount: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(rm), allocator)?
    bytes_mod.push_u8(mutable out, 0xC1 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, shift_digit(op), regs_mod.gp64_reg_low3(rm), allocator)?
    bytes_mod.push_u8(mutable out, amount, allocator)?
}

public function encode_shift_1(
    out: mutable Vec_u8.Vec,
    op: ShiftOp,
    size: regs_mod.OpSize,
    rm: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(rm), allocator)?
    bytes_mod.push_u8(mutable out, 0xD1 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, shift_digit(op), regs_mod.gp64_reg_low3(rm), allocator)?
}

public function encode_shift_cl(
    out: mutable Vec_u8.Vec,
    op: ShiftOp,
    size: regs_mod.OpSize,
    rm: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(rm), allocator)?
    bytes_mod.push_u8(mutable out, 0xD3 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, shift_digit(op), regs_mod.gp64_reg_low3(rm), allocator)?
}

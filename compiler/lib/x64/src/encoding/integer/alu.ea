public function encode_mov_mem_r8(
    out: mutable Vec_u8.Vec,
    base: regs_mod.Gp64Reg,
    disp: i32,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = regs_mod.gp64_reg_num(src)
    let force_rex = (n >= (4 as u8)) && (n <= (7 as u8))
    if force_rex || regs_mod.gp64_is_extended(src) || regs_mod.gp64_is_extended(base) {
        prefix_mod.push_rex(mutable out, false, regs_mod.gp64_is_extended(src), false, regs_mod.gp64_is_extended(base), allocator)?
    }
    bytes_mod.push_u8(mutable out, 0x88 as u8, allocator)?
    modrm_mod.push_mem_base_disp(mutable out, regs_mod.gp64_reg_low3(src), base, disp, allocator)?
}

public function encode_mov_mem_r8_idx(
    out: mutable Vec_u8.Vec,
    base: regs_mod.Gp64Reg,
    index: regs_mod.Gp64Reg,
    scale_log2: u8,
    disp: i32,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires regs_mod.gp64_reg_num(index) != (4 as u8)
    requires scale_log2 <= (3 as u8)
{
    let n = regs_mod.gp64_reg_num(src)
    let force_rex = (n >= (4 as u8)) && (n <= (7 as u8))
    if force_rex || regs_mod.gp64_is_extended(src) || regs_mod.gp64_is_extended(index) || regs_mod.gp64_is_extended(base) {
        prefix_mod.push_rex(mutable out, false, regs_mod.gp64_is_extended(src), regs_mod.gp64_is_extended(index), regs_mod.gp64_is_extended(base), allocator)?
    }
    bytes_mod.push_u8(mutable out, 0x88 as u8, allocator)?
    modrm_mod.push_mem_base_index_disp(mutable out, regs_mod.gp64_reg_low3(src), base, index, scale_log2, disp, allocator)?
}

public function encode_mov_rm_imm(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    imm: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(dst), allocator)?
    bytes_mod.push_u8(mutable out, 0xC7 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, 0 as u8, regs_mod.gp64_reg_low3(dst), allocator)?
    push_imm_sized(mutable out, size, imm, allocator)?
}

public function encode_mov_r_mem_idx(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    base: regs_mod.Gp64Reg,
    index: regs_mod.Gp64Reg,
    scale_log2: u8,
    disp: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires regs_mod.gp64_reg_num(index) != (4 as u8)
    requires scale_log2 <= (3 as u8)
{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(dst), regs_mod.gp64_is_extended(index), regs_mod.gp64_is_extended(base), allocator)?
    bytes_mod.push_u8(mutable out, 0x8B as u8, allocator)?
    modrm_mod.push_mem_base_index_disp(mutable out, regs_mod.gp64_reg_low3(dst), base, index, scale_log2, disp, allocator)?
}

public function encode_mov_mem_r_idx(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    base: regs_mod.Gp64Reg,
    index: regs_mod.Gp64Reg,
    scale_log2: u8,
    disp: i32,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires regs_mod.gp64_reg_num(index) != (4 as u8)
    requires scale_log2 <= (3 as u8)
{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(src), regs_mod.gp64_is_extended(index), regs_mod.gp64_is_extended(base), allocator)?
    bytes_mod.push_u8(mutable out, 0x89 as u8, allocator)?
    modrm_mod.push_mem_base_index_disp(mutable out, regs_mod.gp64_reg_low3(src), base, index, scale_log2, disp, allocator)?
}

public function encode_mov_r64_imm64(
    out: mutable Vec_u8.Vec,
    dst: regs_mod.Gp64Reg,
    imm: i64,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.push_rex(mutable out, true, false, false, regs_mod.gp64_is_extended(dst), allocator)?
    let opcode = (0xB8 as u8) | regs_mod.gp64_reg_low3(dst)
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    bytes_mod.push_i64_le(mutable out, imm, allocator)?
}

public function encode_mov_r32_imm32(
    out: mutable Vec_u8.Vec,
    dst: regs_mod.Gp64Reg,
    imm: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if regs_mod.gp64_is_extended(dst) {
        bytes_mod.push_u8(mutable out, 0x41 as u8, allocator)?
    }

    let opcode = (0xB8 as u8) | regs_mod.gp64_reg_low3(dst)
    bytes_mod.push_u8(mutable out, opcode, allocator)?

    bytes_mod.push_i32_le(mutable out, imm, allocator)?
}


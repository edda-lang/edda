
module x64.encoding.integer.alu

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.sel.regs as regs_mod
import local.encoding.encode.prefix as prefix_mod
import local.encoding.encode.modrm as modrm_mod


spec std.collections.vec.Vec(u8)


public type AluOp {
    case add_
    case or_
    case adc_
    case sbb_
    case and_
    case sub_
    case xor_
    case cmp_
}

derive eq, hash, debug for AluOp

public type Grp3Op {
    case not_
    case neg_
    case mul_
    case imul1_
    case div_
    case idiv_
}

derive eq, hash, debug for Grp3Op


public stable function alu_op_index(op: AluOp) -> u8 {
    return match op {
        case .add_ => 0 as u8
        case .or_  => 1 as u8
        case .adc_ => 2 as u8
        case .sbb_ => 3 as u8
        case .and_ => 4 as u8
        case .sub_ => 5 as u8
        case .xor_ => 6 as u8
        case .cmp_ => 7 as u8
    }
}

public stable function grp3_digit(op: Grp3Op) -> u8 {
    return match op {
        case .not_   => 2 as u8
        case .neg_   => 3 as u8
        case .mul_   => 4 as u8
        case .imul1_ => 5 as u8
        case .div_   => 6 as u8
        case .idiv_  => 7 as u8
    }
}


function push_imm_sized(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    imm: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if regs_mod.op_size_is_16(size) {
        bytes_mod.push_i16_le(mutable out, imm as i16 wrapping, allocator)?
    } else {
        bytes_mod.push_i32_le(mutable out, imm, allocator)?
    }
}


public function encode_alu_rm_r(
    out: mutable Vec_u8.Vec,
    op: AluOp,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(src), false, regs_mod.gp64_is_extended(dst), allocator)?
    let opcode = (0x01 as u8) + (alu_op_index(op) * (8 as u8))
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.gp64_reg_low3(src), regs_mod.gp64_reg_low3(dst), allocator)?
}

public function encode_alu_r_mem(
    out: mutable Vec_u8.Vec,
    op: AluOp,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    base: regs_mod.Gp64Reg,
    disp: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(dst), false, regs_mod.gp64_is_extended(base), allocator)?
    let opcode = (0x03 as u8) + (alu_op_index(op) * (8 as u8))
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_mem_base_disp(mutable out, regs_mod.gp64_reg_low3(dst), base, disp, allocator)?
}

public function encode_alu_rm_imm(
    out: mutable Vec_u8.Vec,
    op: AluOp,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    imm: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(dst), allocator)?
    if imm >= -128 && imm <= 127 {
        bytes_mod.push_u8(mutable out, 0x83 as u8, allocator)?
        modrm_mod.push_modrm_direct(mutable out, alu_op_index(op), regs_mod.gp64_reg_low3(dst), allocator)?
        bytes_mod.push_u8(mutable out, imm as u8 wrapping, allocator)?
    } else {
        bytes_mod.push_u8(mutable out, 0x81 as u8, allocator)?
        modrm_mod.push_modrm_direct(mutable out, alu_op_index(op), regs_mod.gp64_reg_low3(dst), allocator)?
        push_imm_sized(mutable out, size, imm, allocator)?
    }
}

public function encode_mov_rm_r(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    dst: regs_mod.Gp64Reg,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(src), false, regs_mod.gp64_is_extended(dst), allocator)?
    bytes_mod.push_u8(mutable out, 0x89 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.gp64_reg_low3(src), regs_mod.gp64_reg_low3(dst), allocator)?
}


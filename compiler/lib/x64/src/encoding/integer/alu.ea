{
    prefix_mod.emit_size_prefixes(mutable out, size, regs_mod.gp64_is_extended(b), false, regs_mod.gp64_is_extended(a), allocator)?
    bytes_mod.push_u8(mutable out, 0x85 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.gp64_reg_low3(b), regs_mod.gp64_reg_low3(a), allocator)?
}

public function encode_grp3_rm(
    out: mutable Vec_u8.Vec,
    op: Grp3Op,
    size: regs_mod.OpSize,
    rm: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, size, false, false, regs_mod.gp64_is_extended(rm), allocator)?
    bytes_mod.push_u8(mutable out, 0xF7 as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, grp3_digit(op), regs_mod.gp64_reg_low3(rm), allocator)?
}


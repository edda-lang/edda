
module x64.encoding.control.branch

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.sel.regs as regs_mod
import local.encoding.encode.prefix as prefix_mod
import local.encoding.encode.modrm as modrm_mod


spec std.collections.vec.Vec(u8)


public type Cond {
    case o_
    case no_
    case b_
    case ae_
    case e_
    case ne_
    case be_
    case a_
    case s_
    case ns_
    case p_
    case np_
    case l_
    case ge_
    case le_
    case g_
}

derive eq, hash, debug for Cond

public stable function cond_code(c: Cond) -> u8 {
    return match c {
        case .o_  => 0 as u8
        case .no_ => 1 as u8
        case .b_  => 2 as u8
        case .ae_ => 3 as u8
        case .e_  => 4 as u8
        case .ne_ => 5 as u8
        case .be_ => 6 as u8
        case .a_  => 7 as u8
        case .s_  => 8 as u8
        case .ns_ => 9 as u8
        case .p_  => 10 as u8
        case .np_ => 11 as u8
        case .l_  => 12 as u8
        case .ge_ => 13 as u8
        case .le_ => 14 as u8
        case .g_  => 15 as u8
    }
}


public function encode_ret(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xC3 as u8, allocator)?
}

public function encode_ret_imm16(
    out: mutable Vec_u8.Vec,
    imm: u16,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xC2 as u8, allocator)?
    bytes_mod.push_u16_le(mutable out, imm, allocator)?
}

public function encode_leave(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xC9 as u8, allocator)?
}

public function encode_nop(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x90 as u8, allocator)?
}

public function encode_int3(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xCC as u8, allocator)?
}

public function encode_stc(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xF9 as u8, allocator)?
}

public function encode_clc(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xF8 as u8, allocator)?
}

public function encode_ud2(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x0B as u8, allocator)?
}

public function encode_syscall(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x05 as u8, allocator)?
}

public function encode_cmovcc_r_rm(
    out: mutable Vec_u8.Vec,
    c: Cond,
    dst: regs_mod.Gp64Reg,
    src: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.emit_size_prefixes(mutable out, regs_mod.OpSize.qword_, regs_mod.gp64_is_extended(dst), false, regs_mod.gp64_is_extended(src), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, (0x40 as u8) + cond_code(c), allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.gp64_reg_low3(dst), regs_mod.gp64_reg_low3(src), allocator)?
}

public function encode_setcc_rm8(
    out: mutable Vec_u8.Vec,
    c: Cond,
    dst: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let low3 = regs_mod.gp64_reg_low3(dst)
    if regs_mod.gp64_is_extended(dst) {
        prefix_mod.push_rex(mutable out, false, false, false, true, allocator)?
    } else {
        if low3 >= (4 as u8) {
            prefix_mod.push_rex(mutable out, false, false, false, false, allocator)?
        }
    }
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, (0x90 as u8) + cond_code(c), allocator)?
    modrm_mod.push_modrm_direct(mutable out, 0 as u8, low3, allocator)?
}

public function encode_push_r64(
    out: mutable Vec_u8.Vec,
    reg: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if regs_mod.gp64_is_extended(reg) {
        prefix_mod.push_rex(mutable out, false, false, false, true, allocator)?
    }
    bytes_mod.push_u8(mutable out, (0x50 as u8) | regs_mod.gp64_reg_low3(reg), allocator)?
}

public function encode_pop_r64(
    out: mutable Vec_u8.Vec,
    reg: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if regs_mod.gp64_is_extended(reg) {
        prefix_mod.push_rex(mutable out, false, false, false, true, allocator)?
    }
    bytes_mod.push_u8(mutable out, (0x58 as u8) | regs_mod.gp64_reg_low3(reg), allocator)?
}

public function encode_call_rel32(
    out: mutable Vec_u8.Vec,
    rel32: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xE8 as u8, allocator)?
    bytes_mod.push_i32_le(mutable out, rel32, allocator)?
}

public function encode_jmp_rel32(
    out: mutable Vec_u8.Vec,
    rel32: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xE9 as u8, allocator)?
    bytes_mod.push_i32_le(mutable out, rel32, allocator)?
}

public function encode_jmp_rel8(
    out: mutable Vec_u8.Vec,
    rel8: i8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0xEB as u8, allocator)?
    bytes_mod.push_u8(mutable out, rel8 as u8 wrapping, allocator)?
}

public function encode_jcc_rel32(
    out: mutable Vec_u8.Vec,
    c: Cond,
    rel32: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, (0x80 as u8) + cond_code(c), allocator)?
    bytes_mod.push_i32_le(mutable out, rel32, allocator)?
}

public function encode_jcc_rel8(
    out: mutable Vec_u8.Vec,
    c: Cond,
    rel8: i8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, (0x70 as u8) + cond_code(c), allocator)?
    bytes_mod.push_u8(mutable out, rel8 as u8 wrapping, allocator)?
}

public function encode_call_rm(
    out: mutable Vec_u8.Vec,
    reg: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.push_rex_if_needed(mutable out, false, false, false, regs_mod.gp64_is_extended(reg), allocator)?
    bytes_mod.push_u8(mutable out, 0xFF as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, 2 as u8, regs_mod.gp64_reg_low3(reg), allocator)?
}

public function encode_jmp_rm(
    out: mutable Vec_u8.Vec,
    reg: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    prefix_mod.push_rex_if_needed(mutable out, false, false, false, regs_mod.gp64_is_extended(reg), allocator)?
    bytes_mod.push_u8(mutable out, 0xFF as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, 4 as u8, regs_mod.gp64_reg_low3(reg), allocator)?
}


module x64.encoding.encode.prefix

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.sel.regs as regs_mod


spec std.collections.vec.Vec(u8)


public stable function rex(w: bool, r: bool, x: bool, b: bool) -> u8 {
    let w_bit = if w { 0x08 as u8 } else { 0x00 as u8 }
    let r_bit = if r { 0x04 as u8 } else { 0x00 as u8 }
    let x_bit = if x { 0x02 as u8 } else { 0x00 as u8 }
    let b_bit = if b { 0x01 as u8 } else { 0x00 as u8 }
    return (0x40 as u8) | w_bit | r_bit | x_bit | b_bit
}

public stable function rex_needed(w: bool, r: bool, x: bool, b: bool) -> bool {
    return w || r || x || b
}

public function push_rex(
    out: mutable Vec_u8.Vec,
    w: bool,
    r: bool,
    x: bool,
    b: bool,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, rex(w, r, x, b), allocator)?
}

public function push_rex_if_needed(
    out: mutable Vec_u8.Vec,
    w: bool,
    r: bool,
    x: bool,
    b: bool,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if rex_needed(w, r, x, b) {
        bytes_mod.push_u8(mutable out, rex(w, r, x, b), allocator)?
    }
}

public function push_operand_size_prefix(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x66 as u8, allocator)?
}

public function push_address_size_prefix(
    out: mutable Vec_u8.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x67 as u8, allocator)?
}

public function emit_size_prefixes(
    out: mutable Vec_u8.Vec,
    size: regs_mod.OpSize,
    r: bool,
    x: bool,
    b: bool,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if regs_mod.op_size_is_16(size) {
        push_operand_size_prefix(mutable out, allocator)?
    }
    push_rex_if_needed(mutable out, regs_mod.op_size_is_64(size), r, x, b, allocator)?
}

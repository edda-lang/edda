public function encode_roundss(
    out: mutable Vec_u8.Vec,
    dst: regs_mod.XmmReg,
    src: regs_mod.XmmReg,
    mode: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, 0x66 as u8, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(dst), false, regs_mod.xmm_is_extended(src), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x3A as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x0A as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.xmm_reg_low3(dst), regs_mod.xmm_reg_low3(src), allocator)?
    bytes_mod.push_u8(mutable out, mode, allocator)?
}

public function encode_roundsd(
    out: mutable Vec_u8.Vec,
    dst: regs_mod.XmmReg,
    src: regs_mod.XmmReg,
    mode: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, 0x66 as u8, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(dst), false, regs_mod.xmm_is_extended(src), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x3A as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x0B as u8, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.xmm_reg_low3(dst), regs_mod.xmm_reg_low3(src), allocator)?
    bytes_mod.push_u8(mutable out, mode, allocator)?
}


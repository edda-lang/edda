function encode_sse_x_mem_base(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    opcode: u8,
    xmm: regs_mod.XmmReg,
    base: regs_mod.Gp64Reg,
    disp: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(xmm), false, regs_mod.gp64_is_extended(base), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_mem_base_disp(mutable out, regs_mod.xmm_reg_low3(xmm), base, disp, allocator)?
}

function encode_sse_x_mem_idx(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    opcode: u8,
    xmm: regs_mod.XmmReg,
    base: regs_mod.Gp64Reg,
    index: regs_mod.Gp64Reg,
    scale_log2: u8,
    disp: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
    requires regs_mod.gp64_reg_num(index) != (4 as u8)
    requires scale_log2 <= (3 as u8)
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(xmm), regs_mod.gp64_is_extended(index), regs_mod.gp64_is_extended(base), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_mem_base_index_disp(mutable out, regs_mod.xmm_reg_low3(xmm), base, index, scale_log2, disp, allocator)?
}

function encode_sse_x_rip(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    opcode: u8,
    xmm: regs_mod.XmmReg,
    disp: i32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(xmm), false, false, allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_mem_rip_disp32(mutable out, regs_mod.xmm_reg_low3(xmm), disp, allocator)?
}

public function encode_movsd_x_rip(

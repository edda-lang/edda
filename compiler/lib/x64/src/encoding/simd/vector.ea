
module x64.encoding.simd.vector

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.gen.sel.regs as regs_mod
import local.encoding.encode.prefix as prefix_mod
import local.encoding.encode.modrm as modrm_mod


spec std.collections.vec.Vec(u8)


function push_mandatory(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    if mandatory != 0 {
        bytes_mod.push_u8(mutable out, mandatory, allocator)?
    }
}

function encode_sse_xmm_xmm(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    opcode: u8,
    dst: regs_mod.XmmReg,
    src: regs_mod.XmmReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, false, regs_mod.xmm_is_extended(dst), false, regs_mod.xmm_is_extended(src), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.xmm_reg_low3(dst), regs_mod.xmm_reg_low3(src), allocator)?
}

function encode_sse_xmm_gp(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    rex_w: bool,
    opcode: u8,
    xmm_reg: regs_mod.XmmReg,
    gp_rm: regs_mod.Gp64Reg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, rex_w, regs_mod.xmm_is_extended(xmm_reg), false, regs_mod.gp64_is_extended(gp_rm), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.xmm_reg_low3(xmm_reg), regs_mod.gp64_reg_low3(gp_rm), allocator)?
}

function encode_sse_gp_xmm(
    out: mutable Vec_u8.Vec,
    mandatory: u8,
    rex_w: bool,
    opcode: u8,
    gp_reg: regs_mod.Gp64Reg,
    xmm_rm: regs_mod.XmmReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_mandatory(mutable out, mandatory, allocator)?
    prefix_mod.push_rex_if_needed(mutable out, rex_w, regs_mod.gp64_is_extended(gp_reg), false, regs_mod.xmm_is_extended(xmm_rm), allocator)?
    bytes_mod.push_u8(mutable out, 0x0F as u8, allocator)?
    bytes_mod.push_u8(mutable out, opcode, allocator)?
    modrm_mod.push_modrm_direct(mutable out, regs_mod.gp64_reg_low3(gp_reg), regs_mod.xmm_reg_low3(xmm_rm), allocator)?
}


public function encode_movss(
    out: mutable Vec_u8.Vec,
    dst: regs_mod.XmmReg,
    src: regs_mod.XmmReg,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    encode_sse_xmm_xmm(mutable out, 0xF3 as u8, 0x10 as u8, dst, src, allocator)?
}


module link.emit.image.fix.reloc.reloc

import std.mem.alloc
import std.collections.vec
import std.collections.hashmap
import object.coff as coff_mod
import object.coff.wrap.wrap as wrap_mod
import local.emit.layout as layout_mod
import local.emit.image.fix.res.resolve as resolve_mod
import local.emit.image.fix.reloc.defs.defs as defs_mod
import local.emit.image.fix.reloc.build.build as build_mod


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(coff_mod.CoffFile)
spec std.collections.vec.Vec(defs_mod.MergedSection)
spec std.collections.hashmap.StringMap(resolve_mod.Definition)
spec std.collections.hashmap.StringMap(u32)


public function build_relocated_sections(
    objects: Vec_CoffFile.Vec,
    plan: layout_mod.LayoutPlan,
    table: StringMap_Definition.StringMap,
    imports: StringMap_u32.StringMap,
    allocator: Allocator,
) -> Vec_MergedSection.Vec
    with {allocator, err: alloc.AllocError, err: defs_mod.RelocError}
{
    uninit out: Vec_MergedSection.Vec
    Vec_MergedSection.new(init out, allocator)?
    build_mod.append_class(objects, layout_mod.SectionClass.text, wrap_mod.text_characteristics(), plan, table, imports, mutable out, allocator)?
    build_mod.append_class(objects, layout_mod.SectionClass.rdata, wrap_mod.rdata_characteristics(), plan, table, imports, mutable out, allocator)?
    build_mod.append_class(objects, layout_mod.SectionClass.data, wrap_mod.data_characteristics(), plan, table, imports, mutable out, allocator)?
    build_mod.append_class(objects, layout_mod.SectionClass.tls, wrap_mod.data_characteristics(), plan, table, imports, mutable out, allocator)?
    build_mod.append_class(objects, layout_mod.SectionClass.crt, wrap_mod.rdata_characteristics(), plan, table, imports, mutable out, allocator)?
    return out
}

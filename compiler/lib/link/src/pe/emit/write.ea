
module link.pe.emit.write

import std.mem.alloc
import std.collections.vec
import object.bytes as bytes_mod
import local.emit.layout as layout_mod


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(PeSection)


public type PeSection {
    name: String
    rva: u32
    virtual_size: u32
    characteristics: u32
    data: Vec_u8.Vec
}


public type DataDirectories {
    import_rva: u32
    import_size: u32
    iat_rva: u32
    iat_size: u32
    tls_rva: u32
    tls_size: u32
}


function section_alignment() -> u32 { return 0x1000 as u32 }
function file_alignment() -> u32 { return 0x200 as u32 }
function headers_fixed_size() -> u32 { return 0x148 as u32 }
function cnt_code() -> u32 { return 0x00000020 as u32 }
function cnt_init_data() -> u32 { return 0x00000040 as u32 }


function pad_to(out: mutable Vec_u8.Vec, target: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let cur = Vec_u8.len(out)
    if target <= cur { return () }
    var i: usize = cur
    loop decreases (target - i) {
        if i >= target { break }
        Vec_u8.push(mutable out, take (0 as u8), allocator)?
        i = i + 1
    }
}


function write_dos(out: mutable Vec_u8.Vec, e_lfanew: u32, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x4D as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x5A as u8, allocator)?
    pad_to(mutable out, 0x3C as usize, allocator)?
    bytes_mod.push_u32_le(mutable out, e_lfanew, allocator)?
    pad_to(mutable out, 0x40 as usize, allocator)?
}


function write_coff_header(
    out: mutable Vec_u8.Vec,
    num_sections: u16,
    opt_size: u16,
    characteristics: u16,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u16_le(mutable out, 0x8664 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, num_sections, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u16_le(mutable out, opt_size, allocator)?
    bytes_mod.push_u16_le(mutable out, characteristics, allocator)?
}


function write_data_dir(out: mutable Vec_u8.Vec, rva: u32, size: u32, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u32_le(mutable out, rva, allocator)?
    bytes_mod.push_u32_le(mutable out, size, allocator)?
}


function write_optional_header(
    out: mutable Vec_u8.Vec,
    size_of_code: u32,
    size_of_init_data: u32,
    entry_rva: u32,
    base_of_code: u32,
    image_base: u64,
    size_of_image: u32,
    size_of_headers: u32,
    dirs: DataDirectories,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u16_le(mutable out, 0x020B as u16, allocator)?
    bytes_mod.push_u8(mutable out, 14 as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0 as u8, allocator)?
    bytes_mod.push_u32_le(mutable out, size_of_code, allocator)?
    bytes_mod.push_u32_le(mutable out, size_of_init_data, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, entry_rva, allocator)?
    bytes_mod.push_u32_le(mutable out, base_of_code, allocator)?
    bytes_mod.push_u64_le(mutable out, image_base, allocator)?
    bytes_mod.push_u32_le(mutable out, section_alignment(), allocator)?
    bytes_mod.push_u32_le(mutable out, file_alignment(), allocator)?
    bytes_mod.push_u16_le(mutable out, 6 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 6 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, size_of_image, allocator)?
    bytes_mod.push_u32_le(mutable out, size_of_headers, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u16_le(mutable out, 3 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u64_le(mutable out, 0x10000000 as u64, allocator)?
    bytes_mod.push_u64_le(mutable out, 0x1000 as u64, allocator)?
    bytes_mod.push_u64_le(mutable out, 0x100000 as u64, allocator)?
    bytes_mod.push_u64_le(mutable out, 0x1000 as u64, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, 16 as u32, allocator)?
    write_directories(mutable out, dirs, allocator)?
}


function write_directories(out: mutable Vec_u8.Vec, dirs: DataDirectories, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    var i: usize = 0
    loop decreases ((16 as usize) - i) {
        if i >= (16 as usize) { break }
        if i == (1 as usize) {
            write_data_dir(mutable out, dirs.import_rva, dirs.import_size, allocator)?
        } else if i == (9 as usize) {
            write_data_dir(mutable out, dirs.tls_rva, dirs.tls_size, allocator)?
        } else if i == (12 as usize) {
            write_data_dir(mutable out, dirs.iat_rva, dirs.iat_size, allocator)?
        } else {
            write_data_dir(mutable out, 0 as u32, 0 as u32, allocator)?
        }
        i = i + 1
    }
}


function write_section_name(out: mutable Vec_u8.Vec, name: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let nb = name.bytes()
    let n = nb.len()
    var i: usize = 0
    loop decreases ((8 as usize) - i) {
        if i >= (8 as usize) { break }
        let b = if i < n { nb[i] } else { 0 as u8 }
        bytes_mod.push_u8(mutable out, b, allocator)?
        i = i + 1
    }
}


function write_section_header(
    out: mutable Vec_u8.Vec,
    sec: PeSection,
    file_offset: u32,
    raw_size: u32,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    write_section_name(mutable out, sec.name, allocator)?
    bytes_mod.push_u32_le(mutable out, sec.virtual_size, allocator)?
    bytes_mod.push_u32_le(mutable out, sec.rva, allocator)?
    bytes_mod.push_u32_le(mutable out, raw_size, allocator)?
    bytes_mod.push_u32_le(mutable out, file_offset, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u32_le(mutable out, 0 as u32, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u16_le(mutable out, 0 as u16, allocator)?
    bytes_mod.push_u32_le(mutable out, sec.characteristics, allocator)?
}


function raw_size_of(sec: PeSection) -> u32 {
    return layout_mod.align_up(sec.virtual_size, file_alignment())
}


function compute_file_offsets(
    sections: Vec_PeSection.Vec,
    size_of_headers: u32,
    offsets: mutable Vec_u32.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_PeSection.len(sections)
    var cursor = size_of_headers
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        let here = cursor
        Vec_u32.push(mutable offsets, take here, allocator)?
        cursor = cursor + raw_size_of(sec)
        i = i + 1
    }
}


function compute_size_of_image(sections: Vec_PeSection.Vec) -> u32 {
    let n = Vec_PeSection.len(sections)
    var max_end: u32 = section_alignment()
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        let end = sec.rva + sec.virtual_size
        if end > max_end { max_end = end }
        i = i + 1
    }
    return layout_mod.align_up(max_end, section_alignment())
}


function first_code_rva(sections: Vec_PeSection.Vec) -> u32 {
    let n = Vec_PeSection.len(sections)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        if (sec.characteristics & cnt_code()) != (0 as u32) { return sec.rva }
        i = i + 1
    }
    return 0 as u32
}


function sum_raw_with_flag(sections: Vec_PeSection.Vec, flag: u32) -> u32 {
    let n = Vec_PeSection.len(sections)
    var total: u32 = 0
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        if (sec.characteristics & flag) != (0 as u32) { total = total + raw_size_of(sec) }
        i = i + 1
    }
    return total
}


function write_bodies(
    out: mutable Vec_u8.Vec,
    sections: Vec_PeSection.Vec,
    offsets: Vec_u32.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_PeSection.len(sections)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        let off = Vec_u32.at(offsets, i) as usize
        pad_to(mutable out, off, allocator)?
        write_data(mutable out, sec.data, allocator)?
        pad_to(mutable out, off + (raw_size_of(sec) as usize), allocator)?
        i = i + 1
    }
}


function write_data(out: mutable Vec_u8.Vec, data: Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_u8.len(data)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        bytes_mod.push_u8(mutable out, Vec_u8.at(data, i), allocator)?
        i = i + 1
    }
}


public function write_pe(
    sections: Vec_PeSection.Vec,
    entry_rva: u32,
    image_base: u64,
    dirs: DataDirectories,
    allocator: Allocator,
) -> Vec_u8.Vec
    with {allocator, err: alloc.AllocError}
{
    let num_sections = Vec_PeSection.len(sections)
    let section_table_size = (40 as u32) * (num_sections as u32)
    let headers_unpadded = headers_fixed_size() + section_table_size
    let size_of_headers = layout_mod.align_up(headers_unpadded, file_alignment())

    uninit offsets: Vec_u32.Vec
    Vec_u32.new(init offsets, allocator)?
    compute_file_offsets(sections, size_of_headers, mutable offsets, allocator)?

    let size_of_image = compute_size_of_image(sections)
    let size_of_code = sum_raw_with_flag(sections, cnt_code())
    let size_of_init_data = sum_raw_with_flag(sections, cnt_init_data())
    let base_of_code = first_code_rva(sections)
    let characteristics: u16 = 0x0022

    uninit out: Vec_u8.Vec
    Vec_u8.new(init out, allocator)?
    write_dos(mutable out, 0x40 as u32, allocator)?
    bytes_mod.push_u8(mutable out, 0x50 as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x45 as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0 as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0 as u8, allocator)?
    write_coff_header(mutable out, num_sections as u16, 240 as u16, characteristics, allocator)?
    write_optional_header(
        mutable out,
        size_of_code,
        size_of_init_data,
        entry_rva,
        base_of_code,
        image_base,
        size_of_image,
        size_of_headers,
        dirs,
        allocator,
    )?

    let n = Vec_PeSection.len(sections)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sec = Vec_PeSection.at(sections, i)
        let off = Vec_u32.at(offsets, i)
        write_section_header(mutable out, sec, off, raw_size_of(sec), allocator)?
        i = i + 1
    }

    write_bodies(mutable out, sections, offsets, allocator)?
    return out
}

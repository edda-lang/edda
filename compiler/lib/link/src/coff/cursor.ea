
module link.coff.cursor

import std.collections.vec


spec std.collections.vec.Vec(u8)


derive eq, debug for ReadError


public type ReadError {
    case truncated
    case bad_string_table_size
    case bad_section_name_digit
    case bad_archive_magic
}


public type Cursor {
    pos: usize
}


public function at_start() -> Cursor {
    return Cursor { pos: 0 }
}


public function seek(cur: mutable Cursor, pos: usize) -> () {
    cur.pos = pos
}


public function read_u8(bytes: Vec_u8.Vec, cur: mutable Cursor) -> u8
    with {err: ReadError}
{
    let len = Vec_u8.len(bytes)
    if cur.pos >= len { raise ReadError.truncated }
    let b = Vec_u8.at(bytes, cur.pos)
    cur.pos = cur.pos + (1 as usize)
    return b
}


public function read_u16_le(bytes: Vec_u8.Vec, cur: mutable Cursor) -> u16
    with {err: ReadError}
{
    let len = Vec_u8.len(bytes)
    if cur.pos >= len { raise ReadError.truncated }
    if len - cur.pos < (2 as usize) { raise ReadError.truncated }
    let b0 = Vec_u8.at(bytes, cur.pos) as u16
    let b1 = Vec_u8.at(bytes, cur.pos + (1 as usize)) as u16
    cur.pos = cur.pos + (2 as usize)
    return b0 | (b1 << 8)
}


public function read_u32_le(bytes: Vec_u8.Vec, cur: mutable Cursor) -> u32
    with {err: ReadError}
{
    let len = Vec_u8.len(bytes)
    if cur.pos >= len { raise ReadError.truncated }
    if len - cur.pos < (4 as usize) { raise ReadError.truncated }
    let b0 = Vec_u8.at(bytes, cur.pos) as u32
    let b1 = Vec_u8.at(bytes, cur.pos + (1 as usize)) as u32
    let b2 = Vec_u8.at(bytes, cur.pos + (2 as usize)) as u32
    let b3 = Vec_u8.at(bytes, cur.pos + (3 as usize)) as u32
    cur.pos = cur.pos + (4 as usize)
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
}


public function read_u64_le(bytes: Vec_u8.Vec, cur: mutable Cursor) -> u64
    with {err: ReadError}
{
    let len = Vec_u8.len(bytes)
    if cur.pos >= len { raise ReadError.truncated }
    if len - cur.pos < (8 as usize) { raise ReadError.truncated }
    let b0 = Vec_u8.at(bytes, cur.pos) as u64
    let b1 = Vec_u8.at(bytes, cur.pos + (1 as usize)) as u64
    let b2 = Vec_u8.at(bytes, cur.pos + (2 as usize)) as u64
    let b3 = Vec_u8.at(bytes, cur.pos + (3 as usize)) as u64
    let b4 = Vec_u8.at(bytes, cur.pos + (4 as usize)) as u64
    let b5 = Vec_u8.at(bytes, cur.pos + (5 as usize)) as u64
    let b6 = Vec_u8.at(bytes, cur.pos + (6 as usize)) as u64
    let b7 = Vec_u8.at(bytes, cur.pos + (7 as usize)) as u64
    cur.pos = cur.pos + (8 as usize)
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)
}


public function read_i16_le(bytes: Vec_u8.Vec, cur: mutable Cursor) -> i16
    with {err: ReadError}
{
    let v = read_u16_le(bytes, mutable cur)?
    return v as i16 wrapping
}

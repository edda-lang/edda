
module link.argv.coff

import std.collections.vec
import std.mem.alloc
import std.text.string
import local.emit.image.output as output_mod

spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(output_mod.LibSpec)


public function argv_lld_link(
    output: String,
    kind: output_mod.OutputKind,
    inputs: [String],
    libs: Vec_LibSpec.Vec,
    lib_search_paths: Vec_String.Vec,
    extra_args: Vec_String.Vec,
    capacity: usize,
    allocator: Allocator,
) -> Vec_String.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit argv: Vec_String.Vec
    Vec_String.with_capacity(init argv, capacity, allocator)?
    Vec_String.push(mutable argv, string.concat("/OUT:", output, allocator)?, allocator)?
    Vec_String.push(mutable argv, "/OPT:REF", allocator)?
    Vec_String.push(mutable argv, "/OPT:ICF", allocator)?
    if is_dynamic_library(kind) {
        Vec_String.push(mutable argv, "/DLL", allocator)?
    }
    append_lib_search_paths(mutable argv, lib_search_paths, allocator)?
    append_inputs(mutable argv, inputs, allocator)?
    append_libs(mutable argv, libs, allocator)?
    append_extra_args(mutable argv, extra_args, allocator)?
    return argv
}


function append_lib_search_paths(argv: mutable Vec_String.Vec, paths: Vec_String.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_String.len(paths)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let path = Vec_String.at(paths, i)
        Vec_String.push(mutable argv, string.concat("/LIBPATH:", path, allocator)?, allocator)?
        i += 1
    }
}

function append_libs(argv: mutable Vec_String.Vec, libs: Vec_LibSpec.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_LibSpec.len(libs)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let entry = Vec_LibSpec.at(libs, i)
        Vec_String.push(mutable argv, string.concat(entry.name, ".lib", allocator)?, allocator)?
        i += 1
    }
}

function append_inputs(argv: mutable Vec_String.Vec, inputs: [String], allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = inputs.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        Vec_String.push(mutable argv, clone_string(inputs[i], allocator)?, allocator)?
        i += 1
    }
}

function append_extra_args(argv: mutable Vec_String.Vec, extra: Vec_String.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_String.len(extra)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let arg = Vec_String.at(extra, i)
        Vec_String.push(mutable argv, clone_string(arg, allocator)?, allocator)?
        i += 1
    }
}


function clone_string(s: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat(s, "", allocator)?
}

function is_dynamic_library(k: output_mod.OutputKind) -> bool {
    return match k {
        case .dynamic_library => true
        case _                => false
    }
}


module link.error

import std.core.fmt
import std.mem.alloc
import std.text.string
import diagnostics.code as code_mod
import diagnostics.emit.diagnostic as diag_mod
import span.loc.pos.span as span_mod
import target.os as os_mod
import local.emit.image.output as output_mod

derive eq, clone, debug for LinkError


public type LinkError {

    case tool_not_found(tool_name: String, searched_path: String)

    case unresolved_symbols(count: usize, sample: String)

    case duplicate_symbols(count: usize, sample: String)

    case entry_not_found(name: String)

    case unsupported_target_os(os: os_mod.Os)

    case unsupported_kind_for_tool(tool_name: String, kind: output_mod.OutputKind)
}


public function to_diagnostic(e: LinkError, at: span_mod.Span, allocator: Allocator) -> diag_mod.Diagnostic
    with {allocator, err: alloc.AllocError}
{
    let msg = format_message(e, allocator)?
    return diag_mod.error_at(code_mod.link_error(), at, msg)
}


function format_message(e: LinkError, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return match e {
        case .tool_not_found(let tname, let path)         => fmt_tool_not_found(tname, path, allocator)?
        case .unresolved_symbols(let count, let sample)   => fmt_unresolved(count, sample, allocator)?
        case .duplicate_symbols(let count, let sample)    => fmt_duplicate(count, sample, allocator)?
        case .entry_not_found(let name)                   => fmt_entry_not_found(name, allocator)?
        case .unsupported_target_os(let o)                => fmt_unsupported_target_os(o, allocator)?
        case .unsupported_kind_for_tool(let tname, let k) => fmt_unsupported_kind(tname, k, allocator)?
    }
}

function fmt_tool_not_found(tool_name: String, searched: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("tool ", tool_name, allocator)?
    let p2 = string.concat(p1, " not found on PATH (searched: ", allocator)?
    let p3 = string.concat(p2, searched, allocator)?
    return string.concat(p3, ")", allocator)?
}

function fmt_unresolved(count: usize, sample: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let n = fmt.u64_to_string(count as u64, allocator)?
    let p1 = string.concat("link failed: ", n, allocator)?
    let p2 = string.concat(p1, " unresolved external symbol(s), first: ", allocator)?
    return string.concat(p2, sample, allocator)?
}

function fmt_duplicate(count: usize, sample: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let n = fmt.u64_to_string(count as u64, allocator)?
    let p1 = string.concat("link failed: ", n, allocator)?
    let p2 = string.concat(p1, " duplicate definition(s), first: ", allocator)?
    return string.concat(p2, sample, allocator)?
}

function fmt_entry_not_found(name: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("entry symbol `", name, allocator)?
    return string.concat(p1, "` not defined in any input object", allocator)?
}

function fmt_unsupported_target_os(o: os_mod.Os, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let os_name = os_mod.name(o)
    let p1 = string.concat("target os `", os_name, allocator)?
    return string.concat(p1, "` is not in the V1.0 linker matrix", allocator)?
}

function fmt_unsupported_kind(tool_name: String, k: output_mod.OutputKind, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let kname = output_mod.output_kind_name(k)
    let p1 = string.concat("tool ", tool_name, allocator)?
    let p2 = string.concat(p1, " cannot produce ", allocator)?
    let p3 = string.concat(p2, kname, allocator)?
    return string.concat(p3, " output in V1.0", allocator)?
}

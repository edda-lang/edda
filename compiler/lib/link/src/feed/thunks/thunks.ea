
module link.feed.thunks.thunks

import std.mem.alloc
import std.collections.vec
import std.text.string
import object.coff as coff_mod
import object.coff.wrap.wrap as wrap_mod
import local.feed.classify.classify as classify_mod


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(String)
spec std.collections.vec.Vec(coff_mod.CoffRelocation)


function thunk_size() -> usize {
    return 6 as usize
}


function push_thunk_code(code: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.push(mutable code, take (0xFF as u8), allocator)?
    Vec_u8.push(mutable code, take (0x25 as u8), allocator)?
    Vec_u8.push(mutable code, take (0x00 as u8), allocator)?
    Vec_u8.push(mutable code, take (0x00 as u8), allocator)?
    Vec_u8.push(mutable code, take (0x00 as u8), allocator)?
    Vec_u8.push(mutable code, take (0x00 as u8), allocator)?
}


function push_b(code: mutable Vec_u8.Vec, b: u8, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.push(mutable code, take b, allocator)?
}


function push_sub_or_cmp_imm_0x1000(code: mutable Vec_u8.Vec, opcode: u8, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_b(mutable code, 0x48 as u8, allocator)?
    push_b(mutable code, opcode, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
    push_b(mutable code, 0x10 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
}


function push_or_qword_rcx_0(code: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_b(mutable code, 0x48 as u8, allocator)?
    push_b(mutable code, 0x83 as u8, allocator)?
    push_b(mutable code, 0x09 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
}


function push_chkstk_code(code: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_b(mutable code, 0x51 as u8, allocator)?
    push_b(mutable code, 0x50 as u8, allocator)?
    push_sub_or_cmp_imm_0x1000(mutable code, 0x3D as u8, allocator)?
    push_b(mutable code, 0x48 as u8, allocator)?
    push_b(mutable code, 0x8D as u8, allocator)?
    push_b(mutable code, 0x4C as u8, allocator)?
    push_b(mutable code, 0x24 as u8, allocator)?
    push_b(mutable code, 0x18 as u8, allocator)?
    push_b(mutable code, 0x72 as u8, allocator)?
    push_b(mutable code, 0x19 as u8, allocator)?
    push_b(mutable code, 0x48 as u8, allocator)?
    push_b(mutable code, 0x81 as u8, allocator)?
    push_b(mutable code, 0xE9 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
    push_b(mutable code, 0x10 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
    push_b(mutable code, 0x00 as u8, allocator)?
    push_or_qword_rcx_0(mutable code, allocator)?
    push_sub_or_cmp_imm_0x1000(mutable code, 0x2D as u8, allocator)?
    push_sub_or_cmp_imm_0x1000(mutable code, 0x3D as u8, allocator)?
    push_b(mutable code, 0x77 as u8, allocator)?
    push_b(mutable code, 0xE7 as u8, allocator)?
    push_b(mutable code, 0x48 as u8, allocator)?
    push_b(mutable code, 0x29 as u8, allocator)?
    push_b(mutable code, 0xC1 as u8, allocator)?
    push_or_qword_rcx_0(mutable code, allocator)?
    push_b(mutable code, 0x58 as u8, allocator)?
    push_b(mutable code, 0x59 as u8, allocator)?
    push_b(mutable code, 0xC3 as u8, allocator)?
}


function push_zeros(data: mutable Vec_u8.Vec, count: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    var i: usize = 0
    loop decreases (count - i) {
        if i >= count { break }
        Vec_u8.push(mutable data, take (0x00 as u8), allocator)?
        i = i + (1 as usize)
    }
}


function push_ret0_code(code: mutable Vec_u8.Vec, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_b(mutable code, 0x31 as u8, allocator)?
    push_b(mutable code, 0xC0 as u8, allocator)?
    push_b(mutable code, 0xC3 as u8, allocator)?
}


function append_synth_code(
    code: mutable Vec_u8.Vec,
    synth: classify_mod.SynthPlan,
    allocator: Allocator,
) -> (u32, u32, u32, u32, u32, u32)
    with {allocator, err: alloc.AllocError}
{
    let check_cookie_off = Vec_u8.len(code) as u32
    if synth.security_check_cookie {
        push_b(mutable code, 0xC3 as u8, allocator)?
    }
    let gs_handler_off = Vec_u8.len(code) as u32
    if synth.gs_handler_check {
        push_b(mutable code, 0xB8 as u8, allocator)?
        push_b(mutable code, 0x01 as u8, allocator)?
        push_b(mutable code, 0x00 as u8, allocator)?
        push_b(mutable code, 0x00 as u8, allocator)?
        push_b(mutable code, 0x00 as u8, allocator)?
        push_b(mutable code, 0xC3 as u8, allocator)?
    }
    let dyn_tls_off = Vec_u8.len(code) as u32
    if synth.dyn_tls_init {
        push_ret0_code(mutable code, allocator)?
    }
    let rangecheck_off = Vec_u8.len(code) as u32
    if synth.report_rangecheck {
        push_b(mutable code, 0xCC as u8, allocator)?
    }
    let atexit_off = Vec_u8.len(code) as u32
    if synth.atexit_stub {
        push_ret0_code(mutable code, allocator)?
    }
    let get_new_handler_off = Vec_u8.len(code) as u32
    if synth.get_new_handler_stub {
        push_ret0_code(mutable code, allocator)?
    }
    return (check_cookie_off, gs_handler_off, dyn_tls_off, rangecheck_off, atexit_off, get_new_handler_off)
}


function append_synth_data(
    data: mutable Vec_u8.Vec,
    synth: classify_mod.SynthPlan,
    allocator: Allocator,
) -> (u32, u32, u32)
    with {allocator, err: alloc.AllocError}
{
    push_zeros(mutable data, 4 as usize, allocator)?
    let cookie_off = Vec_u8.len(data) as u32
    if synth.security_cookie {
        push_b(mutable data, 0x32 as u8, allocator)?
        push_b(mutable data, 0xA2 as u8, allocator)?
        push_b(mutable data, 0xDF as u8, allocator)?
        push_b(mutable data, 0x2D as u8, allocator)?
        push_b(mutable data, 0x99 as u8, allocator)?
        push_b(mutable data, 0x2B as u8, allocator)?
        push_b(mutable data, 0x00 as u8, allocator)?
        push_b(mutable data, 0x00 as u8, allocator)?
    }
    let isa_off = Vec_u8.len(data) as u32
    if synth.isa_available {
        push_zeros(mutable data, 4 as usize, allocator)?
    }
    let tls_guard_off = Vec_u8.len(data) as u32
    if synth.tls_guard {
        push_b(mutable data, 0x01 as u8, allocator)?
    }
    return (cookie_off, isa_off, tls_guard_off)
}


function add_synth_symbols(
    file: mutable coff_mod.CoffFile,
    synth: classify_mod.SynthPlan,
    code_offs: (u32, u32, u32, u32, u32, u32),
    data_offs: (u32, u32, u32),
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    match code_offs {
        case (let check_cookie_off, let gs_handler_off, let dyn_tls_off, let rangecheck_off, let atexit_off, let get_new_handler_off) => {
            if synth.security_check_cookie {
                wrap_mod.add_symbol(mutable file, "__security_check_cookie", 1 as i16, check_cookie_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
            if synth.gs_handler_check {
                wrap_mod.add_symbol(mutable file, "__GSHandlerCheck", 1 as i16, gs_handler_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
            if synth.dyn_tls_init {
                wrap_mod.add_symbol(mutable file, "__dyn_tls_on_demand_init", 1 as i16, dyn_tls_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
            if synth.report_rangecheck {
                wrap_mod.add_symbol(mutable file, "__report_rangecheckfailure", 1 as i16, rangecheck_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
            if synth.atexit_stub {
                wrap_mod.add_symbol(mutable file, "atexit", 1 as i16, atexit_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
            if synth.get_new_handler_stub {
                wrap_mod.add_symbol(mutable file, "?get_new_handler@std@@YAP6AXXZXZ", 1 as i16, get_new_handler_off, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
            }
        }
    }
    match data_offs {
        case (let cookie_off, let isa_off, let tls_guard_off) => {
            if synth.security_cookie {
                wrap_mod.add_symbol(mutable file, "__security_cookie", 2 as i16, cookie_off, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
            }
            if synth.isa_available {
                wrap_mod.add_symbol(mutable file, "__isa_available", 2 as i16, isa_off, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
            }
            if synth.tls_guard {
                wrap_mod.add_symbol(mutable file, "__tls_guard", 2 as i16, tls_guard_off, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
            }
        }
    }
}


public function build_thunk_object(
    out: init coff_mod.CoffFile,
    thunks: Vec_String.Vec,
    synth: classify_mod.SynthPlan,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    uninit file: coff_mod.CoffFile
    wrap_mod.new_object(init file, coff_mod.CoffMachine.amd64, allocator)?

    let n = Vec_String.len(thunks)
    uninit code: Vec_u8.Vec
    Vec_u8.new(init code, allocator)?
    uninit relocs: Vec_CoffRelocation.Vec
    Vec_CoffRelocation.new(init relocs, allocator)?

    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        push_thunk_code(mutable code, allocator)?
        let site = ((i * thunk_size()) + (2 as usize)) as u32
        let imp_sym_index = ((i * (2 as usize)) + (1 as usize)) as u32
        let r = wrap_mod.make_relocation(site, imp_sym_index, wrap_mod.rel_amd64_rel32())
        Vec_CoffRelocation.push(mutable relocs, take r, allocator)?
        i = i + (1 as usize)
    }
    let chkstk_value = (n * thunk_size()) as u32
    if synth.chkstk {
        push_chkstk_code(mutable code, allocator)?
    }
    let code_offs = append_synth_code(mutable code, synth, allocator)?

    uninit data: Vec_u8.Vec
    Vec_u8.new(init data, allocator)?
    push_zeros(mutable data, 84 as usize, allocator)?
    let data_offs = append_synth_data(mutable data, synth, allocator)?

    let need_tls_index = synth.tls_index || synth.tls_used
    var sym_after_data: usize = n * (2 as usize)
    if synth.chkstk { sym_after_data = sym_after_data + (1 as usize) }
    if synth.type_info_vtable { sym_after_data = sym_after_data + (1 as usize) }
    var idx_tls_index: usize = 0
    if need_tls_index {
        idx_tls_index = sym_after_data
        sym_after_data = sym_after_data + (1 as usize)
    }
    if synth.tls_used { sym_after_data = sym_after_data + (1 as usize) }
    let idx_tls_start = sym_after_data
    let idx_tls_end = sym_after_data + (1 as usize)
    let idx_tls_callbacks = sym_after_data + (2 as usize)

    uninit data_relocs: Vec_CoffRelocation.Vec
    Vec_CoffRelocation.new(init data_relocs, allocator)?
    if synth.tls_used {
        let r_start = wrap_mod.make_relocation(40 as u32, idx_tls_start as u32, wrap_mod.rel_amd64_addr64())
        Vec_CoffRelocation.push(mutable data_relocs, take r_start, allocator)?
        let r_end = wrap_mod.make_relocation(48 as u32, idx_tls_end as u32, wrap_mod.rel_amd64_addr64())
        Vec_CoffRelocation.push(mutable data_relocs, take r_end, allocator)?
        let r_index = wrap_mod.make_relocation(56 as u32, idx_tls_index as u32, wrap_mod.rel_amd64_addr64())
        Vec_CoffRelocation.push(mutable data_relocs, take r_index, allocator)?
        let r_cb = wrap_mod.make_relocation(64 as u32, idx_tls_callbacks as u32, wrap_mod.rel_amd64_addr64())
        Vec_CoffRelocation.push(mutable data_relocs, take r_cb, allocator)?
    }

    wrap_mod.add_section(mutable file, ".text", wrap_mod.text_characteristics(), take code, take relocs, allocator)?
    wrap_mod.add_section(mutable file, ".data", wrap_mod.data_characteristics(), take data, take data_relocs, allocator)?

    var s: usize = 0
    loop decreases (n - s) {
        if s >= n { break }
        let name = Vec_String.at(thunks, s)
        let value = (s * thunk_size()) as u32
        wrap_mod.add_symbol(mutable file, name, 1 as i16, value, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
        let imp_name = string.concat("__imp_", name, allocator)?
        wrap_mod.add_symbol(mutable file, imp_name, 0 as i16, 0 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
        s = s + (1 as usize)
    }
    if synth.chkstk {
        wrap_mod.add_symbol(mutable file, "__chkstk", 1 as i16, chkstk_value, wrap_mod.storage_external(), wrap_mod.symbol_type_function(), allocator)?
    }
    if synth.type_info_vtable {
        wrap_mod.add_symbol(mutable file, "??_7type_info@@6B@", 2 as i16, 0 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
    }
    if need_tls_index {
        wrap_mod.add_symbol(mutable file, "_tls_index", 2 as i16, 24 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
    }
    if synth.tls_used {
        wrap_mod.add_symbol(mutable file, "_tls_used", 2 as i16, 40 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
        wrap_mod.add_symbol(mutable file, "__edda_tls_start", 0 as i16, 0 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
        wrap_mod.add_symbol(mutable file, "__edda_tls_end", 0 as i16, 0 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
        wrap_mod.add_symbol(mutable file, "__edda_tls_callbacks", 2 as i16, 32 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
    }
    if synth.fltused {
        wrap_mod.add_symbol(mutable file, "_fltused", 2 as i16, 80 as u32, wrap_mod.storage_external(), wrap_mod.symbol_type_null(), allocator)?
    }
    add_synth_symbols(mutable file, synth, code_offs, data_offs, allocator)?
    out = file
}

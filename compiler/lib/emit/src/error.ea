
module emit.error

import std.core.fmt
import std.mem.alloc
import std.os.process.spawn.error as spawn_error_mod
import std.os.process.wait as wait_mod
import std.text.string
import diagnostics.code as code_mod
import diagnostics.emit.diagnostic as diag_mod
import span.loc.pos.span as span_mod

derive eq, clone, debug for EmitError


public type EmitError {

    case tool_not_found(tool_name: String, searched_path: String)

    case spawn_failed(tool_name: String, reason: spawn_error_mod.SpawnError)

    case wait_failed(tool_name: String, reason: wait_mod.WaitError)

    case io_during_invoke(message: String)


    case tool_exited_nonzero(tool_name: String, exit_code: i32)
}


public function to_diagnostic(e: EmitError, at: span_mod.Span, allocator: Allocator) -> diag_mod.Diagnostic
    with {allocator, err: alloc.AllocError}
{
    let msg = format_message(e, allocator)?
    return diag_mod.error_at(code_mod.emit_error(), at, msg)
}


function format_message(e: EmitError, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return match e {
        case .tool_not_found(let tname, let path)         => fmt_tool_not_found(tname, path, allocator)?
        case .spawn_failed(let tname, let _r)             => fmt_spawn_failed(tname, allocator)?
        case .wait_failed(let tname, let _r)              => fmt_wait_failed(tname, allocator)?
        case .io_during_invoke(let m)                     => fmt_io_during_invoke(m, allocator)?
        case .tool_exited_nonzero(let tname, let code)    => fmt_tool_exited_nonzero(tname, code, allocator)?
    }
}

function fmt_tool_not_found(tool_name: String, searched: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("tool ", tool_name, allocator)?
    let p2 = string.concat(p1, " not found on PATH (searched: ", allocator)?
    let p3 = string.concat(p2, searched, allocator)?
    return string.concat(p3, ")", allocator)?
}

function fmt_spawn_failed(tool_name: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat("failed to spawn tool ", tool_name, allocator)?
}

function fmt_wait_failed(tool_name: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat("failed to wait on tool ", tool_name, allocator)?
}

function fmt_io_during_invoke(message: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat("io error while reading tool output: ", message, allocator)?
}

function fmt_tool_exited_nonzero(tool_name: String, exit_code: i32, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("tool ", tool_name, allocator)?
    let p2 = string.concat(p1, " exited with code ", allocator)?
    let code_str = fmt.i32_to_string(exit_code, allocator)?
    return string.concat(p2, code_str, allocator)?
}

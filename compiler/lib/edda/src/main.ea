
module edda.main

import std.mem.alloc
import std.os.fs
import std.os.process as process
import std.os.env as env
import diagnostics.emit.collection as diags_mod
import driver.entry as entry_mod


public function main(
    wfs: Filesystem,
    subprocess: Subprocess,
    out: Stdout,
    clock: MonotonicClock,
    wall_clock: Clock,
    errout: Stderr,
    allocator: Allocator,
) -> i32
    with {wfs, rfs, subprocess, out, clock, wall_clock, errout, allocator, panic, divergence, time(ops <= 1)}
{
    let rfs = wfs.read_only()
    let code = handle err: fs.FsError as fe -> fatal_fs(errout, fe) {
        handle err: alloc.AllocError as ae -> fatal_alloc(errout, ae) {
            run_cli(wfs, rfs, subprocess, out, clock, wall_clock, errout, allocator)?
        }
    }
    return code
}


function run_cli(
    wfs: Filesystem,
    rfs: ReadOnlyFilesystem,
    subprocess: Subprocess,
    out: Stdout,
    clock: MonotonicClock,
    wall_clock: Clock,
    errout: Stderr,
    allocator: Allocator,
) -> i32
    with {wfs, rfs, subprocess, out, clock, wall_clock, errout, allocator, err: fs.FsError, err: alloc.AllocError, panic, divergence, time(ops <= 1)}
{
    let args = process.args(allocator)?
    let workspace_root = env.current_dir(allocator)

    uninit diags: diags_mod.Diagnostics
    diags_mod.new_diagnostics(init diags, allocator)?

    return entry_mod.run(args, wfs, rfs, subprocess, out, clock, wall_clock, errout, workspace_root, mutable diags, allocator)?
}


function fatal_fs(errout: Stderr, e: fs.FsError) -> i32
    with {errout}
{
    match e {
        case .not_found(let p) => errout.eprint_line(f"edda: file not found: {p}")
        case .permission_denied(let p) => errout.eprint_line(f"edda: permission denied: {p}")
        case .already_exists(let p) => errout.eprint_line(f"edda: already exists: {p}")
        case .is_a_directory(let p) => errout.eprint_line(f"edda: is a directory: {p}")
        case .not_a_directory(let p) => errout.eprint_line(f"edda: not a directory: {p}")
        case .invalid_utf8 => errout.eprint_line("edda: invalid utf-8 in path")
        case .os_error(let c) => errout.eprint_line(f"edda: os error {c}")
        case .other => errout.eprint_line("edda: filesystem error")
    }
    return 74
}

function fatal_alloc(errout: Stderr, e: alloc.AllocError) -> i32
    with {errout}
{
    match e {
        case .out_of_memory => errout.eprint_line("edda: out of memory")
    }
    return 71
}

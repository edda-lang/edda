
module ir.hlir.attrs

import types.effect.row as facts_mod


derive eq, hash, debug for HlirFnAttrs


public type HlirFnAttrs {
    pure_: bool
    no_alloc: bool
    no_io: bool
    nounwind: bool
    noreturn: bool
    has_alloc_bound: bool
    alloc_bytes_max: u128
    err_bymem: bool
    raw_pure: bool
    raw_trapfree: bool
}


public stable function empty() -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: false,
        no_alloc: false,
        no_io: false,
        nounwind: false,
        noreturn: false,
        has_alloc_bound: false,
        alloc_bytes_max: 0 as u128,
        err_bymem: false,
        raw_pure: false,
        raw_trapfree: false,
    }
}

public stable function all_set() -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: true,
        no_alloc: true,
        no_io: true,
        nounwind: true,
        noreturn: true,
        has_alloc_bound: false,
        alloc_bytes_max: 0 as u128,
        err_bymem: false,
        raw_pure: false,
        raw_trapfree: false,
    }
}

public stable function pure_attrs() -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: true,
        no_alloc: true,
        no_io: true,
        nounwind: true,
        noreturn: false,
        has_alloc_bound: false,
        alloc_bytes_max: 0 as u128,
        err_bymem: false,
        raw_pure: false,
        raw_trapfree: false,
    }
}

public stable function nounwind_attrs() -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: false,
        no_alloc: false,
        no_io: false,
        nounwind: true,
        noreturn: false,
        has_alloc_bound: false,
        alloc_bytes_max: 0 as u128,
        err_bymem: false,
        raw_pure: false,
        raw_trapfree: false,
    }
}

public function from_effect_facts(facts: facts_mod.EffectFacts) -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: facts.pure_,
        no_alloc: facts.no_alloc,
        no_io: facts.no_io,
        nounwind: facts.nounwind,
        noreturn: false,
        has_alloc_bound: facts.has_alloc_bound,
        alloc_bytes_max: facts.alloc_bytes_max,
        err_bymem: false,
        raw_pure: false,
        raw_trapfree: false,
    }
}

public function with_err_bymem(base: HlirFnAttrs, err_bymem: bool) -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: base.pure_,
        no_alloc: base.no_alloc,
        no_io: base.no_io,
        nounwind: base.nounwind,
        noreturn: base.noreturn,
        has_alloc_bound: base.has_alloc_bound,
        alloc_bytes_max: base.alloc_bytes_max,
        err_bymem: err_bymem,
        raw_pure: base.raw_pure,
        raw_trapfree: base.raw_trapfree,
    }
}

public function with_raw_witness(attrs: HlirFnAttrs, raw_pure: bool, raw_trapfree: bool) -> HlirFnAttrs {
    return HlirFnAttrs {
        pure_: attrs.pure_,
        no_alloc: attrs.no_alloc,
        no_io: attrs.no_io,
        nounwind: attrs.nounwind,
        noreturn: attrs.noreturn,
        has_alloc_bound: attrs.has_alloc_bound,
        alloc_bytes_max: attrs.alloc_bytes_max,
        err_bymem: attrs.err_bymem,
        raw_pure: raw_pure,
        raw_trapfree: raw_trapfree,
    }
}

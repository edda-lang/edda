
module ir.hlir.term

import std.collections.vec
import hir.def as def_mod
import hir.node as node_mod
import local.hlir.id.value as value_mod
import local.hlir.id.block as block_mod


spec std.collections.vec.Vec(value_mod.ValueId)
spec std.collections.vec.Vec(SwitchCase)


derive eq, hash, debug for UnwindAction
derive eq, hash, debug for SwitchCase
derive eq, hash, debug for SwitchTargets
derive eq, hash, debug for HlirTermKind
derive eq, hash, debug for HlirTerminator


public type UnwindAction {
    case continue_
    case unreachable_
    case cleanup(target: block_mod.BlockId)
}


public type SwitchCase {
    value: i128
    target: block_mod.BlockId
    args: Vec_ValueId.Vec
}

public type SwitchTargets {
    cases: Vec_SwitchCase.Vec
    default: block_mod.BlockId
    default_args: Vec_ValueId.Vec
}


public type HlirTermKind {
    case goto_(target: block_mod.BlockId, args: Vec_ValueId.Vec)
    case branch(
        cond: value_mod.ValueId,
        true_: block_mod.BlockId,
        true_args: Vec_ValueId.Vec,
        false_: block_mod.BlockId,
        false_args: Vec_ValueId.Vec,
    )
    case switch_(discr: value_mod.ValueId, targets: SwitchTargets)
    case return_(values: Vec_ValueId.Vec)
    case unreachable_
    case raise_(value: value_mod.ValueId, unwind: UnwindAction)
    case panic_(message: value_mod.ValueId)
    case drop_(
        value: value_mod.ValueId,
        destructor: def_mod.DefId,
        target: block_mod.BlockId,
        unwind: UnwindAction,
    )
    case coherence_enter(body_entry: block_mod.BlockId, exit: block_mod.BlockId)
    case coherence_exit(target: block_mod.BlockId)
}


public type HlirTerminator {
    origin: node_mod.NodeId
    kind: HlirTermKind
}


module ir.hlir.lower.ids

import std.mem.alloc
import std.collections.vec

import local.hlir.id.value as hlir_value_mod
import local.hlir.id.block as hlir_block_mod
import local.hlir.id.op as hlir_op_id_mod

import local.lir.id.vreg as lir_vreg_mod
import local.lir.id.block as lir_block_mod
import local.lir.id.op as lir_op_id_mod


spec std.collections.vec.Vec(hlir_value_mod.ValueId)
spec std.collections.vec.Vec(hlir_op_id_mod.OpId)
spec std.collections.vec.Vec(lir_vreg_mod.LirVRegId)
spec std.collections.vec.Vec(lir_op_id_mod.LirOpId)


public stable function vreg_of_value(v: hlir_value_mod.ValueId) -> lir_vreg_mod.LirVRegId
    ensures result.raw == v.raw
{
    return lir_vreg_mod.LirVRegId { raw: v.raw }
}

public stable function block_id_of(b: hlir_block_mod.BlockId) -> lir_block_mod.LirBlockId
    ensures result.raw == b.raw
{
    return lir_block_mod.LirBlockId { raw: b.raw }
}

public stable function op_id_of(o: hlir_op_id_mod.OpId) -> lir_op_id_mod.LirOpId
    ensures result.raw == o.raw
{
    return lir_op_id_mod.LirOpId { raw: o.raw }
}


public function convert_value_id_vec(
    src: Vec_ValueId.Vec,
    allocator: Allocator,
) -> Vec_LirVRegId.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit out: Vec_LirVRegId.Vec
    Vec_LirVRegId.new(init out, allocator)?
    let n = Vec_ValueId.len(src)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let v = Vec_ValueId.at(src, i)
        Vec_LirVRegId.push(mutable out, take vreg_of_value(v), allocator)?
        i += 1
    }
    return out
}

public function convert_op_id_vec(
    src: Vec_OpId.Vec,
    allocator: Allocator,
) -> Vec_LirOpId.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit out: Vec_LirOpId.Vec
    Vec_LirOpId.new(init out, allocator)?
    let n = Vec_OpId.len(src)
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let o = Vec_OpId.at(src, i)
        Vec_LirOpId.push(mutable out, take op_id_of(o), allocator)?
        i += 1
    }
    return out
}

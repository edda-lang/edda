
module ir.hlir.id.op

derive eq, hash, ord, debug for OpId


public type OpId {
    raw: u32
}


public stable function error() -> OpId
    ensures result.raw == 0
{
    return OpId { raw: 0 }
}

public stable function is_error(o: OpId) -> bool
    ensures result == (o.raw == 0)
{
    return o.raw == 0
}


public stable function index(o: OpId) -> usize
    ensures result == (o.raw as usize)
{
    return o.raw as usize
}

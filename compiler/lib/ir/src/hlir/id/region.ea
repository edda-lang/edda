
module ir.hlir.id.region

derive eq, hash, ord, debug for RegionId


public type RegionId {
    raw: u32
}


public stable function error() -> RegionId
    ensures result.raw == 0
{
    return RegionId { raw: 0 }
}

public stable function is_error(r: RegionId) -> bool
    ensures result == (r.raw == 0)
{
    return r.raw == 0
}


public stable function index(r: RegionId) -> usize
    ensures result == (r.raw as usize)
{
    return r.raw as usize
}


module ir.hlir.id.value

derive eq, hash, ord, debug for ValueId


public type ValueId {
    raw: u32
}


public stable function error() -> ValueId
    ensures result.raw == 0
{
    return ValueId { raw: 0 }
}

public stable function is_error(v: ValueId) -> bool
    ensures result == (v.raw == 0)
{
    return v.raw == 0
}


public stable function index(v: ValueId) -> usize
    ensures result == (v.raw as usize)
{
    return v.raw as usize
}

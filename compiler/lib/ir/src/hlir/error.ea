
module ir.hlir.error

import span.loc.pos.span as span_mod


derive eq, hash, debug for UnsupportedKind
derive eq, debug for HlirError


public type UnsupportedKind {
    case reserved_
}

public type HlirError {
    case unsupported_mir_form(at: span_mod.Span, kind: UnsupportedKind)

    case internal_lowering_invariant(at: span_mod.Span, message: String)
}

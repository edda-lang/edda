
module ir.lir.error

import span.loc.pos.span as span_mod


derive eq, hash, debug for LirUnsupportedKind
derive eq, debug for LirError


public type LirUnsupportedKind {
    case reserved_
}

public type LirError {
    case unsupported_hlir_form(at: span_mod.Span, kind: LirUnsupportedKind)

    case internal_lowering_invariant(at: span_mod.Span, message: String)
}

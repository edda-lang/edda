
module ir.lir.id.op

derive eq, hash, ord, debug for LirOpId


public type LirOpId {
    raw: u32
}


public stable function error() -> LirOpId
    ensures result.raw == 0
{
    return LirOpId { raw: 0 }
}

public stable function is_error(o: LirOpId) -> bool
    ensures result == (o.raw == 0)
{
    return o.raw == 0
}


public stable function index(o: LirOpId) -> usize
    ensures result == (o.raw as usize)
{
    return o.raw as usize
}

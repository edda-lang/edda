
module ir.lir.id.vreg

derive eq, hash, ord, debug for LirVRegId


public type LirVRegId {
    raw: u32
}


public stable function error() -> LirVRegId
    ensures result.raw == 0
{
    return LirVRegId { raw: 0 }
}

public stable function is_error(v: LirVRegId) -> bool
    ensures result == (v.raw == 0)
{
    return v.raw == 0
}


public stable function index(v: LirVRegId) -> usize
    ensures result == (v.raw as usize)
{
    return v.raw as usize
}

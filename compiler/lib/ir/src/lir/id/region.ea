
module ir.lir.id.region

derive eq, hash, ord, debug for LirRegionId


public type LirRegionId {
    raw: u32
}


public stable function error() -> LirRegionId
    ensures result.raw == 0
{
    return LirRegionId { raw: 0 }
}

public stable function is_error(r: LirRegionId) -> bool
    ensures result == (r.raw == 0)
{
    return r.raw == 0
}


public stable function index(r: LirRegionId) -> usize
    ensures result == (r.raw as usize)
{
    return r.raw as usize
}

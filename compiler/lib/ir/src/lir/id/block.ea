
module ir.lir.id.block

derive eq, hash, ord, debug for LirBlockId


public type LirBlockId {
    raw: u32
}


public stable function error() -> LirBlockId
    ensures result.raw == 0
{
    return LirBlockId { raw: 0 }
}

public stable function is_error(b: LirBlockId) -> bool
    ensures result == (b.raw == 0)
{
    return b.raw == 0
}


public stable function entry() -> LirBlockId
    ensures result.raw == 1
{
    return LirBlockId { raw: 1 }
}


public stable function index(b: LirBlockId) -> usize
    ensures result == (b.raw as usize)
{
    return b.raw as usize
}


module ir.lir.tree.reg

import std.core.option
import types.pass.ty as ty_mod
import local.lir.id.vreg as vreg_mod


spec std.core.option.Option(PReg)
spec std.core.option.Option(vreg_mod.LirVRegId)


derive eq, hash, debug for RegClass
derive eq, hash, ord, debug for PReg
derive eq, hash, debug for LirVReg
derive eq, hash, debug for Operand
derive eq, hash, debug for MemRef


public type RegClass {
    case gp
    case fp
    case vector
    case mask
}


public type PReg {
    raw: u32
}


public type LirVReg {
    class_: RegClass
    pin: Option_PReg.Option
    ty: ty_mod.TyId
    size: u32
    int_width: u32
    int_signed: bool
    is_ref: bool
}


public function register_width() -> u32 {
    return 8 as u32
}


public function is_by_memory(size: u32) -> bool {
    return size != (1 as u32) && size != (2 as u32) && size != (4 as u32) && size != (8 as u32)
}


public type Operand {
    case vreg(id: vreg_mod.LirVRegId)
    case preg(reg: PReg)
    case imm(value: i64)
}


public type MemRef {
    base: Option_LirVRegId.Option
    index: Option_LirVRegId.Option
    scale: u32
    displacement: i32
}

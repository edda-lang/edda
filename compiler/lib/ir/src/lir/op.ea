
module ir.lir.op

import std.collections.vec
import std.core.option
import types.pass.ty as ty_mod
import hir.node as node_mod
import hir.def as def_mod
import intern.symbol as symbol_mod
import mir.rvalue as mir_rvalue_mod
import local.runtime as runtime_mod
import local.hlir.op as hlir_op_mod
import local.lir.id.vreg as vreg_mod
import local.lir.tree.reg as reg_mod


spec std.collections.vec.Vec(vreg_mod.LirVRegId)


spec std.core.option.Option(vreg_mod.LirVRegId)


derive eq, hash, debug for LBinOp
derive eq, hash, debug for LUnOp
derive eq, hash, debug for LCastKind
derive eq, hash, debug for LConstant
derive eq, hash, debug for LirOpKind
derive eq, hash, debug for LirOp


public type LBinOp {
    case add
    case sub
    case mul
    case add_sat
    case sub_sat
    case mul_sat
    case umulhi
    case smulhi
    case udiv
    case sdiv
    case urem
    case srem
    case bit_and
    case bit_or
    case bit_xor
    case shl
    case lshr
    case ashr
    case icmp_eq
    case icmp_ne
    case icmp_slt
    case icmp_sle
    case icmp_sgt
    case icmp_sge
    case icmp_ult
    case icmp_ule
    case icmp_ugt
    case icmp_uge
}


public type LUnOp {
    case neg
    case bit_not
    case logical_not
    case fsqrt
    case ffloor
    case fceil
    case ftrunc
}


public type LCastKind {
    case integer
    case integer_wrapping
    case integer_saturating
    case integer_checked
    case float
    case float_to_integer
    case integer_to_float
    case reinterpret
}


public type LConstant {
    case int_(value: i128, ty: ty_mod.TyId)
    case float_(bits: u64, width: mir_rvalue_mod.FloatWidth)
    case bool_(value: bool)
    case unit_
    case string_(symbol: symbol_mod.Symbol)
    case fn_ref(def: def_mod.DefId)
    case runtime_fn(fn_: runtime_mod.RuntimeFn)
}


public type LirOpKind {
    case mov(src: reg_mod.Operand, dst: vreg_mod.LirVRegId)
    case copy_(src: vreg_mod.LirVRegId, dst: vreg_mod.LirVRegId)
    case constant_(c: LConstant, dst: vreg_mod.LirVRegId)
    case binary(op: LBinOp, lhs: vreg_mod.LirVRegId, rhs: reg_mod.Operand, dst: vreg_mod.LirVRegId)
    case unary(op: LUnOp, operand: vreg_mod.LirVRegId, dst: vreg_mod.LirVRegId)
    case convert_(src: vreg_mod.LirVRegId, to_width: u32, to_signed: bool, kind: LCastKind, dst: vreg_mod.LirVRegId)
    case load(addr: reg_mod.MemRef, dst: vreg_mod.LirVRegId, width: u32)
    case store(value: vreg_mod.LirVRegId, addr: reg_mod.MemRef, width: u32)
    case call_(callee: reg_mod.Operand, args: Vec_LirVRegId.Vec, return_: Option_LirVRegId.Option)
    case call_indirect(callee: vreg_mod.LirVRegId, args: Vec_LirVRegId.Vec, return_: Option_LirVRegId.Option)
    case make_closure(code: def_mod.DefId, env: vreg_mod.LirVRegId, dst: vreg_mod.LirVRegId)
    case stack_addr(bytes: u32, dst: vreg_mod.LirVRegId)
    case err_flag(dst: vreg_mod.LirVRegId)
    case bounds_check(index: reg_mod.Operand, len: reg_mod.Operand)
    case cmov_carry(src: vreg_mod.LirVRegId, dst: vreg_mod.LirVRegId, when_set: bool)
}


public type LirOp {
    origin: node_mod.NodeId
    kind: LirOpKind
    flags: hlir_op_mod.OpFlags
}


module inspect.dump

import std.core.option
import std.collections.vec
import std.mem.alloc
import intern.symbol as symbol_mod
import intern.interner as interner_mod
import syntax.ast.file as ast_file_mod
import syntax.ast.item as ast_item_mod
import hir.build.file as hir_file_mod
import hir.item as hir_item_mod
import hir.node as node_mod
import types.check as types_check_mod
import types.ty.interner as ty_interner_mod
import mir.file.store as mir_file_mod
import mir.render as render_mod


spec std.core.option.Option(symbol_mod.Symbol)
spec std.collections.vec.Vec(ast_item_mod.Item)
spec std.collections.vec.Vec(hir_item_mod.HItem)
spec std.mem.alloc.Box(ast_item_mod.FnDecl)
spec std.mem.alloc.Box(hir_item_mod.HFnSignature)


public function dump_ast(
    errout: Stderr,
    file: ast_file_mod.File,
    fn_filter: Option_Symbol.Option,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError, divergence}
{
    match fn_filter {
        case .none => errout.eprint_line(f"{file}")
        case .some(let sym) => {
            let items = file.items
            let n = Vec_Item.len(items)
            var i: usize = 0
            loop decreases (n - i) {
                if i >= n { break }
                let it = Vec_Item.at(items, i)
                match it.kind {
                    case .function_(let decl) => {
                        let fd = Box_FnDecl.get(decl)
                        let ident = fd.name
                        let nsym = ident.name
                        if nsym.raw == sym.raw { errout.eprint_line(f"{it}") }
                    }
                    case _ => ()
                }
                i = i + 1
            }
        }
    }
}


public function dump_hir(
    errout: Stderr,
    file: hir_file_mod.HirFile,
    fn_filter: Option_Symbol.Option,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError, divergence}
{
    let items = file.items
    let n = Vec_HItem.len(items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let it = Vec_HItem.at(items, i)
        match fn_filter {
            case .none => errout.eprint_line(f"{it}")
            case .some(let sym) => {
                match it.kind {
                    case .function_(let sig, _) => {
                        let s = Box_HFnSignature.get(sig)
                        let nsym = s.name
                        if nsym.raw == sym.raw { errout.eprint_line(f"{it}") }
                    }
                    case _ => ()
                }
            }
        }
        i = i + 1
    }
}


public function dump_types(
    errout: Stderr,
    file: hir_file_mod.HirFile,
    type_out: types_check_mod.TypeOutput,
    ty_interner: ty_interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError, divergence}
{
    let n = file.next_node_id
    errout.eprint_line(f"node_types ({n} nodes):")
    var i: u32 = 0
    loop decreases (n - i) {
        if i >= n { break }
        let nid = node_mod.NodeId { raw: i }
        let tyid = types_check_mod.type_of_node(type_out, nid)
        let cty = ty_interner_mod.lookup(ty_interner, tyid)
        errout.eprint_line(f"  node {i}: {cty}")
        i = i + 1
    }
}


public function dump_mir(
    errout: Stderr,
    file: mir_file_mod.MirFile,
    it: interner_mod.Interner,
    allocator: Allocator,
) -> ()
    with {errout, allocator, err: alloc.AllocError, divergence}
{
    errout.eprint_line(render_mod.render_file(file, it, allocator)?)
}

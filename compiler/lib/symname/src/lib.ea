
module symname.lib

import std.mem.alloc
import std.text.string as string
import intern.interner as interner_mod
import intern.symbol as symbol_mod
import hir.def as def_mod


public function extern_symbol(
    name: symbol_mod.Symbol,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    return leaf_string(name, interner, allocator)?
}


public function function_symbol(
    name: symbol_mod.Symbol,
    def_id: def_mod.DefId,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let leaf = leaf_string(name, interner, allocator)?
    if string.equals(leaf, "main") {
        return leaf
    }
    let sep = string.concat(leaf, "_", allocator)?
    return string.concat(sep, hex8(def_id.raw, allocator)?, allocator)?
}


public function qualified_symbol(
    prefix: String,
    name: symbol_mod.Symbol,
    def_id: def_mod.DefId,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let leaf = leaf_string(name, interner, allocator)?
    if string.equals(leaf, "main") {
        return leaf
    }
    if string.is_empty(prefix) {
        return function_symbol(name, def_id, interner, allocator)?
    }
    let dotted = string.concat(prefix, ".", allocator)?
    return string.concat(dotted, leaf, allocator)?
}


function leaf_string(
    name: symbol_mod.Symbol,
    interner: interner_mod.Interner,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    if symbol_mod.is_empty(name) {
        return "anon"
    }
    let bytes = interner_mod.lookup(interner, name)
    return bytes_to_string(bytes, allocator)?
}


function bytes_to_string(
    bytes: [u8],
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let n = bytes.len()
    let buf: [u8] = allocator.alloc_array(u8, n)?
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        buf[i] = bytes[i]
        i += 1
    }
    return string.from_owned_utf8(take buf)
}


function hex8(
    v: u32,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let buf: [u8] = allocator.alloc_array(u8, 8 as usize)?
    var i: usize = 0
    loop decreases 8 - i {
        if i >= 8 { break }
        let shift: u32 = (((7 as usize) - i) as u32) * (4 as u32)
        let nibble: u32 = (v >> shift) & (15 as u32)
        buf[i] = hex_digit(nibble)
        i += 1
    }
    return string.from_owned_utf8(take buf)
}


function hex_digit(n: u32) -> u8 {
    return if n < (10 as u32) {
        ((48 as u32) + n) as u8 wrapping
    } else {
        ((97 as u32) + n - (10 as u32)) as u8 wrapping
    }
}


module object.fmt.macho

import std.collections.vec


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(MachoRelocationInfo)
spec std.collections.vec.Vec(MachoSectionBundle)
spec std.collections.vec.Vec(MachoNlist64)


derive eq, hash, debug for MachoCpu
derive eq, hash, debug for MachoKind
derive eq, hash, debug for MachoHeader
derive eq, hash, debug for MachoName16
derive eq, hash, debug for MachoLoadCommandKind
derive eq, hash, debug for MachoSegmentCommand64
derive eq, hash, debug for MachoSection64
derive eq, hash, debug for MachoSymtabCommand
derive eq, hash, debug for MachoNlist64
derive eq, hash, debug for MachoRelocationInfo
derive eq, hash, debug for MachoStringTable
derive eq, hash, debug for MachoSectionBundle
derive eq, hash, debug for MachoFile


public type MachoCpu {
    case any
    case x86_64
    case arm64
}

public stable function cpu_to_i32(c: MachoCpu) -> i32 {
    return match c {
        case .any    => -1 as i32
        case .x86_64 => 0x01000007 as i32
        case .arm64  => 0x0100000C as i32
    }
}


public type MachoKind {
    case object
    case execute
    case dylib
    case bundle
}

public stable function file_to_u32(t: MachoKind) -> u32 {
    return match t {
        case .object  => 0x1 as u32
        case .execute => 0x2 as u32
        case .dylib   => 0x6 as u32
        case .bundle  => 0x8 as u32
    }
}


public type MachoHeader {
    magic: u32
    cputype: MachoCpu
    cpusubtype: i32
    filetype: MachoKind
    ncmds: u32
    sizeofcmds: u32
    flags: u32
    reserved: u32
}

public stable function magic_64_native() -> u32 {
    return 0xFEEDFACF as u32
}


public type MachoName16 {
    lo: u64
    hi: u64
}


public type MachoLoadCommandKind {
    case segment_64
    case symtab
}

public stable function load_command_kind_to_u32(k: MachoLoadCommandKind) -> u32 {
    return match k {
        case .segment_64 => 0x19 as u32
        case .symtab     => 0x2 as u32
    }
}


public type MachoSegmentCommand64 {
    cmd: MachoLoadCommandKind
    cmdsize: u32
    segname: MachoName16
    vmaddr: u64
    vmsize: u64
    fileoff: u64
    filesize: u64
    maxprot: i32
    initprot: i32
    nsects: u32
    flags: u32
}


public type MachoSection64 {
    sectname: MachoName16
    segname: MachoName16
    addr: u64
    size: u64
    offset: u32
    align: u32
    reloff: u32
    nreloc: u32
    flags: u32
    reserved1: u32
    reserved2: u32
    reserved3: u32
}


public type MachoSymtabCommand {
    cmd: MachoLoadCommandKind
    cmdsize: u32
    symoff: u32
    nsyms: u32
    stroff: u32
    strsize: u32
}


public type MachoNlist64 {
    n_strx: u32
    n_type: u8
    n_sect: u8
    n_desc: u16
    n_value: u64
}


public type MachoRelocationInfo {
    r_address: i32
    r_info: u32
}

public stable function make_relocation_info(
    symbolnum: u32,
    pcrel: bool,
    length: u8,
    extern_: bool,
    relocation_type: u8,
) -> u32 {
    let sym = symbolnum & 0x00FFFFFF
    let pc = if pcrel { 1 as u32 } else { 0 as u32 }
    let len_ = (length as u32) & 0x3
    let ex = if extern_ { 1 as u32 } else { 0 as u32 }
    let ty = (relocation_type as u32) & 0xF
    return sym | (pc << 24) | (len_ << 25) | (ex << 27) | (ty << 28)
}


public type MachoStringTable {
    bytes: Vec_u8.Vec
}


public type MachoSectionBundle {
    header: MachoSection64
    data: Vec_u8.Vec
    relocations: Vec_MachoRelocationInfo.Vec
}


public type MachoFile {
    header: MachoHeader
    segment: MachoSegmentCommand64
    sections: Vec_MachoSectionBundle.Vec
    symtab: MachoSymtabCommand
    symbols: Vec_MachoNlist64.Vec
    string_table: MachoStringTable
}


module object.elf.serialize

import std.mem.alloc
import std.collections.vec
import local.bytes as bytes_mod
import local.fmt.elf as elf_mod


spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(u64)
spec std.collections.vec.Vec(elf_mod.ElfSection)
spec std.collections.vec.Vec(elf_mod.ElfSymbol)
spec std.collections.vec.Vec(elf_mod.ElfRela)


public function serialize_header(
    out: mutable Vec_u8.Vec,
    h: elf_mod.ElfHeader,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u8(mutable out, 0x7F as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x45 as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x4C as u8, allocator)?
    bytes_mod.push_u8(mutable out, 0x46 as u8, allocator)?
    bytes_mod.push_u8(mutable out, elf_mod.class_to_u8(h.class), allocator)?
    bytes_mod.push_u8(mutable out, elf_mod.data_to_u8(h.data), allocator)?
    bytes_mod.push_u8(mutable out, 1 as u8, allocator)?
    bytes_mod.push_u8(mutable out, h.os_abi, allocator)?
    bytes_mod.push_u8(mutable out, h.abi_version, allocator)?
    var pad: usize = 0
    loop decreases (7 - pad) {
        if pad >= 7 { break }
        bytes_mod.push_u8(mutable out, 0 as u8, allocator)?
        pad = pad + 1
    }
    bytes_mod.push_u16_le(mutable out, elf_mod.type_to_u16(h.type_), allocator)?
    bytes_mod.push_u16_le(mutable out, elf_mod.machine_to_u16(h.machine), allocator)?
    bytes_mod.push_u32_le(mutable out, h.version, allocator)?
    bytes_mod.push_u64_le(mutable out, h.entry, allocator)?
    bytes_mod.push_u64_le(mutable out, h.phoff, allocator)?
    bytes_mod.push_u64_le(mutable out, h.shoff, allocator)?
    bytes_mod.push_u32_le(mutable out, h.flags, allocator)?
    bytes_mod.push_u16_le(mutable out, h.ehsize, allocator)?
    bytes_mod.push_u16_le(mutable out, h.phentsize, allocator)?
    bytes_mod.push_u16_le(mutable out, h.phnum, allocator)?
    bytes_mod.push_u16_le(mutable out, h.shentsize, allocator)?
    bytes_mod.push_u16_le(mutable out, h.shnum, allocator)?
    bytes_mod.push_u16_le(mutable out, h.shstrndx, allocator)?
}


public function serialize_section_header(
    out: mutable Vec_u8.Vec,
    h: elf_mod.ElfSectionHeader,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u32_le(mutable out, h.sh_name, allocator)?
    bytes_mod.push_u32_le(mutable out, elf_mod.section_type_to_u32(h.sh_type), allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_flags, allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_addr, allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_offset, allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_size, allocator)?
    bytes_mod.push_u32_le(mutable out, h.sh_link, allocator)?
    bytes_mod.push_u32_le(mutable out, h.sh_info, allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_addralign, allocator)?
    bytes_mod.push_u64_le(mutable out, h.sh_entsize, allocator)?
}


public function serialize_symbol(
    out: mutable Vec_u8.Vec,
    s: elf_mod.ElfSymbol,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u32_le(mutable out, s.st_name, allocator)?
    bytes_mod.push_u8(mutable out, s.st_info, allocator)?
    bytes_mod.push_u8(mutable out, s.st_other, allocator)?
    bytes_mod.push_u16_le(mutable out, s.st_shndx, allocator)?
    bytes_mod.push_u64_le(mutable out, s.st_value, allocator)?
    bytes_mod.push_u64_le(mutable out, s.st_size, allocator)?
}


public function serialize_rela(
    out: mutable Vec_u8.Vec,
    r: elf_mod.ElfRela,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    bytes_mod.push_u64_le(mutable out, r.r_offset, allocator)?
    bytes_mod.push_u64_le(mutable out, r.r_info, allocator)?
    bytes_mod.push_i64_le(mutable out, r.r_addend, allocator)?
}


public function serialize_string_table(
    out: mutable Vec_u8.Vec,
    t: elf_mod.ElfStringTable,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    Vec_u8.extend_from_slice(mutable out, Vec_u8.as_slice(t.bytes), allocator)?
}


function compute_first_global(symbols: Vec_ElfSymbol.Vec) -> u32 {
    let n = Vec_ElfSymbol.len(symbols)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let sym = Vec_ElfSymbol.at(symbols, i)
        let binding = (sym.st_info >> 4) & 0x0F
        if binding != 0 {
            return i as u32
        }
        i = i + 1
    }
    return n as u32
}

function section_file_size(section: elf_mod.ElfSection) -> u64 {
    return match section.header.sh_type {
        case .null_  => 0 as u64
        case .nobits => 0 as u64
        case _       => Vec_u8.len(section.data) as u64
    }
}

function section_header_size(section: elf_mod.ElfSection) -> u64 {
    return match section.header.sh_type {
        case .null_  => 0 as u64
        case .nobits => section.header.sh_size
        case _       => Vec_u8.len(section.data) as u64
    }
}

function section_occupies_file(section: elf_mod.ElfSection) -> bool {
    return match section.header.sh_type {
        case .null_  => false
        case .nobits => false
        case _       => true
    }
}

public function serialize_file(
    out: mutable Vec_u8.Vec,
    f: elf_mod.ElfFile,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n_real = Vec_ElfSection.len(f.sections)
    let n_symbols = Vec_ElfSymbol.len(f.symbols)
    let ehsize: u64 = 64
    let symbol_size: u64 = 24
    let rela_size: u64 = 24

    uninit data_offsets: Vec_u64.Vec
    Vec_u64.new(init data_offsets, allocator)?
    var current: u64 = ehsize
    var i: usize = 0
    loop decreases (n_real - i) {
        if i >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, i)
        let occupies = section_occupies_file(section)
        let off: u64 = if occupies { current } else { 0 as u64 }
        Vec_u64.push(mutable data_offsets, take off, allocator)?
        if occupies {
            current = current + section_file_size(section)
        }
        i = i + 1
    }

    let symtab_offset: u64 = current
    let symtab_size: u64 = (n_symbols as u64) * symbol_size
    current = current + symtab_size

    let strtab_offset: u64 = current
    let strtab_size: u64 = Vec_u8.len(f.symbol_names.bytes) as u64
    current = current + strtab_size

    let shstrtab_offset: u64 = current
    let shstrtab_size: u64 = Vec_u8.len(f.section_names.bytes) as u64
    current = current + shstrtab_size

    uninit rela_offsets: Vec_u64.Vec
    Vec_u64.new(init rela_offsets, allocator)?
    var n_rela: usize = 0
    var j: usize = 0
    loop decreases (n_real - j) {
        if j >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, j)
        let nreloc = Vec_ElfRela.len(section.relocations)
        if nreloc > 0 {
            let rela_off: u64 = current
            Vec_u64.push(mutable rela_offsets, take rela_off, allocator)?
            current = current + (nreloc as u64) * rela_size
            n_rela = n_rela + 1
        } else {
            let zero_off: u64 = 0
            Vec_u64.push(mutable rela_offsets, take zero_off, allocator)?
        }
        j = j + 1
    }

    let shoff: u64 = current
    let shnum_val: u16 = (n_real + 3 + n_rela) as u16
    let shstrndx_val: u16 = (n_real + 2) as u16
    let symtab_index: u32 = n_real as u32
    let strtab_index: u32 = (n_real + 1) as u32
    let first_global = compute_first_global(f.symbols)

    let header_fixed = elf_mod.ElfHeader {
        class: f.header.class,
        data: f.header.data,
        os_abi: f.header.os_abi,
        abi_version: f.header.abi_version,
        type_: f.header.type_,
        machine: f.header.machine,
        version: f.header.version,
        entry: f.header.entry,
        phoff: f.header.phoff,
        shoff: shoff,
        flags: f.header.flags,
        ehsize: f.header.ehsize,
        phentsize: f.header.phentsize,
        phnum: f.header.phnum,
        shentsize: f.header.shentsize,
        shnum: shnum_val,
        shstrndx: shstrndx_val,
    }
    serialize_header(mutable out, header_fixed, allocator)?

    var k: usize = 0
    loop decreases (n_real - k) {
        if k >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, k)
        if section_occupies_file(section) {
            Vec_u8.extend_from_slice(mutable out, Vec_u8.as_slice(section.data), allocator)?
        }
        k = k + 1
    }

    var s: usize = 0
    loop decreases (n_symbols - s) {
        if s >= n_symbols { break }
        let symbol = Vec_ElfSymbol.at(f.symbols, s)
        serialize_symbol(mutable out, symbol, allocator)?
        s = s + 1
    }

    serialize_string_table(mutable out, f.symbol_names, allocator)?
    serialize_string_table(mutable out, f.section_names, allocator)?

    var r: usize = 0
    loop decreases (n_real - r) {
        if r >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, r)
        let nreloc = Vec_ElfRela.len(section.relocations)
        var q: usize = 0
        loop decreases (nreloc - q) {
            if q >= nreloc { break }
            let rela = Vec_ElfRela.at(section.relocations, q)
            serialize_rela(mutable out, rela, allocator)?
            q = q + 1
        }
        r = r + 1
    }

    var m: usize = 0
    loop decreases (n_real - m) {
        if m >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, m)
        let real_header = elf_mod.ElfSectionHeader {
            sh_name: section.header.sh_name,
            sh_type: section.header.sh_type,
            sh_flags: section.header.sh_flags,
            sh_addr: section.header.sh_addr,
            sh_offset: Vec_u64.at(data_offsets, m),
            sh_size: section_header_size(section),
            sh_link: section.header.sh_link,
            sh_info: section.header.sh_info,
            sh_addralign: section.header.sh_addralign,
            sh_entsize: section.header.sh_entsize,
        }
        serialize_section_header(mutable out, real_header, allocator)?
        m = m + 1
    }

    let symtab_header = elf_mod.ElfSectionHeader {
        sh_name: 0 as u32,
        sh_type: elf_mod.ElfSectionType.symtab,
        sh_flags: 0 as u64,
        sh_addr: 0 as u64,
        sh_offset: symtab_offset,
        sh_size: symtab_size,
        sh_link: strtab_index,
        sh_info: first_global,
        sh_addralign: 8 as u64,
        sh_entsize: symbol_size,
    }
    serialize_section_header(mutable out, symtab_header, allocator)?

    let strtab_header = elf_mod.ElfSectionHeader {
        sh_name: 0 as u32,
        sh_type: elf_mod.ElfSectionType.strtab,
        sh_flags: 0 as u64,
        sh_addr: 0 as u64,
        sh_offset: strtab_offset,
        sh_size: strtab_size,
        sh_link: 0 as u32,
        sh_info: 0 as u32,
        sh_addralign: 1 as u64,
        sh_entsize: 0 as u64,
    }
    serialize_section_header(mutable out, strtab_header, allocator)?

    let shstrtab_header = elf_mod.ElfSectionHeader {
        sh_name: 0 as u32,
        sh_type: elf_mod.ElfSectionType.strtab,
        sh_flags: 0 as u64,
        sh_addr: 0 as u64,
        sh_offset: shstrtab_offset,
        sh_size: shstrtab_size,
        sh_link: 0 as u32,
        sh_info: 0 as u32,
        sh_addralign: 1 as u64,
        sh_entsize: 0 as u64,
    }
    serialize_section_header(mutable out, shstrtab_header, allocator)?

    var t: usize = 0
    loop decreases (n_real - t) {
        if t >= n_real { break }
        let section = Vec_ElfSection.at(f.sections, t)
        let nreloc = Vec_ElfRela.len(section.relocations)
        if nreloc > 0 {
            let rela_header = elf_mod.ElfSectionHeader {
                sh_name: 0 as u32,
                sh_type: elf_mod.ElfSectionType.rela,
                sh_flags: 0 as u64,
                sh_addr: 0 as u64,
                sh_offset: Vec_u64.at(rela_offsets, t),
                sh_size: (nreloc as u64) * rela_size,
                sh_link: symtab_index,
                sh_info: t as u32,
                sh_addralign: 8 as u64,
                sh_entsize: rela_size,
            }
            serialize_section_header(mutable out, rela_header, allocator)?
        }
        t = t + 1
    }
}

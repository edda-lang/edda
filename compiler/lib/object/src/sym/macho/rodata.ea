
module object.sym.macho.rodata

import std.mem.alloc
import std.collections.vec

import local.fmt.macho as macho_mod
import local.macho.wrap as macho_wrap_mod


spec std.collections.vec.Vec(macho_mod.MachoRelocationInfo)
spec std.collections.vec.Vec(macho_mod.MachoNlist64)
spec std.collections.vec.Vec(macho_mod.MachoSectionBundle)
spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(bool)


public function add_rodata_section(
    file: mutable macho_mod.MachoFile,
    rdata: take Vec_u8.Vec,
    data_offsets: Vec_u32.Vec,
    data_is_string: Vec_bool.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let base_sym_index = Vec_MachoNlist64.len(file.symbols) as u32

    uninit relocs: Vec_MachoRelocationInfo.Vec
    Vec_MachoRelocationInfo.new(init relocs, allocator)?
    let reloc_n = Vec_u32.len(data_offsets)
    var r: usize = 0
    loop decreases reloc_n - r {
        if r >= reloc_n { break }
        if Vec_bool.at(data_is_string, r) {
            let field_va = Vec_u32.at(data_offsets, r)
            let sym_index = base_sym_index + (r as u32)
            Vec_MachoRelocationInfo.push(
                mutable relocs,
                macho_wrap_mod.make_relocation(field_va as i32, sym_index, false, 3 as u8, true, 0 as u8),
                allocator,
            )?
        }
        r += 1
    }

    macho_wrap_mod.add_section(mutable file, "__const", "__DATA", macho_wrap_mod.data_flags(), 4 as u32, take rdata, take relocs, allocator)?
    let section_index = Vec_MachoSectionBundle.len(file.sections) as u8

    let data_n = Vec_u32.len(data_offsets)
    var k: usize = 0
    loop decreases data_n - k {
        if k >= data_n { break }
        let offset = Vec_u32.at(data_offsets, k)
        macho_wrap_mod.add_symbol(
            mutable file,
            "",
            macho_wrap_mod.nlist_local_section(),
            section_index,
            offset as u64,
            allocator,
        )?
        k += 1
    }
}

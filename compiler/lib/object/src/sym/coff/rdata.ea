
module object.sym.coff.rdata

import std.mem.alloc
import std.collections.vec

import local.coff as coff_mod
import local.coff.wrap.wrap as coff_wrap_mod


spec std.collections.vec.Vec(coff_mod.CoffRelocation)
spec std.collections.vec.Vec(coff_mod.CoffSection)
spec std.collections.vec.Vec(coff_mod.CoffSymbol)
spec std.collections.vec.Vec(u32)
spec std.collections.vec.Vec(u8)
spec std.collections.vec.Vec(bool)


public function add_rdata_section(
    file: mutable coff_mod.CoffFile,
    rdata: take Vec_u8.Vec,
    data_defs: Vec_u32.Vec,
    data_offsets: Vec_u32.Vec,
    data_is_string: Vec_bool.Vec,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let base_sym_index = Vec_CoffSymbol.len(file.symbols) as u32

    uninit relocs: Vec_CoffRelocation.Vec
    Vec_CoffRelocation.new(init relocs, allocator)?
    let reloc_n = Vec_u32.len(data_defs)
    var r: usize = 0
    loop decreases reloc_n - r {
        if r >= reloc_n { break }
        if Vec_bool.at(data_is_string, r) {
            let field_va = Vec_u32.at(data_offsets, r)
            let sym_index = base_sym_index + (r as u32)
            Vec_CoffRelocation.push(
                mutable relocs,
                coff_wrap_mod.make_relocation(field_va, sym_index, coff_wrap_mod.rel_amd64_addr64()),
                allocator,
            )?
        }
        r += 1
    }

    coff_wrap_mod.add_section(mutable file, ".rdata", coff_wrap_mod.rdata_characteristics(), take rdata, take relocs, allocator)?
    let section_number = Vec_CoffSection.len(file.sections) as i16

    let data_n = Vec_u32.len(data_defs)
    var k: usize = 0
    loop decreases data_n - k {
        if k >= data_n { break }
        let offset = Vec_u32.at(data_offsets, k)
        coff_wrap_mod.add_symbol(
            mutable file,
            "",
            section_number,
            offset,
            coff_wrap_mod.storage_static(),
            coff_wrap_mod.symbol_type_null(),
            allocator,
        )?
        k += 1
    }
}

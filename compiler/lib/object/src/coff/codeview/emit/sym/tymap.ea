
module object.coff.codeview.emit.sym.tymap

import types.pass.ty as ty_mod
import types.ty.interner as ty_interner_mod
import types.ty.kind as ty_kind_mod

import local.coff.codeview.emit.encode as enc_mod


public function cv_type_for(ty_interner: ty_interner_mod.Interner, ty: ty_mod.TyId) -> u32 {
    var cur = ty
    let fuel = ty_interner_mod.slot_count(ty_interner) + 1 as usize
    var k: usize = 0
    loop decreases fuel - k {
        if k >= fuel { return enc_mod.t_notype() }
        if ty_mod.index(cur) >= ty_interner_mod.slot_count(ty_interner) { return enc_mod.t_notype() }
        match ty_interner_mod.lookup(ty_interner, cur) {
            case .primitive(let p) => return prim_cv_index(p)
            case .refined(let base, _) => {
                cur = base
                k += 1
                continue
            }
            case _ => return enc_mod.t_notype()
        }
    }
    return enc_mod.t_notype()
}


function prim_cv_index(p: ty_kind_mod.PrimKind) -> u32 {
    return match p {
        case .i8_ => 0x0068 as u32
        case .i16_ => 0x0072 as u32
        case .i32_ => 0x0074 as u32
        case .i64_ => 0x0076 as u32
        case .i128_ => 0x0078 as u32
        case .u8_ => 0x0069 as u32
        case .u16_ => 0x0073 as u32
        case .u32_ => 0x0075 as u32
        case .u64_ => 0x0077 as u32
        case .u128_ => 0x0079 as u32
        case .isize_ => 0x0076 as u32
        case .usize_ => 0x0077 as u32
        case .f32_ => 0x0040 as u32
        case .f64_ => 0x0041 as u32
        case .bool_ => 0x0030 as u32
        case .unit_ => 0x0003 as u32
        case .never_ => 0x0003 as u32
        case .codepoint_ => 0x007b as u32
        case .type_meta => enc_mod.t_notype()
        case .heap_ptr => enc_mod.t_notype()
    }
}


module manifest.model.dependency.dependency

derive eq, hash, ord, clone, debug for DependencySource
derive eq, hash, ord, clone, debug for Dependency

public type DependencySource {
    case registry
    case git(url: String)
    case path(rel: String)
}

public type Dependency {
    name: String
    version_req: String
    source: DependencySource
}

public stable function dependency_of(name: take String, version_req: take String, source: DependencySource) -> Dependency {
    return Dependency { name: name, version_req: version_req, source: source }
}

public stable function name(d: Dependency) -> String {
    return d.name
}

public stable function version_req(d: Dependency) -> String {
    return d.version_req
}

public stable function source(d: Dependency) -> DependencySource {
    return d.source
}

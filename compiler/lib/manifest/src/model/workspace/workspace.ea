
module manifest.model.workspace.workspace

import std.collections.vec
import std.core.option

spec std.collections.vec.Vec(String)
spec std.core.option.Option(WorkspaceDiscover)

derive eq, hash, ord, clone, debug for WorkspaceDiscover

public type WorkspaceDiscover {
    case lib_root
    case path(rel: String)
}

public type Workspace {
    members: Vec_String.Vec
    discover: Option_WorkspaceDiscover.Option
}

public function workspace_of(members: take Vec_String.Vec, discover: Option_WorkspaceDiscover.Option) -> Workspace {
    return Workspace { members: members, discover: discover }
}

public function member_count(w: Workspace) -> usize {
    return Vec_String.len(w.members)
}

public function member_at(w: Workspace, idx: usize where idx < member_count(w)) -> String {
    return Vec_String.at(w.members, idx)
}

public stable function discover(w: Workspace) -> Option_WorkspaceDiscover.Option {
    return w.discover
}

public function discover_root_of(w: Workspace) -> String {
    return match w.discover {
        case .none => "lib"
        case .some(let d) => match d {
            case .lib_root      => "lib"
            case .path(let rel) => rel
        }
    }
}


module manifest.model.reserved.reserved

import std.text.string

public function is_reserved(name: String) -> bool {
    if string.equals(name, "std")      { return true }
    if string.equals(name, "codegen")  { return true }
    if string.equals(name, "tests")    { return true }
    if string.equals(name, "bench")    { return true }
    if string.equals(name, "examples") { return true }
    return false
}

public function is_safe_path_segment(name: String) -> bool {
    let bytes = name.bytes()
    let n = bytes.len()
    if n == 0 { return false }
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let b = bytes[i]
        let ok = (b >= 65 && b <= 90) || (b >= 97 && b <= 122) || (b >= 48 && b <= 57) || b == 95 || b == 45
        if !ok { return false }
        i = i + 1
    }
    return true
}


module manifest.model.structmap.structmap

derive eq, clone, debug for StructmapConfig

public type StructmapConfig {
    descendant_tree: bool
}

public stable function structmap_config_of(descendant_tree: bool) -> StructmapConfig {
    return StructmapConfig { descendant_tree: descendant_tree }
}

public function default_structmap_config() -> StructmapConfig {
    return StructmapConfig { descendant_tree: false }
}

public stable function descendant_tree(c: StructmapConfig) -> bool {
    return c.descendant_tree
}


module manifest.manifest

import std.collections.vec
import std.core.option
import diagnostics.emit.lint.config as lint_config_mod
import link.emit.image.output as output_mod
import local.model.build.build as build_mod
import local.model.codegen.gc_schedule as gc_schedule_mod
import local.model.dependency.dependency as dep_mod
import local.model.package.package as pkg_mod
import local.model.structmap.structmap as structmap_mod
import local.model.workspace.workspace as ws_mod

spec std.collections.vec.Vec(dep_mod.Dependency)
spec std.core.option.Option(dep_mod.Dependency)
spec std.core.option.Option(ws_mod.Workspace)
spec std.core.option.Option(String)

public type LoadedManifest {
    case package(
        pkg: pkg_mod.Package,
        deps: Vec_Dependency.Vec,
        build: build_mod.Build,
        workspace: Option_Workspace.Option,
        lints: lint_config_mod.LintConfig,
        structmap: structmap_mod.StructmapConfig,
        codegen: gc_schedule_mod.GcScheduleConfig,
    )
    case workspace_only(
        workspace: ws_mod.Workspace,
        build: build_mod.Build,
        lints: lint_config_mod.LintConfig,
        structmap: structmap_mod.StructmapConfig,
        codegen: gc_schedule_mod.GcScheduleConfig,
    )
}

public function package_name_of(m: LoadedManifest) -> Option_String.Option {
    return match m {
        case .package(let pkg, _, _, _, _, _, _) => Option_String.some(value: pkg_mod.name(pkg))
        case .workspace_only(_, _, _, _, _) => Option_String.none
    }
}

public function kind_of(m: LoadedManifest) -> output_mod.OutputKind {
    return match m {
        case .package(let pkg, _, _, _, _, _, _) => pkg_mod.kind(pkg)
        case .workspace_only(_, _, _, _, _) => output_mod.OutputKind.executable
    }
}

public function is_workspace_only(m: LoadedManifest) -> bool {
    return match m {
        case .package(_, _, _, _, _, _, _) => false
        case .workspace_only(_, _, _, _, _) => true
    }
}

public function has_workspace(m: LoadedManifest) -> bool {
    return match m {
        case .package(_, _, _, let ws, _, _, _) => match ws {
            case .some(_) => true
            case .none    => false
        }
        case .workspace_only(_, _, _, _, _) => true
    }
}

public function workspace_of(m: LoadedManifest) -> Option_Workspace.Option {
    return match m {
        case .package(_, _, _, let ws, _, _, _) => ws
        case .workspace_only(let ws, _, _, _, _) => Option_Workspace.some(value: ws)
    }
}

public function dependency_count_of(m: LoadedManifest) -> usize {
    return match m {
        case .package(_, let deps, _, _, _, _, _) => Vec_Dependency.len(deps)
        case .workspace_only(_, _, _, _, _) => 0 as usize
    }
}

public function dependency_name_at(m: LoadedManifest, i: usize) -> String {
    return match m {
        case .package(_, let deps, _, _, _, _, _) => dep_mod.name(Vec_Dependency.at(deps, i))
        case .workspace_only(_, _, _, _, _) => ""
    }
}

public function dependency_at(m: LoadedManifest, i: usize) -> Option_Dependency.Option {
    return match m {
        case .package(_, let deps, _, _, _, _, _) =>
            if i < Vec_Dependency.len(deps) {
                Option_Dependency.some(value: Vec_Dependency.at(deps, i))
            } else {
                Option_Dependency.none
            }
        case .workspace_only(_, _, _, _, _) => Option_Dependency.none
    }
}

public function build_of(m: LoadedManifest) -> build_mod.Build {
    return match m {
        case .package(_, _, let b, _, _, _, _) => b
        case .workspace_only(_, let b, _, _, _) => b
    }
}

public function lints_of(m: LoadedManifest) -> lint_config_mod.LintConfig {
    return match m {
        case .package(_, _, _, _, let l, _, _) => l
        case .workspace_only(_, _, let l, _, _) => l
    }
}

public function structmap_of(m: LoadedManifest) -> structmap_mod.StructmapConfig {
    return match m {
        case .package(_, _, _, _, _, let s, _) => s
        case .workspace_only(_, _, _, let s, _) => s
    }
}

public function codegen_of(m: LoadedManifest) -> gc_schedule_mod.GcScheduleConfig {
    return match m {
        case .package(_, _, _, _, _, _, let c) => c
        case .workspace_only(_, _, _, _, let c) => c
    }
}

public function with_workspace(m: take LoadedManifest, ws: take ws_mod.Workspace) -> LoadedManifest {
    return match m {
        case .package(let pkg, let deps, let build, _, let lints, let structmap, let codegen) =>
            LoadedManifest.package(
                pkg: pkg,
                deps: deps,
                build: build,
                workspace: Option_Workspace.some(value: ws),
                lints: lints,
                structmap: structmap,
                codegen: codegen,
            )
        case .workspace_only(_, let build, let lints, let structmap, let codegen) =>
            LoadedManifest.workspace_only(
                workspace: ws,
                build: build,
                lints: lints,
                structmap: structmap,
                codegen: codegen,
            )
    }
}

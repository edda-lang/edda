
module manifest.build.lockfile.write.write

import std.mem.alloc
import std.text.string
import local.model.lockfile.lockfile as lf_mod


public function write_lockfile(lf: lf_mod.LoadedLockfile, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    var acc: String = write_meta_block(lf, allocator)?
    let rn = lf_mod.rune_count(lf)
    var i: usize = 0 as usize
    loop decreases (rn - i) {
        if i >= rn { break }
        let block = write_rune_block(lf_mod.rune_at(lf, i), allocator)?
        acc = string.concat(acc, block, allocator)?
        i = i + 1 as usize
    }
    let cn = lf_mod.contract_baseline_count(lf)
    var j: usize = 0 as usize
    loop decreases (cn - j) {
        if j >= cn { break }
        let block = write_contract_baseline_block(lf_mod.contract_baseline_at(lf, j), allocator)?
        acc = string.concat(acc, block, allocator)?
        j = j + 1 as usize
    }
    return acc
}


function write_kv(acc: String, key: String, value: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let a1 = string.concat(acc, key, allocator)?
    let a2 = string.concat(a1, " = \"", allocator)?
    let a3 = string.concat(a2, value, allocator)?
    return string.concat(a3, "\"\n", allocator)?
}


function write_meta_block(lf: lf_mod.LoadedLockfile, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let a0 = write_kv("[lockfile_meta]\n", "lockfile_hash", lf_mod.lockfile_hash(lf), allocator)?
    return string.concat(a0, "\n", allocator)?
}


function write_rune_block(r: lf_mod.Rune, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let a0 = write_kv("[[rune]]\n", "name", lf_mod.name(r), allocator)?
    let a1 = write_kv(a0, "version", lf_mod.version(r), allocator)?
    let a2 = write_kv(a1, "source", lf_mod.source(r), allocator)?
    let a3 = write_kv(a2, "rune_hash", lf_mod.rune_hash(r), allocator)?
    let a4 = write_kv(a3, "surface_hash", lf_mod.surface_hash(r), allocator)?
    let a5 = write_kv(a4, "effect_hash", lf_mod.effect_hash(r), allocator)?
    let a6 = write_kv(a5, "publisher_key", lf_mod.publisher_key(r), allocator)?
    let a7 = write_kv(a6, "publisher_sig", lf_mod.publisher_sig(r), allocator)?
    let a8 = write_deps_array(a7, r, allocator)?
    return string.concat(a8, "\n", allocator)?
}


function write_deps_array(acc: String, r: lf_mod.Rune, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let n = lf_mod.dep_count(r)
    var out: String = string.concat(acc, "deps = [", allocator)?
    var i: usize = 0 as usize
    loop decreases (n - i) {
        if i >= n { break }
        if i > 0 as usize {
            out = string.concat(out, ", ", allocator)?
        }
        let a1 = string.concat(out, "\"", allocator)?
        let a2 = string.concat(a1, lf_mod.dep_at(r, i), allocator)?
        out = string.concat(a2, "\"", allocator)?
        i = i + 1 as usize
    }
    return string.concat(out, "]\n", allocator)?
}


function write_contract_baseline_block(cb: lf_mod.ContractBaseline, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let a0 = write_kv("[[contract_baseline]]\n", "qualified_name", lf_mod.qualified_name(cb), allocator)?
    let a1 = write_kv(a0, "contract_hash", lf_mod.contract_hash(cb), allocator)?
    let a2 = write_kv(a1, "version_introduced", lf_mod.version_introduced(cb), allocator)?
    return string.concat(a2, "\n", allocator)?
}

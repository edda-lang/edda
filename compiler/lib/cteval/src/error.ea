
module cteval.error

import std.core.fmt
import std.mem.alloc
import std.text.string
import diagnostics.code as code_mod
import diagnostics.emit.diagnostic as diag_mod
import span.loc.pos.span as span_mod


derive eq, debug for ComptimeError


public type ComptimeError {
    case purity_loss(
        at: span_mod.Span,
        callee_name: String,
        offending_effect: String,
    )

    case target_supports_non_capability(
        at: span_mod.Span,
        ty_name: String,
    )

    case field_index_out_of_range(
        at: span_mod.Span,
        ty_name: String,
        requested: u32,
        max: u32,
    )

    case field_not_found(
        at: span_mod.Span,
        ty_name: String,
        field_name: String,
    )

    case overflow(
        at: span_mod.Span,
        message: String,
    )

    case evaluation_failed(
        at: span_mod.Span,
        message: String,
    )
}


public function to_diagnostic(e: ComptimeError, allocator: Allocator) -> diag_mod.Diagnostic
    with {allocator, err: alloc.AllocError}
{
    let at = span_of(e)
    let msg = format_message(e, allocator)?
    return match e {
        case .purity_loss(_, _, _) =>
            diag_mod.error_at(code_mod.comptime_purity_loss(), at, msg)
        case .target_supports_non_capability(_, _) =>
            diag_mod.error_at(code_mod.comptime_target_supports_non_capability(), at, msg)
        case .field_index_out_of_range(_, _, _, _) =>
            diag_mod.error_at(code_mod.comptime_field_index_out_of_range(), at, msg)
        case .field_not_found(_, _, _) =>
            diag_mod.error_at(code_mod.comptime_field_not_found(), at, msg)
        case .overflow(_, _) =>
            diag_mod.error_at(code_mod.comptime_overflow(), at, msg)
        case .evaluation_failed(_, _) =>
            diag_mod.error_at(code_mod.comptime_evaluation_failed(), at, msg)
    }
}


public stable function span_of(e: ComptimeError) -> span_mod.Span {
    return match e {
        case .purity_loss(let at, _, _) => at
        case .target_supports_non_capability(let at, _) => at
        case .field_index_out_of_range(let at, _, _, _) => at
        case .field_not_found(let at, _, _) => at
        case .overflow(let at, _) => at
        case .evaluation_failed(let at, _) => at
    }
}


function format_message(e: ComptimeError, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return match e {
        case .purity_loss(_, let callee, let effect) =>
            fmt_purity_loss(callee, effect, allocator)?
        case .target_supports_non_capability(_, let ty_name) =>
            fmt_target_supports_non_capability(ty_name, allocator)?
        case .field_index_out_of_range(_, let ty_name, let requested, let max) =>
            fmt_field_index_out_of_range(ty_name, requested, max, allocator)?
        case .field_not_found(_, let ty_name, let field_name) =>
            fmt_field_not_found(ty_name, field_name, allocator)?
        case .overflow(_, let message) =>
            fmt_overflow(message, allocator)?
        case .evaluation_failed(_, let message) =>
            fmt_evaluation_failed(message, allocator)?
    }
}

function fmt_purity_loss(
    callee_name: String,
    offending_effect: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("comptime context cannot call `", callee_name, allocator)?
    let p2 = string.concat(p1, "`: declared effect `", allocator)?
    let p3 = string.concat(p2, offending_effect, allocator)?
    return string.concat(
        p3,
        "` is outside the comptime-pure envelope `{panic, yield: T}`",
        allocator,
    )?
}

function fmt_target_supports_non_capability(
    ty_name: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("`target.supports` expects a capability type, got `", ty_name, allocator)?
    return string.concat(
        p1,
        "` — the locked capability vocabulary is in CLAUDE.md \"Capabilities\"",
        allocator,
    )?
}

function fmt_field_index_out_of_range(
    ty_name: String,
    requested: u32,
    max: u32,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("field index out of range for `", ty_name, allocator)?
    let p2 = string.concat(p1, "`: requested ", allocator)?
    let requested_str = fmt.u32_to_string(requested, allocator)?
    let p3 = string.concat(p2, requested_str, allocator)?
    let p4 = string.concat(p3, ", `field_count` is ", allocator)?
    let max_str = fmt.u32_to_string(max, allocator)?
    let p5 = string.concat(p4, max_str, allocator)?
    return string.concat(
        p5,
        " — iterate via `0..<field_count(T)`",
        allocator,
    )?
}

function fmt_field_not_found(
    ty_name: String,
    field_name: String,
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let p1 = string.concat("type `", ty_name, allocator)?
    let p2 = string.concat(p1, "` has no field named `", allocator)?
    let p3 = string.concat(p2, field_name, allocator)?
    return string.concat(p3, "`", allocator)?
}

function fmt_overflow(message: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat("comptime integer overflow: ", message, allocator)?
}

function fmt_evaluation_failed(message: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.concat("comptime evaluation failed: ", message, allocator)?
}

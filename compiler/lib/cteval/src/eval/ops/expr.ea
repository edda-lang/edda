function apply_is_container(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_type_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t) => bool_to_eval_result(category_mod.is_container(t, ctx.ty_interner))
        case .wrong_arity(_) => failed_eval(at, "is_container expects exactly 1 Type argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_type => failed_eval(at, "is_container expects a Type argument")
    }
}


function layout_result_to_eval_result(lr: layout_mod.LayoutResult, at: span_mod.Span) -> EvalResult {
    return match lr {
        case .ok(let n) => EvalResult.ok(
            value: value_mod.ComptimeValue.int_unsigned(
                value: n as u64,
                width: value_mod.IntWidth.wsize,
            ),
        )
        case .unsupported(let msg) => failed_eval(at, msg)
    }
}

function bool_to_eval_result(b: bool) -> EvalResult {
    return EvalResult.ok(value: value_mod.ComptimeValue.bool_(value: b))
}

function call_user_function(
    callee: def_mod.DefId,
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let item_opt = find_function_item(ctx, callee)
    let item = match item_opt {
        case .some(let i) => i
        case .none => return failed_eval(at, "callee DefId does not resolve to a function item in this file or the program's other files")
    }
    return match item.kind {
        case .function_(let sig_box, let body) =>
            evaluate_user_function_body(callee, sig_box, body, args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case _ => failed_eval(at, "callee DefId resolves to a non-function item; cannot invoke at comptime")
    }
}

function evaluate_user_function_body(
    callee: def_mod.DefId,
    sig_box: Box_HFnSignature.Box,
    body: hir_tree.HBlock,
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let _ = callee
    let sig = Box_HFnSignature.get(sig_box)
    let purity_result = check_callee_purity(callee, ctx)
    match purity_result {
        case .impure(let offending) => return EvalResult.failed(
            error: err_mod.ComptimeError.purity_loss(
                at: at,
                callee_name: "<callee>",
                offending_effect: offending,
            ),
        )
        case .pure_ => ()
    }
    let saved_depth = env_mod.depth(env)
    let bind_outcome = bind_params(sig, args, mutable env, ctx, mutable sym_interner, allocator, at)?
    match bind_outcome {
        case .failed(let e) => {
            env_mod.truncate_to(mutable env, saved_depth)
            return EvalResult.failed(error: e)
        }
        case .ok(_) => ()
    }
    let body_result = evaluate_block(body, mutable env, ctx, mutable sym_interner, allocator, at)?
    env_mod.truncate_to(mutable env, saved_depth)
    return match env_mod.signal_of(env) {
        case .return_(let v) => {
            env_mod.clear_signal(mutable env)
            EvalResult.ok(value: v)
        }
        case .none_ => body_result
        case _ => {
            env_mod.clear_signal(mutable env)
            failed_eval(at, "comptime function body terminated with a `break`/`continue` that escaped its enclosing loop — the typechecker should have rejected this upstream")
        }
    }
}

function check_callee_purity(
    callee: def_mod.DefId,
    ctx: ctx_mod.EvalCtx,
) -> purity_mod.PurityCheck {
    let opt_sig = types_check_mod.signature_of(ctx.type_output, callee)
    return match opt_sig {
        case .some(let s) => purity_mod.check_row(s.effects, ctx.effect_interner)
        case .none => purity_mod.PurityCheck.impure(offending_effect: "signature unavailable")
    }
}

function bind_params(
    sig: hir_item_mod.HFnSignature,
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let param_count = Vec_HParam.len(sig.params)
    let arg_count = Vec_HArg.len(args)
    if param_count != arg_count {
        return failed_eval(at, "comptime call arity mismatch — callee expects different number of args")
    }
    var i: usize = 0
    loop
        decreases (param_count - i)
    {
        if i >= param_count {
            break
        }
        let arg = Vec_HArg.at(args, i)
        let arg_result = evaluate_expr(arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
        let arg_value = match arg_result {
            case .ok(let v) => v
            case .failed(let e) => return EvalResult.failed(error: e)
        }
        let param = Vec_HParam.at(sig.params, i)
        env_mod.push_binding(mutable env, param.def_id, take arg_value, allocator)?
        i = i + 1
    }
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}


function evaluate_dyn_call_rejected(at: span_mod.Span) -> EvalResult {
    return failed_eval(
        at,
        "dyn_call cannot evaluate at comptime — closure literals do not yet lower",
    )
}


function find_in_file(
    file: hir_file_mod.HirFile,
    target: def_mod.DefId,
) -> Option_HItem.Option {
    let items = file.items
    let n = Vec_HItem.len(items)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let item = Vec_HItem.at(items, i)
        if item.def_id.raw == target.raw {
            return Option_HItem.some(value: item)
        }
        i = i + 1
    }
    return Option_HItem.none
}


function find_in_files(
    files: Vec_HirFile.Vec,
    target: def_mod.DefId,
) -> Option_HItem.Option {
    let n = Vec_HirFile.len(files)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let hit = find_in_file(Vec_HirFile.at(files, i), target)
        match hit {
            case .some(_) => return hit
            case .none => ()
        }
        i = i + 1
    }
    return Option_HItem.none
}


function find_function_item(
    ctx: ctx_mod.EvalCtx,
    target: def_mod.DefId,
) -> Option_HItem.Option {
    return match find_in_file(ctx.file, target) {
        case .some(let item) => Option_HItem.some(value: item)
        case .none => match ctx.program_files {
            case .some(let files) => find_in_files(files, target)
            case .none => Option_HItem.none
        }
    }
}


function evaluate_block(
    block: hir_tree.HBlock,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let saved_depth = env_mod.depth(env)
    let stmts = block.stmts
    let n = Vec_HStmt.len(stmts)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let stmt = Vec_HStmt.at(stmts, i)
        let stmt_result = evaluate_stmt(stmt, mutable env, ctx, mutable sym_interner, allocator, at)?
        match stmt_result {
            case .failed(let e) => {
                env_mod.truncate_to(mutable env, saved_depth)
                return EvalResult.failed(error: e)
            }
            case .ok(_) => ()
        }
        match env_mod.signal_of(env) {
            case .none_ => ()
            case _ => {
                env_mod.truncate_to(mutable env, saved_depth)
                return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
            }
        }
        i = i + 1
    }
    let final_result = match block.trailing {
        case .some(let box_e) => {
            let trailing = Box_HExpr.get(box_e)
            evaluate_expr(trailing, mutable env, ctx, mutable sym_interner, allocator, at)?
        }
        case .none => EvalResult.ok(value: value_mod.ComptimeValue.unit_)
    }
    env_mod.truncate_to(mutable env, saved_depth)
    return final_result
}


function evaluate_if(
    cond_box: Box_HExpr.Box,
    then_block: hir_tree.HBlock,
    else_block: Option_HBlock.Option,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let cond_expr = Box_HExpr.get(cond_box)
    let cond_result = evaluate_expr(cond_expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    let cond_value = match cond_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let cond_bool = match cond_value {
        case .bool_(let b) => b
        case _ => return failed_eval(at, "comptime if predicate must be a bool value")
    }
    if cond_bool {
        return evaluate_block(then_block, mutable env, ctx, mutable sym_interner, allocator, at)?
    }
    return match else_block {
        case .some(let b) => evaluate_block(b, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .none => EvalResult.ok(value: value_mod.ComptimeValue.unit_)
    }
}


function evaluate_match(
    scrutinee_box: Box_HExpr.Box,
    arms: Vec_HArm.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let scrutinee = Box_HExpr.get(scrutinee_box)
    let scrutinee_result = evaluate_expr(scrutinee, mutable env, ctx, mutable sym_interner, allocator, at)?
    let scrutinee_value = match scrutinee_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let n = Vec_HArm.len(arms)
    var i: usize = 0
    loop
        decreases (n - i)
    {
        if i >= n {
            break
        }
        let arm = Vec_HArm.at(arms, i)
        let pat_result = try_match_pat(arm.pat, scrutinee_value, at)
        match pat_result {
            case .unsupported(let e) => return EvalResult.failed(error: e)
            case .no_match => ()
            case .matched => {
                let snapshot = env_mod.depth(env)
                let bound_value = clone_ComptimeValue.clone(scrutinee_value)
                push_arm_bindings(mutable env, arm.bindings, take bound_value, allocator)?
                let guard_outcome = evaluate_arm_guard(arm.guard, mutable env, ctx, mutable sym_interner, allocator, at)?
                match guard_outcome {
                    case .failed(let e) => {
                        env_mod.truncate_to(mutable env, snapshot)
                        return EvalResult.failed(error: e)
                    }
                    case .ok(let guard_value) => match guard_value {
                        case .bool_(let b) => {
                            if b {
                                let body_result = evaluate_expr(arm.body, mutable env, ctx, mutable sym_interner, allocator, at)?
                                env_mod.truncate_to(mutable env, snapshot)
                                return body_result
                            }
                        }
                        case _ => {
                            env_mod.truncate_to(mutable env, snapshot)
                            return failed_eval(at, "comptime match guard must evaluate to bool")
                        }
                    }
                }
                env_mod.truncate_to(mutable env, snapshot)
            }
        }
        i = i + 1
    }
    return failed_eval(at, "comptime match: no arm matched the scrutinee value (non-exhaustive at this evaluation site)")
}

function push_arm_bindings(
    env: mutable env_mod.ComptimeEnv,
    bindings: Vec_HBinding.Vec,
    scrutinee: take value_mod.ComptimeValue,
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = Vec_HBinding.len(bindings)
    if n == 0 {
        return
    }
    let binding = Vec_HBinding.at(bindings, 0)
    env_mod.push_binding(mutable env, binding.def_id, take scrutinee, allocator)?
}

function evaluate_arm_guard(
    guard: Option_HExpr.Option,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    return match guard {
        case .none => EvalResult.ok(value: value_mod.ComptimeValue.bool_(value: true))
        case .some(let guard_expr) => evaluate_expr(guard_expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    }
}

type PatMatchResult {
    case matched
    case no_match
    case unsupported(error: err_mod.ComptimeError)
}

function try_match_pat(
    pat: ast_tree.Pat,
    scrutinee: value_mod.ComptimeValue,
    at: span_mod.Span,
) -> PatMatchResult {
    return match pat.kind {
        case .wildcard => PatMatchResult.matched
        case .literal(let lit) => match_literal_against(lit, scrutinee, at)
        case .binding(_) => PatMatchResult.matched
        case .range(_, _, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match range pattern not admitted by Edda v0.1 per CLAUDE.md \"Match\" anti-patterns",
            ),
        )
        case .tuple(_) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match tuple pattern — compound value lattice reserved for post-V1.0 per 04-specs-comptime.md §3.2",
            ),
        )
        case .slice(_, _, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match slice pattern not admitted by Edda v0.1 per CLAUDE.md \"Match\" anti-patterns",
            ),
        )
        case .variant(_, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match variant pattern — compound value lattice reserved for post-V1.0 per 04-specs-comptime.md §3.2",
            ),
        )
        case .struct_(_, _, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match struct pattern — compound value lattice reserved for post-V1.0 per 04-specs-comptime.md §3.2",
            ),
        )
        case .or_(_) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match or-pattern not admitted by Edda v0.1 per CLAUDE.md \"Match\" anti-patterns",
            ),
        )
        case .at_binding(_, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match @-binding pattern not admitted by Edda v0.1 per CLAUDE.md \"Match\" anti-patterns",
            ),
        )
        case .guard(_, _) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime nested-guard pattern reached; the arm's top-level guard is on HArm.guard — nested guard inside a pattern is not part of the Edda v0.1 pattern surface",
            ),
        )
        case .error => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match reached an error-sentinel pattern; underlying syntax/lowering diagnostic is upstream",
            ),
        )
    }
}

function match_literal_against(
    lit: ast_literal.Literal,
    scrutinee: value_mod.ComptimeValue,
    at: span_mod.Span,
) -> PatMatchResult {
    return match lit {
        case .bool(let lit_b) => match scrutinee {
            case .bool_(let s_b) =>
                if lit_b == s_b { PatMatchResult.matched } else { PatMatchResult.no_match }
            case _ => PatMatchResult.no_match
        }
        case .unit => match scrutinee {
            case .unit_ => PatMatchResult.matched
            case _ => PatMatchResult.no_match
        }
        case .str(let lit_sym) => match scrutinee {
            case .string_(let s_sym) =>
                if lit_sym.raw == s_sym.raw { PatMatchResult.matched } else { PatMatchResult.no_match }
            case _ => PatMatchResult.no_match
        }
        case .int(let lit_v, _) => match_int_literal(lit_v, scrutinee)
        case .float(_) => PatMatchResult.unsupported(
            error: err_mod.ComptimeError.evaluation_failed(
                at: at,
                message: "comptime match on float literal — gated on float-literal evaluation",
            ),
        )
    }
}

function match_int_literal(
    lit_v: u128,
    scrutinee: value_mod.ComptimeValue,
) -> PatMatchResult {
    let max_i64 = 9223372036854775807 as u128
    let max_u64 = 18446744073709551615 as u128
    return match scrutinee {
        case .int_signed(let s_v, _) => {
            if lit_v > max_i64 {
                PatMatchResult.no_match
            } else {
                let lit_as_i64 = lit_v as i64
                if lit_as_i64 == s_v { PatMatchResult.matched } else { PatMatchResult.no_match }
            }
        }
        case .int_unsigned(let s_v, _) => {
            if lit_v > max_u64 {
                PatMatchResult.no_match
            } else {
                let lit_as_u64 = lit_v as u64
                if lit_as_u64 == s_v { PatMatchResult.matched } else { PatMatchResult.no_match }
            }
        }
        case _ => PatMatchResult.no_match
    }
}

function evaluate_stmt(
    stmt: hir_tree.HStmt,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    return match stmt.kind {
        case .let_(_, _, let bindings, _, let init_) =>
            evaluate_let_stmt(bindings, init_, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .uninit_(_, _, _) => failed_eval(at, "comptime body `uninit` declaration: Phase 2g+")
        case .assign(let target, let op, let rhs) =>
            evaluate_assign_stmt(target, op, rhs, mutable env, ctx, mutable sym_interner, allocator, at)?
    }
}

function evaluate_assign_stmt(
    target: hir_tree.HExpr,
    op: ast_ops.AssignOp,
    rhs: hir_tree.HExpr,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let target_def_id = match target.kind {
        case .use_(let d) => d
        case _ => return failed_eval(
            at,
            "comptime `assign` to a non-binding target (field / index / tuple lvalue) — compound-value lvalues are post-V1.0 per 04-specs-comptime.md §3.2",
        )
    }
    let rhs_result = evaluate_expr(rhs, mutable env, ctx, mutable sym_interner, allocator, at)?
    let rhs_value = match rhs_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let compute_result = match op {
        case .plain => EvalResult.ok(value: rhs_value)
        case .add => compound_assign_value(target_def_id, ast_ops.BinOp.add, rhs_value, env, at)
        case .sub => compound_assign_value(target_def_id, ast_ops.BinOp.sub, rhs_value, env, at)
        case .mul => compound_assign_value(target_def_id, ast_ops.BinOp.mul, rhs_value, env, at)
        case .div => compound_assign_value(target_def_id, ast_ops.BinOp.div, rhs_value, env, at)
        case .mod => compound_assign_value(target_def_id, ast_ops.BinOp.mod, rhs_value, env, at)
        case .bit_and => failed_eval(at, "comptime `&=` — bitwise compound assigns post-V1.0 per CLAUDE.md V1.0 decidable fragment")
        case .bit_or => failed_eval(at, "comptime `|=` — bitwise compound assigns post-V1.0 per CLAUDE.md V1.0 decidable fragment")
        case .bit_xor => failed_eval(at, "comptime `^=` — bitwise compound assigns post-V1.0 per CLAUDE.md V1.0 decidable fragment")
        case .shl => failed_eval(at, "comptime `<<=` — bitwise compound assigns post-V1.0 per CLAUDE.md V1.0 decidable fragment")
        case .shr => failed_eval(at, "comptime `>>=` — bitwise compound assigns post-V1.0 per CLAUDE.md V1.0 decidable fragment")
    }
    let assign_value = match compute_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let written = env_mod.assign_binding(mutable env, target_def_id, take assign_value)
    if !written {
        return failed_eval(
            at,
            "comptime `assign` to a binding not in env — either the variable was never declared in this scope, or the typechecker missed an assign-to-immutable rejection upstream",
        )
    }
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}

function compound_assign_value(
    target_def_id: def_mod.DefId,
    op: ast_ops.BinOp,
    rhs_value: value_mod.ComptimeValue,
    env: env_mod.ComptimeEnv,
    at: span_mod.Span,
) -> EvalResult
{
    let current_opt = env_mod.lookup(env, target_def_id)
    return match current_opt {
        case .none => failed_eval(
            at,
            "comptime compound `assign` to a binding not in env — variable was never declared in this scope",
        )
        case .some(let current) => binary_outcome_to_eval_result(
            binary_mod.apply_binary(op, current, rhs_value, at),
        )
    }
}

function evaluate_let_stmt(
    bindings: Vec_HBinding.Vec,
    init_: hir_tree.HExpr,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let init_result = evaluate_expr(init_, mutable env, ctx, mutable sym_interner, allocator, at)?
    let init_value = match init_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let n = Vec_HBinding.len(bindings)
    if n == 0 {
        return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
    }
    if n > 1 {
        return failed_eval(
            at,
            "comptime body `let` destructuring (multi-name pattern) needs pattern-vs-ComptimeValue deconstruction; Phase 2g+",
        )
    }
    let binding = Vec_HBinding.at(bindings, 0)
    env_mod.push_binding(mutable env, binding.def_id, take init_value, allocator)?
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}


function unary_outcome_to_eval_result(o: unary_mod.UnaryOutcome) -> EvalResult {
    return match o {
        case .ok(let v) => EvalResult.ok(value: v)
        case .failed(let e) => EvalResult.failed(error: e)
    }
}

function binary_outcome_to_eval_result(o: binary_mod.BinaryOutcome) -> EvalResult {
    return match o {
        case .ok(let v) => EvalResult.ok(value: v)
        case .failed(let e) => EvalResult.failed(error: e)
    }
}


function comptime_loop_budget() -> usize {
    return 1048576 as usize
}

function evaluate_loop(
    body: hir_tree.HBlock,
    label: Option_Symbol.Option,
    decreases_: Option_Box_HExpr.Option,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let _ = label
    let _ = decreases_
    let budget = comptime_loop_budget()
    var iters: usize = 0
    loop
        decreases (budget - iters)
    {
        if iters >= budget {
            return failed_eval(
                at,
                "comptime `loop` exceeded the evaluation iteration budget — a comptime-evaluated loop must terminate within a bounded number of iterations; check the loop's exit condition",
            )
        }
        let body_result = evaluate_block(body, mutable env, ctx, mutable sym_interner, allocator, at)?
        match body_result {
            case .failed(let e) => return EvalResult.failed(error: e)
            case .ok(_) => ()
        }
        match env_mod.signal_of(env) {
            case .none_ => ()
            case .continue_ => env_mod.clear_signal(mutable env)
            case .break_(let v) => {
                env_mod.clear_signal(mutable env)
                return EvalResult.ok(value: v)
            }
            case .return_(_) => return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
        }
        iters = iters + 1
    }
    return failed_eval(
        at,
        "comptime `loop` terminated without `break` or `return` (unreachable — the iteration-budget guard returns first)",
    )
}

function evaluate_break(
    label: Option_Symbol.Option,
    value_opt: Option_Box_HExpr.Option,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    match label {
        case .some(_) => return failed_eval(
            at,
            "comptime labeled `break` — only unlabeled `break` targeting the innermost loop is supported at comptime",
        )
        case .none => ()
    }
    let value = match value_opt {
        case .none => value_mod.ComptimeValue.unit_
        case .some(let box_e) => {
            let r = evaluate_expr(Box_HExpr.get(box_e), mutable env, ctx, mutable sym_interner, allocator, at)?
            match r {
                case .failed(let e) => return EvalResult.failed(error: e)
                case .ok(let v) => v
            }
        }
    }
    env_mod.set_signal(mutable env, value_mod.ControlSignal.break_(value: value))
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}

function evaluate_continue(
    label: Option_Symbol.Option,
    env: mutable env_mod.ComptimeEnv,
    at: span_mod.Span,
) -> EvalResult {
    match label {
        case .some(_) => return failed_eval(
            at,
            "comptime labeled `continue` — only unlabeled `continue` targeting the innermost loop is supported at comptime",
        )
        case .none => ()
    }
    env_mod.set_signal(mutable env, value_mod.ControlSignal.continue_)
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}

function evaluate_return(
    value_opt: Option_Box_HExpr.Option,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let value = match value_opt {
        case .none => value_mod.ComptimeValue.unit_
        case .some(let box_e) => {
            let r = evaluate_expr(Box_HExpr.get(box_e), mutable env, ctx, mutable sym_interner, allocator, at)?
            match r {
                case .failed(let e) => return EvalResult.failed(error: e)
                case .ok(let v) => v
            }
        }
    }
    env_mod.set_signal(mutable env, value_mod.ControlSignal.return_(value: value))
    return EvalResult.ok(value: value_mod.ComptimeValue.unit_)
}


function failed_eval(at: span_mod.Span, message: String) -> EvalResult {
    return EvalResult.failed(
        error: err_mod.ComptimeError.evaluation_failed(at: at, message: message),
    )
}

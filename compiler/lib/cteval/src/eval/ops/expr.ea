    return match outcome {
        case .ok(let d) => effects_of_function(d, ctx, at)
        case .wrong_arity(_) => failed_eval(at, "effects_of expects exactly 1 function argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_function => failed_eval(at, "effects_of expects a function-typed argument (a callable identifier)")
    }
}

function effects_of_function(def: def_mod.DefId, ctx: ctx_mod.EvalCtx, at: span_mod.Span) -> EvalResult {
    return match types_check_mod.signature_of(ctx.type_output, def) {
        case .some(let sig) => EvalResult.ok(value: value_mod.ComptimeValue.effect_row(row: sig.effects))
        case .none => failed_eval(at, "effects_of: function signature not found for the given DefId (upstream resolve or typecheck gap)")
    }
}

function apply_contract_hash_of(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,

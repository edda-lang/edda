import specs.error as spec_err_mod


spec std.mem.alloc.Box(hir_tree.HExpr)
spec std.mem.alloc.Box(hir_item_mod.HFnSignature)
spec std.core.option.Option(hir_item_mod.HItem)
spec std.core.option.Option(hir_tree.HBlock)
spec std.core.option.Option(hir_tree.HExpr)
spec std.core.option.Option(Box_HExpr)
spec std.core.option.Option(symbol.Symbol)
spec std.core.option.Option(cap_mod.Capability)
spec std.collections.vec.Vec(hir_tree.HArg)
spec std.collections.vec.Vec(hir_tree.HStmt)
spec std.collections.vec.Vec(hir_tree.HBinding)
spec std.collections.vec.Vec(hir_tree.HArm)
spec std.collections.vec.Vec(hir_item_mod.HParam)
spec std.collections.vec.Vec(hir_item_mod.HItem)
spec std.collections.vec.Vec(ty_mod.TyId)
spec std.collections.vec.Vec(hir_file_mod.HirFile)
spec std.core.option.Option(Vec_HirFile)
spec std.core.copy.clone(value_mod.ComptimeValue)
spec std.collections.vec.Vec(value_mod.ComptimeValue)


derive eq, debug for EvalResult


public type EvalResult {
    case ok(value: value_mod.ComptimeValue)
    case failed(error: err_mod.ComptimeError)
}

type TypeArgOutcome {
    case ok(ty: ty_mod.TyId)
    case wrong_arity(got: usize)
    case arg_eval_failed(error: err_mod.ComptimeError)
    case not_a_type
}


public function evaluate_expr(
    e: hir_tree.HExpr,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let node_at = match hir_file_mod.span_of_opt(ctx.file, e.node_id) {
        case .some(let s) => s
        case .none => if span_mod.is_dummy(at) { ctx.file.source.span } else { at }
    }
    return match e.kind {
        case .literal(let lit) => evaluate_literal(lit, sym_interner, node_at)
        case .use_(let def_id) => evaluate_use(def_id, env, ctx, node_at)
        case .ident_literal(_) =>
            failed_eval(node_at, "identifier literal is only valid as the field-name argument of `offset_of(T, field)`; it carries no comptime value of its own (the `offset_of` handler reads it directly without evaluating it)")

        case .unary(let op, let inner_box) =>
            evaluate_unary_recursive(op, inner_box, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .binary(let op, let lhs_box, let rhs_box) =>
            evaluate_binary_recursive(op, lhs_box, rhs_box, mutable env, ctx, mutable sym_interner, allocator, node_at)?

        case .call(let callee, let args) =>
            evaluate_call(callee, args, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .dyn_call(_, _) => evaluate_dyn_call_rejected(node_at)
        case .method_call(_, _) =>
            failed_eval(node_at, "method-call expression at comptime — receiver-based dispatch is not wired into the comptime evaluator; the V1.0 comptime surface dispatches builtins and user functions via direct `call` only")

        case .if_(let cond_box, let then_block, let else_block) =>
            evaluate_if(cond_box, then_block, else_block, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .block_(let body) =>
            evaluate_block(body, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .match_(let scrutinee_box, let arms) =>
            evaluate_match(scrutinee_box, arms, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .loop_(let body, let label, let decreases_) =>
            evaluate_loop(body, label, decreases_, mutable env, ctx, mutable sym_interner, allocator, node_at)?

        case .comptime_(let inner_box) =>
            evaluate_expr(Box_HExpr.get(inner_box), mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .comptime_block(let body) =>
            evaluate_block(body, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .comptime_for(_, _, _, _, _) =>
            failed_eval(node_at, "comptime `for` is unrolled by the per-instance comptime-expansion phase (compile.instantiate.unroll) before typecheck; it carries no value in expression-position evaluation")

        case .tuple(_) =>
            failed_eval(node_at, "tuple comptime value — compound comptime values (records, variants, lists) reserved for post-V1.0 per 04-specs-comptime.md §3.2")
        case .struct_lit(_, _) =>
            failed_eval(node_at, "struct-literal comptime value — compound comptime values reserved for post-V1.0 per 04-specs-comptime.md §3.2")
        case .variant_ctor(_, _, _) =>
            failed_eval(node_at, "variant-construction comptime value — compound comptime values (records, variants, lists) reserved for post-V1.0 per 04-specs-comptime.md §3.2")
        case .field(_, _) =>
            failed_eval(node_at, "field projection — requires compound-value carrier in ComptimeValue lattice (post-V1.0)")
        case .positional(_, _) =>
            failed_eval(node_at, "positional field projection — requires compound-value carrier in ComptimeValue lattice (post-V1.0)")
        case .index(_, _) =>
            failed_eval(node_at, "index expression — slice/array values not in the ComptimeValue lattice (post-V1.0)")
        case .subrange(_, _, _, _) =>
            failed_eval(node_at, "subrange expression — slice/array values not in the ComptimeValue lattice (post-V1.0)")
        case .range(_, _, _) =>
            failed_eval(node_at, "range expression — range values not in the ComptimeValue lattice (post-V1.0)")

        case .cast(_, _, _) =>
            failed_eval(node_at, "comptime cast — value-level cast dispatch (trapping/wrapping/saturating/checked) not yet wired; Phase 2g+")

        case .raise_(_) =>
            failed_eval(node_at, "comptime `raise` reached — function should have been rejected by purity check (`err: T` not in comptime envelope); upstream pass-through")
        case .panic_(_) =>
            failed_eval(node_at, "comptime `panic` triggered — comptime panic surfaces as a compile error per codex §3.3 (admitted but signals invariant violation)")
        case .return_(let value_box) =>
            evaluate_return(value_box, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .break_(let label, let value_box) =>
            evaluate_break(label, value_box, mutable env, ctx, mutable sym_interner, allocator, node_at)?
        case .continue_(let label) =>
            evaluate_continue(label, mutable env, node_at)

        case .scope_(_, _, _) =>
            failed_eval(node_at, "`scope(...)` form not admissible at comptime — concurrent / coherence forms require runtime executors")
        case .handle_(_, _, _, _) =>
            failed_eval(node_at, "effect `handle` not admissible at comptime — handlers operate over runtime effect rows")

        case .closure(_) =>
            failed_eval(node_at, "closure literal as a comptime value — closure MIR lowering (capture-env + lifted body) not yet wired")
        case .spawn_(_) =>
            failed_eval(node_at, "spawn expression as a comptime value — concurrent spawn cannot execute at compile time")

        case .forall_(_, _, _) =>
            failed_eval(node_at, "bounded `forall` admissible only in refinement positions (where / requires / ensures); reaching it here means the predicate escaped its refinement scope")
        case .exists_(_, _, _) =>
            failed_eval(node_at, "bounded `exists` admissible only in refinement positions (where / requires / ensures); reaching it here means the predicate escaped its refinement scope")

        case .error =>
            failed_eval(node_at, "expression is the parser/lowering recovery sentinel — underlying syntax/lowering diagnostic is upstream")
    }
}


function evaluate_literal(lit: hir_tree.HLiteral, sym_interner: symbol_interner_mod.Interner, at: span_mod.Span) -> EvalResult {
    return match lit {
        case .bool(let v) =>
            EvalResult.ok(value: value_mod.ComptimeValue.bool_(value: v))
        case .unit =>
            EvalResult.ok(value: value_mod.ComptimeValue.unit_)
        case .int(let v, _) => evaluate_int_literal(v, at)
        case .float(let sym, _) => evaluate_float_literal(sym, sym_interner, at)
        case .str(let sym) =>
            EvalResult.ok(value: value_mod.ComptimeValue.string_(value: sym))
    }
}

function evaluate_float_literal(sym: symbol.Symbol, sym_interner: symbol_interner_mod.Interner, at: span_mod.Span) -> EvalResult {
    if (sym.raw as usize) >= symbol_interner_mod.slot_count(sym_interner) {
        return failed_eval(at, "float literal symbol out of range for the lex-time interner (upstream invariant violation)")
    }
    let bytes = symbol_interner_mod.lookup(sym_interner, sym)
    return handle err: str.ParseFloatError as _e -> failed_eval(at, "invalid float literal — lexer produced bytes that std.text.str.parse_f64 rejected") {
        let v = str.parse_f64(bytes)?
        EvalResult.ok(value: value_mod.ComptimeValue.float_f64(value: v))
    }
}

function evaluate_int_literal(value: u128, at: span_mod.Span) -> EvalResult {
    let max_i64 = 9223372036854775807 as u128
    if value > max_i64 {
        return failed_eval(at, "128-bit literal not yet wired in comptime evaluator (value exceeds i64 range)")
    }
    return EvalResult.ok(
        value: value_mod.ComptimeValue.int_signed(
            value: value as i64,
            width: value_mod.IntWidth.w64,
        ),
    )
}


function evaluate_unary_recursive(
    op: ast_ops.UnOp,
    inner_box: Box_HExpr.Box,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let inner = Box_HExpr.get(inner_box)
    let inner_result = evaluate_expr(inner, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match inner_result {
        case .failed(let e) => EvalResult.failed(error: e)
        case .ok(let v) => {
            let outcome = unary_mod.apply_unary(op, v, at)
            unary_outcome_to_eval_result(outcome)
        }
    }
}


function evaluate_binary_recursive(
    op: ast_ops.BinOp,
    lhs_box: Box_HExpr.Box,
    rhs_box: Box_HExpr.Box,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let lhs = Box_HExpr.get(lhs_box)
    let lhs_result = evaluate_expr(lhs, mutable env, ctx, mutable sym_interner, allocator, at)?
    let lv = match lhs_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let rhs = Box_HExpr.get(rhs_box)
    let rhs_result = evaluate_expr(rhs, mutable env, ctx, mutable sym_interner, allocator, at)?
    let rv = match rhs_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => v
    }
    let outcome = binary_mod.apply_binary(op, lv, rv, at)
    return binary_outcome_to_eval_result(outcome)
}


function evaluate_use(
    def_id: def_mod.DefId,
    env: env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    at: span_mod.Span,
) -> EvalResult {
    if def_id.raw == 0 {
        return failed_eval(
            at,
            "unresolved path in comptime context — resolver / typecheck pass produced an error sentinel for this site; underlying diagnostic is upstream",
        )
    }
    let env_opt = env_mod.lookup(env, def_id)
    match env_opt {
        case .some(let v) => return EvalResult.ok(value: v)
        case .none => ()
    }
    let prim_opt = types_check_mod.prim_def_id_to_ty_id(ctx.type_output, def_id)
    match prim_opt {
        case .some(let t) => return EvalResult.ok(value: value_mod.ComptimeValue.type_meta(ty: t))
        case .none => ()
    }
    let cap_opt = types_check_mod.cap_def_id_to_ty_id(ctx.type_output, def_id)
    match cap_opt {
        case .some(let t) => return EvalResult.ok(value: value_mod.ComptimeValue.type_meta(ty: t))
        case .none => ()
    }
    let user_opt = types_check_mod.type_id_of_def(ctx.type_output, def_id)
    match user_opt {
        case .some(let t) => return EvalResult.ok(value: value_mod.ComptimeValue.type_meta(ty: t))
        case .none => ()
    }
    let sig_opt = types_check_mod.signature_of(ctx.type_output, def_id)
    match sig_opt {
        case .some(_) => return EvalResult.ok(value: value_mod.ComptimeValue.function_meta(def: def_id))
        case .none => ()
    }
    return failed_eval(
        at,
        "use_(def_id) is not bound in env, not a primitive type, not a user-declared type, and not a function item — likely a module-meta carrier (lands alongside spec-monomorphisation wiring)",
    )
}


function evaluate_call(
    callee: def_mod.DefId,
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    if callee.raw == 0 {
        return failed_eval(
            at,
            "unresolved callee in comptime context (likely a comptime builtin function name whose evaluation is not yet wired)",
        )
    }
    let tag_opt = registry_mod.classify(ctx.builtin_registry, callee)
    return match tag_opt {
        case .some(let tag) => dispatch_builtin(tag, args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .none => call_user_function(callee, args, mutable env, ctx, mutable sym_interner, allocator, at)?
    }
}

function dispatch_builtin(
    tag: registry_mod.BuiltinTag,
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    return match tag {
        case .size_of => apply_size_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .align_of => apply_align_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_signed => apply_is_signed(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_unsigned => apply_is_unsigned(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_integer => apply_is_integer(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_floating => apply_is_floating(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_numeric => apply_is_numeric(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_primitive => apply_is_primitive(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_sum => apply_is_sum(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_copy => apply_is_copy(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .is_container => apply_is_container(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .offset_of => apply_offset_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .field_count => apply_field_count(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .field_name_at => apply_field_name_at(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .field_type_at => apply_field_type_at(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .target_has => apply_target_has(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .target_supports => apply_target_supports(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .parameters_of => apply_parameters_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .effects_of => apply_effects_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .refinements_of => failed_eval(at, "builtin `refinements_of(F)` — requires code-quotation primitives (multi-stage programming surface) to carry predicate ASTs as comptime values; pending the codex design lock")
        case .contract_hash_of => apply_contract_hash_of(args, mutable env, ctx, mutable sym_interner, allocator, at)?
        case .pattern_of => failed_eval(at, "builtin `pattern_of(item)` — pending the spec-origin back-pointer on generated HItems (requires lib/specs's monomorphisation pass landing); per codex §4.4 `pattern_of` reports the qualified name of the spec that produced an item, not a doc-line marker")
    }
}


function extract_single_type_arg(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> TypeArgOutcome
    with {divergence, allocator, err: alloc.AllocError}
{
    let n = Vec_HArg.len(args)
    if n != 1 {
        return TypeArgOutcome.wrong_arity(got: n)
    }
    let arg = Vec_HArg.at(args, 0)
    let arg_result = evaluate_expr(arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match arg_result {
        case .failed(let e) => TypeArgOutcome.arg_eval_failed(error: e)
        case .ok(let v) => match v {
            case .type_meta(let t) => TypeArgOutcome.ok(ty: t)
            case _ => TypeArgOutcome.not_a_type
        }
    }
}


function apply_size_of(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_type_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t) => layout_result_to_eval_result(layout_mod.size_of(t, ctx.ty_interner, ctx.type_output, ctx.triple), at)
        case .wrong_arity(_) => failed_eval(at, "size_of expects exactly 1 Type argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_type => failed_eval(at, "size_of expects a Type argument")
    }
}

function apply_field_type_at(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_type_and_index_args(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t, let i) => field_type_to_eval_result(layout_mod.field_type_at(t, i, ctx.ty_interner, ctx.type_output), at)
        case .wrong_arity(_) => failed_eval(at, "field_type_at expects exactly 2 arguments: (Type, usize)")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .first_not_a_type => failed_eval(at, "field_type_at first argument must be a Type")
        case .second_not_a_usize => failed_eval(at, "field_type_at second argument must be a non-negative integer")
    }
}

function field_type_to_eval_result(r: layout_mod.FieldTypeResult, at: span_mod.Span) -> EvalResult {
    return match r {
        case .ok(let elem_ty) => EvalResult.ok(
            value: value_mod.ComptimeValue.type_meta(ty: elem_ty),
        )
        case .out_of_range(_, _) => failed_eval(at, "field_type_at: index out of range for the type's field count")
        case .unsupported(let msg) => failed_eval(at, msg)
    }
}

function apply_offset_of(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let n = Vec_HArg.len(args)
    if n != (2 as usize) {
        return failed_eval(at, "offset_of expects exactly 2 arguments: (Type, field-name identifier)")
    }
    let type_arg = Vec_HArg.at(args, 0)
    let ty_result = evaluate_expr(type_arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    let t = match ty_result {
        case .failed(let e) => return EvalResult.failed(error: e)
        case .ok(let v) => match v {
            case .type_meta(let tt) => tt
            case _ => return failed_eval(at, "offset_of first argument must be a Type")
        }
    }
    let field_arg = Vec_HArg.at(args, 1)
    let field_name = match field_arg.expr.kind {
        case .ident_literal(let name) => name
        case _ => return failed_eval(at, "offset_of second argument must be a literal field name (e.g. offset_of(Point, x)); the field name must be a single identifier")
    }
    return layout_result_to_eval_result(layout_mod.offset_of(t, field_name, ctx.ty_interner, ctx.type_output, ctx.triple), at)
}

type TwoArgsOutcome {
    case ok(ty: ty_mod.TyId, idx: usize)
    case wrong_arity(got: usize)
    case arg_eval_failed(error: err_mod.ComptimeError)
    case first_not_a_type
    case second_not_a_usize
}

function extract_type_and_index_args(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> TwoArgsOutcome
    with {divergence, allocator, err: alloc.AllocError}
{
    let n = Vec_HArg.len(args)
    if n != 2 {
        return TwoArgsOutcome.wrong_arity(got: n)
    }
    let ty_arg = Vec_HArg.at(args, 0)
    let idx_arg = Vec_HArg.at(args, 1)
    let ty_result = evaluate_expr(ty_arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    let ty = match ty_result {
        case .failed(let e) => return TwoArgsOutcome.arg_eval_failed(error: e)
        case .ok(let v) => match v {
            case .type_meta(let t) => t
            case _ => return TwoArgsOutcome.first_not_a_type
        }
    }
    let idx_result = evaluate_expr(idx_arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    let idx = match idx_result {
        case .failed(let e) => return TwoArgsOutcome.arg_eval_failed(error: e)
        case .ok(let v) => match v {
            case .int_signed(let s_v, _) => {
                if s_v < 0 {
                    return TwoArgsOutcome.second_not_a_usize
                }
                s_v as usize
            }
            case .int_unsigned(let u_v, _) => u_v as usize
            case _ => return TwoArgsOutcome.second_not_a_usize
        }
    }
    return TwoArgsOutcome.ok(ty: ty, idx: idx)
}

function apply_field_count(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_type_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t) => layout_result_to_eval_result(layout_mod.field_count(t, ctx.ty_interner, ctx.type_output), at)
        case .wrong_arity(_) => failed_eval(at, "field_count expects exactly 1 Type argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_type => failed_eval(at, "field_count expects a Type argument")
    }
}

function apply_field_name_at(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_type_and_index_args(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t, let i) => field_name_to_eval_result(layout_mod.field_name_at(t, i, ctx.ty_interner, ctx.type_output), at)
        case .wrong_arity(_) => failed_eval(at, "field_name_at expects exactly 2 arguments: (Type, usize)")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .first_not_a_type => failed_eval(at, "field_name_at first argument must be a Type")
        case .second_not_a_usize => failed_eval(at, "field_name_at second argument must be a non-negative integer")
    }
}

function field_name_to_eval_result(r: layout_mod.FieldNameResult, at: span_mod.Span) -> EvalResult {
    return match r {
        case .ok(let sym) => EvalResult.ok(
            value: value_mod.ComptimeValue.string_(value: sym),
        )
        case .out_of_range(_, _) => failed_eval(at, "field_name_at: index out of range for the type's field count")
        case .unsupported(let msg) => failed_eval(at, msg)
    }
}


type StringArgOutcome {
    case ok(sym: symbol.Symbol)
    case wrong_arity(got: usize)
    case arg_eval_failed(error: err_mod.ComptimeError)
    case not_a_string
}

function extract_single_string_arg(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> StringArgOutcome
    with {divergence, allocator, err: alloc.AllocError}
{
    let n = Vec_HArg.len(args)
    if n != 1 {
        return StringArgOutcome.wrong_arity(got: n)
    }
    let arg = Vec_HArg.at(args, 0)
    let arg_result = evaluate_expr(arg.expr, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match arg_result {
        case .failed(let e) => StringArgOutcome.arg_eval_failed(error: e)
        case .ok(let v) => match v {
            case .string_(let sym) => StringArgOutcome.ok(sym: sym)
            case _ => StringArgOutcome.not_a_string
        }
    }
}

function apply_target_has(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_string_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let sym) => target_has_via_symbol(sym, sym_interner, ctx, at)
        case .wrong_arity(_) => failed_eval(at, "target_has expects exactly 1 String argument naming a target feature flag")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_string => failed_eval(at, "target_has expects a String argument naming a target feature flag")
    }
}

function target_has_via_symbol(sym: symbol.Symbol, sym_interner: symbol_interner_mod.Interner, ctx: ctx_mod.EvalCtx, at: span_mod.Span) -> EvalResult {
    if (sym.raw as usize) >= symbol_interner_mod.slot_count(sym_interner) {
        return failed_eval(at, "target_has: feature-name symbol out of range for the lex-time interner (upstream invariant violation)")
    }
    let bytes = symbol_interner_mod.lookup(sym_interner, sym)
    let feature = string.from_owned_utf8(take bytes)
    return gate_result_to_eval_result(target_builtin_mod.has(feature, ctx.triple), at)
}


type FunctionArgOutcome {

    return match outcome {
        case .ok(let d) => contract_hash_of_function(d, ctx, mutable sym_interner, allocator, at)?
        case .wrong_arity(_) => failed_eval(at, "contract_hash_of expects exactly 1 function argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_function => failed_eval(at, "contract_hash_of expects a function-typed argument (a callable identifier)")
    }
}

function contract_hash_of_function(
    def: def_mod.DefId,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let fnsig = match types_check_mod.signature_of(ctx.type_output, def) {
        case .some(let s) => s
        case .none => return failed_eval(at, "contract_hash_of: typecheck signature not found for the given DefId (upstream resolve or typecheck gap)")
    }
    let name = match find_hitem_by_def(def, ctx.file) {
        case .none => return failed_eval(at, "contract_hash_of: function DefId not found in current file (upstream resolve or cross-file lookup gap)")
        case .some(let item) => match item.kind {
            case .function_(let sig_box, _) => Box_HFnSignature.get(sig_box).name
            case .function_extern(let sig_box, _, _, _) => Box_HFnSignature.get(sig_box).name
            case _ => return failed_eval(at, "contract_hash_of: DefId does not resolve to a function item")
        }
    }
    return handle err: spec_err_mod.SpecError as _e -> failed_eval(at, "contract_hash_of: the signature references a composite type or a capability / typed-effect (`err:` / `yield:`) row entry the Phase-1 spec surface-encoder does not yet encode; coverage extends with the encoder walker phase") {
        let hash = specs_sig_mod.surface_of(fnsig, name, at, ctx.ty_interner, ctx.effect_interner, sym_interner, allocator)?
        let hex = specs_hash_mod.to_hex(hash, allocator)?
        let sym = symbol_interner_mod.intern(mutable sym_interner, hex, allocator)?
        EvalResult.ok(value: value_mod.ComptimeValue.string_(value: sym))
    }
}

function apply_parameters_of(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_function_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let d) => parameters_of_function(d, ctx, allocator, at)?
        case .wrong_arity(_) => failed_eval(at, "parameters_of expects exactly 1 function argument")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_function => failed_eval(at, "parameters_of expects a function-typed argument (a callable identifier)")
    }
}

function parameters_of_function(
    def: def_mod.DefId,
    ctx: ctx_mod.EvalCtx,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    return match find_hitem_by_def(def, ctx.file) {
        case .none => failed_eval(at, "parameters_of: function DefId not found in current file (upstream resolve or cross-file lookup gap)")
        case .some(let item) => match item.kind {
            case .function_(let sig_box, _) =>
                build_parameter_list(Box_HFnSignature.get(sig_box), def, ctx, allocator, at)?
            case .function_extern(let sig_box, _, _, _) =>
                build_parameter_list(Box_HFnSignature.get(sig_box), def, ctx, allocator, at)?
            case _ => failed_eval(at, "parameters_of: DefId does not resolve to a function item")
        }
    }
}

function build_parameter_list(
    hsig: hir_item_mod.HFnSignature,
    def: def_mod.DefId,
    ctx: ctx_mod.EvalCtx,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let opt_fnsig = types_check_mod.signature_of(ctx.type_output, def)
    let fnsig = match opt_fnsig {
        case .some(let s) => s
        case .none =>
            return failed_eval(at, "parameters_of: typecheck signature not found for the given DefId (upstream resolve or typecheck gap)")
    }
    let hparam_count = Vec_HParam.len(hsig.params)
    let ty_param_count = Vec_TyId.len(fnsig.params)
    if hparam_count != ty_param_count {
        return failed_eval(at, "parameters_of: HFnSignature/FnSig parameter-count divergence (upstream typecheck/HIR mismatch)")
    }
    uninit items: Vec_ComptimeValue.Vec
    Vec_ComptimeValue.new(init items, allocator)?
    var i: usize = 0
    loop
        decreases (hparam_count - i)
    {
        if i >= hparam_count {
            break
        }
        let hparam = Vec_HParam.at(hsig.params, i)
        let pty = Vec_TyId.at(fnsig.params, i)
        let pmeta = value_mod.ComptimeValue.parameter_meta(
            name: hparam.name,
            ty: pty,
            mode: hparam.mode,
        )
        Vec_ComptimeValue.push(mutable items, take pmeta, allocator)?
        i = i + 1
    }
    return EvalResult.ok(value: value_mod.ComptimeValue.list_(items: items))
}

function find_hitem_by_def(
    def: def_mod.DefId,
    file: hir_file_mod.HirFile,
) -> Option_HItem.Option
    with {divergence}
{
    let n = Vec_HItem.len(file.items)
    var i: usize = 0
    loop decreases (n - i) {
        if i >= n { break }
        let item = Vec_HItem.at(file.items, i)
        if item.def_id.raw == def.raw {
            return Option_HItem.some(value: item)
        }
        i = i + 1
    }
    return Option_HItem.none
}

function apply_target_supports(
    args: Vec_HArg.Vec,
    env: mutable env_mod.ComptimeEnv,
    ctx: ctx_mod.EvalCtx,
    sym_interner: mutable symbol_interner_mod.Interner,
    allocator: Allocator,
    at: span_mod.Span,
) -> EvalResult
    with {divergence, allocator, err: alloc.AllocError}
{
    let outcome = extract_single_type_arg(args, mutable env, ctx, mutable sym_interner, allocator, at)?
    return match outcome {
        case .ok(let t) => resolve_cap_and_query(t, ctx, at)
        case .wrong_arity(_) => failed_eval(at, "target.supports expects exactly 1 Type argument naming a locked nominal capability")
        case .arg_eval_failed(let e) => EvalResult.failed(error: e)
        case .not_a_type => failed_eval(at, "target.supports expects a Type argument naming a locked nominal capability")
    }
}

function resolve_cap_and_query(t: ty_mod.TyId, ctx: ctx_mod.EvalCtx, at: span_mod.Span) -> EvalResult
    with {divergence}
{
    return match types_check_mod.cap_of(t, ctx.ty_interner) {
        case .some(let cap) => gate_result_to_eval_result(
            target_builtin_mod.supports(cap, ctx.triple), at,
        )
        case .none => EvalResult.failed(
            error: err_mod.ComptimeError.target_supports_non_capability(
                at: at,
                ty_name: "<non-capability type>",
            ),
        )
    }
}

function gate_result_to_eval_result(r: target_builtin_mod.TargetGateResult, at: span_mod.Span) -> EvalResult {
    return match r {
        case .answered(let b) => EvalResult.ok(value: value_mod.ComptimeValue.bool_(value: b))
        case .unsupported_query(let msg) => failed_eval(at, msg)
    }
}



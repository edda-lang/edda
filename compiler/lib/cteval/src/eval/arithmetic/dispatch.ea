
module cteval.eval.arithmetic.dispatch

import span.loc.pos.span as span_mod
import syntax.ast.ops as ast_ops
import local.state.value as value_mod
import cteval.eval.arithmetic.outcome as outcome_mod
import cteval.eval.arithmetic.signed as signed_mod
import cteval.eval.arithmetic.unsigned as unsigned_mod


public function apply_arithmetic(
    op: ast_ops.BinOp,
    lv: value_mod.ComptimeValue,
    rv: value_mod.ComptimeValue,
    at: span_mod.Span,
) -> outcome_mod.ArithOutcome {
    return match lv {
        case .int_signed(let av, let width) => match rv {
            case .int_signed(let bv, _) => signed_mod.apply(op, av, bv, width, at)
            case _ => outcome_mod.failed_arith_operands(at)
        }
        case .int_unsigned(let av, let width) => match rv {
            case .int_unsigned(let bv, _) => unsigned_mod.apply(op, av, bv, width, at)
            case _ => outcome_mod.failed_arith_operands(at)
        }
        case _ => outcome_mod.failed_arith_operands(at)
    }
}

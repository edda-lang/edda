
module cteval.eval.arithmetic.outcome

import span.loc.pos.span as span_mod
import local.error as err_mod
import local.state.value as value_mod


derive eq, debug for ArithOutcome
derive eq, debug for AddishKind


public type ArithOutcome {
    case ok(value: value_mod.ComptimeValue)
    case failed(error: err_mod.ComptimeError)
}

public type AddishKind {
    case add
    case sub
    case mul
}


public function overflow_outcome(at: span_mod.Span, op_label: String) -> ArithOutcome {
    return ArithOutcome.failed(
        error: err_mod.ComptimeError.overflow(at: at, message: op_label),
    )
}

public function failed_arith_operands(at: span_mod.Span) -> ArithOutcome {
    return ArithOutcome.failed(
        error: err_mod.ComptimeError.evaluation_failed(
            at: at,
            message: "arithmetic operands must be same-kind integers",
        ),
    )
}

public function failed_arith_unsupported(at: span_mod.Span) -> ArithOutcome {
    return ArithOutcome.failed(
        error: err_mod.ComptimeError.evaluation_failed(
            at: at,
            message: "non-arithmetic BinOp reached arithmetic dispatcher",
        ),
    )
}

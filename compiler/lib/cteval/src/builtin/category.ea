
module cteval.builtin.category

import types.pass.ty as ty_mod
import types.ty.kind as ty_kind_mod
import types.ty.interner as ty_interner_mod
import types.check as types_check_mod
import hir.def as def_mod
import std.collections.vec

spec std.collections.vec.Vec(ty_mod.TyId)


public function is_signed(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(let kind) => prim_kind_is_signed(kind)
        case .refined(let base, _) => is_signed(base, ty_interner)
        case _ => false
    }
}

public function is_unsigned(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(let kind) => prim_kind_is_unsigned(kind)
        case .refined(let base, _) => is_unsigned(base, ty_interner)
        case _ => false
    }
}

public function is_integer(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(let kind) => prim_kind_is_integer(kind)
        case .refined(let base, _) => is_integer(base, ty_interner)
        case _ => false
    }
}

public function is_floating(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(let kind) => prim_kind_is_floating(kind)
        case .refined(let base, _) => is_floating(base, ty_interner)
        case _ => false
    }
}

public function is_numeric(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    return is_integer(t, ty_interner) || is_floating(t, ty_interner)
}

public function is_primitive(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(_) => true
        case .string_ => true
        case .refined(let base, _) => is_primitive(base, ty_interner)
        case _ => false
    }
}

public function is_sum(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .sum_(_) => true
        case .refined(let base, _) => is_sum(base, ty_interner)
        case _ => false
    }
}

public function is_container(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .spec_instance(_, _) => true
        case .refined(let base, _) => is_container(base, ty_interner)
        case _ => false
    }
}

public function is_copy(t: ty_mod.TyId, ty_interner: ty_interner_mod.Interner, out: types_check_mod.TypeOutput) -> bool
    with {divergence}
{
    if ty_mod.is_error(t) {
        return false
    }
    if types_check_mod.is_linear_or_affine_ty(out, t, ty_interner) {
        return false
    }
    let cty = ty_interner_mod.lookup(ty_interner, t)
    return match cty {
        case .primitive(_) => true
        case .string_ => true
        case .tuple_(let elems) => tuple_elems_are_copy(elems, ty_interner, out)
        case .record(let def) => record_fields_are_copy(def, ty_interner, out)
        case .sum_(let def) => sum_variants_are_copy(def, ty_interner, out)
        case .refined(let base, _) => is_copy(base, ty_interner, out)
        case _ => false
    }
}


function tuple_elems_are_copy(elems: Vec_TyId.Vec, ty_interner: ty_interner_mod.Interner, out: types_check_mod.TypeOutput) -> bool
    with {divergence}
{
    let n = Vec_TyId.len(elems)
    var i: usize = 0 as usize
    loop {
        if i >= n { return true }
        if !is_copy(Vec_TyId.at(elems, i), ty_interner, out) {
            return false
        }
        i = i + 1 as usize
    }
}


function record_fields_are_copy(def: def_mod.DefId, ty_interner: ty_interner_mod.Interner, out: types_check_mod.TypeOutput) -> bool
    with {divergence}
{
    let n = types_check_mod.field_ty_count(out, def)
    var i: usize = 0 as usize
    loop {
        if i >= n { return true }
        if !is_copy(types_check_mod.field_ty_at(out, def, i), ty_interner, out) {
            return false
        }
        i = i + 1 as usize
    }
}


function sum_variants_are_copy(def: def_mod.DefId, ty_interner: ty_interner_mod.Interner, out: types_check_mod.TypeOutput) -> bool
    with {divergence}
{
    let n = types_check_mod.variant_count_of(out, def)
    var i: usize = 0 as usize
    loop {
        if i >= n { return true }
        if !is_copy(types_check_mod.variant_payload_ty(out, def, i as u32), ty_interner, out) {
            return false
        }
        i = i + 1 as usize
    }
}


function prim_kind_is_signed(kind: ty_kind_mod.PrimKind) -> bool {
    return match kind {
        case .i8_ => true
        case .i16_ => true
        case .i32_ => true
        case .i64_ => true
        case .i128_ => true
        case .isize_ => true
        case _ => false
    }
}

function prim_kind_is_unsigned(kind: ty_kind_mod.PrimKind) -> bool {
    return match kind {
        case .u8_ => true
        case .u16_ => true
        case .u32_ => true
        case .u64_ => true
        case .u128_ => true
        case .usize_ => true
        case _ => false
    }
}

function prim_kind_is_integer(kind: ty_kind_mod.PrimKind) -> bool {
    return prim_kind_is_signed(kind) || prim_kind_is_unsigned(kind)
}

function prim_kind_is_floating(kind: ty_kind_mod.PrimKind) -> bool {
    return match kind {
        case .f32_ => true
        case .f64_ => true
        case _ => false
    }
}


module cteval.builtin.target.reg.target

import std.text.string as string
import target.capability as target_cap_mod
import target.triple as triple_mod
import target.os as os_mod
import target.arch as arch_mod


derive eq, debug for TargetGateResult


public type TargetGateResult {
    case answered(value: bool)
    case unsupported_query(message: String)
}


public stable function supports(
    cap: target_cap_mod.Capability,
    triple: triple_mod.TargetTriple,
) -> TargetGateResult {
    return TargetGateResult.answered(value: target_cap_mod.supports(triple, cap))
}

public function has(feature: String, triple: triple_mod.TargetTriple) -> TargetGateResult {
    let os = triple_mod.os(triple)
    if string.equals(feature, "windows")    { return TargetGateResult.answered(value: os == os_mod.Os.windows) }
    if string.equals(feature, "linux")      { return TargetGateResult.answered(value: os == os_mod.Os.linux) }
    if string.equals(feature, "macos")      { return TargetGateResult.answered(value: os == os_mod.Os.macos) }
    if string.equals(feature, "freebsd")    { return TargetGateResult.answered(value: os == os_mod.Os.freebsd) }
    if string.equals(feature, "bare-metal") { return TargetGateResult.answered(value: os == os_mod.Os.bare_metal) }
    if string.equals(feature, "wasi")       { return TargetGateResult.answered(value: os == os_mod.Os.wasi) }
    let arch = triple_mod.arch(triple)
    if string.equals(feature, "x86-64")     { return TargetGateResult.answered(value: arch == arch_mod.Arch.x86_64) }
    if string.equals(feature, "aarch64")    { return TargetGateResult.answered(value: arch == arch_mod.Arch.aarch64) }
    if string.equals(feature, "riscv64")    { return TargetGateResult.answered(value: arch == arch_mod.Arch.riscv64) }
    if string.equals(feature, "wasm32")     { return TargetGateResult.answered(value: arch == arch_mod.Arch.wasm32) }
    if string.equals(feature, "wasm64")     { return TargetGateResult.answered(value: arch == arch_mod.Arch.wasm64) }
    return TargetGateResult.unsupported_query(
        message: "unknown target feature flag (known: windows linux macos freebsd bare-metal wasi x86-64 aarch64 riscv64 wasm32 wasm64)",
    )
}


module cteval.res.purity

import std.collections.vec
import types.pass.effect as effect_mod
import types.effect.interner as effect_interner_mod
import types.effect.row as effect_row_mod


spec std.collections.vec.Vec(effect_row_mod.CEntry)


derive eq, debug for PurityCheck


public type PurityCheck {
    case pure_
    case impure(offending_effect: String)
}


public function check_row(
    row_id: effect_mod.EffectRowId,
    row_interner: effect_interner_mod.Interner,
) -> PurityCheck {
    if effect_mod.is_empty(row_id) {
        return PurityCheck.pure_
    }
    let row = effect_interner_mod.lookup(row_interner, row_id)
    let n = Vec_CEntry.len(row.entries)
    for i in 0..<n {
        let entry = Vec_CEntry.at(row.entries, i)
        let check = check_entry(entry)
        match check {
            case .pure_ => {}
            case .impure(let offending) =>
                return PurityCheck.impure(offending_effect: offending)
        }
    }
    return PurityCheck.pure_
}


function check_entry(entry: effect_row_mod.CEntry) -> PurityCheck {
    return match entry {
        case .panic_ => PurityCheck.pure_
        case .yield_(_) => PurityCheck.pure_
        case .capability(_) => PurityCheck.impure(offending_effect: "capability")
        case .err_(_) => PurityCheck.impure(offending_effect: "err")
        case .cancellation_ => PurityCheck.impure(offending_effect: "cancellation")
        case .divergence_ => PurityCheck.impure(offending_effect: "divergence")
        case .nondet_ => PurityCheck.impure(offending_effect: "nondet")
        case .alloc_(_) => PurityCheck.impure(offending_effect: "alloc")
        case .io_(_) => PurityCheck.impure(offending_effect: "io")
        case .time_(_) => PurityCheck.impure(offending_effect: "time")
    }
}


module hir.node

derive eq, hash, ord, debug for NodeId

public type NodeId {
    raw: u32
}


public stable function error() -> NodeId
    ensures result.raw == 0
{
    return NodeId { raw: 0 }
}

public stable function is_error(n: NodeId) -> bool
    ensures result == (n.raw == 0)
{
    return n.raw == 0
}


public stable function index(n: NodeId) -> usize
    ensures result == (n.raw as usize)
{
    return n.raw as usize
}

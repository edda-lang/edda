
module query.graph.idx.key

import cache.addr.hash as hash_mod

derive clone, debug for QueryKey


public type QueryKey {
    kind: u32
    arg_hash: hash_mod.ArtifactHash
}


public function new(kind: u32, arg_hash: hash_mod.ArtifactHash) -> QueryKey {
    return QueryKey { kind: kind, arg_hash: arg_hash }
}

public function equals(a: QueryKey, b: QueryKey) -> bool {
    if a.kind != b.kind { return false }
    return hash_equals(a.arg_hash, b.arg_hash)
}

public function hash_equals(a: hash_mod.ArtifactHash, b: hash_mod.ArtifactHash) -> bool {
    return a.w0 == b.w0 && a.w1 == b.w1 && a.w2 == b.w2 && a.w3 == b.w3
}

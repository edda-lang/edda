
module query.persist.wire

import std.collections.vec
import std.mem.alloc
import cache.addr.hash as hash_mod

spec std.collections.vec.Vec(u8)


public type DecodeError {
    case bad_magic
    case schema_mismatch(found: u32, supported: u32)
    case truncated
    case integrity_mismatch
}


public function push_u8(buf: mutable Vec_u8.Vec, v: u8, allocator: Allocator) -> ()
    with {allocator, divergence, err: alloc.AllocError}
{
    Vec_u8.push(mutable buf, v, allocator)?
}

public function push_u32_be(buf: mutable Vec_u8.Vec, v: u32, allocator: Allocator) -> ()
    with {allocator, divergence, err: alloc.AllocError}
{
    Vec_u8.push(mutable buf, ((v >> 24) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 16) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 8) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, (v & 255) as u8, allocator)?
}

public function push_u64_be(buf: mutable Vec_u8.Vec, v: u64, allocator: Allocator) -> ()
    with {allocator, divergence, err: alloc.AllocError}
{
    Vec_u8.push(mutable buf, ((v >> 56) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 48) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 40) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 32) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 24) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 16) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, ((v >> 8) & 255) as u8, allocator)?
    Vec_u8.push(mutable buf, (v & 255) as u8, allocator)?
}

public function push_hash_be(buf: mutable Vec_u8.Vec, h: hash_mod.ArtifactHash, allocator: Allocator) -> ()
    with {allocator, divergence, err: alloc.AllocError}
{
    push_u64_be(mutable buf, h.w0, allocator)?
    push_u64_be(mutable buf, h.w1, allocator)?
    push_u64_be(mutable buf, h.w2, allocator)?
    push_u64_be(mutable buf, h.w3, allocator)?
}


public function read_u8(bytes: [u8], pos: usize) -> (u8, usize)
    with {err: DecodeError}
{
    if pos + 1 > bytes.len() { raise DecodeError.truncated }
    return (bytes[pos], pos + 1)
}

public function read_u32_be(bytes: [u8], pos: usize) -> (u32, usize)
    with {err: DecodeError}
{
    if pos + 4 > bytes.len() { raise DecodeError.truncated }
    let v: u32 = ((bytes[pos] as u32) << 24)
               | ((bytes[pos + 1] as u32) << 16)
               | ((bytes[pos + 2] as u32) << 8)
               |  (bytes[pos + 3] as u32)
    return (v, pos + 4)
}

public function read_u64_be(bytes: [u8], pos: usize) -> (u64, usize)
    with {err: DecodeError}
{
    if pos + 8 > bytes.len() { raise DecodeError.truncated }
    let v: u64 = ((bytes[pos] as u64) << 56)
               | ((bytes[pos + 1] as u64) << 48)
               | ((bytes[pos + 2] as u64) << 40)
               | ((bytes[pos + 3] as u64) << 32)
               | ((bytes[pos + 4] as u64) << 24)
               | ((bytes[pos + 5] as u64) << 16)
               | ((bytes[pos + 6] as u64) << 8)
               |  (bytes[pos + 7] as u64)
    return (v, pos + 8)
}

public function read_hash_be(bytes: [u8], pos: usize) -> (hash_mod.ArtifactHash, usize)
    with {err: DecodeError}
{
    let r0 = read_u64_be(bytes, pos)?
    let r1 = read_u64_be(bytes, r0.1)?
    let r2 = read_u64_be(bytes, r1.1)?
    let r3 = read_u64_be(bytes, r2.1)?
    let h = hash_mod.ArtifactHash { w0: r0.0, w1: r1.0, w2: r2.0, w3: r3.0 }
    return (h, r3.1)
}

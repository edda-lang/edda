module linear_handle.main

import std.io.stream

linear type FileHandle {
    fd: i32
}

public function open(fs: Filesystem, path: String) -> FileHandle
    with {fs, err: stream.IoError}
extern "edda_example_file_open"

public function read_all(h: mutable FileHandle, fs: Filesystem) -> [u8]
    with {fs}
extern "edda_example_file_read_all"

public function close(h: take FileHandle, fs: Filesystem) -> ()
    with {fs}
extern "edda_example_file_close"

public function read_with_close(fs: Filesystem, path: String) -> [u8]
    with {fs, err: stream.IoError}
{
    var h = open(fs, path)?
    let data = read_all(mutable h, fs)
    close(take h, fs)
    return data
}

public function open_and_close(fs: Filesystem, path: String) -> ()
    with {fs, err: stream.IoError}
{
    let h = open(fs, path)?
    close(take h, fs)
}

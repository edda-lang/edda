module decimal_parser.main

import std.os.fs
import std.io.stream
import local.error
import local.parser

public function main(rfs: ReadOnlyFilesystem, out: Stdout, allocator: Allocator) -> ()
    with {
        rfs,
        out,
        allocator,
        err: fs.FsError,
        err: error.ParseError,
    }
{
    let bytes = fs.read_bytes(rfs, "input.txt", allocator)?
    let n = parser.parse_i32(bytes)?
    out.print_line(f"parsed: {n}")
}

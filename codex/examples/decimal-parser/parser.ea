module decimal_parser.parser

import local.error

public function parse_i32(input: [u8]) -> i32
    with {err: error.ParseError}
{
    if input.len() == 0 {
        raise error.ParseError.empty_input
    }

    var pos: usize = 0
    var negative: bool = false
    if input[0] == 0x2D {
        negative = true
        pos = 1
    } else if input[0] == 0x2B {
        pos = 1
    }

    if pos >= input.len() {
        raise error.ParseError.unexpected_char(at: pos, byte: 0)
    }

    var value: i32 = 0
    loop decreases (input.len() - pos) {
        if pos >= input.len() {
            break
        }
        let b = input[pos]
        if b < 0x30 || b > 0x39 {
            raise error.ParseError.unexpected_char(at: pos, byte: b)
        }
        if value > 214_748_363 {
            raise error.ParseError.overflow(at: pos)
        }
        let digit = (b - 0x30) as i32
        value = value * 10 + digit
        pos += 1
    }

    return if negative { -value } else { value }
}

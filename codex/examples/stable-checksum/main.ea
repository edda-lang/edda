module stable_checksum.main

public stable function fletcher16(bytes: [u8]) -> u16 {
    var sum1: u16 = 0
    var sum2: u16 = 0
    for b in bytes {
        sum1 = (sum1 + (b as u16)) % 255
        sum2 = (sum2 + sum1) % 255
    }
    return (sum2 << 8) | sum1
}

public stable function checksum_mix(a: [u8], b: [u8]) -> u16 {
    let ca = fletcher16(a)
    let cb = fletcher16(b)
    return ca ^ cb
}

public stable function checksum_equal(x: u16, y: u16) -> bool {
    return x == y
}

module clamp_and_classify.main

public type Grade {
    case a
    case b
    case c
    case d
    case f
}

public function clamp(value: i32, lo: i32, hi: i32) -> i32
    requires hi >= lo
    ensures  result >= lo
    ensures  result <= hi
{
    if value < lo {
        return lo
    } else if value > hi {
        return hi
    } else {
        return value
    }
}

public function classify(score: i32 where score >= 0 && score <= 100) -> Grade {
    if score >= 90 {
        return Grade.a
    } else if score >= 80 {
        return Grade.b
    } else if score >= 70 {
        return Grade.c
    } else if score >= 60 {
        return Grade.d
    } else {
        return Grade.f
    }
}

public function demote(g: Grade) -> Grade {
    return match g {
        case .a => Grade.b
        case .b => Grade.c
        case .c => Grade.d
        case .d => Grade.f
        case .f => Grade.f
    }
}

public function promote(g: Grade) -> Grade {
    return match g {
        case .f => Grade.d
        case .d => Grade.c
        case .c => Grade.b
        case .b => Grade.a
        case .a => Grade.a
    }
}

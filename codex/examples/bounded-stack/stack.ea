module bounded_stack.stack

import std.mem.alloc as alloc

spec std.mem.alloc.Array(i64)

public type IntStack {
    capacity: usize
    len: usize where len <= capacity
    data: [i64] where data.len() == capacity
}

public function int_stack_init(out: init IntStack, cap: usize, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let raw = Array_i64.alloc(allocator, cap)?
    out = IntStack { capacity: cap, len: 0, data: raw }
}

public function int_stack_push(stack: mutable IntStack, item: i64) -> ()
    with {panic}
    requires stack.len <= stack.capacity
    ensures  stack.len <= stack.capacity
{
    if stack.len == stack.capacity {
        panic("int_stack_push to full stack")
    }
    stack.data[stack.len] = item
    stack.len += 1
}

public function int_stack_pop(stack: mutable IntStack) -> i64
    with {panic}
    requires stack.len <= stack.capacity
    ensures  stack.len <= stack.capacity
{
    if stack.len == 0 {
        panic("int_stack_pop from empty stack")
    }
    stack.len -= 1
    return stack.data[stack.len]
}

public function int_stack_peek(stack: IntStack) -> i64
    with {panic}
    requires stack.len <= stack.capacity
{
    if stack.len == 0 {
        panic("int_stack_peek on empty stack")
    }
    return stack.data[stack.len - 1]
}

public function int_stack_len(stack: IntStack) -> usize
    requires stack.len <= stack.capacity
    ensures  result <= stack.capacity
{
    return stack.len
}

public function int_stack_is_empty(stack: IntStack) -> bool {
    return stack.len == 0
}

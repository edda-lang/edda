module bounded_stack.main

import std.mem.alloc as alloc
import local.stack

public function sum_through_stack(n: usize, allocator: Allocator) -> i64
    with {allocator, err: alloc.AllocError, panic}
    requires n < 1_000_000
{
    uninit s: stack.IntStack
    stack.int_stack_init(init s, n, allocator)?

    for i in 1..=n {
        stack.int_stack_push(mutable s, i as i64)
    }

    var total: i64 = 0
    for _ in 0..<n {
        total += stack.int_stack_pop(mutable s)
    }
    return total
}

public function gauss_sum(n: usize) -> i64
    requires n < 1_000_000
{
    let nn = n as i64
    return nn * (nn + 1) / 2
}

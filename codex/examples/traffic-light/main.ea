module traffic_light.main

public type Phase {
    case red
    case green
    case yellow(seconds_remaining: i32 where seconds_remaining >= 0)
}

public type Event {
    case timer_tick
    case pedestrian_press
    case emergency_override
}

public function step(phase: Phase, event: Event) -> Phase {
    return match (phase, event) {
        case (_, .emergency_override) => Phase.red

        case (.green, .pedestrian_press) => Phase.yellow(seconds_remaining: 3)

        case (.red, .timer_tick)   => Phase.green
        case (.green, .timer_tick) => Phase.yellow(seconds_remaining: 3)

        case (.yellow(let s), .timer_tick) where s > 0 =>
            Phase.yellow(seconds_remaining: s - 1)
        case (.yellow(_), .timer_tick) => Phase.red

        case (.red, .pedestrian_press)       => phase
        case (.yellow(_), .pedestrian_press) => phase
    }
}

public function is_go(phase: Phase) -> bool {
    return match phase {
        case .red       => false
        case .green     => true
        case .yellow(_) => true
    }
}

public function must_stop(phase: Phase) -> bool {
    return match phase {
        case .red       => true
        case .green     => false
        case .yellow(_) => false
    }
}

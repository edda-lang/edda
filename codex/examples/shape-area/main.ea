module shape_area.main

public function pi() -> f64 {
    return 3.14159265358979
}

public type Shape {
    case circle(radius: f64 where radius >= 0.0)
    case rectangle(width: f64 where width >= 0.0, height: f64 where height >= 0.0)
    case square(side: f64 where side >= 0.0)
}

public function area(s: Shape) -> f64 {
    return match s {
        case .circle(let r)           => pi() * r * r
        case .rectangle(let w, let h) => w * h
        case .square(let side)        => side * side
    }
}

public function perimeter(s: Shape) -> f64 {
    return match s {
        case .circle(let r)           => 2.0 * pi() * r
        case .rectangle(let w, let h) => 2.0 * (w + h)
        case .square(let side)        => 4.0 * side
    }
}

public function same_area(a: Shape, b: Shape) -> bool {
    return area(a) == area(b)
}

public function scale(s: Shape, k: f64 where k >= 0.0) -> Shape {
    return match s {
        case .circle(let r)           => Shape.circle(radius: r * k)
        case .rectangle(let w, let h) => Shape.rectangle(width: w * k, height: h * k)
        case .square(let side)        => Shape.square(side: side * k)
    }
}

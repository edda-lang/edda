module derive_eq_hash.main

import std.mem.alloc as alloc

public type Point {
    x: i32
    y: i32
}

derive eq, hash, debug for Point

public function points_equal(a: Point, b: Point) -> bool {
    return eq_Point.eq(a, b)
}

public function hash_respects_equality(a: Point, b: Point) -> bool
    requires eq_Point.eq(a, b)
    ensures result == true
{
    return hash_Point.hash(a) == hash_Point.hash(b)
}

public function point_to_string(p: Point, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return f"Point(x={p.x}, y={p.y})"
}

{
  "name": "vscode-edda",
  "displayName": "Edda Language Support",
  "description": "Syntax highlighting and the bundled \"Edda Default\" color theme for the Edda programming language.",
  "version": "0.2.0",
  "publisher": "edda-lang",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "contributes": {
    "languages": [
      {
        "id": "edda",
        "aliases": ["Edda", "edda"],
        "extensions": [".ea"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "edda",
        "scopeName": "source.ea",
        "path": "./syntaxes/edda.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Edda Default",
        "uiTheme": "vs-dark",
        "path": "./themes/edda-default-color-theme.json"
      }
    ]
  }
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Edda",
  "scopeName": "source.ea",
  "fileTypes": ["ea"],
  "patterns": [
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#effect-row" },
    { "include": "#spec-invocation" },
    { "include": "#spec-declaration" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#import-statement" },
    { "include": "#module-statement" },
    { "include": "#stability" },
    { "include": "#cast-mode" },
    { "include": "#handle-effect" },
    { "include": "#scope-kind" },
    { "include": "#keywords-diverging" },
    { "include": "#keywords-mode" },
    { "include": "#keywords-concurrency" },
    { "include": "#keywords-cast" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-refinement" },
    { "include": "#keywords-quantifier" },
    { "include": "#keywords-effect-row-bare" },
    { "include": "#keyword-result" },
    { "include": "#literals-boolean" },
    { "include": "#literal-unit" },
    { "include": "#types-bottom" },
    { "include": "#types-primitive" },
    { "include": "#types-capability-builtin" },
    { "include": "#types-builtin-other" },
    { "include": "#types-user" },
    { "include": "#postfix-await" },
    { "include": "#variant-constructor" },
    { "include": "#method-call" },
    { "include": "#member-access" },
    { "include": "#function-call" },
    { "include": "#operators-arithmetic-explicit" },
    { "include": "#postfix-error-propagate" },
    { "include": "#operators-range" },
    { "include": "#operators-arrow" },
    { "include": "#operators-comparison" },
    { "include": "#operators-equality" },
    { "include": "#operators-logical" },
    { "include": "#operators-shift" },
    { "include": "#operators-bitwise" },
    { "include": "#operators-arithmetic" },
    { "include": "#operators-assignment" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "strings": {
      "patterns": [
        { "include": "#string-triple" },
        { "include": "#string-interpolated" },
        { "include": "#string-plain" }
      ]
    },

    "string-triple": {
      "name": "string.quoted.triple.ea",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.ea" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.ea" }
      },
      "patterns": [
        { "include": "#string-escape" }
      ]
    },

    "string-plain": {
      "name": "string.quoted.double.ea",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.ea" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.ea" }
      },
      "patterns": [
        { "include": "#string-escape" }
      ]
    },

    "string-interpolated": {
      "name": "string.quoted.double.interpolated.ea",
      "begin": "(f)(\")",
      "end": "\"",
      "beginCaptures": {
        "1": { "name": "storage.type.string.interpolation.ea" },
        "2": { "name": "punctuation.definition.string.begin.ea" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.ea" }
      },
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation-slot" }
      ]
    },

    "string-escape": {
      "name": "constant.character.escape.ea",
      "match": "\\\\(.|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]{1,6}\\})"
    },

    "string-interpolation-slot": {
      "name": "meta.interpolation.ea",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.ea" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.ea" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ea",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.ea",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.hex.ea",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.ea",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.ea",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.integer.ea",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.attribute.ea",
          "match": "@(layout|align|repr|abi|unverified|trust|deprecated|property|target_requires)\\b"
        },
        {
          "name": "invalid.illegal.attribute.ea",
          "match": "@[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "effect-row": {
      "name": "meta.effect-row.ea",
      "begin": "\\b(with|captures)\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.other.effect-row.ea" },
        "2": { "name": "punctuation.section.effect-row.begin.ea" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.effect-row.end.ea" }
      },
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(\\.)\\s*([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.ea" },
            "2": { "name": "punctuation.accessor.ea" },
            "3": { "name": "entity.name.type.error.ea" }
          }
        },
        {
          "match": "\\b(err|panic|yield|cancellation|divergence|nondet|alloc|io|time)\\b",
          "name": "keyword.other.effect.ea"
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.error.ea"
        },
        { "include": "#numbers" },
        {
          "match": "<=|>=",
          "name": "keyword.operator.comparison.ea"
        },
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.parameter.capability.ea"
        },
        {
          "match": ":",
          "name": "punctuation.separator.effect.ea"
        },
        {
          "match": ",",
          "name": "punctuation.separator.row.ea"
        },
        {
          "match": "\\(|\\)",
          "name": "punctuation.section.paren.ea"
        }
      ]
    },

    "spec-invocation": {
      "match": "\\b(spec)\\s+([a-z_][a-zA-Z0-9_]*(?:\\.[a-z_][a-zA-Z0-9_]*)*)(\\.)([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.spec.ea" },
        "2": { "name": "entity.name.namespace.ea" },
        "3": { "name": "punctuation.accessor.ea" },
        "4": { "name": "entity.name.type.ea" }
      }
    },

    "spec-declaration": {
      "match": "\\b(spec)\\s+([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.spec.ea" },
        "2": { "name": "entity.name.type.ea" }
      }
    },

    "function-declaration": {
      "match": "\\b(function)\\s+([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.function.ea" },
        "2": { "name": "entity.name.function.ea" }
      }
    },

    "type-declaration": {
      "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.ea" },
        "2": { "name": "entity.name.type.ea" }
      }
    },

    "import-statement": {
      "match": "\\b(import)\\s+([a-z_][a-zA-Z0-9_]*(?:\\s*\\.\\s*[a-z_][a-zA-Z0-9_]*)*)",
      "captures": {
        "1": { "name": "keyword.declaration.import.ea" },
        "2": { "name": "entity.name.namespace.ea" }
      }
    },

    "module-statement": {
      "match": "\\b(module)\\s+([a-z_][a-zA-Z0-9_]*(?:\\s*\\.\\s*[a-z_][a-zA-Z0-9_]*)*)",
      "captures": {
        "1": { "name": "keyword.declaration.module.ea" },
        "2": { "name": "entity.name.namespace.ea" }
      }
    },

    "stability": {
      "name": "storage.modifier.stability.ea",
      "match": "(?<![\\w.])(stable|unstable)(?=\\s+(?:function|type|public)\\b)"
    },

    "cast-mode": {
      "match": "\\b(as)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(wrapping|saturating|checked)\\b",
      "captures": {
        "1": { "name": "keyword.operator.cast.ea" },
        "2": {
          "patterns": [
            { "include": "#types-primitive" },
            { "include": "#types-builtin-other" },
            { "include": "#types-user" }
          ]
        },
        "3": { "name": "storage.modifier.cast-mode.ea" }
      }
    },

    "handle-effect": {
      "match": "\\b(handle)\\s+(err|cancellation|divergence|nondet)\\b",
      "captures": {
        "1": { "name": "keyword.control.ea" },
        "2": { "name": "keyword.other.effect.ea" }
      }
    },

    "scope-kind": {
      "match": "\\b(scope)\\s*(\\()\\s*(exec|coherence)\\s*(\\))",
      "captures": {
        "1": { "name": "keyword.control.concurrency.ea" },
        "2": { "name": "punctuation.section.paren.ea" },
        "3": { "name": "constant.language.scope-kind.ea" },
        "4": { "name": "punctuation.section.paren.ea" }
      }
    },

    "keywords-diverging": {
      "name": "keyword.control.diverging.ea",
      "match": "\\b(raise|panic)\\b"
    },

    "keywords-mode": {
      "name": "storage.modifier.mode.ea",
      "match": "(?<![\\w.])(mutable|take|init)\\b"
    },

    "keywords-concurrency": {
      "name": "keyword.control.concurrency.ea",
      "match": "\\b(scope)\\b"
    },

    "keywords-cast": {
      "name": "keyword.operator.cast.ea",
      "match": "\\b(as)\\b"
    },

    "keywords-control": {
      "name": "keyword.control.ea",
      "match": "\\b(return|match|case|if|else|loop|for|in|break|continue|handle)\\b"
    },

    "keywords-declaration": {
      "name": "keyword.declaration.ea",
      "match": "\\b(function|type|spec|module|import|public|let|var|uninit|comptime|derive|extern|linear|affine)\\b"
    },

    "keywords-refinement": {
      "name": "keyword.other.refinement.ea",
      "match": "\\b(where|requires|ensures|decreases|provides)\\b"
    },

    "keywords-quantifier": {
      "name": "keyword.other.quantifier.ea",
      "match": "\\b(forall|exists)\\b"
    },

    "keywords-effect-row-bare": {
      "name": "keyword.other.effect-row.ea",
      "match": "\\b(with|captures)\\b"
    },

    "keyword-result": {
      "name": "variable.language.result.ea",
      "match": "\\b(result)\\b"
    },

    "literals-boolean": {
      "name": "constant.language.boolean.ea",
      "match": "\\b(true|false)\\b"
    },

    "literal-unit": {
      "name": "constant.language.unit.ea",
      "match": "(?<![\\w)\\]])\\(\\)"
    },

    "types-bottom": {
      "name": "support.type.bottom.ea",
      "match": "\\b(never)\\b"
    },

    "types-primitive": {
      "name": "support.type.primitive.ea",
      "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|isize|usize|f32|f64|bool)\\b"
    },

    "types-capability-builtin": {
      "name": "support.class.capability.builtin.ea",
      "match": "\\b(Filesystem|ReadOnlyFilesystem|SandboxedFilesystem|Network|LocalhostNetwork|RestrictedNetwork|Clock|MonotonicClock|Random|DeterministicRandom|Allocator|BoundedAllocator|Executor|Stdin|Stdout|Stderr|Subprocess|Debugger)\\b"
    },

    "types-builtin-other": {
      "name": "support.class.builtin.ea",
      "match": "\\b(String|Codepoint|Type|HeapPtr)\\b"
    },

    "types-user": {
      "name": "entity.name.type.ea",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "postfix-await": {
      "match": "(\\.)(await)\\b",
      "captures": {
        "1": { "name": "punctuation.accessor.ea" },
        "2": { "name": "keyword.operator.await.ea" }
      }
    },

    "variant-constructor": {
      "match": "(?<![\\w)\\]])(\\.)([a-z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "punctuation.accessor.ea" },
        "2": { "name": "variable.other.enummember.ea" }
      }
    },

    "method-call": {
      "match": "(\\.)([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "punctuation.accessor.ea" },
        "2": { "name": "entity.name.function.method.ea" }
      }
    },

    "member-access": {
      "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "punctuation.accessor.ea" },
        "2": { "name": "variable.other.member.ea" }
      }
    },

    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.ea" }
      }
    },

    "operators-arithmetic-explicit": {
      "name": "keyword.operator.arithmetic.explicit.ea",
      "match": "\\+%|-%|\\*%|\\+\\||-\\||\\*\\||\\+\\?|-\\?|\\*\\?|%\\?"
    },

    "postfix-error-propagate": {
      "name": "keyword.operator.error-propagate.ea",
      "match": "\\?"
    },

    "operators-range": {
      "name": "keyword.operator.range.ea",
      "match": "\\.\\.<|\\.\\.=|\\.\\."
    },

    "operators-arrow": {
      "name": "keyword.operator.arrow.ea",
      "match": "->|=>"
    },

    "operators-comparison": {
      "name": "keyword.operator.comparison.ea",
      "match": "<=|>=|<(?![<=])|>(?![>=])"
    },

    "operators-equality": {
      "name": "keyword.operator.equality.ea",
      "match": "==|!="
    },

    "operators-logical": {
      "name": "keyword.operator.logical.ea",
      "match": "&&|\\|\\||!(?!=)"
    },

    "operators-shift": {
      "name": "keyword.operator.bitwise.shift.ea",
      "match": "<<|>>"
    },

    "operators-bitwise": {
      "name": "keyword.operator.bitwise.ea",
      "match": "&(?!&)|\\|(?!\\|)|\\^|~"
    },

    "operators-arithmetic": {
      "name": "keyword.operator.arithmetic.ea",
      "match": "\\+|-(?!>)|\\*|/|%"
    },

    "operators-assignment": {
      "name": "keyword.operator.assignment.ea",
      "match": "=(?![=>])"
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.brace.ea", "match": "\\{|\\}" },
        { "name": "punctuation.section.bracket.ea", "match": "\\[|\\]" },
        { "name": "punctuation.section.paren.ea", "match": "\\(|\\)" },
        { "name": "punctuation.separator.comma.ea", "match": "," },
        { "name": "punctuation.separator.colon.ea", "match": ":" }
      ]
    }

  }
}

{
  "name": "Edda Default",
  "type": "dark",
  "semanticHighlighting": false,
  "colors": {
    "editor.background": "#2e3440",
    "editor.foreground": "#d8dee9",
    "editorLineNumber.foreground": "#4c566a",
    "editorLineNumber.activeForeground": "#a3b1c2",
    "editor.selectionBackground": "#434c5e",
    "editor.lineHighlightBackground": "#343b48",
    "editorCursor.foreground": "#d8dee9",
    "editorWhitespace.foreground": "#3b4252",
    "editorIndentGuide.background": "#3b4252",
    "editorIndentGuide.activeBackground": "#4c566a"
  },
  "tokenColors": [

    {
      "name": "Strings (sage)",
      "scope": [
        "string.quoted.double.ea",
        "string.quoted.double.interpolated.ea",
        "string.quoted.triple.ea"
      ],
      "settings": {
        "foreground": "#a3be8c"
      }
    },
    {
      "name": "f-string prefix",
      "scope": "storage.type.string.interpolation.ea",
      "settings": {
        "foreground": "#b48ead",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String escapes (muted thunder)",
      "scope": "constant.character.escape.ea",
      "settings": {
        "foreground": "#d4b870"
      }
    },
    {
      "name": "String interpolation braces",
      "scope": [
        "punctuation.section.interpolation.begin.ea",
        "punctuation.section.interpolation.end.ea"
      ],
      "settings": {
        "foreground": "#b48ead",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Numbers (pale frost-green)",
      "scope": [
        "constant.numeric.integer.ea",
        "constant.numeric.float.ea",
        "constant.numeric.hex.ea",
        "constant.numeric.binary.ea",
        "constant.numeric.octal.ea"
      ],
      "settings": {
        "foreground": "#b3d6b0"
      }
    },
    {
      "name": "Boolean and unit literals (frost-blue)",
      "scope": [
        "constant.language.boolean.ea",
        "constant.language.unit.ea"
      ],
      "settings": {
        "foreground": "#81a1c1"
      }
    },

    {
      "name": "Attributes — closed whitelist of nine (aurora-cyan)",
      "scope": "storage.modifier.attribute.ea",
      "settings": {
        "foreground": "#a8e0e8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Unknown attribute — hard error (mjolnir red)",
      "scope": "invalid.illegal.attribute.ea",
      "settings": {
        "foreground": "#d4525c",
        "fontStyle": "bold underline"
      }
    },

    {
      "name": "Declaration keywords (twilight purple)",
      "scope": [
        "keyword.declaration.ea",
        "keyword.declaration.function.ea",
        "keyword.declaration.type.ea",
        "keyword.declaration.spec.ea",
        "keyword.declaration.import.ea",
        "keyword.declaration.module.ea"
      ],
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "name": "Control-flow keywords (twilight purple)",
      "scope": "keyword.control.ea",
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "name": "Refinement and quantifier keywords — where / requires / ensures / decreases / provides / forall / exists",
      "scope": [
        "keyword.other.refinement.ea",
        "keyword.other.quantifier.ea"
      ],
      "settings": {
        "foreground": "#b48ead",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Cast operator (as) and explicit cast modes",
      "scope": [
        "keyword.operator.cast.ea",
        "storage.modifier.cast-mode.ea"
      ],
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "name": "Effect-row keywords — with / captures (twilight purple, plain — the row body carries the load)",
      "scope": "keyword.other.effect-row.ea",
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "name": "Stability soft-keywords — stable / unstable (aurora-cyan)",
      "scope": "storage.modifier.stability.ea",
      "settings": {
        "foreground": "#a8e0e8",
        "fontStyle": "bold"
      }
    },

    {
      "name": "raise / panic (mjolnir red, originator)",
      "scope": "keyword.control.diverging.ea",
      "settings": {
        "foreground": "#d4525c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Effect kinds — err / panic / yield / cancellation / divergence / nondet / graded (thunder yellow, originator)",
      "scope": "keyword.other.effect.ea",
      "settings": {
        "foreground": "#f0c860",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Postfix ? error propagation (thunder yellow, propagator)",
      "scope": "keyword.operator.error-propagate.ea",
      "settings": {
        "foreground": "#f0c860"
      }
    },
    {
      "name": "Explicit-mode arithmetic — wrapping / saturating / checked (muted thunder)",
      "scope": "keyword.operator.arithmetic.explicit.ea",
      "settings": {
        "foreground": "#d4b870"
      }
    },

    {
      "name": "Mode keywords — mutable / take / init (heather rose, originator)",
      "scope": "storage.modifier.mode.ea",
      "settings": {
        "foreground": "#c885a8",
        "fontStyle": "bold"
      }
    },

    {
      "name": "scope keyword and scope kind — exec / coherence (ice-blue)",
      "scope": [
        "keyword.control.concurrency.ea",
        "constant.language.scope-kind.ea"
      ],
      "settings": {
        "foreground": "#7eb1d0"
      }
    },
    {
      "name": "Postfix .await (ice-blue)",
      "scope": "keyword.operator.await.ea",
      "settings": {
        "foreground": "#7eb1d0"
      }
    },

    {
      "name": "result — reserved return-value binding inside ensures (frost-blue, italic)",
      "scope": "variable.language.result.ea",
      "settings": {
        "foreground": "#81a1c1",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Capability params in effect row (forge ember, active privilege use)",
      "scope": "variable.parameter.capability.ea",
      "settings": {
        "foreground": "#e89060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Capability builtin types (hearth amber, static description)",
      "scope": "support.class.capability.builtin.ea",
      "settings": {
        "foreground": "#d4a060"
      }
    },

    {
      "name": "never type (pale mjolnir, the unreachable wound)",
      "scope": "support.type.bottom.ea",
      "settings": {
        "foreground": "#c46e76"
      }
    },
    {
      "name": "Primitive types (frost-teal)",
      "scope": "support.type.primitive.ea",
      "settings": {
        "foreground": "#8fbcbb"
      }
    },
    {
      "name": "Built-in non-capability types — String / Codepoint / Type (frost-cyan)",
      "scope": "support.class.builtin.ea",
      "settings": {
        "foreground": "#88c0d0"
      }
    },
    {
      "name": "User types (frost-cyan)",
      "scope": [
        "entity.name.type.ea",
        "entity.name.type.error.ea"
      ],
      "settings": {
        "foreground": "#88c0d0"
      }
    },

    {
      "name": "Function names — declaration (frost-deep)",
      "scope": "entity.name.function.ea",
      "settings": {
        "foreground": "#5e81ac"
      }
    },
    {
      "name": "Function names — call site (frost-deep)",
      "scope": "entity.name.function.call.ea",
      "settings": {
        "foreground": "#5e81ac"
      }
    },
    {
      "name": "Method names (frost-deep)",
      "scope": "entity.name.function.method.ea",
      "settings": {
        "foreground": "#5e81ac"
      }
    },

    {
      "name": "Sum-variant constructors — dot-prefixed (frost-blue)",
      "scope": "variable.other.enummember.ea",
      "settings": {
        "foreground": "#81a1c1"
      }
    },
    {
      "name": "Member / field access (frost-blue)",
      "scope": "variable.other.member.ea",
      "settings": {
        "foreground": "#81a1c1"
      }
    },
    {
      "name": "Namespace (module / import / spec paths, frost-blue)",
      "scope": "entity.name.namespace.ea",
      "settings": {
        "foreground": "#81a1c1"
      }
    },

    {
      "name": "Operators — comparison, equality, logical, bitwise, arithmetic, assignment, range (snow)",
      "scope": [
        "keyword.operator.comparison.ea",
        "keyword.operator.equality.ea",
        "keyword.operator.logical.ea",
        "keyword.operator.bitwise.ea",
        "keyword.operator.bitwise.shift.ea",
        "keyword.operator.arithmetic.ea",
        "keyword.operator.assignment.ea",
        "keyword.operator.range.ea"
      ],
      "settings": {
        "foreground": "#d8dee9"
      }
    },
    {
      "name": "Arrows -> and => (twilight purple, grammar)",
      "scope": "keyword.operator.arrow.ea",
      "settings": {
        "foreground": "#b48ead"
      }
    },

    {
      "name": "Accessor dot",
      "scope": "punctuation.accessor.ea",
      "settings": {
        "foreground": "#d8dee9"
      }
    },
    {
      "name": "Punctuation — braces, brackets, parens, separators",
      "scope": [
        "punctuation.section.brace.ea",
        "punctuation.section.bracket.ea",
        "punctuation.section.paren.ea",
        "punctuation.section.effect-row.begin.ea",
        "punctuation.section.effect-row.end.ea",
        "punctuation.separator.comma.ea",
        "punctuation.separator.colon.ea",
        "punctuation.separator.row.ea",
        "punctuation.separator.effect.ea",
        "punctuation.definition.string.begin.ea",
        "punctuation.definition.string.end.ea"
      ],
      "settings": {
        "foreground": "#d8dee9"
      }
    }

  ]
}

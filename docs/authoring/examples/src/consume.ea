module authoring.consume

import local.option

spec authoring.option.Option(i64)

public function first_positive(xs: [i64]) -> Option_i64.Option {
    for x in xs {
        if x > 0 {
            return Option_i64.Option.some(x)
        }
    }
    return Option_i64.Option.none
}

public function value_or_zero(opt: take Option_i64.Option) -> i64 {
    return Option_i64.unwrap_or(take opt, 0)
}

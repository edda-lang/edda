module authoring.tree

import std.mem.alloc
import std.core.option

spec std.mem.alloc.Box(TreeNode)
spec std.core.option.Option(Box_TreeNode.Box)

public type TreeNode {
    value: i64
    left: Option_Box_TreeNode_Box.Option
    right: Option_Box_TreeNode_Box.Option
}

public function leaf(value: i64) -> TreeNode {
    return TreeNode {
        value: value,
        left: Option_Box_TreeNode_Box.Option.none,
        right: Option_Box_TreeNode_Box.Option.none,
    }
}

public function branch(value: i64, left: take TreeNode, right: take TreeNode, allocator: Allocator) -> TreeNode
    with {allocator, err: alloc.AllocError}
{
    let boxed_left = Box_TreeNode.new(take left, allocator)?
    let boxed_right = Box_TreeNode.new(take right, allocator)?
    return TreeNode {
        value: value,
        left: Option_Box_TreeNode_Box.Option.some(value: boxed_left),
        right: Option_Box_TreeNode_Box.Option.some(value: boxed_right),
    }
}

public function count(t: TreeNode, fuel: usize) -> usize
    decreases fuel
{
    if fuel == 0 {
        return 0
    }
    let left_count: usize = match t.left {
        case .some(let b) => count(Box_TreeNode.get(b), fuel - 1)
        case .none        => 0
    }
    let right_count: usize = match t.right {
        case .some(let b) => count(Box_TreeNode.get(b), fuel - 1)
        case .none        => 0
    }
    return 1 +| left_count +| right_count
}

spec std.mem.alloc.Box(Chain)
spec std.mem.alloc.Box(Link)

public type Chain {
    tag: i64
    next: Box_Link
}

public type Link {
    weight: f64
    back: Box_Chain
}

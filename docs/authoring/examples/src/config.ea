module authoring.config

import std.os.fs

public function read_config(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> String
    with {rfs, allocator, err: fs.FsError}
    requires path.len() > 0
{
    return fs.read_to_string(rfs, path, allocator)?
}

public function read_scoped(wfs: Filesystem, name: String, allocator: Allocator) -> String
    with {wfs, allocator, err: fs.FsError}
    requires name.len() > 0
{
    let rfs = fs.read_only(wfs)
    let scoped = fs.scoped_to(rfs, "/etc/app")
    return read_config(scoped, name, allocator)?
}

public function read_or_default(rfs: ReadOnlyFilesystem, path: String, fallback: String, allocator: Allocator) -> String
    with {rfs, allocator}
    requires path.len() > 0
{
    return handle err: fs.FsError as e -> fallback {
        read_config(rfs, path, allocator)?
    }
}

module authoring.option

public spec Option(comptime T: Type) {

    public type Option {
        case some(T)
        case none
    }

    public function is_some(opt: Option) -> bool {
        return match opt {
            case .some(_) => true
            case .none    => false
        }
    }

    public function is_none(opt: Option) -> bool {
        return match opt {
            case .some(_) => false
            case .none    => true
        }
    }

    public function unwrap(opt: take Option) -> T with {panic} {
        return match opt {
            case .some(let value) => value
            case .none            => panic("Option.unwrap called on .none")
        }
    }

    public function unwrap_or(opt: take Option, fallback: take T) -> T {
        return match opt {
            case .some(let value) => value
            case .none            => fallback
        }
    }
}

module linalg.vec3

import std.math.float


public type Vec3 {
    x: f64
    y: f64
    z: f64
}

public function vec3(x: f64, y: f64, z: f64) -> Vec3 {
    return Vec3 { x: x, y: y, z: z }
}

public function zero() -> Vec3 {
    return Vec3 { x: 0.0, y: 0.0, z: 0.0 }
}

public function splat(s: f64) -> Vec3 {
    return Vec3 { x: s, y: s, z: s }
}

public function add(a: Vec3, b: Vec3) -> Vec3 {
    return Vec3 { x: a.x + b.x, y: a.y + b.y, z: a.z + b.z }
}

public function sub(a: Vec3, b: Vec3) -> Vec3 {
    return Vec3 { x: a.x - b.x, y: a.y - b.y, z: a.z - b.z }
}

public function scale(v: Vec3, s: f64) -> Vec3 {
    return Vec3 { x: v.x * s, y: v.y * s, z: v.z * s }
}

public function neg(v: Vec3) -> Vec3 {
    return Vec3 { x: 0.0 - v.x, y: 0.0 - v.y, z: 0.0 - v.z }
}

public function dot(a: Vec3, b: Vec3) -> f64 {
    return a.x * b.x + a.y * b.y + a.z * b.z
}

public function cross(a: Vec3, b: Vec3) -> Vec3 {
    return Vec3 { x: a.y * b.z - a.z * b.y, y: a.z * b.x - a.x * b.z, z: a.x * b.y - a.y * b.x }
}

public function length_sq(v: Vec3) -> f64 {
    return v.x * v.x + v.y * v.y + v.z * v.z
}

public function distance_sq(a: Vec3, b: Vec3) -> f64 {
    let dx = a.x - b.x
    let dy = a.y - b.y
    let dz = a.z - b.z
    return dx * dx + dy * dy + dz * dz
}

public function lerp(a: Vec3, b: Vec3, t: f64) -> Vec3 {
    return Vec3 { x: a.x + (b.x - a.x) * t, y: a.y + (b.y - a.y) * t, z: a.z + (b.z - a.z) * t }
}

public function length(v: Vec3) -> f64 {
    return float.sqrt_f64(length_sq(v))
}

public function distance(a: Vec3, b: Vec3) -> f64 {
    return float.sqrt_f64(distance_sq(a, b))
}

public function normalize(v: Vec3) -> Vec3 {
    let len = length(v)
    return if len != 0.0 { scale(v, 1.0 / len) } else { zero() }
}

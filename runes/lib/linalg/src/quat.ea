module linalg.quat

import std.math.float
import local.vec3
import local.mat4


public type Quat {
    x: f64
    y: f64
    z: f64
    w: f64
}

public function identity() -> Quat {
    return Quat { x: 0.0, y: 0.0, z: 0.0, w: 1.0 }
}

public function dot(a: Quat, b: Quat) -> f64 {
    return a.x * b.x + a.y * b.y + a.z * b.z + a.w * b.w
}

public function length(q: Quat) -> f64 {
    return float.sqrt_f64(dot(q, q))
}

public function normalize(q: Quat) -> Quat {
    let len = length(q)
    return if len != 0.0 {
        Quat { x: q.x / len, y: q.y / len, z: q.z / len, w: q.w / len }
    } else { identity() }
}

public function from_axis_angle(axis: vec3.Vec3, angle: f64) -> Quat {
    let n = vec3.normalize(axis)
    let half = angle * 0.5
    let s = float.sin_f64(half)
    return Quat { x: n.x * s, y: n.y * s, z: n.z * s, w: float.cos_f64(half) }
}

public function mul(a: Quat, b: Quat) -> Quat {
    return Quat {
        x: a.w * b.x + a.x * b.w + a.y * b.z - a.z * b.y,
        y: a.w * b.y - a.x * b.z + a.y * b.w + a.z * b.x,
        z: a.w * b.z + a.x * b.y - a.y * b.x + a.z * b.w,
        w: a.w * b.w - a.x * b.x - a.y * b.y - a.z * b.z
    }
}

public function slerp(a: Quat, b: Quat, t: f64) -> Quat {
    let cosom0 = dot(a, b)
    let flip = cosom0 < 0.0
    let cosom = if flip { 0.0 - cosom0 } else { cosom0 }
    let bq = if flip {
        Quat { x: 0.0 - b.x, y: 0.0 - b.y, z: 0.0 - b.z, w: 0.0 - b.w }
    } else { b }
    let sinom_sq = 1.0 - cosom * cosom
    let sinom = float.sqrt_f64(if sinom_sq > 0.0 { sinom_sq } else { 0.0 })
    return if sinom > 0.000001 {
        let omega = float.atan2_f64(sinom, cosom)
        let scale0 = float.sin_f64((1.0 - t) * omega) / sinom
        let scale1 = float.sin_f64(t * omega) / sinom
        Quat {
            x: a.x * scale0 + bq.x * scale1,
            y: a.y * scale0 + bq.y * scale1,
            z: a.z * scale0 + bq.z * scale1,
            w: a.w * scale0 + bq.w * scale1
        }
    } else {
        normalize(Quat {
            x: a.x + (bq.x - a.x) * t,
            y: a.y + (bq.y - a.y) * t,
            z: a.z + (bq.z - a.z) * t,
            w: a.w + (bq.w - a.w) * t
        })
    }
}

public function to_mat4(q: Quat) -> mat4.Mat4 {
    let xx = q.x * q.x
    let yy = q.y * q.y
    let zz = q.z * q.z
    let xy = q.x * q.y
    let xz = q.x * q.z
    let yz = q.y * q.z
    let wx = q.w * q.x
    let wy = q.w * q.y
    let wz = q.w * q.z
    return mat4.Mat4 {
        c0r0: 1.0 - 2.0 * (yy + zz),
        c0r1: 2.0 * (xy + wz),
        c0r2: 2.0 * (xz - wy),
        c0r3: 0.0,
        c1r0: 2.0 * (xy - wz),
        c1r1: 1.0 - 2.0 * (xx + zz),
        c1r2: 2.0 * (yz + wx),
        c1r3: 0.0,
        c2r0: 2.0 * (xz + wy),
        c2r1: 2.0 * (yz - wx),
        c2r2: 1.0 - 2.0 * (xx + yy),
        c2r3: 0.0,
        c3r0: 0.0, c3r1: 0.0, c3r2: 0.0, c3r3: 1.0
    }
}

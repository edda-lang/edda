
module tls.wire

import local.error

public function read_u8(buf: [u8], pos: usize) -> u8
    with {err: error.TlsError}
{
    if pos + (1 as usize) > buf.len() { raise error.TlsError.bad_record }
    return buf[pos]
}

public function read_u16_be(buf: [u8], pos: usize) -> u16
    with {err: error.TlsError}
{
    if pos + (2 as usize) > buf.len() { raise error.TlsError.bad_record }
    let hi = buf[pos] as u16
    let lo = buf[pos + (1 as usize)] as u16
    return (hi << 8) | lo
}

public function read_u24_be(buf: [u8], pos: usize) -> u32
    with {err: error.TlsError}
{
    if pos + (3 as usize) > buf.len() { raise error.TlsError.bad_record }
    let b0 = buf[pos] as u32
    let b1 = buf[pos + (1 as usize)] as u32
    let b2 = buf[pos + (2 as usize)] as u32
    return (b0 << 16) | (b1 << 8) | b2
}

public function read_u32_be(buf: [u8], pos: usize) -> u32
    with {err: error.TlsError}
{
    if pos + (4 as usize) > buf.len() { raise error.TlsError.bad_record }
    let b0 = buf[pos] as u32
    let b1 = buf[pos + (1 as usize)] as u32
    let b2 = buf[pos + (2 as usize)] as u32
    let b3 = buf[pos + (3 as usize)] as u32
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
}

public function write_u8(buf: mutable [u8], pos: usize, value: u8) -> usize
    with {err: error.TlsError}
{
    if pos + (1 as usize) > buf.len() { raise error.TlsError.bad_record }
    buf[pos] = value
    return pos + (1 as usize)
}

function _low_u16(v: u16) -> u8 {
    return (v & 0xff) as u8
}

function _low_u32(v: u32) -> u8 {
    return (v & 0xff) as u8
}

public function write_u16_be(buf: mutable [u8], pos: usize, value: u16) -> usize
    with {err: error.TlsError}
{
    if pos + (2 as usize) > buf.len() { raise error.TlsError.bad_record }
    buf[pos] = _low_u16(value >> 8)
    buf[pos + (1 as usize)] = _low_u16(value)
    return pos + (2 as usize)
}

public function write_u24_be(
    buf: mutable [u8],
    pos: usize,
    value: u32 where value <= 0xffffff as u32,
) -> usize
    with {err: error.TlsError}
{
    if pos + (3 as usize) > buf.len() { raise error.TlsError.bad_record }
    buf[pos] = _low_u32(value >> 16)
    buf[pos + (1 as usize)] = _low_u32(value >> 8)
    buf[pos + (2 as usize)] = _low_u32(value)
    return pos + (3 as usize)
}

public function write_u32_be(buf: mutable [u8], pos: usize, value: u32) -> usize
    with {err: error.TlsError}
{
    if pos + (4 as usize) > buf.len() { raise error.TlsError.bad_record }
    buf[pos] = _low_u32(value >> 24)
    buf[pos + (1 as usize)] = _low_u32(value >> 16)
    buf[pos + (2 as usize)] = _low_u32(value >> 8)
    buf[pos + (3 as usize)] = _low_u32(value)
    return pos + (4 as usize)
}

public function write_bytes(buf: mutable [u8], pos: usize, src: [u8]) -> usize
    with {err: error.TlsError}
{
    let n = src.len()
    if pos + n > buf.len() { raise error.TlsError.bad_record }
    var i: usize = 0 as usize
    loop decreases n - i {
        if i >= n { break }
        buf[pos + i] = src[i]
        i = i + (1 as usize)
    }
    return pos + n
}

public function require_remaining(buf: [u8], pos: usize, n: usize) -> ()
    with {err: error.TlsError}
{
    if pos + n > buf.len() { raise error.TlsError.bad_record }
}


module tls.handshake.extension

unstable public type ExtensionType {
    case server_name
    case max_fragment_length
    case status_request
    case supported_groups
    case signature_algorithms
    case use_srtp
    case heartbeat
    case application_layer_protocol_negotiation
    case signed_certificate_timestamp
    case client_certificate_type
    case server_certificate_type
    case padding
    case pre_shared_key
    case early_data
    case supported_versions
    case cookie
    case psk_key_exchange_modes
    case certificate_authorities
    case oid_filters
    case post_handshake_auth
    case signature_algorithms_cert
    case key_share
    case unknown(value: u16)
}

public function extension_type_wire(t: ExtensionType) -> u16 {
    return match t {
        case .server_name                            => 0 as u16
        case .max_fragment_length                    => 1 as u16
        case .status_request                         => 5 as u16
        case .supported_groups                       => 10 as u16
        case .signature_algorithms                   => 13 as u16
        case .use_srtp                               => 14 as u16
        case .heartbeat                              => 15 as u16
        case .application_layer_protocol_negotiation => 16 as u16
        case .signed_certificate_timestamp           => 18 as u16
        case .client_certificate_type                => 19 as u16
        case .server_certificate_type                => 20 as u16
        case .padding                                => 21 as u16
        case .pre_shared_key                         => 41 as u16
        case .early_data                             => 42 as u16
        case .supported_versions                     => 43 as u16
        case .cookie                                 => 44 as u16
        case .psk_key_exchange_modes                 => 45 as u16
        case .certificate_authorities                => 47 as u16
        case .oid_filters                            => 48 as u16
        case .post_handshake_auth                    => 49 as u16
        case .signature_algorithms_cert              => 50 as u16
        case .key_share                              => 51 as u16
        case .unknown(let v)                         => v
    }
}

public function extension_type_from_wire(v: u16) -> ExtensionType {
    if v == (0 as u16)  { return ExtensionType.server_name }
    if v == (1 as u16)  { return ExtensionType.max_fragment_length }
    if v == (5 as u16)  { return ExtensionType.status_request }
    if v == (10 as u16) { return ExtensionType.supported_groups }
    if v == (13 as u16) { return ExtensionType.signature_algorithms }
    if v == (14 as u16) { return ExtensionType.use_srtp }
    if v == (15 as u16) { return ExtensionType.heartbeat }
    if v == (16 as u16) { return ExtensionType.application_layer_protocol_negotiation }
    if v == (18 as u16) { return ExtensionType.signed_certificate_timestamp }
    if v == (19 as u16) { return ExtensionType.client_certificate_type }
    if v == (20 as u16) { return ExtensionType.server_certificate_type }
    if v == (21 as u16) { return ExtensionType.padding }
    if v == (41 as u16) { return ExtensionType.pre_shared_key }
    if v == (42 as u16) { return ExtensionType.early_data }
    if v == (43 as u16) { return ExtensionType.supported_versions }
    if v == (44 as u16) { return ExtensionType.cookie }
    if v == (45 as u16) { return ExtensionType.psk_key_exchange_modes }
    if v == (47 as u16) { return ExtensionType.certificate_authorities }
    if v == (48 as u16) { return ExtensionType.oid_filters }
    if v == (49 as u16) { return ExtensionType.post_handshake_auth }
    if v == (50 as u16) { return ExtensionType.signature_algorithms_cert }
    if v == (51 as u16) { return ExtensionType.key_share }
    return ExtensionType.unknown(value: v)
}


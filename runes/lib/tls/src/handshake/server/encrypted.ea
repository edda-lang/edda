
module tls.handshake.server.encrypted

import std.mem.alloc
import local.error
import local.wire
import local.handshake.kind as hs_kind
import local.handshake.message as hs_msg

public function decode_encrypted_extensions(body: [u8]) -> ()
    with {err: error.TlsError}
{
    if body.len() < (2 as usize) { raise error.TlsError.bad_handshake }
    let ext_total = wire.read_u16_be(body, 0 as usize)? as usize
    if (2 as usize) + ext_total != body.len() {
        raise error.TlsError.bad_handshake
    }
}

function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _alloc_bytes(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: error.TlsError}
{
    return handle err: alloc.AllocError -> (raise error.TlsError.out_of_memory) {
        _alloc_u8_slots(allocator, n)?
    }
}

public function encode_encrypted_extensions(allocator: Allocator) -> [u8]
    with {allocator, err: error.TlsError}
{
    let total = hs_msg.header_len() + (2 as usize)
    var buf = _alloc_bytes(allocator, total)?
    var pos = hs_msg.write_header(
        mutable buf,
        0 as usize,
        hs_kind.HandshakeKind.encrypted_extensions,
        2 as u32,
    )?
    pos = wire.write_u16_be(mutable buf, pos, 0 as u16)?
    let _ = pos
    return buf
}

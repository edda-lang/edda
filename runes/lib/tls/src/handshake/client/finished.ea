
module tls.handshake.client.finished

import std.crypto.mac.hmac.sha256 as hmac
import std.mem.alloc
import local.error
import local.handshake.kind as hs_kind
import local.handshake.message as hs_msg

function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _alloc_bytes(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: error.TlsError}
{
    return handle err: alloc.AllocError -> (raise error.TlsError.out_of_memory) {
        _alloc_u8_slots(allocator, n)?
    }
}

public function encode_finished_sha256(
    finished_key: [u8] where finished_key.len() == 32,
    transcript_hash: [u8] where transcript_hash.len() == 32,
    allocator: Allocator,
) -> [u8]
    with {allocator, err: error.TlsError}
{
    let total = hs_msg.header_len() + (32 as usize)
    var buf = _alloc_bytes(allocator, total)?
    let _ = hs_msg.write_header(
        mutable buf,
        0 as usize,
        hs_kind.HandshakeKind.finished,
        32 as u32,
    )?
    hmac.hmac_sha256(finished_key, transcript_hash, mutable buf, hs_msg.header_len())
    return buf
}

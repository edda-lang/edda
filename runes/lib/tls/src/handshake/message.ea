
module tls.handshake.message

import local.error
import local.wire
import local.handshake.kind as hs_kind

public function header_len() -> usize { return 4 as usize }

unstable public type MessageHeader {
    kind: hs_kind.HandshakeKind
    body_len: usize
}

public function write_header(
    buf: mutable [u8],
    pos: usize,
    kind: hs_kind.HandshakeKind,
    body_len: u32 where body_len <= 0xffffff as u32,
) -> usize
    with {err: error.TlsError}
{
    var p = wire.write_u8(mutable buf, pos, hs_kind.handshake_kind_wire(kind))?
    p = wire.write_u24_be(mutable buf, p, body_len)?
    return p
}

public function read_header(buf: [u8], pos: usize) -> MessageHeader
    with {err: error.TlsError}
{
    let kind = hs_kind.handshake_kind_from_wire(wire.read_u8(buf, pos)?)?
    let body_len = wire.read_u24_be(buf, pos + (1 as usize))? as usize
    return MessageHeader { kind: kind, body_len: body_len }
}

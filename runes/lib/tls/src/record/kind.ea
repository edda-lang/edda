
module tls.record.kind

import local.error

unstable public type RecordKind {
    case change_cipher_spec
    case alert
    case handshake
    case application_data
    case heartbeat
}

public function record_kind_wire(k: RecordKind) -> u8 {
    return match k {
        case .change_cipher_spec => 20 as u8
        case .alert              => 21 as u8
        case .handshake          => 22 as u8
        case .application_data   => 23 as u8
        case .heartbeat          => 24 as u8
    }
}

public function record_kind_from_wire(b: u8) -> RecordKind
    with {err: error.TlsError}
{
    if b == (20 as u8) { return RecordKind.change_cipher_spec }
    if b == (21 as u8) { return RecordKind.alert }
    if b == (22 as u8) { return RecordKind.handshake }
    if b == (23 as u8) { return RecordKind.application_data }
    if b == (24 as u8) { return RecordKind.heartbeat }
    raise error.TlsError.unexpected_message
}

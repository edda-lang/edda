
module tls.crypto.signature

import local.error

unstable public type SignatureScheme {
    case rsa_pkcs1_sha256
    case rsa_pkcs1_sha384
    case rsa_pkcs1_sha512

    case ecdsa_secp256r1_sha256
    case ecdsa_secp384r1_sha384
    case ecdsa_secp521r1_sha512

    case rsa_pss_rsae_sha256
    case rsa_pss_rsae_sha384
    case rsa_pss_rsae_sha512

    case ed25519
    case ed448

    case rsa_pss_pss_sha256
    case rsa_pss_pss_sha384
    case rsa_pss_pss_sha512
}

public function sig_scheme_wire(s: SignatureScheme) -> u16 {
    return match s {
        case .rsa_pkcs1_sha256       => 0x0401 as u16
        case .rsa_pkcs1_sha384       => 0x0501 as u16
        case .rsa_pkcs1_sha512       => 0x0601 as u16
        case .ecdsa_secp256r1_sha256 => 0x0403 as u16
        case .ecdsa_secp384r1_sha384 => 0x0503 as u16
        case .ecdsa_secp521r1_sha512 => 0x0603 as u16
        case .rsa_pss_rsae_sha256    => 0x0804 as u16
        case .rsa_pss_rsae_sha384    => 0x0805 as u16
        case .rsa_pss_rsae_sha512    => 0x0806 as u16
        case .ed25519                => 0x0807 as u16
        case .ed448                  => 0x0808 as u16
        case .rsa_pss_pss_sha256     => 0x0809 as u16
        case .rsa_pss_pss_sha384     => 0x080A as u16
        case .rsa_pss_pss_sha512     => 0x080B as u16
    }
}

public function sig_scheme_from_wire(v: u16) -> SignatureScheme
    with {err: error.TlsError}
{
    if v == (0x0804 as u16) { return SignatureScheme.rsa_pss_rsae_sha256 }
    if v == (0x0403 as u16) { return SignatureScheme.ecdsa_secp256r1_sha256 }
    if v == (0x0807 as u16) { return SignatureScheme.ed25519 }
    raise error.TlsError.unsupported_signature_algorithm
}

public function sig_scheme_is_supported(s: SignatureScheme) -> bool {
    return match s {
        case .rsa_pss_rsae_sha256    => true
        case .ecdsa_secp256r1_sha256 => true
        case .ed25519                => true
        case .rsa_pkcs1_sha256       => false
        case .rsa_pkcs1_sha384       => false
        case .rsa_pkcs1_sha512       => false
        case .ecdsa_secp384r1_sha384 => false
        case .ecdsa_secp521r1_sha512 => false
        case .rsa_pss_rsae_sha384    => false
        case .rsa_pss_rsae_sha512    => false
        case .ed448                  => false
        case .rsa_pss_pss_sha256     => false
        case .rsa_pss_pss_sha384     => false
        case .rsa_pss_pss_sha512     => false
    }
}

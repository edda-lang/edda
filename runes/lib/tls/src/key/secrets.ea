
module tls.key.secrets

import std.mem.alloc
import local.error
import local.key.schedule as schedule

unstable public type TrafficKeys {
    key: [u8]
    iv: [u8] where iv.len() == 12
}

unstable public type HandshakeSecrets {
    handshake_secret: [u8]
    client_hs_traffic: [u8]
    server_hs_traffic: [u8]
}

unstable public type AppSecrets {
    client_ap_traffic: [u8]
    server_ap_traffic: [u8]
}

function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _alloc_bytes(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: error.TlsError}
{
    return handle err: alloc.AllocError -> (raise error.TlsError.out_of_memory) {
        _alloc_u8_slots(allocator, n)?
    }
}

function _zeros32(allocator: Allocator) -> [u8]
    with {allocator, err: error.TlsError}
{
    let buf = _alloc_bytes(allocator, 32 as usize)?
    var i: usize = 0 as usize
    loop decreases (32 as usize) - i {
        if i >= (32 as usize) { break }
        buf[i] = 0 as u8
        i = i + (1 as usize)
    }
    return buf
}

public function early_secret(allocator: Allocator) -> [u8]
    with {allocator, err: error.TlsError}
{
    let zero_salt = _zeros32(allocator)?
    let zero_ikm = _zeros32(allocator)?
    var out = _alloc_bytes(allocator, 32 as usize)?
    schedule.extract_sha256(zero_salt, zero_ikm, mutable out)
    return out
}

function _derived_for(
    secret: [u8] where secret.len() == 32,
    empty_hash: [u8] where empty_hash.len() == 32,
    allocator: Allocator,
) -> [u8]
    with {allocator, err: error.TlsError}
{
    var out = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_secret(secret, schedule.label_derived(), empty_hash, mutable out)
    return out
}

public function derive_handshake_secrets(
    shared_secret: [u8],
    early: [u8] where early.len() == 32,
    empty_hash: [u8] where empty_hash.len() == 32,
    transcript_hash: [u8] where transcript_hash.len() == 32,
    allocator: Allocator,
) -> HandshakeSecrets
    with {allocator, err: error.TlsError}
{
    let derived = _derived_for(early, empty_hash, allocator)?
    var hs = _alloc_bytes(allocator, 32 as usize)?
    schedule.extract_sha256(derived, shared_secret, mutable hs)
    var c_hs = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_secret(hs, schedule.label_c_hs_traffic(), transcript_hash, mutable c_hs)
    var s_hs = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_secret(hs, schedule.label_s_hs_traffic(), transcript_hash, mutable s_hs)
    return HandshakeSecrets {
        handshake_secret: hs,
        client_hs_traffic: c_hs,
        server_hs_traffic: s_hs,
    }
}

public function derive_application_secrets(
    handshake_secret: [u8] where handshake_secret.len() == 32,
    empty_hash: [u8] where empty_hash.len() == 32,
    transcript_hash: [u8] where transcript_hash.len() == 32,
    allocator: Allocator,
) -> AppSecrets
    with {allocator, err: error.TlsError}
{
    let derived = _derived_for(handshake_secret, empty_hash, allocator)?
    let zero_ikm = _zeros32(allocator)?
    var master = _alloc_bytes(allocator, 32 as usize)?
    schedule.extract_sha256(derived, zero_ikm, mutable master)
    var c_ap = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_secret(master, schedule.label_c_ap_traffic(), transcript_hash, mutable c_ap)
    var s_ap = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_secret(master, schedule.label_s_ap_traffic(), transcript_hash, mutable s_ap)
    return AppSecrets {
        client_ap_traffic: c_ap,
        server_ap_traffic: s_ap,
    }
}

public function traffic_key_iv(
    traffic_secret: [u8] where traffic_secret.len() == 32,
    key_len: usize where key_len >= 1 && key_len <= 8160,
    allocator: Allocator,
) -> TrafficKeys
    with {allocator, err: error.TlsError}
{
    var key = _alloc_bytes(allocator, key_len)?
    var iv = _alloc_bytes(allocator, 12 as usize)?
    schedule.derive_traffic_key_iv(traffic_secret, mutable key, mutable iv)
    return TrafficKeys { key: key, iv: iv }
}

public function finished_key(
    traffic_secret: [u8] where traffic_secret.len() == 32,
    allocator: Allocator,
) -> [u8]
    with {allocator, err: error.TlsError}
{
    var fk = _alloc_bytes(allocator, 32 as usize)?
    schedule.derive_finished_key(traffic_secret, mutable fk)
    return fk
}

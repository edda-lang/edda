
module regex.engine.exec.utf8

public function decode_at(input: [u8], pos: usize) -> (u32, usize) {
    let b0 = input[pos]
    if b0 < (0x80 as u8) {
        return (b0 as u32, 1 as usize)
    }
    let n = input.len()
    if b0 < (0xC2 as u8) {
        return (b0 as u32, 1 as usize)
    }
    if b0 < (0xE0 as u8) {
        if pos + 1 as usize >= n { return (b0 as u32, 1 as usize) }
        let b1 = input[pos + 1 as usize]
        if (b1 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        let cp = ((b0 as u32) & (0x1F as u32)) << (6 as u32)
               | ((b1 as u32) & (0x3F as u32))
        return (cp, 2 as usize)
    }
    if b0 < (0xF0 as u8) {
        if pos + 2 as usize >= n { return (b0 as u32, 1 as usize) }
        let b1 = input[pos + 1 as usize]
        let b2 = input[pos + 2 as usize]
        if (b1 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        if (b2 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        let cp = ((b0 as u32) & (0x0F as u32)) << (12 as u32)
               | ((b1 as u32) & (0x3F as u32)) << (6 as u32)
               | ((b2 as u32) & (0x3F as u32))
        return (cp, 3 as usize)
    }
    if b0 < (0xF5 as u8) {
        if pos + 3 as usize >= n { return (b0 as u32, 1 as usize) }
        let b1 = input[pos + 1 as usize]
        let b2 = input[pos + 2 as usize]
        let b3 = input[pos + 3 as usize]
        if (b1 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        if (b2 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        if (b3 & (0xC0 as u8)) != (0x80 as u8) { return (b0 as u32, 1 as usize) }
        let cp = ((b0 as u32) & (0x07 as u32)) << (18 as u32)
               | ((b1 as u32) & (0x3F as u32)) << (12 as u32)
               | ((b2 as u32) & (0x3F as u32)) << (6 as u32)
               | ((b3 as u32) & (0x3F as u32))
        return (cp, 4 as usize)
    }
    return (b0 as u32, 1 as usize)
}

public function encoded_length(cp: u32) -> usize {
    if cp < (0x80 as u32)    { return 1 as usize }
    if cp < (0x800 as u32)   { return 2 as usize }
    if cp < (0x10000 as u32) { return 3 as usize }
    return 4 as usize
}

public function decode_prev(input: [u8], pos: usize) -> (u32, usize) {
    if pos == 0 as usize { return (0 as u32, 0 as usize) }
    var back: usize = 1 as usize
    loop decreases 4 as usize - back + 1 as usize {
        if back > 4 as usize { break }
        if pos < back { break }
        let b = input[pos - back]
        if (b & (0xC0 as u8)) != (0x80 as u8) {
            let (cp, len) = decode_at(input, pos - back)
            if len == back { return (cp, len) }
            return (b as u32, 1 as usize)
        }
        back = back + 1 as usize
    }
    return (input[pos - 1 as usize] as u32, 1 as usize)
}

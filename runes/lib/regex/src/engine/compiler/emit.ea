
module regex.engine.compiler.emit

import std.mem.alloc
import regex.syntax.grammar.ast
import regex.syntax.grammar.charset
import regex.syntax.grammar.mode
import regex.syntax.errors
import regex.engine.exec.program
import local.engine.compiler.alloc as compiler_alloc

spec std.mem.alloc.Box(ast.RegexAst)

public type EmitCtx {
    instructions: [program.Instruction]
    class_table: [charset.CharSet]
    instr_cursor: [u32]
    class_cursor: [u32]
    feature_flags: [u32]
}

public function push_instr(ctx: EmitCtx, ins: program.Instruction) -> u32
    with {err: errors.CompileError}
{
    let i = ctx.instr_cursor[0 as usize]
    let len = ctx.instructions.len() as u32
    if i >= len {
        raise errors.CompileError.pattern_too_long
    }
    ctx.instructions[i as usize] = ins
    ctx.instr_cursor[0 as usize] = i +% (1 as u32)
    return i
}

function _patch_jump(ctx: EmitCtx, at: u32, target: u32) -> () {
    ctx.instructions[at as usize] = program.Instruction.jump(target: target)
}

function _patch_split(ctx: EmitCtx, at: u32, a: u32, b: u32) -> () {
    ctx.instructions[at as usize] = program.Instruction.split(a: a, b: b)
}

function _push_class(ctx: EmitCtx, cs: charset.CharSet) -> u32
    with {err: errors.CompileError}
{
    let i = ctx.class_cursor[0 as usize]
    let len = ctx.class_table.len() as u32
    if i >= len {
        raise errors.CompileError.pattern_too_long
    }
    ctx.class_table[i as usize] = cs
    ctx.class_cursor[0 as usize] = i +% (1 as u32)
    return i
}

function _mark_lookaround(ctx: EmitCtx) -> () {
    ctx.feature_flags[0 as usize] = ctx.feature_flags[0 as usize] | (1 as u32)
}

function _mark_backref(ctx: EmitCtx) -> () {
    ctx.feature_flags[0 as usize] = ctx.feature_flags[0 as usize] | (2 as u32)
}

public function has_lookaround(ctx: EmitCtx) -> bool {
    return (ctx.feature_flags[0 as usize] & (1 as u32)) != 0 as u32
}

public function has_backref(ctx: EmitCtx) -> bool {
    return (ctx.feature_flags[0 as usize] & (2 as u32)) != 0 as u32
}

function _cursor(ctx: EmitCtx) -> u32 {
    return ctx.instr_cursor[0 as usize]
}

public function emit(
    node: ast.RegexAst,
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    return match node {
        case .empty => ()
        case .literal(let cp) => {
            let _ = push_instr(ctx, program.Instruction.literal(cp: cp))?
            ()
        }
        case .any_char => {
            let ins = if flags.dotall {
                program.Instruction.any
            } else {
                program.Instruction.any_no_nl
            }
            let _ = push_instr(ctx, ins)?
            ()
        }
        case .anchor_node(let a) => {
            let _ = push_instr(ctx, program.Instruction.anchor_op(kind: a))?
            ()
        }
        case .class_node(let cs) => {
            let idx = _push_class(ctx, cs)?
            let _ = push_instr(ctx, program.Instruction.class_ref(idx: idx))?
            ()
        }
        case .backref(let n) => {
            _mark_backref(ctx)
            let _ = push_instr(ctx, program.Instruction.backref_op(index: n))?
            ()
        }
        case .concat(let items) => _emit_seq(items, ctx, flags, mutable allocator)?
        case .alternate(let bs) => _emit_alt(bs, ctx, flags, mutable allocator)?
        case .repeat_node(let inner, let bnd) =>
            _emit_repeat(inner.get(), bnd, ctx, flags, mutable allocator)?
        case .group_node(let inner, let kind) =>
            _emit_group(inner.get(), kind, ctx, flags, mutable allocator)?
    }
}

function _emit_seq(
    items: [Box_RegexAst],
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    let n = items.len()
    var i: usize = 0 as usize
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        emit(items[i].get(), ctx, flags, mutable allocator)?
        i = i + 1 as usize
    }
    return ()
}

function _emit_alt(
    branches: [Box_RegexAst],
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    let k = branches.len()
    if k == 0 as usize { return () }
    if k == 1 as usize {
        emit(branches[0 as usize].get(), ctx, flags, mutable allocator)?
        return ()
    }
    let fixup_splits = compiler_alloc.alloc_u32_slots(allocator, k - 1 as usize)?
    let fixup_jumps  = compiler_alloc.alloc_u32_slots(allocator, k - 1 as usize)?
    var i: usize = 0 as usize
    loop decreases k - i + 1 as usize {
        if i >= k { break }
        if i + 1 as usize < k {
            let s = push_instr(ctx, program.Instruction.split(a: 0 as u32, b: 0 as u32))?
            fixup_splits[i] = s
            emit(branches[i].get(), ctx, flags, mutable allocator)?
            let j = push_instr(ctx, program.Instruction.jump(target: 0 as u32))?
            fixup_jumps[i] = j
        } else {
            emit(branches[i].get(), ctx, flags, mutable allocator)?
        }
        i = i + 1 as usize
    }
    let end_pc = _cursor(ctx)
    var f: usize = 0 as usize
    let m = k - 1 as usize
    loop decreases m - f + 1 as usize {
        if f >= m { break }
        let split_pc = fixup_splits[f]
        let body_pc = split_pc +% (1 as u32)
        let next_pc = if f + 1 as usize < m {
            fixup_splits[f + 1 as usize]
        } else {
            fixup_jumps[m - 1 as usize] +% (1 as u32)
        }
        _patch_split(ctx, split_pc, body_pc, next_pc)
        _patch_jump(ctx, fixup_jumps[f], end_pc)
        f = f + 1 as usize
    }
    return ()
}

function _emit_repeat(
    inner: ast.RegexAst,
    bnd: ast.RepeatBound,
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    let min_v = bnd.min
    return match bnd.max {
        case .none => _emit_unbounded(inner, min_v, bnd.lazy, ctx, flags, mutable allocator)?
        case .some(let max_v) => _emit_bounded(inner, min_v, max_v, bnd.lazy, ctx, flags, mutable allocator)?
    }
}

function _emit_unbounded(
    inner: ast.RegexAst,
    min_v: u32,
    lazy: bool,
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    var k: u32 = 0 as u32
    loop decreases (min_v as usize) - (k as usize) + 1 as usize {
        if k >= min_v { break }
        emit(inner, ctx, flags, mutable allocator)?
        k = k +% (1 as u32)
    }
    let split_pc = push_instr(ctx, program.Instruction.split(a: 0 as u32, b: 0 as u32))?
    let body_pc = _cursor(ctx)
    emit(inner, ctx, flags, mutable allocator)?
    let _ = push_instr(ctx, program.Instruction.jump(target: split_pc))?
    let exit_pc = _cursor(ctx)
    let a = if lazy { exit_pc } else { body_pc }
    let b = if lazy { body_pc } else { exit_pc }
    _patch_split(ctx, split_pc, a, b)
    return ()
}

function _emit_bounded(
    inner: ast.RegexAst,
    min_v: u32,
    max_v: u32,
    lazy: bool,
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    if max_v < min_v {
        raise errors.CompileError.bad_repeat_count(at: 0 as usize)
    }
    var k: u32 = 0 as u32
    loop decreases (min_v as usize) - (k as usize) + 1 as usize {
        if k >= min_v { break }
        emit(inner, ctx, flags, mutable allocator)?
        k = k +% (1 as u32)
    }
    let span = max_v -% min_v
    if span == 0 as u32 { return () }
    let span_us = span as usize
    let fixups = compiler_alloc.alloc_u32_slots(allocator, span_us)?
    var j: u32 = 0 as u32
    loop decreases (span as usize) - (j as usize) + 1 as usize {
        if j >= span { break }
        let s = push_instr(ctx, program.Instruction.split(a: 0 as u32, b: 0 as u32))?
        fixups[j as usize] = s
        emit(inner, ctx, flags, mutable allocator)?
        j = j +% (1 as u32)
    }
    let exit_pc = _cursor(ctx)
    var f: usize = 0 as usize
    loop decreases span_us - f + 1 as usize {
        if f >= span_us { break }
        let s_pc = fixups[f]
        let body_pc = s_pc +% (1 as u32)
        let a = if lazy { exit_pc } else { body_pc }
        let b = if lazy { body_pc } else { exit_pc }
        _patch_split(ctx, s_pc, a, b)
        f = f + 1 as usize
    }
    return ()
}

function _emit_group(
    inner: ast.RegexAst,
    kind: ast.GroupKind,
    ctx: EmitCtx,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> ()
    with {allocator, err: errors.CompileError, divergence}
{
    return match kind {
        case .capture(let idx) => {
            let start_slot = (2 as u32) *% idx
            let end_slot = start_slot +% (1 as u32)
            let _ = push_instr(ctx, program.Instruction.save(slot: start_slot))?
            emit(inner, ctx, flags, mutable allocator)?
            let _ = push_instr(ctx, program.Instruction.save(slot: end_slot))?
            ()
        }
        case .non_capturing => emit(inner, ctx, flags, mutable allocator)?
        case .lookaround(_) => {
            _mark_lookaround(ctx)
            emit(inner, ctx, flags, mutable allocator)?
            ()
        }
    }
}

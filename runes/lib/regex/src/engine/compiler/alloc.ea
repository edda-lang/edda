
module regex.engine.compiler.alloc

import std.mem.alloc
import regex.syntax.grammar.charset
import regex.syntax.errors
import regex.engine.exec.program

function _raw_instr_slots(allocator: Allocator, n: usize) -> [program.Instruction]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _raw_class_slots(allocator: Allocator, n: usize) -> [charset.CharSet]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _raw_u32_slots(allocator: Allocator, n: usize) -> [u32]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

public function alloc_instr_slots(allocator: Allocator, n: usize) -> [program.Instruction]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_instr_slots(allocator, n)?
    }
}

public function alloc_class_slots(allocator: Allocator, n: usize) -> [charset.CharSet]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_class_slots(allocator, n)?
    }
}

public function alloc_u32_slots(allocator: Allocator, n: usize) -> [u32]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_u32_slots(allocator, n)?
    }
}

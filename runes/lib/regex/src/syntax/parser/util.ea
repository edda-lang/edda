
module regex.syntax.parser.util

import std.mem.alloc
import std.text.string
import regex.syntax.grammar.ast
import regex.syntax.grammar.charset
import regex.syntax.errors

spec std.mem.alloc.Box(ast.RegexAst)


function _raw_box_slots(allocator: Allocator, n: usize) -> [Box_RegexAst]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _raw_name_slots(allocator: Allocator, n: usize) -> [ast.NamedCapture]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _raw_range_slots(allocator: Allocator, n: usize) -> [charset.CharRange]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _raw_u32_slots(allocator: Allocator, n: usize) -> [u32]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

public function bytes_to_string(b: [u8], allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return string.bytes_slice_to_string(b, 0 as usize, b.len(), allocator)?
}


public function alloc_box_slots(allocator: Allocator, n: usize) -> [Box_RegexAst]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_box_slots(allocator, n)?
    }
}

public function alloc_range_slots(allocator: Allocator, n: usize) -> [charset.CharRange]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_range_slots(allocator, n)?
    }
}

public function alloc_u32_slots(allocator: Allocator, n: usize) -> [u32]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_u32_slots(allocator, n)?
    }
}

public function alloc_name_slots(allocator: Allocator, n: usize) -> [ast.NamedCapture]
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        _raw_name_slots(allocator, n)?
    }
}

public function box_node(node: take ast.RegexAst, allocator: mutable Allocator) -> Box_RegexAst
    with {allocator, err: errors.CompileError}
{
    return handle err: alloc.AllocError -> { raise errors.CompileError.allocation_failed } {
        Box_RegexAst.new(take node, allocator)?
    }
}


public function is_digit(c: u8) -> bool {
    return c >= 48 as u8 && c <= 57 as u8
}

public function is_hex_digit(c: u8) -> bool {
    if c >= 48 as u8 && c <= 57 as u8 { return true }
    if c >= 97 as u8 && c <= 102 as u8 { return true }
    if c >= 65 as u8 && c <= 70 as u8 { return true }
    return false
}

public function hex_value(c: u8) -> u32 {
    if c >= 48 as u8 && c <= 57 as u8 { return (c - 48 as u8) as u32 }
    if c >= 97 as u8 && c <= 102 as u8 { return ((c - 97 as u8) as u32) + (10 as u32) }
    if c >= 65 as u8 && c <= 70 as u8 { return ((c - 65 as u8) as u32) + (10 as u32) }
    return 0 as u32
}

public function is_name_start(c: u8) -> bool {
    if c >= 65 as u8 && c <= 90 as u8  { return true }
    if c >= 97 as u8 && c <= 122 as u8 { return true }
    if c == 95 as u8 { return true }
    return false
}

public function is_name_continue(c: u8) -> bool {
    if c >= 48 as u8 && c <= 57 as u8  { return true }
    return is_name_start(c)
}

public function bytes_eq(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n = a.len()
    var i: usize = 0 as usize
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i = i + 1 as usize
    }
    return true
}

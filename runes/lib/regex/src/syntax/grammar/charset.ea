
module regex.syntax.grammar.charset

public type CharRange {
    lo: u32
    hi: u32
}

public type CharSet {
    ranges: [CharRange]
    negated: bool
}

public function charset_from_ranges(ranges: take [CharRange], negated: bool) -> CharSet {
    return CharSet {
        ranges: ranges,
        negated: negated,
    }
}

public function char_range(lo: u32, hi: u32) -> CharRange {
    return CharRange { lo: lo, hi: hi }
}

public function charset_contains(cs: CharSet, cp: u32) -> bool {
    let n = cs.ranges.len()
    var i: usize = 0 as usize
    var hit: bool = false
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        let r = cs.ranges[i]
        if cp >= r.lo && cp <= r.hi {
            hit = true
            break
        }
        i = i + 1 as usize
    }
    if cs.negated { return !hit }
    return hit
}

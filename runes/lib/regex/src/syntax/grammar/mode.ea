
module regex.syntax.grammar.mode

public type Flags {
    case_insensitive: bool
    multiline: bool
    dotall: bool
    extended: bool
    ungreedy: bool
}

public function default_flags() -> Flags {
    return Flags {
        case_insensitive: false,
        multiline: false,
        dotall: false,
        extended: false,
        ungreedy: false,
    }
}

public function with_case_insensitive(f: Flags, on: bool) -> Flags {
    return Flags {
        case_insensitive: on,
        multiline: f.multiline,
        dotall: f.dotall,
        extended: f.extended,
        ungreedy: f.ungreedy,
    }
}

public function with_multiline(f: Flags, on: bool) -> Flags {
    return Flags {
        case_insensitive: f.case_insensitive,
        multiline: on,
        dotall: f.dotall,
        extended: f.extended,
        ungreedy: f.ungreedy,
    }
}

public function with_dotall(f: Flags, on: bool) -> Flags {
    return Flags {
        case_insensitive: f.case_insensitive,
        multiline: f.multiline,
        dotall: on,
        extended: f.extended,
        ungreedy: f.ungreedy,
    }
}

public function with_extended(f: Flags, on: bool) -> Flags {
    return Flags {
        case_insensitive: f.case_insensitive,
        multiline: f.multiline,
        dotall: f.dotall,
        extended: on,
        ungreedy: f.ungreedy,
    }
}

public function with_ungreedy(f: Flags, on: bool) -> Flags {
    return Flags {
        case_insensitive: f.case_insensitive,
        multiline: f.multiline,
        dotall: f.dotall,
        extended: f.extended,
        ungreedy: on,
    }
}

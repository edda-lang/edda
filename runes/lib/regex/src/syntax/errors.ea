
module regex.syntax.errors

public type CompileError {
    case unexpected_end
    case unbalanced_paren(at: usize)
    case bad_class_range(at: usize)
    case unterminated_class(at: usize)
    case bad_escape(at: usize)
    case bad_hex_escape(at: usize)
    case bad_quantifier(at: usize)
    case repeat_without_atom(at: usize)
    case bad_repeat_count(at: usize)
    case bad_group_flag(at: usize)
    case unknown_perl_class(at: usize)
    case bad_unicode_class(at: usize)
    case unsupported_feature(at: usize)
    case nested_repetition(at: usize)
    case empty_alternative(at: usize)
    case too_many_captures
    case pattern_too_long
    case allocation_failed
}

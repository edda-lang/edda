
module regex.api.compile

import regex.syntax.grammar.mode
import regex.syntax.errors
import regex.syntax.parser
import regex.engine.compiler
import local.api as api_mod

public function compile_with_flags(
    pattern: String,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> api_mod.Regex
    with {allocator, err: api_mod.RegexError, divergence}
{
    return handle err: errors.CompileError -> { raise api_mod.RegexError.compile_failed(err: errors.CompileError.unexpected_end) } {
        _compile_via_path(pattern, flags, mutable allocator)?
    }
}

public function compile(
    pattern: String,
    allocator: mutable Allocator,
) -> api_mod.Regex
    with {allocator, err: api_mod.RegexError, divergence}
{
    return compile_with_flags(pattern, mode.default_flags(), mutable allocator)?
}

function _compile_via_path(
    pattern: String,
    flags: mode.Flags,
    allocator: mutable Allocator,
) -> api_mod.Regex
    with {allocator, err: errors.CompileError, divergence}
{
    let (node, num_caps, names) = parser.parse(pattern, flags, mutable allocator)?
    let prog = compiler.compile_ast(node, num_caps, flags, mutable allocator)?
    return api_mod.Regex { prog: prog, names: names }
}


module pgsql.codec.binary

import std.mem.alloc
import local.error
import local.oid.scalar as oid
import local.link.wire


function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"


function _require_len(bytes: [u8], expected: usize, type_oid: u32) -> ()
    with {err: error.EncodingError}
{
    if bytes.len() != expected {
        raise error.EncodingError.malformed_payload(oid: type_oid)
    }
}


public function encode_bool(value: bool, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 1 as usize)?
    let b: u8 = if value { 1 as u8 } else { 0 as u8 }
    let _ = wire.write_u8(mutable bytes, 0 as usize, b)?
    return bytes
}

public function decode_bool(bytes: [u8]) -> bool
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 1 as usize, oid.bool_oid())?
    let b = wire.read_u8(bytes, 0 as usize)?
    if b == (0 as u8) { return false }
    if b == (1 as u8) { return true }
    raise error.EncodingError.malformed_payload(oid: oid.bool_oid())
}


public function encode_int2(value: i16, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 2 as usize)?
    let _ = wire.write_i16_be(mutable bytes, 0 as usize, value)?
    return bytes
}

public function decode_int2(bytes: [u8]) -> i16
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 2 as usize, oid.int2_oid())?
    return wire.read_i16_be(bytes, 0 as usize)?
}


public function encode_int4(value: i32, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 4 as usize)?
    let _ = wire.write_i32_be(mutable bytes, 0 as usize, value)?
    return bytes
}

public function decode_int4(bytes: [u8]) -> i32
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 4 as usize, oid.int4_oid())?
    return wire.read_i32_be(bytes, 0 as usize)?
}


public function encode_int8(value: i64, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 8 as usize)?
    let _ = wire.write_i64_be(mutable bytes, 0 as usize, value)?
    return bytes
}

public function decode_int8(bytes: [u8]) -> i64
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 8 as usize, oid.int8_oid())?
    return wire.read_i64_be(bytes, 0 as usize)?
}


public function encode_oid(value: u32, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 4 as usize)?
    let _ = wire.write_i32_be(mutable bytes, 0 as usize, value as i32 wrapping)?
    return bytes
}

public function decode_oid(bytes: [u8]) -> u32
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 4 as usize, oid.oid_oid())?
    let raw = wire.read_i32_be(bytes, 0 as usize)?
    return raw as u32 wrapping
}


public function encode_char(value: u8, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var bytes = _alloc_u8_slots(allocator, 1 as usize)?
    let _ = wire.write_u8(mutable bytes, 0 as usize, value)?
    return bytes
}

public function decode_char(bytes: [u8]) -> u8
    with {err: error.EncodingError, err: error.ProtocolError}
{
    _require_len(bytes, 1 as usize, oid.char_oid())?
    return wire.read_u8(bytes, 0 as usize)?
}


public function encode_bytea(value: [u8]) -> [u8] {
    return value
}

public function decode_bytea(bytes: [u8]) -> [u8] {
    return bytes
}


public function encode_text(value: [u8]) -> [u8] {
    return value
}

public function decode_text(bytes: [u8]) -> [u8] {
    return bytes
}


public function encode_uuid(value: [u8]) -> [u8]
    requires value.len() == 16
{
    return value
}

public function decode_uuid(bytes: [u8]) -> [u8]
    with {err: error.EncodingError}
{
    _require_len(bytes, 16 as usize, oid.uuid_oid())?
    return bytes
}

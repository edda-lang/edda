
module pgsql.message.fe.startup

import std.mem.alloc
import local.error
import local.link.wire
import local.message.framing


public function protocol_v3_0() -> i32 { return 196608 as i32 }

public function ssl_request_code() -> i32 { return 80877103 as i32 }

public function cancel_request_code() -> i32 { return 80877102 as i32 }


public type StartupParam {
    name: [u8]
    value: [u8]
}


function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _startup_size(params: [StartupParam]) -> usize {
    var size = (9 as usize)
    let n = params.len()
    var i: usize = 0 as usize
    loop decreases n - i {
        if i >= n { break }
        size = size
            + params[i].name.len() + (1 as usize)
            + params[i].value.len() + (1 as usize)
        i = i + (1 as usize)
    }
    return size
}

public function encode_startup(
    protocol_version: i32,
    params: [StartupParam],
    allocator: Allocator,
) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    let size = _startup_size(params)
    var buf = _alloc_u8_slots(allocator, size)?
    let body_start = framing.open_untagged(mutable buf, 0 as usize)?
    var p = wire.write_i32_be(mutable buf, body_start, protocol_version)?
    let n = params.len()
    var i: usize = 0 as usize
    loop decreases n - i {
        if i >= n { break }
        p = wire.write_cstring(mutable buf, p, params[i].name)?
        p = wire.write_cstring(mutable buf, p, params[i].value)?
        i = i + (1 as usize)
    }
    p = wire.write_u8(mutable buf, p, 0 as u8)?
    let _ = framing.close_untagged(mutable buf, 0 as usize, p)?
    return buf
}

public function encode_ssl_request(
    allocator: Allocator,
) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var buf = _alloc_u8_slots(allocator, 8 as usize)?
    let body_start = framing.open_untagged(mutable buf, 0 as usize)?
    let p = wire.write_i32_be(mutable buf, body_start, ssl_request_code())?
    let _ = framing.close_untagged(mutable buf, 0 as usize, p)?
    return buf
}

public function encode_cancel_request(
    pid: i32,
    secret: i32,
    allocator: Allocator,
) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    var buf = _alloc_u8_slots(allocator, 16 as usize)?
    let body_start = framing.open_untagged(mutable buf, 0 as usize)?
    var p = wire.write_i32_be(mutable buf, body_start, cancel_request_code())?
    p = wire.write_i32_be(mutable buf, p, pid)?
    p = wire.write_i32_be(mutable buf, p, secret)?
    let _ = framing.close_untagged(mutable buf, 0 as usize, p)?
    return buf
}


module pgsql.message.be.reply.status

import local.error
import local.link.wire


public type ParameterStatus {
    name: [u8]
    value: [u8]
}

public function decode_parameter_status(body: [u8]) -> ParameterStatus
    with {err: error.ProtocolError}
{
    let name_cs = wire.read_cstring(body, 0 as usize)?
    let value_cs = wire.read_cstring(body, name_cs.next_pos)?
    return ParameterStatus {
        name: body[name_cs.bytes_lo..<name_cs.bytes_hi],
        value: body[value_cs.bytes_lo..<value_cs.bytes_hi],
    }
}


public type BackendKeyData {
    pid: i32
    secret_key: i32
}

public function decode_backend_key_data(body: [u8]) -> BackendKeyData
    with {err: error.ProtocolError}
{
    let pid = wire.read_i32_be(body, 0 as usize)?
    let secret = wire.read_i32_be(body, 4 as usize)?
    return BackendKeyData { pid: pid, secret_key: secret }
}


public type TransactionStatus {
    case idle
    case in_transaction
    case in_failed_transaction
}

public type ReadyForQuery {
    transaction_status: TransactionStatus
}

public function tx_status_idle() -> u8 { return 73 as u8 }

public function tx_status_in_tx() -> u8 { return 84 as u8 }

public function tx_status_failed_tx() -> u8 { return 69 as u8 }

public function decode_ready_for_query(body: [u8]) -> ReadyForQuery
    with {err: error.ProtocolError}
{
    let b = wire.read_u8(body, 0 as usize)?
    if b == tx_status_idle() {
        return ReadyForQuery { transaction_status: TransactionStatus.idle }
    }
    if b == tx_status_in_tx() {
        return ReadyForQuery { transaction_status: TransactionStatus.in_transaction }
    }
    if b == tx_status_failed_tx() {
        return ReadyForQuery { transaction_status: TransactionStatus.in_failed_transaction }
    }
    raise error.ProtocolError.malformed_message
}

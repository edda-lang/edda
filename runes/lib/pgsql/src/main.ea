
module pgsql.main

import std.io.stream
import local.error

public function main(out: Stdout) -> ()
    with {out}
{
    let _ = error.ProtocolError.malformed_message
    out.print_line("pgsql v0.0.12: scaffold + framing + auth + connect + simple-query + extended-query + binary-codec + result-format + drain-to-ready + row-decode + portal-resume + text-typed + tx")
}

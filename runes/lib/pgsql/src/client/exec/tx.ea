
module pgsql.client.exec.tx

import std.mem.alloc
import std.net.socket
import local.error
import local.client.session.startup.connect
import local.client.exec.query


public function begin(
    conn: mutable connect.Connection,
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let _ = query.run_simple_query(mutable conn, "BEGIN".bytes(), allocator)?
}

public function commit(
    conn: mutable connect.Connection,
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let _ = query.run_simple_query(mutable conn, "COMMIT".bytes(), allocator)?
}

public function rollback(
    conn: mutable connect.Connection,
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let _ = query.run_simple_query(mutable conn, "ROLLBACK".bytes(), allocator)?
}


public function savepoint(
    conn: mutable connect.Connection,
    name: [u8],
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let sql = _build_savepoint_sql("SAVEPOINT ".bytes(), name, allocator)?
    let _ = query.run_simple_query(mutable conn, sql, allocator)?
}

public function release_savepoint(
    conn: mutable connect.Connection,
    name: [u8],
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let sql = _build_savepoint_sql("RELEASE SAVEPOINT ".bytes(), name, allocator)?
    let _ = query.run_simple_query(mutable conn, sql, allocator)?
}

public function rollback_to_savepoint(
    conn: mutable connect.Connection,
    name: [u8],
    allocator: Allocator,
) -> ()
    with {
        allocator,
        err: socket.SocketError, err: alloc.AllocError,
        err: error.ProtocolError, err: error.QueryError,
        divergence,
    }
{
    let sql = _build_savepoint_sql("ROLLBACK TO SAVEPOINT ".bytes(), name, allocator)?
    let _ = query.run_simple_query(mutable conn, sql, allocator)?
}


function _alloc_u8_slots(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _build_savepoint_sql(
    verb: [u8],
    name: [u8],
    allocator: Allocator,
) -> [u8]
    with {allocator, err: alloc.AllocError}
{
    let vn = verb.len()
    let nn = name.len()
    let buf = _alloc_u8_slots(allocator, vn + nn)?
    var i: usize = 0 as usize
    loop decreases vn - i {
        if i >= vn { break }
        buf[i] = verb[i]
        i = i + (1 as usize)
    }
    var j: usize = 0 as usize
    loop decreases nn - j {
        if j >= nn { break }
        buf[vn + j] = name[j]
        j = j + (1 as usize)
    }
    return buf
}


module pgsql.client.session.auth.cleartext

import std.mem.alloc
import local.error
import local.message.fe.auth as fe_auth

public function build_response(
    password: [u8],
    allocator: Allocator,
) -> [u8]
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return fe_auth.encode_password_message(password, allocator)?
}

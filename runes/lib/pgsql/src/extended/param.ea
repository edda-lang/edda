
module pgsql.extended.param

import std.mem.alloc
import local.error
import local.codec.binary as binary_codec
import local.message.fe.extended as fe_extended


public type Param {
    case null_value
    case text(value: [u8])
    case binary(value: [u8])
}


public type BindArgs {
    params: [fe_extended.BindParam]
    formats: [i16]
}


function _alloc_bind_param_slots(allocator: Allocator, n: usize) -> [fe_extended.BindParam]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"

function _alloc_i16_slots(allocator: Allocator, n: usize) -> [i16]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"


public function to_bind_args(params: [Param], allocator: Allocator) -> BindArgs
    with {allocator, err: alloc.AllocError}
{
    let n = params.len()
    let bind_params = _alloc_bind_param_slots(allocator, n)?
    let formats = _alloc_i16_slots(allocator, n)?
    var i: usize = 0 as usize
    loop decreases n - i {
        if i >= n { break }
        match params[i] {
            case .null_value => {
                bind_params[i] = fe_extended.BindParam {
                    is_null: true,
                    value: "".bytes(),
                }
                formats[i] = fe_extended.format_text()
            }
            case .text(let v) => {
                bind_params[i] = fe_extended.BindParam {
                    is_null: false,
                    value: v,
                }
                formats[i] = fe_extended.format_text()
            }
            case .binary(let v) => {
                bind_params[i] = fe_extended.BindParam {
                    is_null: false,
                    value: v,
                }
                formats[i] = fe_extended.format_binary()
            }
        }
        i = i + (1 as usize)
    }
    return BindArgs { params: bind_params, formats: formats }
}


public function bool_binary(value: bool, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_bool(value, allocator)?)
}

public function int2_binary(value: i16, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_int2(value, allocator)?)
}

public function int4_binary(value: i32, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_int4(value, allocator)?)
}

public function int8_binary(value: i64, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_int8(value, allocator)?)
}

public function oid_binary(value: u32, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_oid(value, allocator)?)
}

public function char_binary(value: u8, allocator: Allocator) -> Param
    with {allocator, err: alloc.AllocError, err: error.ProtocolError}
{
    return Param.binary(value: binary_codec.encode_char(value, allocator)?)
}

public function bytea_binary(value: [u8]) -> Param {
    return Param.binary(value: binary_codec.encode_bytea(value))
}

public function text_binary(value: [u8]) -> Param {
    return Param.binary(value: binary_codec.encode_text(value))
}

public function uuid_binary(value: [u8]) -> Param
    requires value.len() == 16
{
    return Param.binary(value: binary_codec.encode_uuid(value))
}

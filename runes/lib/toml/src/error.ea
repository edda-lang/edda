
module toml.error

public type ParseError {
    case unexpected_byte(at: usize)
    case unterminated_string(at: usize)
    case bad_escape(at: usize)
    case bad_number(at: usize)
    case bad_key(at: usize)
    case reserved_in_subset(at: usize)
    case unexpected_token(at: usize)
    case unexpected_eof(at: usize)
    case missing_equals(at: usize)
    case missing_bracket(at: usize)
    case missing_newline(at: usize)
    case duplicate_key(at: usize)
    case key_after_table(at: usize)
    case mixed_array(at: usize)
    case allocation_failed
}

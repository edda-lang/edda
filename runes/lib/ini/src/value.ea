module ini.value

import std.core.option

spec option.Option(String)


public type Pair {
    key: String
    value: String
}

public type Section {
    name: String
    pairs: [Pair]
}

public type Ini {
    sections: [Section]
}


function _bytes_eq(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n = a.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i = i + 1 as usize
    }
    return true
}

function _section_get(pairs: [Pair], key: [u8]) -> Option_String {
    let n = pairs.len()
    var i: usize = n
    loop decreases i {
        if i == 0 as usize { break }
        i = i - 1 as usize
        if _bytes_eq(pairs[i].key.bytes(), key) {
            return Option_String.some(value: pairs[i].value)
        }
    }
    return Option_String.none
}

public function sections(ini: Ini) -> [Section] {
    return ini.sections
}

public function get(ini: Ini, section: String, key: String) -> Option_String {
    let secs = ini.sections
    let target_section = section.bytes()
    let target_key = key.bytes()
    let n = secs.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        if _bytes_eq(secs[i].name.bytes(), target_section) {
            return _section_get(secs[i].pairs, target_key)
        }
        i = i + 1 as usize
    }
    return Option_String.none
}

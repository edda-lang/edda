
module hermod.fetch.response

import local.message.body as body_mod
import local.proto.headers as headers_mod
import local.proto.status as status_mod
import local.message.response as response_mod

public function status_code(r: response_mod.Response) -> u16 {
    return status_mod.status_code(response_mod.response_status(r))
}

public function is_success(r: response_mod.Response) -> bool {
    return status_mod.status_is_success(response_mod.response_status(r))
}

public function is_redirect(r: response_mod.Response) -> bool {
    return status_mod.status_is_redirect(response_mod.response_status(r))
}

public function is_error(r: response_mod.Response) -> bool {
    let s = response_mod.response_status(r)
    return status_mod.status_is_client_error(s) || status_mod.status_is_server_error(s)
}

public function body_bytes(r: response_mod.Response) -> [u8] {
    return body_mod.body_bytes(response_mod.response_body(r))
}

public function body_len(r: response_mod.Response) -> usize {
    return body_mod.body_len(response_mod.response_body(r))
}

public function header_bytes_or(
    r: response_mod.Response,
    name: [u8],
    fallback: [u8],
) -> [u8] {
    return headers_mod.headers_value_or(response_mod.response_headers(r), name, fallback)
}

public function has_header(r: response_mod.Response, name: [u8]) -> bool {
    return headers_mod.headers_has(response_mod.response_headers(r), name)
}

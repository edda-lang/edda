
module hermod.fetch.polite.num

public type Seconds {
    secs: i64
    present: bool
}

function _no_seconds() -> Seconds {
    return Seconds { secs: 0 as i64, present: false }
}

public function parse_seconds(value: [u8]) -> Seconds
    ensures result.secs >= 0 as i64
    ensures result.secs <= 86400 as i64
{
    var i: usize = 0 as usize
    loop decreases value.len() - i {
        if i >= value.len() { break }
        if value[i] != 32 as u8 && value[i] != 9 as u8 { break }
        i = i + 1 as usize
    }
    if i >= value.len() || value[i] < 48 as u8 || value[i] > 57 as u8 {
        return _no_seconds()
    }
    let cap: i64 = 86400 as i64
    var acc: i64 = 0 as i64
    loop decreases value.len() - i {
        if i >= value.len() { break }
        let b = value[i]
        if b < 48 as u8 || b > 57 as u8 { break }
        if acc >= cap { break }
        let d = (b - 48 as u8) as i64
        acc = acc * 10 as i64 + d
        i = i + 1 as usize
    }
    let secs = if acc > cap { cap } else { acc }
    return Seconds { secs: secs, present: true }
}

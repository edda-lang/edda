
module hermod.uri.types

public type Uri {
    scheme: [u8]
    host: [u8]
    port: u16
    target: [u8]
}

public function uri_http(host: [u8], port: u16, target: [u8]) -> Uri {
    return Uri {
        scheme: "http".bytes(),
        host: host,
        port: port,
        target: target,
    }
}

public function uri_https(host: [u8], port: u16, target: [u8]) -> Uri {
    return Uri {
        scheme: "https".bytes(),
        host: host,
        port: port,
        target: target,
    }
}

public function uri_default_port_http() -> u16 { return 80 as u16 }

public function uri_default_port_https() -> u16 { return 443 as u16 }

public function uri_scheme(u: Uri) -> [u8] { return u.scheme }

public function uri_host(u: Uri) -> [u8] { return u.host }

public function uri_port(u: Uri) -> u16 { return u.port }

public function uri_target(u: Uri) -> [u8] { return u.target }

public function uri_is_https(u: Uri) -> bool {
    let s = u.scheme
    if s.len() != 5 as usize { return false }
    return s[0] == 104 as u8
        && s[1] == 116 as u8
        && s[2] == 116 as u8
        && s[3] == 112 as u8
        && s[4] == 115 as u8
}

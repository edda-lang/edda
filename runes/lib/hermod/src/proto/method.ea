
module hermod.proto.method

public type Method {
    case method_get
    case method_post
    case method_put
    case method_patch
    case method_delete
    case method_head
    case method_options
    case method_connect
    case method_trace
}

public function method_token(m: Method) -> [u8] {
    return match m {
        case .method_get     => "GET".bytes()
        case .method_post    => "POST".bytes()
        case .method_put     => "PUT".bytes()
        case .method_patch   => "PATCH".bytes()
        case .method_delete  => "DELETE".bytes()
        case .method_head    => "HEAD".bytes()
        case .method_options => "OPTIONS".bytes()
        case .method_connect => "CONNECT".bytes()
        case .method_trace   => "TRACE".bytes()
    }
}

public function method_tag(m: Method) -> u8 {
    return match m {
        case .method_get     => 1 as u8
        case .method_post    => 2 as u8
        case .method_put     => 3 as u8
        case .method_patch   => 4 as u8
        case .method_delete  => 5 as u8
        case .method_head    => 6 as u8
        case .method_options => 7 as u8
        case .method_connect => 8 as u8
        case .method_trace   => 9 as u8
    }
}

public function method_is_idempotent(m: Method) -> bool {
    return match m {
        case .method_post    => false
        case .method_patch   => false
        case .method_connect => false
        case _               => true
    }
}

public function method_is_safe(m: Method) -> bool {
    return match m {
        case .method_get     => true
        case .method_head    => true
        case .method_options => true
        case .method_trace   => true
        case _               => false
    }
}


module hermod.message.request

import std.mem.alloc
import local.proto.method as method_mod
import local.uri.types as uri_mod
import local.proto.headers as headers_mod
import local.message.body as body_mod

public type Request {
    method: method_mod.Method
    uri: uri_mod.Uri
    headers: headers_mod.Headers
    body: body_mod.Body
}

public function request_new(
    m: method_mod.Method,
    u: uri_mod.Uri,
    h: headers_mod.Headers,
    b: body_mod.Body,
) -> Request {
    return Request { method: m, uri: u, headers: h, body: b }
}

public function request_get(
    u: uri_mod.Uri,
    header_cap: usize,
    allocator: mutable Allocator,
) -> Request
    with {allocator, err: alloc.AllocError}
{
    let h = headers_mod.headers_with_capacity(header_cap, mutable allocator)?
    return Request {
        method: method_mod.Method.method_get,
        uri: u,
        headers: h,
        body: body_mod.body_empty(),
    }
}

public function request_post(
    u: uri_mod.Uri,
    b: body_mod.Body,
    header_cap: usize,
    allocator: mutable Allocator,
) -> Request
    with {allocator, err: alloc.AllocError}
{
    let h = headers_mod.headers_with_capacity(header_cap, mutable allocator)?
    return Request {
        method: method_mod.Method.method_post,
        uri: u,
        headers: h,
        body: b,
    }
}

public function request_method(r: Request) -> method_mod.Method { return r.method }

public function request_uri(r: Request) -> uri_mod.Uri { return r.uri }

public function request_headers(r: Request) -> headers_mod.Headers { return r.headers }

public function request_body(r: Request) -> body_mod.Body { return r.body }

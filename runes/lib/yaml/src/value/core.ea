
module yaml.value.core

import std.mem.alloc
import std.core.option

spec alloc.Box(YamlValue)
spec option.Option(YamlValue)
spec option.Option(String)
spec option.Option(i64)
spec option.Option(f64)
spec option.Option(bool)
spec option.Option(Mapping)
spec option.Option(Sequence)

public type MappingEntry {
    key: String
    value: Box_YamlValue
}

public type Mapping {
    entries: [MappingEntry]
}

public type Sequence {
    items: [Box_YamlValue]
}

public type YamlValue {
    case null_value
    case bool_value(bool)
    case int_value(i64)
    case float_value(f64)
    case str_value(String)
    case sequence(Sequence)
    case mapping(Mapping)
}


public function is_null(v: YamlValue) -> bool {
    return match v {
        case .null_value => true
        case _           => false
    }
}

public function is_bool(v: YamlValue) -> bool {
    return match v {
        case .bool_value(_) => true
        case _              => false
    }
}

public function is_int(v: YamlValue) -> bool {
    return match v {
        case .int_value(_) => true
        case _             => false
    }
}

public function is_float(v: YamlValue) -> bool {
    return match v {
        case .float_value(_) => true
        case _               => false
    }
}

public function is_str(v: YamlValue) -> bool {
    return match v {
        case .str_value(_) => true
        case _             => false
    }
}

public function is_sequence(v: YamlValue) -> bool {
    return match v {
        case .sequence(_) => true
        case _            => false
    }
}

public function is_mapping(v: YamlValue) -> bool {
    return match v {
        case .mapping(_) => true
        case _           => false
    }
}


public function as_bool(v: YamlValue) -> Option_bool {
    return match v {
        case .bool_value(let b) => Option_bool.some(value: b)
        case _                  => Option_bool.none
    }
}

public function as_int(v: YamlValue) -> Option_i64 {
    return match v {
        case .int_value(let n) => Option_i64.some(value: n)
        case _                 => Option_i64.none
    }
}

public function as_float(v: YamlValue) -> Option_f64 {
    return match v {
        case .float_value(let f) => Option_f64.some(value: f)
        case _                   => Option_f64.none
    }
}

public function as_str(v: take YamlValue) -> Option_String {
    return match v {
        case .str_value(let s) => Option_String.some(value: s)
        case _                 => Option_String.none
    }
}


function _bytes_eq(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n = a.len()
    var i: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i = i + 1 as usize
    }
    return true
}

function _entries_get(entries: [MappingEntry], key: [u8]) -> Option_YamlValue {
    let n = entries.len()
    var i: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if _bytes_eq(entries[i].key.bytes(), key) {
            return Option_YamlValue.some(value: entries[i].value.get())
        }
        i = i + 1 as usize
    }
    return Option_YamlValue.none
}


public function len(m: Mapping) -> usize {
    return m.entries.len()
}

public function has(m: Mapping, key: String) -> bool {
    let entries = m.entries
    let target = key.bytes()
    let n = entries.len()
    var i: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if _bytes_eq(entries[i].key.bytes(), target) { return true }
        i = i + 1 as usize
    }
    return false
}

public function get(m: Mapping, key: String) -> Option_YamlValue {
    return _entries_get(m.entries, key.bytes())
}

public function get_scalar(m: Mapping, key: String) -> Option_String {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .str_value(let s) => Option_String.some(value: s)
            case _                 => Option_String.none
        }
        case .none => Option_String.none
    }
}

public function get_int(m: Mapping, key: String) -> Option_i64 {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .int_value(let n) => Option_i64.some(value: n)
            case _                 => Option_i64.none
        }
        case .none => Option_i64.none
    }
}

public function get_float(m: Mapping, key: String) -> Option_f64 {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .float_value(let f) => Option_f64.some(value: f)
            case _                   => Option_f64.none
        }
        case .none => Option_f64.none
    }
}

public function get_bool(m: Mapping, key: String) -> Option_bool {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .bool_value(let b) => Option_bool.some(value: b)
            case _                  => Option_bool.none
        }
        case .none => Option_bool.none
    }
}

public function get_mapping(m: Mapping, key: String) -> Option_Mapping {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .mapping(let sub) => Option_Mapping.some(value: sub)
            case _                 => Option_Mapping.none
        }
        case .none => Option_Mapping.none
    }
}

public function get_sequence(m: Mapping, key: String) -> Option_Sequence {
    let found = _entries_get(m.entries, key.bytes())
    return match found {
        case .some(let v) => match v {
            case .sequence(let sq) => Option_Sequence.some(value: sq)
            case _                 => Option_Sequence.none
        }
        case .none => Option_Sequence.none
    }
}

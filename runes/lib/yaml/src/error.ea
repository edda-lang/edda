
module yaml.error

public type ParseError {
    case empty_input
    case tab_indentation(at: usize)
    case bad_indentation(at: usize)
    case unexpected_byte(at: usize)
    case missing_colon(at: usize)
    case empty_key(at: usize)
    case mixed_indicators(at: usize)
    case allocation_failed
}

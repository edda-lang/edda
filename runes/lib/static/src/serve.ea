module static.serve

import std.os.fs
import std.text.string


public type StaticError {
    case traversal_rejected
    case filesystem(fs.FsError)
}

public type Served {
    content_type: String
    bytes: [u8]
    content_length: usize
    cache_control: String
}

public function content_type_for(path: String) -> String {
    if string.ends_with(path, ".html") || string.ends_with(path, ".htm") {
        return "text/html; charset=utf-8"
    }
    if string.ends_with(path, ".css") {
        return "text/css; charset=utf-8"
    }
    if string.ends_with(path, ".js") || string.ends_with(path, ".mjs") {
        return "text/javascript; charset=utf-8"
    }
    if string.ends_with(path, ".json") {
        return "application/json"
    }
    if string.ends_with(path, ".svg") {
        return "image/svg+xml"
    }
    if string.ends_with(path, ".png") {
        return "image/png"
    }
    if string.ends_with(path, ".jpg") || string.ends_with(path, ".jpeg") {
        return "image/jpeg"
    }
    if string.ends_with(path, ".gif") {
        return "image/gif"
    }
    if string.ends_with(path, ".webp") {
        return "image/webp"
    }
    if string.ends_with(path, ".ico") {
        return "image/x-icon"
    }
    if string.ends_with(path, ".woff2") {
        return "font/woff2"
    }
    if string.ends_with(path, ".woff") {
        return "font/woff"
    }
    if string.ends_with(path, ".wasm") {
        return "application/wasm"
    }
    if string.ends_with(path, ".pdf") {
        return "application/pdf"
    }
    if string.ends_with(path, ".xml") {
        return "application/xml"
    }
    if string.ends_with(path, ".txt") {
        return "text/plain; charset=utf-8"
    }
    return "application/octet-stream"
}

function default_cache_control() -> String {
    return "public, max-age=3600"
}

public function has_traversal(path: String) -> bool {
    return string.contains(path, "..")
}

public function mount(rfs: ReadOnlyFilesystem, root: String) -> ReadOnlyFilesystem
    with {rfs}
{
    return fs.scoped_to(rfs, root)
}

public function read_file(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> Served
    with {rfs, allocator, err: StaticError}
{
    if has_traversal(path) {
        raise StaticError.traversal_rejected
    }
    let bytes = handle err: fs.FsError as e -> raise StaticError.filesystem(e) {
        fs.read_bytes(rfs, path, allocator)?
    }
    let ct = content_type_for(path)
    return Served {
        content_type: ct,
        bytes: bytes,
        content_length: bytes.len(),
        cache_control: default_cache_control(),
    }
}

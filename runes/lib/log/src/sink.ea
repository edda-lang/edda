module log.sink

import std.io.stream
import local.level as level_mod

public function log(out: Stdout, level: level_mod.Level, msg: String) -> ()
    with {out}
{
    let name = level_mod.level_name(level)
    out.print_line(f"{name} {msg}")
}

public function log_err(errout: Stderr, level: level_mod.Level, msg: String) -> ()
    with {errout}
{
    let name = level_mod.level_name(level)
    errout.eprint_line(f"{name} {msg}")
}

public function trace(out: Stdout, msg: String) -> ()
    with {out}
{
    log(out, level_mod.Level.trace, msg)
}

public function debug(out: Stdout, msg: String) -> ()
    with {out}
{
    log(out, level_mod.Level.debug, msg)
}

public function info(out: Stdout, msg: String) -> ()
    with {out}
{
    log(out, level_mod.Level.info, msg)
}

public function warn(errout: Stderr, msg: String) -> ()
    with {errout}
{
    log_err(errout, level_mod.Level.warn, msg)
}

public function error(errout: Stderr, msg: String) -> ()
    with {errout}
{
    log_err(errout, level_mod.Level.error, msg)
}

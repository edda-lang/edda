module uuid.uuid

import std.mem.alloc
import std.crypto.random
import std.core.option
import std.text.string

spec std.core.option.Option(Uuid)


public type Uuid {
    hi: u64
    lo: u64
}


function byte_at(u: Uuid, i: usize where i < 16) -> u8 {
    let word: u64 = if i < 8 { u.hi } else { u.lo }
    let idx: usize = i % 8
    let shift: u64 = (56 as usize - 8 as usize * idx) as u64
    return ((word >> shift) & 0xff) as u8
}

function pack_word(b: [u8], offset: usize where offset + 8 <= b.len()) -> u64 {
    var acc: u64 = 0
    var i: usize = 0
    loop decreases 8 - i {
        if i >= 8 { break }
        acc = (acc << 8) | (b[offset + i] as u64)
        i += 1
    }
    return acc
}

function from_word_bytes(b: [u8] where b.len() == 16) -> Uuid {
    let hi: u64 = pack_word(b, 0)
    let lo: u64 = pack_word(b, 8)
    return Uuid { hi: hi, lo: lo }
}

function nibble_to_hex(n: u8 where n < 16) -> u8
    ensures result < 128
{
    if n < 10 { return 0x30 + n }
    return 0x61 + (n - 10)
}

function decode_nibble(c: u8) -> u8 {
    if c >= 0x30 && c <= 0x39 { return c - 0x30 }
    if c >= 0x61 && c <= 0x66 { return c - 0x61 + 10 }
    if c >= 0x41 && c <= 0x46 { return c - 0x41 + 10 }
    return 0xff
}


public function nil() -> Uuid {
    return Uuid { hi: 0, lo: 0 }
}

public function version(u: Uuid) -> u8 {
    return byte_at(u, 6) >> 4
}

public function v4(rand: Random, allocator: Allocator) -> Uuid
    with {rand, allocator, err: alloc.AllocError}
{
    var buf: [u8] = allocator.alloc_array(u8, 16 as usize)?
    random.fill(rand, mutable buf)
    buf[6] = (buf[6] & 0x0f) | 0x40
    buf[8] = (buf[8] & 0x3f) | 0x80
    return from_word_bytes(buf)
}

public function v7(ms: u64, rand: Random, allocator: Allocator) -> Uuid
    with {rand, allocator, err: alloc.AllocError}
{
    var buf: [u8] = allocator.alloc_array(u8, 16 as usize)?
    random.fill(rand, mutable buf)
    buf[0] = ((ms >> 40) & 0xff) as u8
    buf[1] = ((ms >> 32) & 0xff) as u8
    buf[2] = ((ms >> 24) & 0xff) as u8
    buf[3] = ((ms >> 16) & 0xff) as u8
    buf[4] = ((ms >> 8) & 0xff) as u8
    buf[5] = (ms & 0xff) as u8
    buf[6] = (buf[6] & 0x0f) | 0x70
    buf[8] = (buf[8] & 0x3f) | 0x80
    return from_word_bytes(buf)
}

public function to_bytes(u: Uuid, allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError}
    ensures result.len() == 16
{
    var out: [u8] = allocator.alloc_array(u8, 16 as usize)?
    var i: usize = 0
    loop decreases 16 - i {
        if i >= 16 { break }
        out[i] = byte_at(u, i)
        i += 1
    }
    return out
}

public function from_bytes(b: [u8]) -> Option_Uuid.Option {
    if b.len() != 16 as usize {
        return Option_Uuid.Option.none
    }
    return Option_Uuid.Option.some(value: from_word_bytes(b))
}

public function format(u: Uuid, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    var out: [u8] = allocator.alloc_array(u8, 36 as usize)?
    var src: usize = 0
    var dst: usize = 0
    loop decreases 16 - src {
        if src >= 16 { break }
        if src == 4 || src == 6 || src == 8 || src == 10 {
            out[dst] = 0x2d
            dst += 1
        }
        let b: u8 = byte_at(u, src)
        out[dst] = nibble_to_hex(b >> 4)
        out[dst + 1] = nibble_to_hex(b & 0x0f)
        dst += 2
        src += 1
    }
    return string.from_owned_utf8(take out)
}

function decode_into(bytes: [u8], start: usize, out: mutable [u8]) -> bool
    requires start + 32 <= bytes.len()
    requires out.len() >= 16
{
    var i: usize = 0
    loop decreases 16 - i {
        if i >= 16 { break }
        let hi: u8 = decode_nibble(bytes[start + 2 * i])
        let lo: u8 = decode_nibble(bytes[start + 2 * i + 1])
        if hi >= 16 || lo >= 16 { return false }
        out[i] = hi * 16 + lo
        i += 1
    }
    return true
}

function has_canonical_hyphens(bytes: [u8] where bytes.len() == 36) -> bool {
    return bytes[8] == 0x2d && bytes[13] == 0x2d && bytes[18] == 0x2d && bytes[23] == 0x2d
}

function strip_hyphens(bytes: [u8] where bytes.len() == 36, out: mutable [u8] where out.len() >= 32) -> () {
    var src: usize = 0
    var dst: usize = 0
    loop decreases 36 - src {
        if src >= 36 { break }
        if src == 8 || src == 13 || src == 18 || src == 23 {
            src += 1
            continue
        }
        out[dst] = bytes[src]
        dst += 1
        src += 1
    }
}

public function parse(s: String, allocator: Allocator) -> Option_Uuid.Option
    with {allocator, err: alloc.AllocError}
{
    let bytes: [u8] = s.bytes()
    let n: usize = bytes.len()
    var raw: [u8] = allocator.alloc_array(u8, 16 as usize)?
    if n == 32 as usize {
        if !decode_into(bytes, 0, mutable raw) {
            return Option_Uuid.Option.none
        }
        return Option_Uuid.Option.some(value: from_word_bytes(raw))
    }
    if n == 36 as usize {
        if !has_canonical_hyphens(bytes) {
            return Option_Uuid.Option.none
        }
        var packed: [u8] = allocator.alloc_array(u8, 32 as usize)?
        strip_hyphens(bytes, mutable packed)
        if !decode_into(packed, 0, mutable raw) {
            return Option_Uuid.Option.none
        }
        return Option_Uuid.Option.some(value: from_word_bytes(raw))
    }
    return Option_Uuid.Option.none
}

public function is_valid(s: String, allocator: Allocator) -> bool
    with {allocator, err: alloc.AllocError}
{
    return match parse(s, allocator)? {
        case .some(_) => true
        case .none    => false
    }
}

module markdown.lines.scan

import std.mem.alloc
import std.collections.vec
import std.text.string

spec vec.Vec(Line)

public type Line {
    text: String
}

public function split(data: [u8], allocator: Allocator) -> Vec_Line.Vec
    with {allocator, err: alloc.AllocError}
{
    uninit lines: Vec_Line.Vec
    Vec_Line.new(init lines, allocator)?
    let n = data.len()
    var start: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if data[i] == 10 {
            push_line(mutable lines, data, start, i, allocator)?
            start = i + 1
        }
        i += 1
    }
    push_line(mutable lines, data, start, n, allocator)?
    return lines
}

function push_line(
    lines: mutable Vec_Line.Vec,
    data: [u8],
    lo: usize,
    hi: usize where lo <= hi && hi <= data.len(),
    allocator: Allocator,
) -> ()
    with {allocator, err: alloc.AllocError}
{
    var end: usize = hi
    if end > lo && data[end - 1] == 13 {
        end = end - 1
    }
    let text = slice_to_string(data, lo, end, allocator)?
    Vec_Line.push(mutable lines, take Line { text: text }, allocator)?
}

function slice_to_string(
    data: [u8],
    lo: usize,
    hi: usize where lo <= hi && hi <= data.len(),
    allocator: Allocator,
) -> String
    with {allocator, err: alloc.AllocError}
{
    let len = hi - lo
    let buf: [u8] = allocator.alloc_array(u8, len)?
    var i: usize = 0
    loop
        decreases len - i
    {
        if i >= len { break }
        buf[i] = data[lo + i]
        i += 1
    }
    return string.from_owned_utf8(take buf)
}

public function is_blank(ln: Line) -> bool {
    let b = ln.text.bytes()
    let n = b.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if !is_space(b[i]) { return false }
        i += 1
    }
    return true
}

public function is_fence(ln: Line) -> bool {
    let b = lstrip(ln.text.bytes())
    if b.len() < 3 { return false }
    return b[0] == 96 && b[1] == 96 && b[2] == 96
}

public function is_hr(ln: Line) -> bool {
    let b = lstrip(ln.text.bytes())
    let n = b.len()
    if n < 3 { return false }
    let marker = b[0]
    if marker != 45 && marker != 42 && marker != 95 { return false }
    var count: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let c = b[i]
        if c == marker {
            count += 1
        } else if !is_space(c) {
            return false
        }
        i += 1
    }
    return count >= 3
}

public function heading_level(ln: Line) -> usize {
    let b = ln.text.bytes()
    let n = b.len()
    var hashes: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if b[i] != 35 { break }
        hashes += 1
        i += 1
    }
    if hashes < 1 || hashes > 6 { return 0 }
    if hashes >= n { return 0 }
    if b[hashes] != 32 { return 0 }
    return hashes
}

public function heading_content_lo(ln: Line, level: usize where level >= 1 && level <= 6) -> usize {
    let n = ln.text.bytes().len()
    let stop = level + 1
    if stop <= n { return stop }
    return n
}

public function is_ul_item(ln: Line) -> bool {
    let b = lstrip(ln.text.bytes())
    if b.len() < 2 { return false }
    let marker = b[0]
    if marker != 45 && marker != 42 { return false }
    return b[1] == 32
}

public function is_ol_item(ln: Line) -> bool {
    return ol_marker_len(ln) > 0
}

public function ol_content_lo(ln: Line) -> usize {
    let n = ln.text.bytes().len()
    let lead = leading_spaces(ln.text.bytes())
    let m = ol_marker_len(ln)
    let lo = lead + m
    if lo <= n { return lo }
    return n
}

public function ul_content_lo(ln: Line) -> usize {
    let n = ln.text.bytes().len()
    let lead = leading_spaces(ln.text.bytes())
    let lo = lead + 2
    if lo <= n { return lo }
    return n
}

public function is_blockquote(ln: Line) -> bool {
    let b = lstrip(ln.text.bytes())
    if b.len() < 1 { return false }
    return b[0] == 62
}

public function bq_content_lo(ln: Line) -> usize {
    let b = ln.text.bytes()
    let lead = leading_spaces(b)
    let n = b.len()
    var lo: usize = lead + 1
    if lo > n { return n }
    if lo < n && b[lo] == 32 {
        lo = lo + 1
    }
    return lo
}

public function is_paragraph_line(ln: Line) -> bool {
    if is_blank(ln) { return false }
    if is_fence(ln) { return false }
    if is_hr(ln) { return false }
    if heading_level(ln) > 0 { return false }
    if is_ul_item(ln) { return false }
    if is_ol_item(ln) { return false }
    if is_blockquote(ln) { return false }
    return true
}

public function has_hard_break(ln: Line) -> bool {
    let b = ln.text.bytes()
    let n = b.len()
    if n < 2 { return false }
    return b[n - 1] == 32 && b[n - 2] == 32
}

public function content(ln: Line, lo: usize, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let b = ln.text.bytes()
    let n = b.len()
    let start = if lo <= n { lo } else { n }
    var hi: usize = n
    loop
        decreases hi - start
    {
        if hi <= start { break }
        if !is_space(b[hi - 1]) { break }
        hi -= 1
    }
    var begin: usize = start
    loop
        decreases hi - begin
    {
        if begin >= hi { break }
        if !is_space(b[begin]) { break }
        begin += 1
    }
    return slice_to_string(b, begin, hi, allocator)?
}

public function line_bytes(ln: Line) -> [u8] {
    return ln.text.bytes()
}

function ol_marker_len(ln: Line) -> usize {
    let b = ln.text.bytes()
    let n = b.len()
    let lead = leading_spaces(b)
    var i: usize = lead
    var digits: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let c = b[i]
        if c < 48 || c > 57 { break }
        digits += 1
        i += 1
    }
    if digits == 0 { return 0 }
    if i + 1 >= n { return 0 }
    if b[i] != 46 { return 0 }
    if b[i + 1] != 32 { return 0 }
    return digits + 2
}

function leading_spaces(b: [u8]) -> usize
    ensures result <= b.len()
{
    let n = b.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if !is_space(b[i]) { break }
        i += 1
    }
    return i
}

function lstrip(b: [u8]) -> [u8] {
    let lead = leading_spaces(b)
    return b[lead..]
}

function is_space(byte: u8) -> bool {
    return byte == 32 || byte == 9
}

module markdown.escape.sink

import std.mem.alloc
import std.text.string
import textbuilder.builder as tb

public type Sink {
    out: tb.Builder
}

public function new(allocator: Allocator) -> Sink
    with {allocator, err: alloc.AllocError}
{
    let out = tb.new(allocator)?
    return Sink { out: out }
}

public function push_raw(s: mutable Sink, text: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    tb.push_str(mutable s.out, text, allocator)?
}

public function push_byte(s: mutable Sink, byte: u8, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    tb.push_byte(mutable s.out, take byte, allocator)?
}

public function push_escaped(s: mutable Sink, text: String, allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    push_escaped_bytes(mutable s, text.bytes(), allocator)?
}

public function push_escaped_bytes(s: mutable Sink, data: [u8], allocator: Allocator) -> ()
    with {allocator, err: alloc.AllocError}
{
    let n = data.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let byte = data[i]
        if byte == 38 {
            tb.push_str(mutable s.out, "&amp;", allocator)?
        } else if byte == 60 {
            tb.push_str(mutable s.out, "&lt;", allocator)?
        } else if byte == 62 {
            tb.push_str(mutable s.out, "&gt;", allocator)?
        } else if byte == 34 {
            tb.push_str(mutable s.out, "&quot;", allocator)?
        } else if byte == 39 {
            tb.push_str(mutable s.out, "&#39;", allocator)?
        } else {
            tb.push_byte(mutable s.out, take byte, allocator)?
        }
        i += 1
    }
}

public function finish(s: Sink, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let bytes = tb.to_bytes(s.out, allocator)?
    return string.from_owned_utf8(take bytes)
}

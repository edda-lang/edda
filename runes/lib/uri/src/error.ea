
module uri.error

public type ParseError {
    case empty_input
    case missing_scheme(at: usize)
    case bad_scheme_start(at: usize)
    case bad_scheme_char(at: usize)
    case bad_host(at: usize)
    case empty_host(at: usize)
    case unclosed_ip_literal(at: usize)
    case bad_port(at: usize)
    case port_out_of_range(at: usize)
    case bad_percent_encoding(at: usize)
    case allocation_failed
}

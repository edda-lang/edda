
module uri.value

import std.core.option

spec option.Option(String)
spec option.Option(u16)

public type Uri {
    scheme: String
    userinfo: Option_String
    host: Option_String
    port: Option_u16
    path: String
    query: Option_String
    fragment: Option_String
}

public function scheme(u: Uri) -> String {
    return u.scheme
}

public function userinfo(u: Uri) -> Option_String {
    return u.userinfo
}

public function host(u: Uri) -> Option_String {
    return u.host
}

public function port(u: Uri) -> Option_u16 {
    return u.port
}

public function path(u: Uri) -> String {
    return u.path
}

public function query(u: Uri) -> Option_String {
    return u.query
}

public function fragment(u: Uri) -> Option_String {
    return u.fragment
}

public function has_authority(u: Uri) -> bool {
    return match u.host {
        case .some(_) => true
        case .none    => false
    }
}

public type UriReference {
    scheme: Option_String
    userinfo: Option_String
    host: Option_String
    port: Option_u16
    path: String
    query: Option_String
    fragment: Option_String
}

public function has_scheme(r: UriReference) -> bool {
    return match r.scheme {
        case .some(_) => true
        case .none    => false
    }
}

public function reference_has_authority(r: UriReference) -> bool {
    return match r.host {
        case .some(_) => true
        case .none    => false
    }
}

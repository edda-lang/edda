
module uri.codec.percent

import std.mem.alloc
import uri.error

function _alloc_byte_slab(allocator: Allocator, n: usize) -> [u8]
    with {allocator, err: alloc.AllocError}
extern "__edda_alloc_array"


function _is_digit(c: u8) -> bool {
    return c >= 48 as u8 && c <= 57 as u8
}

function _is_hex(c: u8) -> bool {
    return _is_digit(c)
        || (c >= 65 as u8 && c <= 70 as u8)
        || (c >= 97 as u8 && c <= 102 as u8)
}

function _hex_value(c: u8) -> u32 {
    if c >= 48 as u8 && c <= 57 as u8 {
        return (c - 48 as u8) as u32
    }
    if c >= 97 as u8 && c <= 102 as u8 {
        return ((c - 97 as u8) as u32) + (10 as u32)
    }
    return ((c - 65 as u8) as u32) + (10 as u32)
}

function _is_alpha(c: u8) -> bool {
    return (c >= 65 as u8 && c <= 90 as u8)
        || (c >= 97 as u8 && c <= 122 as u8)
}

public function is_unreserved(c: u8) -> bool {
    return _is_alpha(c)
        || _is_digit(c)
        || c == 45 as u8
        || c == 46 as u8
        || c == 95 as u8
        || c == 126 as u8
}

public function is_sub_delim(c: u8) -> bool {
    return c == 33 as u8
        || c == 36 as u8
        || c == 38 as u8
        || c == 39 as u8
        || c == 40 as u8
        || c == 41 as u8
        || c == 42 as u8
        || c == 43 as u8
        || c == 44 as u8
        || c == 59 as u8
        || c == 61 as u8
}

public function is_pchar_safe(c: u8) -> bool {
    return is_unreserved(c)
        || is_sub_delim(c)
        || c == 58 as u8
        || c == 64 as u8
}

public function is_query_component_safe(c: u8) -> bool {
    if c == 38 as u8 || c == 61 as u8 {
        return false
    }
    return is_pchar_safe(c)
        || c == 47 as u8
        || c == 63 as u8
}

public function is_userinfo_safe(c: u8) -> bool {
    return is_unreserved(c)
        || is_sub_delim(c)
}

function _hex_digit(n: u32) -> u8 {
    let d = n & (0xF as u32)
    if d < (10 as u32) {
        return ((d & (0xFF as u32)) +% (48 as u32)) as u8
    }
    return (((d -% (10 as u32)) & (0xFF as u32)) +% (65 as u32)) as u8
}


public function decode(src: [u8], allocator: Allocator) -> [u8]
    with {allocator, err: error.ParseError, err: alloc.AllocError}
{
    let n = src.len()
    let buf = _alloc_byte_slab(allocator, n)?
    var i: usize = 0
    var p: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        let c = src[i]
        if c != 37 as u8 {
            buf[p] = c
            p = p + 1 as usize
            i = i + 1 as usize
        } else {
            if i + 2 as usize >= n {
                raise error.ParseError.bad_percent_encoding(at: i)
            }
            let h = src[i + 1 as usize]
            let l = src[i + 2 as usize]
            if !_is_hex(h) || !_is_hex(l) {
                raise error.ParseError.bad_percent_encoding(at: i)
            }
            let v: u32 = (_hex_value(h) << (4 as u32)) | _hex_value(l)
            buf[p] = (v & (0xFF as u32)) as u8
            p = p + 1 as usize
            i = i + 3 as usize
        }
    }
    return buf[0 as usize..<p]
}


public function measure_encoded_with(
    src: [u8], safe: function(u8) -> bool,
) -> usize {
    let n = src.len()
    var i: usize = 0
    var out: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if safe(src[i]) {
            out = out + 1 as usize
        } else {
            out = out + 3 as usize
        }
        i = i + 1 as usize
    }
    return out
}

public function encode_into_with(
    buf: mutable [u8], pos: usize, src: [u8], safe: function(u8) -> bool,
) -> usize {
    let n = src.len()
    var i: usize = 0
    var p: usize = pos
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        let c = src[i]
        if safe(c) {
            buf[p] = c
            p = p + 1 as usize
        } else {
            buf[p] = 37 as u8
            buf[p + 1 as usize] = _hex_digit(((c & (0xFF as u8)) as u32) >> (4 as u32))
            buf[p + 2 as usize] = _hex_digit((c & (0xFF as u8)) as u32)
            p = p + 3 as usize
        }
        i = i + 1 as usize
    }
    return p
}


public function encode(src: [u8], allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError}
{
    let need = measure_encoded_with(src, is_unreserved)
    var buf = _alloc_byte_slab(allocator, need)?
    let end = encode_into_with(mutable buf, 0 as usize, src, is_unreserved)
    return buf[0 as usize..<end]
}

public function encode_path_segment(src: [u8], allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError}
{
    let need = measure_encoded_with(src, is_pchar_safe)
    var buf = _alloc_byte_slab(allocator, need)?
    let end = encode_into_with(mutable buf, 0 as usize, src, is_pchar_safe)
    return buf[0 as usize..<end]
}

public function encode_query_component(src: [u8], allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError}
{
    let need = measure_encoded_with(src, is_query_component_safe)
    var buf = _alloc_byte_slab(allocator, need)?
    let end = encode_into_with(mutable buf, 0 as usize, src, is_query_component_safe)
    return buf[0 as usize..<end]
}

public function encode_userinfo(src: [u8], allocator: Allocator) -> [u8]
    with {allocator, err: alloc.AllocError}
{
    let need = measure_encoded_with(src, is_userinfo_safe)
    var buf = _alloc_byte_slab(allocator, need)?
    let end = encode_into_with(mutable buf, 0 as usize, src, is_userinfo_safe)
    return buf[0 as usize..<end]
}

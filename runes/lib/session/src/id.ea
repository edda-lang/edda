module session.id

import std.mem.alloc
import std.crypto.random
import std.encoding.hex


function _id_byte_len() -> usize {
    return 32 as usize
}

public function generate(rand: Random, allocator: Allocator) -> String
    with {rand, allocator, err: alloc.AllocError}
{
    var buf: [u8] = allocator.alloc_array(u8, _id_byte_len())?
    random.fill(rand, mutable buf)
    return hex.encode(buf, allocator)?
}

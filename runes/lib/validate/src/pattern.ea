module validate.pattern

import regex.api as regex_api
import regex.api.compile as re_compile
import regex.api.find as re_find


function _email_pattern() -> String {
    return "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
}

function _url_pattern() -> String {
    return "^https?://[A-Za-z0-9.-]+(:[0-9]+)?(/[^\\s]*)?$"
}

function _full_match(pattern: String, s: String, allocator: mutable Allocator) -> bool
    with {allocator, err: regex_api.RegexError, divergence}
{
    let re = re_compile.compile(pattern, mutable allocator)?
    return re_find.is_match(re, s.bytes(), mutable allocator)?
}

public function is_email(s: String, allocator: mutable Allocator) -> bool
    with {allocator, err: regex_api.RegexError, divergence}
{
    return _full_match(_email_pattern(), s, mutable allocator)?
}

public function is_url(s: String, allocator: mutable Allocator) -> bool
    with {allocator, err: regex_api.RegexError, divergence}
{
    return _full_match(_url_pattern(), s, mutable allocator)?
}

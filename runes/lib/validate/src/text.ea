module validate.text

import std.text.ascii


public function is_empty(s: String) -> bool {
    return s.bytes().len() == 0 as usize
}

public function len_between(s: String, lo: usize, hi: usize) -> bool {
    let n = s.bytes().len()
    return n >= lo && n <= hi
}

public function is_ascii(s: String) -> bool {
    let sb = s.bytes()
    let n = sb.len()
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        if !ascii.is_ascii(sb[i]) { return false }
        i += 1
    }
    return true
}

public function is_alphanumeric(s: String) -> bool {
    let sb = s.bytes()
    let n = sb.len()
    if n == 0 as usize { return false }
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        if !ascii.is_alphanumeric(sb[i]) { return false }
        i += 1
    }
    return true
}

public function is_int(s: String) -> bool {
    let sb = s.bytes()
    let n = sb.len()
    if n == 0 as usize { return false }
    var start: usize = 0
    if sb[0] == 43 as u8 || sb[0] == 45 as u8 {
        start = 1 as usize
    }
    if start >= n { return false }
    var i: usize = start
    loop decreases n - i {
        if i >= n { break }
        if !ascii.is_digit(sb[i]) { return false }
        i += 1
    }
    return true
}

public function is_uuid(s: String) -> bool {
    let sb = s.bytes()
    if sb.len() != 36 as usize { return false }
    var i: usize = 0
    loop decreases 36 as usize - i {
        if i >= 36 as usize { break }
        if _is_hyphen_position(i) {
            if sb[i] != 45 as u8 { return false }
        } else {
            if !ascii.is_hex_digit(sb[i]) { return false }
        }
        i += 1
    }
    return true
}

function _is_hyphen_position(i: usize) -> bool {
    return i == 8 as usize || i == 13 as usize || i == 18 as usize || i == 23 as usize
}

module csrf.token

import std.mem.alloc
import std.crypto.random
import std.crypto.subtle
import std.encoding.hex


function _token_byte_len() -> usize {
    return 32 as usize
}

public function generate(rand: Random, allocator: Allocator) -> String
    with {rand, allocator, err: alloc.AllocError}
{
    var buf: [u8] = allocator.alloc_array(u8, _token_byte_len())?
    random.fill(rand, mutable buf)
    return hex.encode(buf, allocator)?
}

public function verify(expected: String, provided: String) -> bool {
    return subtle.eq_bytes(expected.bytes(), provided.bytes())
}

module jsonpointer.escape

import std.mem.alloc
import std.text.string


function _byte_slash() -> u8 {
    return 47 as u8
}

function _byte_tilde() -> u8 {
    return 126 as u8
}

function _byte_zero() -> u8 {
    return 48 as u8
}

function _byte_one() -> u8 {
    return 49 as u8
}

function _count_specials(bytes: [u8]) -> usize {
    let n = bytes.len()
    var count: usize = 0
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let b = bytes[i]
        if b == _byte_tilde() || b == _byte_slash() {
            count = count +| 1 as usize
        }
        i += 1
    }
    return count
}

public function escape_token(s: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let src = s.bytes()
    let n = src.len()
    let extra = _count_specials(src)
    let out_len = n +| extra
    let buf: [u8] = allocator.alloc_array(u8, out_len)?
    var i: usize = 0
    var w: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let b = src[i]
        if b == _byte_tilde() {
            buf[w] = _byte_tilde()
            buf[w +| 1 as usize] = _byte_zero()
            w = w +| 2 as usize
        } else if b == _byte_slash() {
            buf[w] = _byte_tilde()
            buf[w +| 1 as usize] = _byte_one()
            w = w +| 2 as usize
        } else {
            buf[w] = b
            w = w +| 1 as usize
        }
        i += 1
    }
    return string.from_owned_utf8(take buf)
}

function _unescaped_len(bytes: [u8]) -> usize {
    let n = bytes.len()
    var count: usize = 0
    var i: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let b = bytes[i]
        if b == _byte_tilde() && i +| 1 as usize < n {
            let nxt = bytes[i +| 1 as usize]
            if nxt == _byte_zero() || nxt == _byte_one() {
                count = count +| 1 as usize
                i = i +| 2 as usize
                continue
            }
        }
        count = count +| 1 as usize
        i += 1
    }
    return count
}

public function unescape_token(s: String, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return unescape_bytes(s.bytes(), allocator)?
}

public function unescape_bytes(src: [u8], allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    let n = src.len()
    let out_len = _unescaped_len(src)
    let buf: [u8] = allocator.alloc_array(u8, out_len)?
    var i: usize = 0
    var w: usize = 0
    loop decreases n - i {
        if i >= n { break }
        let b = src[i]
        if b == _byte_tilde() && i +| 1 as usize < n {
            let nxt = src[i +| 1 as usize]
            if nxt == _byte_one() {
                buf[w] = _byte_slash()
                w = w +| 1 as usize
                i = i +| 2 as usize
                continue
            } else if nxt == _byte_zero() {
                buf[w] = _byte_tilde()
                w = w +| 1 as usize
                i = i +| 2 as usize
                continue
            }
        }
        buf[w] = b
        w = w +| 1 as usize
        i += 1
    }
    return string.from_owned_utf8(take buf)
}

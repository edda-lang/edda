module tinysql.model.value

public type ColumnType {
    case int_type
    case text_type
    case bool_type
}

public type Value {
    case integer(i64)
    case text(String)
    case boolean(bool)
    case null_value
}

function _bytes_eq(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n = a.len()
    var i: usize = 0
    loop decreases n - i + 1 as usize {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i = i + 1 as usize
    }
    return true
}

public function is_null(v: Value) -> bool {
    return match v {
        case .null_value => true
        case _           => false
    }
}

public function type_of(v: Value) -> ColumnType {
    return match v {
        case .integer(_) => ColumnType.int_type
        case .text(_)    => ColumnType.text_type
        case .boolean(_) => ColumnType.bool_type
        case .null_value => ColumnType.text_type
    }
}

public function type_matches(v: Value, t: ColumnType) -> bool {
    return match v {
        case .null_value => true
        case .integer(_) => match t { case .int_type => true  case _ => false }
        case .text(_)    => match t { case .text_type => true  case _ => false }
        case .boolean(_) => match t { case .bool_type => true  case _ => false }
    }
}

public function equals(a: Value, b: Value) -> bool {
    return match a {
        case .null_value => match b { case .null_value => true  case _ => false }
        case .integer(let x) => match b {
            case .integer(let y) => x == y
            case _               => false
        }
        case .boolean(let x) => match b {
            case .boolean(let y) => x == y
            case _               => false
        }
        case .text(let x) => match b {
            case .text(let y) => _bytes_eq(x.bytes(), y.bytes())
            case _            => false
        }
    }
}

function _bytes_cmp(a: [u8], b: [u8]) -> i64 {
    let na = a.len()
    let nb = b.len()
    let m = if na < nb { na } else { nb }
    var i: usize = 0
    loop decreases m - i + 1 as usize {
        if i >= m { break }
        let ca = a[i] as i64
        let cb = b[i] as i64
        if ca < cb { return -1 as i64 }
        if ca > cb { return 1 as i64 }
        i = i + 1 as usize
    }
    if na < nb { return -1 as i64 }
    if na > nb { return 1 as i64 }
    return 0 as i64
}

public function compare(a: Value, b: Value) -> i64 {
    return match a {
        case .integer(let x) => match b {
            case .integer(let y) => if x < y { -1 as i64 } else { if x > y { 1 as i64 } else { 0 as i64 } }
            case _               => -1 as i64
        }
        case .boolean(let x) => match b {
            case .boolean(let y) => {
                let xi = if x { 1 as i64 } else { 0 as i64 }
                let yi = if y { 1 as i64 } else { 0 as i64 }
                if xi < yi { -1 as i64 } else { if xi > yi { 1 as i64 } else { 0 as i64 } }
            }
            case _ => -1 as i64
        }
        case .text(let x) => match b {
            case .text(let y) => _bytes_cmp(x.bytes(), y.bytes())
            case _            => -1 as i64
        }
        case .null_value => match b {
            case .null_value => 0 as i64
            case _           => -1 as i64
        }
    }
}

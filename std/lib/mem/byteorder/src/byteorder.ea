
module std.mem.byteorder

public stable function read_u16_le(
    buf: [u8],
    offset: usize where offset + 2 <= buf.len(),
) -> u16
{
    return (buf[offset] as u16) | ((buf[offset + 1] as u16) << 8)
}

public stable function read_u16_be(
    buf: [u8],
    offset: usize where offset + 2 <= buf.len(),
) -> u16
{
    return ((buf[offset] as u16) << 8) | (buf[offset + 1] as u16)
}

public function write_u16_le(
    buf: mutable [u8],
    offset: usize where offset + 2 <= buf.len(),
    value: u16,
) -> ()
{
    buf[offset] = value as u8 wrapping
    buf[offset + 1] = (value >> 8) as u8 wrapping
}

public function write_u16_be(
    buf: mutable [u8],
    offset: usize where offset + 2 <= buf.len(),
    value: u16,
) -> ()
{
    buf[offset] = (value >> 8) as u8 wrapping
    buf[offset + 1] = value as u8 wrapping
}


public stable function read_u32_le(
    buf: [u8],
    offset: usize where offset + 4 <= buf.len(),
) -> u32
{
    return (buf[offset] as u32)
        | ((buf[offset + 1] as u32) << 8)
        | ((buf[offset + 2] as u32) << 16)
        | ((buf[offset + 3] as u32) << 24)
}

public stable function read_u32_be(
    buf: [u8],
    offset: usize where offset + 4 <= buf.len(),
) -> u32
{
    return ((buf[offset] as u32) << 24)
        | ((buf[offset + 1] as u32) << 16)
        | ((buf[offset + 2] as u32) << 8)
        | (buf[offset + 3] as u32)
}

public function write_u32_le(
    buf: mutable [u8],
    offset: usize where offset + 4 <= buf.len(),
    value: u32,
) -> ()
{
    buf[offset] = value as u8 wrapping
    buf[offset + 1] = (value >> 8) as u8 wrapping
    buf[offset + 2] = (value >> 16) as u8 wrapping
    buf[offset + 3] = (value >> 24) as u8 wrapping
}

public function write_u32_be(
    buf: mutable [u8],
    offset: usize where offset + 4 <= buf.len(),
    value: u32,
) -> ()
{
    buf[offset] = (value >> 24) as u8 wrapping
    buf[offset + 1] = (value >> 16) as u8 wrapping
    buf[offset + 2] = (value >> 8) as u8 wrapping
    buf[offset + 3] = value as u8 wrapping
}


public stable function read_u64_le(
    buf: [u8],
    offset: usize where offset + 8 <= buf.len(),
) -> u64
{
    return (buf[offset] as u64)
        | ((buf[offset + 1] as u64) << 8)
        | ((buf[offset + 2] as u64) << 16)
        | ((buf[offset + 3] as u64) << 24)
        | ((buf[offset + 4] as u64) << 32)
        | ((buf[offset + 5] as u64) << 40)
        | ((buf[offset + 6] as u64) << 48)
        | ((buf[offset + 7] as u64) << 56)
}

public stable function read_u64_be(
    buf: [u8],
    offset: usize where offset + 8 <= buf.len(),
) -> u64
{
    return ((buf[offset] as u64) << 56)
        | ((buf[offset + 1] as u64) << 48)
        | ((buf[offset + 2] as u64) << 40)
        | ((buf[offset + 3] as u64) << 32)
        | ((buf[offset + 4] as u64) << 24)
        | ((buf[offset + 5] as u64) << 16)
        | ((buf[offset + 6] as u64) << 8)
        | (buf[offset + 7] as u64)
}

public function write_u64_le(
    buf: mutable [u8],
    offset: usize where offset + 8 <= buf.len(),
    value: u64,
) -> ()
{
    buf[offset] = value as u8 wrapping
    buf[offset + 1] = (value >> 8) as u8 wrapping
    buf[offset + 2] = (value >> 16) as u8 wrapping
    buf[offset + 3] = (value >> 24) as u8 wrapping
    buf[offset + 4] = (value >> 32) as u8 wrapping
    buf[offset + 5] = (value >> 40) as u8 wrapping
    buf[offset + 6] = (value >> 48) as u8 wrapping
    buf[offset + 7] = (value >> 56) as u8 wrapping
}

public function write_u64_be(
    buf: mutable [u8],
    offset: usize where offset + 8 <= buf.len(),
    value: u64,
) -> ()
{
    buf[offset] = (value >> 56) as u8 wrapping
    buf[offset + 1] = (value >> 48) as u8 wrapping
    buf[offset + 2] = (value >> 40) as u8 wrapping
    buf[offset + 3] = (value >> 32) as u8 wrapping
    buf[offset + 4] = (value >> 24) as u8 wrapping
    buf[offset + 5] = (value >> 16) as u8 wrapping
    buf[offset + 6] = (value >> 8) as u8 wrapping
    buf[offset + 7] = value as u8 wrapping
}


public stable function read_i32_le(
    buf: [u8],
    offset: usize where offset + 4 <= buf.len(),
) -> i32
{
    return read_u32_le(buf, offset) as i32 wrapping
}

public stable function read_i32_be(
    buf: [u8],
    offset: usize where offset + 4 <= buf.len(),
) -> i32
{
    return read_u32_be(buf, offset) as i32 wrapping
}

public function write_i32_le(
    buf: mutable [u8],
    offset: usize where offset + 4 <= buf.len(),
    value: i32,
) -> ()
{
    write_u32_le(mutable buf, offset, value as u32 wrapping)
}

public function write_i32_be(
    buf: mutable [u8],
    offset: usize where offset + 4 <= buf.len(),
    value: i32,
) -> ()
{
    write_u32_be(mutable buf, offset, value as u32 wrapping)
}

public stable function read_i64_le(
    buf: [u8],
    offset: usize where offset + 8 <= buf.len(),
) -> i64
{
    return read_u64_le(buf, offset) as i64 wrapping
}

public stable function read_i64_be(
    buf: [u8],
    offset: usize where offset + 8 <= buf.len(),
) -> i64
{
    return read_u64_be(buf, offset) as i64 wrapping
}

public function write_i64_le(
    buf: mutable [u8],
    offset: usize where offset + 8 <= buf.len(),
    value: i64,
) -> ()
{
    write_u64_le(mutable buf, offset, value as u64 wrapping)
}

public function write_i64_be(
    buf: mutable [u8],
    offset: usize where offset + 8 <= buf.len(),
    value: i64,
) -> ()
{
    write_u64_be(mutable buf, offset, value as u64 wrapping)
}


module std.mem.alloc

public type AllocError {
    case out_of_memory
}

public spec Box(comptime T: Type) {


    public type Box {
    }

    public function new(value: take T, allocator: Allocator) -> Box
        with {allocator, err: alloc.AllocError}
    extern "__edda_alloc"

    public function get(b: Box) -> T
    extern "__edda_box_read"



    public function unbox(b: take Box, allocator: mutable Allocator) -> T
        with {allocator}
    extern "__edda_box_unbox"

    public function drop(b: take Box) -> ()
    extern "__edda_free"
}

public function fork(a: Allocator) -> Allocator
    with {a}
    extern "__edda_heap_fork"

public function close(a: take Allocator) -> ()
    with {a}
    extern "__edda_heap_destroy"

public spec Array(comptime T: Type) where size_of(T) > 0 {

    public function alloc(allocator: Allocator, n: usize) -> [T]
        with {allocator, err: alloc.AllocError}
        ensures result.len() == n
    extern "__edda_alloc_array"
}

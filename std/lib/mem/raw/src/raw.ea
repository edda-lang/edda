
module std.mem.raw

public spec Mem(comptime T: Type) {

    public stable function swap(a: mutable T, b: mutable T) -> () {
        let tmp = a
        a = b
        b = tmp
    }

    public stable function replace(slot: mutable T, new: take T) -> T {
        let old = slot
        slot = new
        return old
    }
}

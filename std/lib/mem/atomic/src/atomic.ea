
module std.mem.atomic

public affine type AtomicI32 {
    slot: i32,
}

public stable function atomic_i32_new(initial: i32) -> AtomicI32 {
    return AtomicI32 { slot: initial }
}

public function atomic_i32_load(a: AtomicI32) -> i32
    extern "__edda_atomic_i32_load"

public function atomic_i32_store(a: mutable AtomicI32, value: i32) -> ()
    extern "__edda_atomic_i32_store"

public function atomic_i32_compare_exchange(
    a: mutable AtomicI32,
    expected: i32,
    desired: i32,
) -> i32
    extern "__edda_atomic_i32_compare_exchange"

public function atomic_i32_fetch_add(a: mutable AtomicI32, delta: i32) -> i32
    extern "__edda_atomic_i32_fetch_add"

public function atomic_i32_fetch_sub(a: mutable AtomicI32, delta: i32) -> i32
    extern "__edda_atomic_i32_fetch_sub"



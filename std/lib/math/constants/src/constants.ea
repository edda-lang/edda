
module std.math.constants


public function pi_f64() -> f64 {
    return 3.141592653589793
}

public function tau_f64() -> f64 {
    return 6.283185307179586
}

public function half_pi_f64() -> f64 {
    return 1.5707963267948966
}

public function e_f64() -> f64 {
    return 2.718281828459045
}

public function ln_2_f64() -> f64 {
    return 0.6931471805599453
}

public function ln_10_f64() -> f64 {
    return 2.302585092994046
}

public function log2_e_f64() -> f64 {
    return 1.4426950408889634
}

public function log10_e_f64() -> f64 {
    return 0.4342944819032518
}

public function sqrt_2_f64() -> f64 {
    return 1.4142135623730951
}

public function frac_1_sqrt_2_f64() -> f64 {
    return 0.7071067811865476
}

public function sqrt_3_f64() -> f64 {
    return 1.7320508075688772
}

public function phi_f64() -> f64 {
    return 1.618033988749895
}


public function pi_f32() -> f32 {
    return 3.1415927
}

public function tau_f32() -> f32 {
    return 6.2831855
}

public function half_pi_f32() -> f32 {
    return 1.5707964
}

public function e_f32() -> f32 {
    return 2.7182817
}

public function ln_2_f32() -> f32 {
    return 0.6931472
}

public function ln_10_f32() -> f32 {
    return 2.3025851
}

public function log2_e_f32() -> f32 {
    return 1.442695
}

public function log10_e_f32() -> f32 {
    return 0.4342945
}

public function sqrt_2_f32() -> f32 {
    return 1.4142135
}

public function frac_1_sqrt_2_f32() -> f32 {
    return 0.70710677
}

public function sqrt_3_f32() -> f32 {
    return 1.7320508
}

public function phi_f32() -> f32 {
    return 1.618034
}

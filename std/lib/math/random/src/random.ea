
module std.math.random

public function next_u64(rng: mutable Random) -> u64
    with {rng, nondet}
    extern "__edda_random_next_u64"

public function next_u32(rng: mutable Random) -> u32
    with {rng, nondet}
    extern "__edda_random_next_u32"

public function in_range_u64(
    rng: mutable Random,
    lo: u64,
    hi: u64 where lo < hi,
) -> u64
    with {rng, nondet}
    ensures result >= lo
    ensures result < hi
    extern "__edda_random_in_range_u64"

public function next_bool(rng: mutable Random) -> bool
    with {rng, nondet}
{
    return (next_u64(mutable rng) & 1) == 1
}

public function fill_bytes(rng: mutable Random, buf: mutable [u8]) -> ()
    with {rng, nondet}
    extern "__edda_random_fill_bytes"

public function deterministic(rng: Random, seed: u64) -> DeterministicRandom
    with {rng}
    extern "__edda_random_deterministic"


public stable function det_next_u64(rng: mutable DeterministicRandom) -> u64
    with {rng}
    extern "__edda_det_random_next_u64"

public stable function det_next_u32(rng: mutable DeterministicRandom) -> u32
    with {rng}
    extern "__edda_det_random_next_u32"

public stable function det_in_range_u64(
    rng: mutable DeterministicRandom,
    lo: u64,
    hi: u64 where lo < hi,
) -> u64
    with {rng}
    ensures result >= lo
    ensures result < hi
    extern "__edda_det_random_in_range_u64"

public stable function det_next_bool(rng: mutable DeterministicRandom) -> bool
    with {rng}
{
    return (det_next_u64(mutable rng) & 1) == 1
}

public stable function det_fill_bytes(
    rng: mutable DeterministicRandom,
    buf: mutable [u8],
) -> ()
    with {rng}
    extern "__edda_det_random_fill_bytes"


module std.math.scalar


public function abs_i64(n: i64) -> i64
    with {panic}
{
    if n == -9223372036854775808 {
        panic("abs_i64 overflow on i64::MIN")
    }
    if n < 0 {
        return -n
    }
    return n
}

public function abs_i32(n: i32) -> i32
    with {panic}
{
    if n == -2147483648 {
        panic("abs_i32 overflow on i32::MIN")
    }
    if n < 0 {
        return -n
    }
    return n
}


public function min_i64(a: i64, b: i64) -> i64 {
    return if a <= b { a } else { b }
}

public function max_i64(a: i64, b: i64) -> i64 {
    return if a >= b { a } else { b }
}


public function min_i32(a: i32, b: i32) -> i32 {
    return if a <= b { a } else { b }
}

public function max_i32(a: i32, b: i32) -> i32 {
    return if a >= b { a } else { b }
}


public function min_u64(a: u64, b: u64) -> u64 {
    return if a <= b { a } else { b }
}

public function max_u64(a: u64, b: u64) -> u64 {
    return if a >= b { a } else { b }
}


public function min_usize(a: usize, b: usize) -> usize {
    return if a <= b { a } else { b }
}

public function max_usize(a: usize, b: usize) -> usize {
    return if a >= b { a } else { b }
}


public function clamp_i64(value: i64, lo: i64, hi: i64) -> i64
    requires lo <= hi
    ensures  result >= lo
    ensures  result <= hi
{
    if value < lo {
        return lo
    } else if value > hi {
        return hi
    } else {
        return value
    }
}

public function clamp_usize(value: usize, lo: usize, hi: usize) -> usize
    requires lo <= hi
    ensures  result >= lo
    ensures  result <= hi
{
    if value < lo {
        return lo
    } else if value > hi {
        return hi
    } else {
        return value
    }
}


public function ceil_div_usize(a: usize, b: usize) -> usize
    requires b > 0
{
    if a == 0 {
        return 0
    }
    return ((a - 1) / b) + 1
}

public function log2_floor_usize(n: usize) -> usize
    requires n > 0
{
    var x: usize = n
    var bits: usize = 0
    loop
        decreases x
    {
        if x <= 1 { break }
        x = x / 2
        bits += 1
    }
    return bits
}

public function is_power_of_two_usize(n: usize) -> bool {
    if n == 0 {
        return false
    }
    return (n & (n - 1)) == 0
}


public stable function f64_to_bits(value: f64) -> u64
    extern "__edda_f64_to_bits"

public stable function f64_from_bits(bits: u64) -> f64
    extern "__edda_f64_from_bits"

public stable function f32_to_bits(value: f32) -> u32
    extern "__edda_f32_to_bits"

public stable function f32_from_bits(bits: u32) -> f32
    extern "__edda_f32_from_bits"

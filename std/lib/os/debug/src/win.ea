
module std.os.debug.win

public function debug_active_process(pid: u32) -> i32
    extern "DebugActiveProcess" from "kernel32.dll"

public function debug_active_process_stop(pid: u32) -> i32
    extern "DebugActiveProcessStop" from "kernel32.dll"

public function wait_for_debug_event(evt: u64, ms: u32) -> i32
    extern "WaitForDebugEvent" from "kernel32.dll"

public function continue_debug_event(pid: u32, tid: u32, status: u32) -> i32
    extern "ContinueDebugEvent" from "kernel32.dll"

public function open_thread(access: u32, inherit: i32, tid: u32) -> u64
    extern "OpenThread" from "kernel32.dll"

public function close_handle(h: u64) -> i32
    extern "CloseHandle" from "kernel32.dll"

public function get_thread_context(thread: u64, ctx: u64) -> i32
    extern "GetThreadContext" from "kernel32.dll"

public function set_thread_context(thread: u64, ctx: u64) -> i32
    extern "SetThreadContext" from "kernel32.dll"

public function read_process_memory(proc: u64, base: u64, buf: u64, size: u64, read_out: u64) -> i32
    extern "ReadProcessMemory" from "kernel32.dll"

public function write_process_memory(proc: u64, base: u64, buf: u64, size: u64, written: u64) -> i32
    extern "WriteProcessMemory" from "kernel32.dll"

public function flush_instruction_cache(proc: u64, base: u64, size: u64) -> i32
    extern "FlushInstructionCache" from "kernel32.dll"

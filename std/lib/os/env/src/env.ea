
module std.os.env

import std.core.option

spec std.core.option.Option(String)

public type EnvError {
    case not_set(name: String)
    case invalid_utf8(name: String)
}

function getenv(name: String, out: mutable String, allocator: Allocator) -> i32
    with {allocator}
    extern "__edda_getenv"

public function read_optional(name: String, allocator: Allocator) -> Option_String
    with {allocator}
{
    var value: String = ""
    let found = getenv(name, mutable value, allocator)
    return if found == 1 {
        Option_String.some(value: value)
    } else {
        Option_String.none
    }
}

public function current_dir(allocator: Allocator) -> String
    with {allocator}
    extern "__edda_cwd"

public function self_exe_path(allocator: Allocator) -> String
    with {allocator}
    extern "__edda_self_exe_path"



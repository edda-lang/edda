
module std.os.process.caps

function get_std_handle(n_std_handle: u64) -> u64
    extern "GetStdHandle" from "kernel32.dll"

public function inherit_fd() -> u64 {
    return 0xFFFFFFFFFFFFFFFF
}

public function stdin_fd(h: take Stdin) -> u64
    extern "__edda_cap_fd_stdin"

@abi("__edda_cap_fd_stdin")
public function stdin_fd_impl(c: u64) -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF6)
    } else {
        return c
    }
}

public function stdout_fd(h: take Stdout) -> u64
    extern "__edda_cap_fd_stdout"

@abi("__edda_cap_fd_stdout")
public function stdout_fd_impl(c: u64) -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF5)
    } else {
        return c
    }
}

public function stderr_fd(h: take Stderr) -> u64
    extern "__edda_cap_fd_stderr"

@abi("__edda_cap_fd_stderr")
public function stderr_fd_impl(c: u64) -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF4)
    } else {
        return c
    }
}

public function fs_fd(h: take Filesystem) -> u64
    extern "__edda_cap_fd_fs"

@abi("__edda_cap_fd_fs")
public function fs_fd_impl(c: u64) -> u64 {
    return c
}

public function rofs_fd(h: take ReadOnlyFilesystem) -> u64
    extern "__edda_cap_fd_rofs"

@abi("__edda_cap_fd_rofs")
public function rofs_fd_impl(c: u64) -> u64 {
    return c
}


public function inherit_stdin() -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF6)
    } else {
        return 0
    }
}

public function inherit_stdout() -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF5)
    } else {
        return 1
    }
}

public function inherit_stderr() -> u64 {
    comptime if target_has("windows") {
        return get_std_handle(0xFFFFFFF4)
    } else {
        return 2
    }
}

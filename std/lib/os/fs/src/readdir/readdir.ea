
module std.os.fs.readdir
import local.readdir.error as rderr
import local.readdir.win as win
import local.readdir.linux as linux

public function read_dir(rfs: ReadOnlyFilesystem, path: String, allocator: Allocator) -> [String]
    with {rfs, allocator, err: rderr.ReadDirError}
{
    comptime if target_has("windows") {
        return win.read_dir_windows(rfs, path, allocator)?
    } else {
        return linux.read_dir_linux(rfs, path, allocator)?
    }
}

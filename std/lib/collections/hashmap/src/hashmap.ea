
module std.collections.hashmap

import std.mem.alloc
import std.core.hash
import std.core.option
import local.table

public function string_hash(s: String) -> u64 {
    return hash.hash_string(s)
}

public function string_eq(a: String, b: String) -> bool {
    return a == b
}

public spec StringMap(comptime V: Type) {
    spec std.collections.hashmap.table.HashMap(String, V, string_hash, string_eq)
    spec std.core.option.Option(V)

    public type StringMap { inner: HashMap_String_V_string_hash_string_eq.HashMap }

    public function new(allocator: Allocator) -> StringMap
        with {allocator, err: alloc.AllocError}
    {
        return StringMap { inner: HashMap_String_V_string_hash_string_eq.new(allocator)? }
    }

    public function len(map: StringMap) -> usize {
        return HashMap_String_V_string_hash_string_eq.len(map.inner)
    }

    public function is_empty(map: StringMap) -> bool {
        return HashMap_String_V_string_hash_string_eq.is_empty(map.inner)
    }

    public function contains(map: StringMap, key: String) -> bool {
        return HashMap_String_V_string_hash_string_eq.contains(map.inner, key)
    }

    public function get(map: StringMap, key: String) -> Option_V {
        return HashMap_String_V_string_hash_string_eq.get(map.inner, key)
    }

    public function insert(map: mutable StringMap, key: String, value: take V, allocator: Allocator) -> Option_V
        with {allocator, err: alloc.AllocError}
    {
        return HashMap_String_V_string_hash_string_eq.insert(mutable map.inner, key, take value, allocator)?
    }

    public function remove(map: mutable StringMap, key: String) -> Option_V {
        return HashMap_String_V_string_hash_string_eq.remove(mutable map.inner, key)
    }

    public function contains_bytes(map: StringMap, key: [u8]) -> bool {
        let h = hash.hash_u8_slice(key)
        let idx = _probe_index_bytes(map.inner, key, h)
        return map.inner.entries[idx].occupied
    }

    public function get_bytes(map: StringMap, key: [u8]) -> Option_V {
        let h = hash.hash_u8_slice(key)
        let idx = _probe_index_bytes(map.inner, key, h)
        let slot = map.inner.entries[idx]
        if slot.occupied {
            return Option_V.some(value: slot.value)
        }
        return Option_V.none
    }

    function _bytes_equals(a: String, key: [u8]) -> bool {
        let ab = a.bytes()
        let n: usize = ab.len()
        if n != key.len() { return false }
        var i: usize = 0
        loop
            decreases n - i
        {
            if i >= n { break }
            if ab[i] != key[i] { return false }
            i += 1
        }
        return true
    }

    function _probe_index_bytes(inner: HashMap_String_V_string_hash_string_eq.HashMap, key: [u8], hash: u64) -> usize {
        let cap = inner.entries.len()
        let mask = cap - 1
        var i: usize = (hash as usize) & mask
        var probes: usize = 0
        loop
            decreases cap - probes
        {
            if probes >= cap { return i }
            let slot = inner.entries[i]
            if !slot.occupied { return i }
            if slot.hash == hash && _bytes_equals(slot.key, key) { return i }
            i = (i + 1) & mask
            probes += 1
        }
    }
}

public function i64_hash(n: i64) -> u64 {
    return hash.hash_i64(n)
}

public function i64_eq(a: i64, b: i64) -> bool {
    return a == b
}

public spec IntMap(comptime V: Type) {
    spec std.collections.hashmap.table.HashMap(i64, V, i64_hash, i64_eq)
    spec std.core.option.Option(V)

    public type IntMap { inner: HashMap_i64_V_i64_hash_i64_eq.HashMap }

    public function new(allocator: Allocator) -> IntMap
        with {allocator, err: alloc.AllocError}
    {
        return IntMap { inner: HashMap_i64_V_i64_hash_i64_eq.new(allocator)? }
    }

    public stable function len(map: IntMap) -> usize {
        return map.inner.len
    }

    public function is_empty(map: IntMap) -> bool {
        return HashMap_i64_V_i64_hash_i64_eq.is_empty(map.inner)
    }

    public function clone_of(map: IntMap, allocator: Allocator) -> IntMap
        with {allocator, err: alloc.AllocError}
    {
        return IntMap { inner: HashMap_i64_V_i64_hash_i64_eq.clone(map.inner, allocator)? }
    }

    public function contains(map: IntMap, key: i64) -> bool {
        return HashMap_i64_V_i64_hash_i64_eq.contains(map.inner, key)
    }

    public stable function get(map: IntMap, key: i64) -> Option_V {
        return _int_get(map, key)
    }

    function _int_get(map: IntMap, key: i64) -> Option_V {
        return HashMap_i64_V_i64_hash_i64_eq.get(map.inner, key)
    }

    public function insert(map: mutable IntMap, key: i64, value: take V, allocator: Allocator) -> Option_V
        with {allocator, err: alloc.AllocError}
    {
        return HashMap_i64_V_i64_hash_i64_eq.insert(mutable map.inner, key, take value, allocator)?
    }

    public function remove(map: mutable IntMap, key: i64) -> Option_V {
        return HashMap_i64_V_i64_hash_i64_eq.remove(mutable map.inner, key)
    }

    public function clear(map: mutable IntMap) -> () {
        HashMap_i64_V_i64_hash_i64_eq.clear(mutable map.inner)
    }
}


module std.collections.deque

public spec Deque(comptime T: Type, comptime CAPACITY: usize) where CAPACITY > 0 {

    public type Deque {
        buffer: [T] where buffer.len() == CAPACITY,
        head: usize where head < CAPACITY,
        len: usize where len <= CAPACITY,
    }


    public stable function capacity(d: Deque) -> usize
        ensures result == CAPACITY
    {
        return CAPACITY
    }

    public stable function len(d: Deque) -> usize
        ensures result <= CAPACITY
    {
        return d.len
    }

    public stable function is_empty(d: Deque) -> bool {
        return d.len == 0
    }

    public stable function is_full(d: Deque) -> bool {
        return d.len == CAPACITY
    }


    public stable function get(d: Deque, i: usize where i < d.len) -> T {
        let physical: usize = (d.head + i) % CAPACITY
        return d.buffer[physical]
    }


    public stable function push_back(d: mutable Deque where d.len < CAPACITY, value: take T) -> () {
        let physical: usize = (d.head + d.len) % CAPACITY
        d.buffer[physical] = value
        d.len = d.len + 1
    }

    public stable function push_front(d: mutable Deque where d.len < CAPACITY, value: take T) -> () {
        let new_head: usize = if d.head == 0 { CAPACITY - 1 } else { d.head - 1 }
        d.head = new_head
        d.buffer[d.head] = value
        d.len = d.len + 1
    }


    public stable function pop_back(d: mutable Deque where d.len > 0) -> T {
        let physical: usize = (d.head + d.len - 1) % CAPACITY
        let value: T = d.buffer[physical]
        d.len = d.len - 1
        return value
    }

    public stable function pop_front(d: mutable Deque where d.len > 0) -> T {
        let value: T = d.buffer[d.head]
        d.head = (d.head + 1) % CAPACITY
        d.len = d.len - 1
        return value
    }


    public stable function clear(d: mutable Deque) -> () {
        d.head = 0
        d.len = 0
    }
}

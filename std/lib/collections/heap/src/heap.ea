
module std.collections.heap

import std.mem.alloc
import std.core.option


public spec MinHeap(comptime T: Type) {
    spec std.core.option.Option(T)

    public type MinHeap {
        data: [T]
        len: usize where len <= data.len()
    }

    public function _realloc_array(data: take [T], n: usize, allocator: Allocator) -> [T]
        with {allocator, err: alloc.AllocError}
    extern "__edda_realloc_array"

    public function new(allocator: Allocator) -> MinHeap
        with {allocator, err: alloc.AllocError}
    {
        let raw = allocator.alloc_array(T, 0)?
        return MinHeap { data: raw, len: 0 }
    }

    public function with_capacity(cap: usize, allocator: Allocator) -> MinHeap
        with {allocator, err: alloc.AllocError}
    {
        let raw = allocator.alloc_array(T, cap)?
        return MinHeap { data: raw, len: 0 }
    }

    public stable function len(h: MinHeap) -> usize {
        return h.len
    }

    public stable function is_empty(h: MinHeap) -> bool {
        return h.len == 0
    }

    public stable function capacity(h: MinHeap) -> usize {
        return h.data.len()
    }

    public function clear(h: mutable MinHeap) -> () {
        h.len = 0
    }

    public function peek(h: MinHeap) -> Option_T {
        if h.len == 0 {
            return Option_T.none
        }
        return Option_T.some(value: h.data[0])
    }

    public function push(h: mutable MinHeap, value: take T, allocator: Allocator) -> ()
        with {allocator, err: alloc.AllocError}
    {
        _reserve(mutable h, h.len + 1, allocator)?
        h.data[h.len] = value
        h.len += 1
        _sift_up(mutable h, h.len - 1)
    }

    public function pop(h: mutable MinHeap) -> Option_T {
        if h.len == 0 {
            return Option_T.none
        }
        let root = h.data[0]
        let last_idx: usize = h.len - 1
        h.data[0] = h.data[last_idx]
        h.len = last_idx
        if h.len > 0 {
            _sift_down(mutable h, 0)
        }
        return Option_T.some(value: root)
    }

    function _sift_up(h: mutable MinHeap, start: usize where start < h.len) -> () {
        var i: usize = start
        loop
            decreases i
        {
            if i == 0 { break }
            let parent: usize = (i - 1) / 2
            if h.data[i] < h.data[parent] {
                let tmp = h.data[parent]
                h.data[parent] = h.data[i]
                h.data[i] = tmp
                i = parent
            } else {
                break
            }
        }
    }

    function _sift_down(h: mutable MinHeap, start: usize where start < h.len) -> () {
        var i: usize = start
        loop
            decreases h.len - i
        {
            let left: usize = 2 * i + 1
            if left >= h.len { break }
            let right: usize = 2 * i + 2
            var smallest: usize = i
            if h.data[left] < h.data[smallest] {
                smallest = left
            }
            if right < h.len {
                if h.data[right] < h.data[smallest] {
                    smallest = right
                }
            }
            if smallest == i { break }
            let tmp = h.data[i]
            h.data[i] = h.data[smallest]
            h.data[smallest] = tmp
            i = smallest
        }
    }

    function _reserve(h: mutable MinHeap, min_cap: usize, allocator: Allocator) -> ()
        with {allocator, err: alloc.AllocError}
    {
        let cap = h.data.len()
        if cap >= min_cap { return }
        let initial_cap: usize = 8
        let two: usize = 2
        let doubled: usize = if cap == 0 { initial_cap } else { cap * two }
        let target: usize = if doubled >= min_cap { doubled } else { min_cap }
        h.data = _realloc_array(take h.data, target, allocator)?
    }
}


public spec MaxHeap(comptime T: Type) {
    spec std.core.option.Option(T)

    public type MaxHeap {
        data: [T]
        len: usize where len <= data.len()
    }

    public function _realloc_array(data: take [T], n: usize, allocator: Allocator) -> [T]
        with {allocator, err: alloc.AllocError}
    extern "__edda_realloc_array"

    public function new(allocator: Allocator) -> MaxHeap
        with {allocator, err: alloc.AllocError}
    {
        let raw = allocator.alloc_array(T, 0)?
        return MaxHeap { data: raw, len: 0 }
    }

    public function with_capacity(cap: usize, allocator: Allocator) -> MaxHeap
        with {allocator, err: alloc.AllocError}
    {
        let raw = allocator.alloc_array(T, cap)?
        return MaxHeap { data: raw, len: 0 }
    }

    public stable function len(h: MaxHeap) -> usize {
        return h.len
    }

    public stable function is_empty(h: MaxHeap) -> bool {
        return h.len == 0
    }

    public stable function capacity(h: MaxHeap) -> usize {
        return h.data.len()
    }

    public function clear(h: mutable MaxHeap) -> () {
        h.len = 0
    }

    public function peek(h: MaxHeap) -> Option_T {
        if h.len == 0 {
            return Option_T.none
        }
        return Option_T.some(value: h.data[0])
    }

    public function push(h: mutable MaxHeap, value: take T, allocator: Allocator) -> ()
        with {allocator, err: alloc.AllocError}
    {
        _reserve(mutable h, h.len + 1, allocator)?
        h.data[h.len] = value
        h.len += 1
        _sift_up(mutable h, h.len - 1)
    }

    public function pop(h: mutable MaxHeap) -> Option_T {
        if h.len == 0 {
            return Option_T.none
        }
        let root = h.data[0]
        let last_idx: usize = h.len - 1
        h.data[0] = h.data[last_idx]
        h.len = last_idx
        if h.len > 0 {
            _sift_down(mutable h, 0)
        }
        return Option_T.some(value: root)
    }

    function _sift_up(h: mutable MaxHeap, start: usize where start < h.len) -> () {
        var i: usize = start
        loop
            decreases i
        {
            if i == 0 { break }
            let parent: usize = (i - 1) / 2
            if h.data[i] > h.data[parent] {
                let tmp = h.data[parent]
                h.data[parent] = h.data[i]
                h.data[i] = tmp
                i = parent
            } else {
                break
            }
        }
    }

    function _sift_down(h: mutable MaxHeap, start: usize where start < h.len) -> () {
        var i: usize = start
        loop
            decreases h.len - i
        {
            let left: usize = 2 * i + 1
            if left >= h.len { break }
            let right: usize = 2 * i + 2
            var largest: usize = i
            if h.data[left] > h.data[largest] {
                largest = left
            }
            if right < h.len {
                if h.data[right] > h.data[largest] {
                    largest = right
                }
            }
            if largest == i { break }
            let tmp = h.data[i]
            h.data[i] = h.data[largest]
            h.data[largest] = tmp
            i = largest
        }
    }

    function _reserve(h: mutable MaxHeap, min_cap: usize, allocator: Allocator) -> ()
        with {allocator, err: alloc.AllocError}
    {
        let cap = h.data.len()
        if cap >= min_cap { return }
        let initial_cap: usize = 8
        let two: usize = 2
        let doubled: usize = if cap == 0 { initial_cap } else { cap * two }
        let target: usize = if doubled >= min_cap { doubled } else { min_cap }
        h.data = _realloc_array(take h.data, target, allocator)?
    }
}


module std.collections.bitset

import std.core.option

spec std.core.option.Option(usize)


public stable function bytes_needed(n_bits: usize) -> usize {
    return (n_bits + 7) / 8
}


public stable function get(bytes: [u8], index: usize where index < bytes.len() * 8) -> bool {
    let byte_idx: usize = index / 8
    let bit_pos: usize = index % 8
    let mask: u8 = 1 << (bit_pos as u8)
    return (bytes[byte_idx] & mask) != 0
}

public stable function set(
    bytes: mutable [u8],
    index: usize where index < bytes.len() * 8,
) -> () {
    let byte_idx: usize = index / 8
    let bit_pos: usize = index % 8
    let mask: u8 = 1 << (bit_pos as u8)
    bytes[byte_idx] = bytes[byte_idx] | mask
}

public stable function clear(
    bytes: mutable [u8],
    index: usize where index < bytes.len() * 8,
) -> () {
    let byte_idx: usize = index / 8
    let bit_pos: usize = index % 8
    let mask: u8 = 1 << (bit_pos as u8)
    bytes[byte_idx] = bytes[byte_idx] & (255 - mask)
}

public stable function toggle(
    bytes: mutable [u8],
    index: usize where index < bytes.len() * 8,
) -> () {
    let byte_idx: usize = index / 8
    let bit_pos: usize = index % 8
    let mask: u8 = 1 << (bit_pos as u8)
    bytes[byte_idx] = bytes[byte_idx] ^ mask
}


public stable function count_set_bits(bytes: [u8]) -> usize {
    let n: usize = bytes.len()
    var total: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        total += _popcount_byte(bytes[i])
        i += 1
    }
    return total
}

public stable function count_clear_bits(bytes: [u8], n_bits: usize) -> usize {
    let avail_bits: usize = bytes.len() * 8
    let scan: usize = if n_bits < avail_bits { n_bits } else { avail_bits }
    var clear_count: usize = 0
    var i: usize = 0
    loop
        decreases scan - i
    {
        if i >= scan { break }
        if !get(bytes, i) {
            clear_count += 1
        }
        i += 1
    }
    return clear_count
}

public stable function find_first_set(bytes: [u8]) -> Option_usize {
    let n: usize = bytes.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { return Option_usize.none }
        if bytes[i] != 0 {
            let eight: usize = 8
            var bit: usize = 0
            loop
                decreases eight - bit
            {
                if bit >= eight { break }
                let mask: u8 = 1 << (bit as u8)
                if (bytes[i] & mask) != 0 {
                    return Option_usize.some(value: i * 8 + bit)
                }
                bit += 1
            }
        }
        i += 1
    }
}

public stable function find_first_clear(bytes: [u8], n_bits: usize) -> Option_usize {
    let avail_bits: usize = bytes.len() * 8
    let scan: usize = if n_bits < avail_bits { n_bits } else { avail_bits }
    var i: usize = 0
    loop
        decreases scan - i
    {
        if i >= scan { return Option_usize.none }
        if !get(bytes, i) {
            return Option_usize.some(value: i)
        }
        i += 1
    }
}


public stable function fill(bytes: mutable [u8]) -> () {
    let n: usize = bytes.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        bytes[i] = 255
        i += 1
    }
}

public stable function clear_all(bytes: mutable [u8]) -> () {
    let n: usize = bytes.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        bytes[i] = 0
        i += 1
    }
}


stable function _popcount_byte(byte: u8) -> usize {
    var v: u8 = byte
    var count: usize = 0
    loop
        decreases v
    {
        if v == 0 { break }
        v = v & (v - 1)
        count += 1
    }
    return count
}

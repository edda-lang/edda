
module std.collections.slice

import std.core.option

spec std.core.option.Option(usize)


public function eq_u8(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n: usize = a.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}

public function eq_i32(a: [i32], b: [i32]) -> bool {
    if a.len() != b.len() { return false }
    let n: usize = a.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}

public function eq_i64(a: [i64], b: [i64]) -> bool {
    if a.len() != b.len() { return false }
    let n: usize = a.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}

public function eq_usize(a: [usize], b: [usize]) -> bool {
    if a.len() != b.len() { return false }
    let n: usize = a.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}


public function find_u8(haystack: [u8], needle: u8) -> Option_usize {
    let n: usize = haystack.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if haystack[i] == needle {
            return Option_usize.some(value: i)
        }
        i += 1
    }
    return Option_usize.none
}

public function find_i64(haystack: [i64], needle: i64) -> Option_usize {
    let n: usize = haystack.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if haystack[i] == needle {
            return Option_usize.some(value: i)
        }
        i += 1
    }
    return Option_usize.none
}

public function contains_u8(haystack: [u8], needle: u8) -> bool {
    return match find_u8(haystack, needle) {
        case .some(_) => true
        case .none    => false
    }
}

public function starts_with_u8(haystack: [u8], prefix: [u8]) -> bool {
    if prefix.len() > haystack.len() { return false }
    let n: usize = prefix.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if haystack[i] != prefix[i] { return false }
        i += 1
    }
    return true
}

public function ends_with_u8(haystack: [u8], suffix: [u8]) -> bool {
    if suffix.len() > haystack.len() { return false }
    let offset = haystack.len() - suffix.len()
    let n: usize = suffix.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if haystack[offset + i] != suffix[i] { return false }
        i += 1
    }
    return true
}


public function copy_u8(dst: mutable [u8], src: [u8]) -> ()
    where dst.len() >= src.len()
extern "__edda_copy_array"


public function reverse_u8_in_place(slice: mutable [u8]) -> () {
    if slice.len() == 0 { return }
    var lo: usize = 0
    var hi: usize = slice.len() - 1
    loop
        decreases hi - lo
    {
        if lo >= hi { break }
        let tmp = slice[lo]
        slice[lo] = slice[hi]
        slice[hi] = tmp
        lo += 1
        hi -= 1
    }
}

public function reverse_i64_in_place(slice: mutable [i64]) -> () {
    if slice.len() == 0 { return }
    var lo: usize = 0
    var hi: usize = slice.len() - 1
    loop
        decreases hi - lo
    {
        if lo >= hi { break }
        let tmp = slice[lo]
        slice[lo] = slice[hi]
        slice[hi] = tmp
        lo += 1
        hi -= 1
    }
}

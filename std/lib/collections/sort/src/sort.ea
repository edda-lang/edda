
module std.collections.sort


public function sort_i64(slice: mutable [i64]) -> () {
    if slice.len() < 2 { return }
    quicksort_i64(mutable slice, 0, slice.len() - 1)
}

function quicksort_i64(slice: mutable [i64], lo: usize, hi: usize) -> ()
    decreases hi - lo
{
    if lo >= hi { return }
    let p = partition_i64(mutable slice, lo, hi)
    if p > lo {
        quicksort_i64(mutable slice, lo, p - 1)
    }
    if p < hi {
        quicksort_i64(mutable slice, p + 1, hi)
    }
}

function partition_i64(slice: mutable [i64], lo: usize, hi: usize) -> usize
    requires lo < hi
    ensures result >= lo
    ensures result <= hi
{
    let n: usize = slice.len()
    let mid = lo + (hi - lo) / 2
    if slice[mid] < slice[lo] {
        let t = slice[lo]; slice[lo] = slice[mid]; slice[mid] = t
    }
    if slice[hi] < slice[lo] {
        let t = slice[lo]; slice[lo] = slice[hi]; slice[hi] = t
    }
    if slice[hi] < slice[mid] {
        let t = slice[mid]; slice[mid] = slice[hi]; slice[hi] = t
    }
    let pivot = slice[mid]
    let tmp = slice[mid]; slice[mid] = slice[hi - 1]; slice[hi - 1] = tmp
    var i: usize = lo
    var j: usize = hi - 1
    loop
        decreases n - i
    {
        loop
            decreases n - i
        {
            if i + 1 >= n { break }
            i += 1
            if slice[i] >= pivot { break }
        }
        loop
            decreases j
        {
            if j == 0 { break }
            j -= 1
            if slice[j] <= pivot { break }
        }
        if i >= j { break }
        let s = slice[i]; slice[i] = slice[j]; slice[j] = s
    }
    let f = slice[i]; slice[i] = slice[hi - 1]; slice[hi - 1] = f
    if i < lo { return lo }
    if i > hi { return hi }
    return i
}

public function is_sorted_i64(slice: [i64]) -> bool {
    if slice.len() < 2 { return true }
    let n: usize = slice.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i + 1 >= n { break }
        if slice[i] > slice[i + 1] { return false }
        i += 1
    }
    return true
}



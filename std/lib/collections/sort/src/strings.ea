
module std.collections.sort.strings


public function sort_strings(slice: mutable [String]) -> () {
    if slice.len() < 2 { return }
    quicksort_strings(mutable slice, 0, slice.len() - 1)
}

function quicksort_strings(slice: mutable [String], lo: usize, hi: usize) -> ()
    decreases hi - lo
{
    if lo >= hi { return }
    let p = partition_strings(mutable slice, lo, hi)
    if p > lo {
        quicksort_strings(mutable slice, lo, p - 1)
    }
    if p < hi {
        quicksort_strings(mutable slice, p + 1, hi)
    }
}

function partition_strings(slice: mutable [String], lo: usize, hi: usize) -> usize
    requires lo < hi
    ensures result >= lo
    ensures result <= hi
{
    let n: usize = slice.len()
    let mid = lo + (hi - lo) / 2
    if string_less(slice[mid], slice[lo]) {
        let t = slice[lo]; slice[lo] = slice[mid]; slice[mid] = t
    }
    if string_less(slice[hi], slice[lo]) {
        let t = slice[lo]; slice[lo] = slice[hi]; slice[hi] = t
    }
    if string_less(slice[hi], slice[mid]) {
        let t = slice[mid]; slice[mid] = slice[hi]; slice[hi] = t
    }
    let pivot = slice[mid]
    let tmp = slice[mid]; slice[mid] = slice[hi - 1]; slice[hi - 1] = tmp
    var i: usize = lo
    var j: usize = hi - 1
    loop
        decreases n - i
    {
        loop
            decreases n - i
        {
            if i + 1 >= n { break }
            i += 1
            if !string_less(slice[i], pivot) { break }
        }
        loop
            decreases j
        {
            if j == 0 { break }
            j -= 1
            if !string_less(pivot, slice[j]) { break }
        }
        if i >= j { break }
        let s = slice[i]; slice[i] = slice[j]; slice[j] = s
    }
    let f = slice[i]; slice[i] = slice[hi - 1]; slice[hi - 1] = f
    if i < lo { return lo }
    if i > hi { return hi }
    return i
}

function string_less(a: String, b: String) -> bool {
    let ab = a.bytes()
    let bb = b.bytes()
    let n = if ab.len() < bb.len() { ab.len() } else { bb.len() }
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if ab[i] < bb[i] { return true }
        if ab[i] > bb[i] { return false }
        i += 1
    }
    return ab.len() < bb.len()
}

public function is_sorted_strings(slice: [String]) -> bool {
    if slice.len() < 2 { return true }
    let n: usize = slice.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i + 1 >= n { break }
        if string_less(slice[i + 1], slice[i]) { return false }
        i += 1
    }
    return true
}

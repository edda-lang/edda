
module std.bytes

public stable function equal(a: [u8], b: [u8]) -> bool {
    if a.len() != b.len() { return false }
    let n: usize = a.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if a[i] != b[i] { return false }
        i += 1
    }
    return true
}

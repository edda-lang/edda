
module std.core.hash

import std.math.scalar


public function fnv_offset() -> u64 {
    return 14695981039346656037
}

public function fnv_prime() -> u64 {
    return 1099511628211
}


public function hash_u8_slice(bytes: [u8]) -> u64 {
    var h: u64 = fnv_offset()
    let n: usize = bytes.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        h = h ^ (bytes[i] as u64)
        h = h *% fnv_prime()
        i += 1
    }
    return h
}

public function hash_string(s: String) -> u64 {
    return hash_u8_slice(s.bytes())
}


public function hash_i64(n: i64) -> u64 {
    return hash_u64(n as u64)
}

public function hash_u64(n: u64) -> u64 {
    var h: u64 = fnv_offset()
    var v: u64 = n
    let bytes_in_u64: usize = 8
    var k: usize = 0
    loop
        decreases bytes_in_u64 - k
    {
        if k >= bytes_in_u64 { break }
        let byte: u64 = v & 255
        h = h ^ byte
        h = h *% fnv_prime()
        v = v >> 8
        k += 1
    }
    return h
}

public function hash_usize(n: usize) -> u64 {
    return hash_u64(n as u64)
}


public function hash_value<comptime U: Type>(v: U) -> u64 {
    comptime if U == bool {
        return hash_u64(if v { 1 } else { 0 })
    } else { comptime if U == u8 {
        return hash_u64(v as u64)
    } else { comptime if U == i8 {
        return hash_i64(v as i64)
    } else { comptime if U == u16 {
        return hash_u64(v as u64)
    } else { comptime if U == i16 {
        return hash_i64(v as i64)
    } else { comptime if U == u32 {
        return hash_u64(v as u64)
    } else { comptime if U == i32 {
        return hash_i64(v as i64)
    } else { comptime if U == u64 {
        return hash_u64(v)
    } else { comptime if U == i64 {
        return hash_i64(v)
    } else { comptime if U == usize {
        return hash_usize(v)
    } else { comptime if U == isize {
        return hash_i64(v as i64)
    } else { comptime if U == u128 {
        let lo: u64 = v as u64 wrapping
        let hi: u64 = (v >> 64) as u64 wrapping
        let h: u64 = (fnv_offset() ^ hash_u64(lo)) *% fnv_prime()
        return (h ^ hash_u64(hi)) *% fnv_prime()
    } else { comptime if U == i128 {
        let wide: u128 = v as u128 wrapping
        let lo: u64 = wide as u64 wrapping
        let hi: u64 = (wide >> 64) as u64 wrapping
        let h: u64 = (fnv_offset() ^ hash_u64(lo)) *% fnv_prime()
        return (h ^ hash_u64(hi)) *% fnv_prime()
    } else { comptime if U == f32 {
        return hash_u64(scalar.f32_to_bits(v) as u64)
    } else { comptime if U == f64 {
        return hash_u64(scalar.f64_to_bits(v))
    } else { comptime if U == String {
        return hash_string(v)
    } else {
        return fnv_offset()
    } } } } } } } } } } } } } } } }
}


public spec hash(comptime T: Type) {
    public function hash(v: T) -> u64 {
        return hash_value(v)
    }
}

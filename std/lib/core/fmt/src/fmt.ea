    with {allocator, err: alloc.AllocError}
{
    if n == 0 {
        let zero: [u8] = allocator.alloc_array(u8, 1)?
        zero[0] = 0x30
        return string.from_owned_utf8(take zero)
    }
    let scratch: [u8] = allocator.alloc_array(u8, 39)?
    var written: usize = 0
    var value: u128 = n
    loop
        decreases value
    {
        if value == 0 { break }
        let digit: u8 = (value % 10) as u8
        scratch[written] = digit + 0x30
        value = value / 10
        written += 1
    }
    let out: [u8] = allocator.alloc_array(u8, written)?
    var i: usize = 0
    loop
        decreases written - i
    {
        if i >= written { break }
        out[i] = scratch[written - 1 - i]

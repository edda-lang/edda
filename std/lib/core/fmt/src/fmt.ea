
module std.core.fmt
import std.text.string

import std.mem.alloc
import std.collections.vec
import std.collections.hashmap
import std.core.option
import std.math.scalar
import local.dragon


public function string_concat(a: String, b: String) -> String
    extern "__edda_string_concat"


public function u64_to_string(n: u64, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    if n == 0 {
        let zero: [u8] = allocator.alloc_array(u8, 1)?
        zero[0] = 0x30
        return string.from_owned_utf8(take zero)
    }
    let scratch: [u8] = allocator.alloc_array(u8, 20)?
    var written: usize = 0
    var value: u64 = n
    loop
        decreases value
    {
        if value == 0 { break }
        let digit: u8 = (value % 10) as u8
        scratch[written] = digit + 0x30
        value = value / 10
        written += 1
    }
    let out: [u8] = allocator.alloc_array(u8, written)?
    var i: usize = 0
    loop
        decreases written - i
    {
        if i >= written { break }
        out[i] = scratch[written - 1 - i]
        i += 1
    }
    return string.from_owned_utf8(take out)
}

public function u32_to_string(n: u32, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return u64_to_string(n as u64, allocator)?
}

public function usize_to_string(n: usize, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return u64_to_string(n as u64, allocator)?
}


public function i64_to_string(n: i64, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    if n >= 0 {
        return u64_to_string(n as u64, allocator)?
    }
    let magnitude: u64 = ((0 - (n + 1)) as u64) + 1
    let scratch: [u8] = allocator.alloc_array(u8, 20)?
    var written: usize = 0
    var value: u64 = magnitude
    loop
        decreases value
    {
        if value == 0 { break }
        let digit: u8 = (value % 10) as u8
        scratch[written] = digit + 0x30
        value = value / 10
        written += 1
    }
    let out: [u8] = allocator.alloc_array(u8, written + 1)?
    out[0] = 0x2D
    var i: usize = 0
    loop
        decreases written - i
    {
        if i >= written { break }
        out[1 + i] = scratch[written - 1 - i]
        i += 1
    }
    return string.from_owned_utf8(take out)
}

public function i32_to_string(n: i32, allocator: Allocator) -> String
    with {allocator, err: alloc.AllocError}
{
    return i64_to_string(n as i64, allocator)?
}



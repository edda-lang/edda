
module std.core.range

public spec Range(comptime T: Type) {

    public type Range {
        start: T,
        end: T where end >= start,
    }

    public stable function from_bounds(start: T, end: T where end >= start) -> Range {
        return Range { start: start, end: end }
    }

    public stable function is_empty(r: Range) -> bool {
        return r.start == r.end
    }

    public stable function len(r: Range) -> T {
        return r.end - r.start
    }

    public stable function contains(r: Range, x: T) -> bool {
        return x >= r.start && x < r.end
    }

    public stable function start(r: Range) -> T {
        return r.start
    }

    public stable function end(r: Range) -> T {
        return r.end
    }
}


module std.core.outcome

import std.core.option

public spec Outcome(comptime T: Type, comptime E: Type) {

    spec std.core.option.Option(T)
    spec std.core.option.Option(E)

    public type Outcome {
        case ok(value: T)
        case err(value: E)
    }


    public function is_ok(r: Outcome) -> bool {
        return match r {
            case .ok(_)  => true
            case .err(_) => false
        }
    }

    public function is_err(r: Outcome) -> bool {
        return match r {
            case .ok(_)  => false
            case .err(_) => true
        }
    }


    public function unwrap(r: take Outcome) -> T with {panic} {
        return match r {
            case .ok(let value) => value
            case .err(_)        => panic("Outcome.unwrap called on .err")
        }
    }

    public function expect(r: take Outcome, msg: take String) -> T with {panic} {
        return match r {
            case .ok(let value) => value
            case .err(_)        => panic(msg)
        }
    }

    public function expect_err(r: take Outcome, msg: take String) -> E with {panic} {
        return match r {
            case .ok(_)          => panic(msg)
            case .err(let value) => value
        }
    }

    public function unwrap_or(r: take Outcome, default: take T) -> T {
        return match r {
            case .ok(let value) => value
            case .err(_)        => default
        }
    }


    public function ok(r: take Outcome) -> Option_T {
        return match r {
            case .ok(let value) => Option_T.some(value: value)
            case .err(_)        => Option_T.none
        }
    }

    public function err(r: take Outcome) -> Option_E {
        return match r {
            case .ok(_)         => Option_E.none
            case .err(let value) => Option_E.some(value: value)
        }
    }





}

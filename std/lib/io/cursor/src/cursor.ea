
module std.io.cursor

public type CursorError {
    case eof
}

public type Cursor {
    buffer: [u8],
    position: usize where position <= buffer.len(),
}


public stable function new(buffer: [u8]) -> Cursor {
    return Cursor { buffer: buffer, position: 0 }
}

public stable function at(buffer: [u8], position: usize where position <= buffer.len()) -> Cursor {
    return Cursor { buffer: buffer, position: position }
}

public stable function position(c: Cursor) -> usize
    ensures result <= c.buffer.len()
{
    return c.position
}

public stable function remaining(c: Cursor) -> usize
    ensures result == c.buffer.len() - c.position
{
    return c.buffer.len() - c.position
}

public stable function is_at_end(c: Cursor) -> bool {
    return c.position == c.buffer.len()
}


public stable function advance(c: mutable Cursor, n: usize where c.position + n <= c.buffer.len()) -> () {
    c.position = c.position + n
}

public stable function seek(c: mutable Cursor, pos: usize where pos <= c.buffer.len()) -> () {
    c.position = pos
}

public stable function reset(c: mutable Cursor) -> () {
    c.position = 0
}


public function read_u8(c: mutable Cursor) -> u8
    with {err: CursorError}
    extern "__edda_cursor_read_u8"

public function peek_u8(c: Cursor) -> u8
    with {err: CursorError}
    extern "__edda_cursor_peek_u8"


public function read_u16_le(c: mutable Cursor) -> u16
    with {err: CursorError}
    extern "__edda_cursor_read_u16_le"

public function read_u16_be(c: mutable Cursor) -> u16
    with {err: CursorError}
    extern "__edda_cursor_read_u16_be"

public function read_u32_le(c: mutable Cursor) -> u32
    with {err: CursorError}
    extern "__edda_cursor_read_u32_le"

public function read_u32_be(c: mutable Cursor) -> u32
    with {err: CursorError}
    extern "__edda_cursor_read_u32_be"

public function read_u64_le(c: mutable Cursor) -> u64
    with {err: CursorError}
    extern "__edda_cursor_read_u64_le"

public function read_u64_be(c: mutable Cursor) -> u64
    with {err: CursorError}
    extern "__edda_cursor_read_u64_be"


public function read_into(
    c: mutable Cursor,
    n: usize,
    out: mutable [u8],
    offset: usize where offset + n <= out.len(),
) -> usize
    with {err: CursorError}
    ensures result == n
    extern "__edda_cursor_read_into"

public function skip(c: mutable Cursor, n: usize) -> ()
    with {err: CursorError}
    extern "__edda_cursor_skip"

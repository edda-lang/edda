
module std.text.utf8

public stable function codepoint_byte_length(cp: Codepoint) -> usize
    ensures result >= 1
    ensures result <= 4
    extern "__edda_utf8_codepoint_byte_length"

public stable function max_byte_length() -> usize {
    return 4
}


public stable function is_leading_byte(byte: u8) -> bool {
    return byte <= 127 || byte >= 192
}

public stable function is_continuation_byte(byte: u8) -> bool {
    return byte >= 128 && byte <= 191
}

public stable function sequence_length_from_leading(byte: u8 where is_leading_byte(byte)) -> usize
    ensures result >= 1
    ensures result <= 4
{
    if byte < 0x80 { return 1 }
    if byte < 0xE0 { return 2 }
    if byte < 0xF0 { return 3 }
    return 4
}


public stable function validate(bytes: [u8]) -> bool
{
    var i: usize = 0
    loop
        decreases bytes.len() - i
    {
        if i >= bytes.len() { break }
        let b0: u8 = bytes[i]
        if b0 < 0x80 {
            i = i + 1
        } else if b0 < 0xC2 {
            return false
        } else if b0 < 0xE0 {
            if i + 1 >= bytes.len() { return false }
            if !is_continuation_byte(bytes[i + 1]) { return false }
            i = i + 2
        } else if b0 < 0xF0 {
            if i + 2 >= bytes.len() { return false }
            let b1: u8 = bytes[i + 1]
            let b2: u8 = bytes[i + 2]
            if !is_continuation_byte(b1) || !is_continuation_byte(b2) { return false }
            if b0 == 0xE0 && b1 < 0xA0 { return false }
            if b0 == 0xED && b1 > 0x9F { return false }
            i = i + 3
        } else if b0 < 0xF5 {
            if i + 3 >= bytes.len() { return false }
            let b1: u8 = bytes[i + 1]
            let b2: u8 = bytes[i + 2]
            let b3: u8 = bytes[i + 3]
            if !is_continuation_byte(b1) || !is_continuation_byte(b2) || !is_continuation_byte(b3) { return false }
            if b0 == 0xF0 && b1 < 0x90 { return false }
            if b0 == 0xF4 && b1 > 0x8F { return false }
            i = i + 4
        } else {
            return false
        }
    }
    return true
}

public stable function count_codepoints(bytes: [u8] where validate(bytes)) -> usize
    ensures result <= bytes.len()
{
    var count: usize = 0
    var i: usize = 0
    loop
        decreases bytes.len() - i
    {
        if i >= bytes.len() { break }
        if !is_continuation_byte(bytes[i]) { count = count + 1 }
        i = i + 1
    }
    return count
}

public stable function decode_at(
    bytes: [u8] where validate(bytes),
    i: usize where i < bytes.len() && is_leading_byte(bytes[i]),
) -> (Codepoint, usize)
    extern "__edda_utf8_decode_at"


public function encode_into(
    cp: Codepoint,
    buf: mutable [u8] where buf.len() >= codepoint_byte_length(cp),
    offset: usize where offset + codepoint_byte_length(cp) <= buf.len(),
) -> usize
    ensures result == codepoint_byte_length(cp)
    extern "__edda_utf8_encode_into"

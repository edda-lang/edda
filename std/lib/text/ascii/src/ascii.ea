
module std.text.ascii

public stable function is_ascii(byte: u8) -> bool {
    return byte <= 127
}

public stable function is_digit(byte: u8) -> bool {
    return byte >= 48 && byte <= 57
}

public stable function is_uppercase(byte: u8) -> bool {
    return byte >= 65 && byte <= 90
}

public stable function is_lowercase(byte: u8) -> bool {
    return byte >= 97 && byte <= 122
}

public stable function is_alpha(byte: u8) -> bool {
    return is_uppercase(byte) || is_lowercase(byte)
}

public stable function is_alphanumeric(byte: u8) -> bool {
    return is_alpha(byte) || is_digit(byte)
}

public stable function is_whitespace(byte: u8) -> bool {
    return byte == 32 || byte == 9 || byte == 10 || byte == 13
}

public stable function is_hex_digit(byte: u8) -> bool {
    return is_digit(byte) || (byte >= 65 && byte <= 70) || (byte >= 97 && byte <= 102)
}

public stable function is_control(byte: u8) -> bool {
    return byte <= 31 || byte == 127
}

public stable function is_printable(byte: u8) -> bool {
    return byte >= 32 && byte <= 126
}


public stable function to_uppercase(byte: u8) -> u8 {
    return if is_lowercase(byte) {
        byte - 32
    } else {
        byte
    }
}

public stable function to_lowercase(byte: u8) -> u8 {
    return if is_uppercase(byte) {
        byte + 32
    } else {
        byte
    }
}


public stable function digit_value(byte: u8 where byte >= 48 && byte <= 57) -> u8
    ensures result <= 9
{
    return byte - 48
}

public stable function hex_digit_value(byte: u8 where is_hex_digit(byte)) -> u8
    ensures result <= 15
{
    return if byte <= 57 {
        byte - 48
    } else if byte <= 70 {
        byte - 55
    } else {
        byte - 87
    }
}

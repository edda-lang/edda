
module std.text.itoa


public type ItoaError {
    case buffer_too_small
}


public stable function digit_count_u64(value: u64) -> usize
    ensures result >= 1
    ensures result <= 20
{
    if value == 0 { return 1 }
    var v: u64 = value
    var count: usize = 0
    loop
        decreases v
    {
        if v == 0 { break }
        v = v / 10
        count += 1
    }
    return count
}

public stable function hex_digit_count_u64(value: u64) -> usize
    ensures result >= 1
    ensures result <= 16
{
    if value == 0 { return 1 }
    var v: u64 = value
    var count: usize = 0
    loop
        decreases v
    {
        if v == 0 { break }
        v = v >> 4
        count += 1
    }
    return count
}

public stable function max_decimal_digits_u64() -> usize {
    return 20
}

public stable function max_decimal_digits_i64() -> usize {
    return 20
}

public stable function max_hex_digits_u64() -> usize {
    return 16
}

public stable function write_u64(
    value: u64,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    let n: usize = out.len()
    let digits: usize = digit_count_u64(value)
    if offset + digits > n {
        raise ItoaError.buffer_too_small
    }
    var v: u64 = value
    var i: usize = 0
    loop
        decreases digits - i
    {
        if i >= digits { break }
        let pos: usize = offset + digits - 1 - i
        let d: u8 = (v % 10) as u8
        out[pos] = d + 48
        v = v / 10
        i += 1
    }
    return offset + digits
}


public stable function write_u64_padded(
    value: u64,
    width: usize,
    pad_byte: u8,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    let n: usize = out.len()
    let digits: usize = digit_count_u64(value)
    let total: usize = if width > digits { width } else { digits }
    if offset + total > n {
        raise ItoaError.buffer_too_small
    }
    let pad_count: usize = total - digits
    var i: usize = 0
    loop
        decreases pad_count - i
    {
        if i >= pad_count { break }
        out[offset + i] = pad_byte
        i += 1
    }
    return write_u64(value, mutable out, offset + pad_count)?
}

public stable function write_i64(
    value: i64,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    let n: usize = out.len()
    var v: i64 = value
    var w: usize = offset

    if v < 0 {
        if w >= n {
            raise ItoaError.buffer_too_small
        }
        out[w] = 45
        w += 1
        v = -v
    }

    var digits: usize = 1
    var t: i64 = v
    loop
        decreases t
    {
        if t < 10 { break }
        t = t / 10
        digits += 1
    }
    if w + digits > n {
        raise ItoaError.buffer_too_small
    }
    var i: usize = 0
    loop
        decreases digits - i
    {
        if i >= digits { break }
        let pos: usize = w + digits - 1 - i
        let d: i64 = v % 10
        out[pos] = (d as u8) + 48
        v = v / 10
        i += 1
    }
    return w + digits
}

stable function _write_hex_at(
    value: u64,
    out: mutable [u8],
    offset: usize,
    letter_offset: u8,
) -> usize
    with {err: ItoaError}
{
    let n: usize = out.len()
    let digits: usize = hex_digit_count_u64(value)
    if offset + digits > n {
        raise ItoaError.buffer_too_small
    }
    var v: u64 = value
    var i: usize = 0
    loop
        decreases digits - i
    {
        if i >= digits { break }
        let pos: usize = offset + digits - 1 - i
        let d: u8 = (v & 15) as u8
        out[pos] = if d < 10 { d + 48 } else { d - 10 + letter_offset }
        v = v >> 4
        i += 1
    }
    return offset + digits
}

public stable function write_u64_hex(
    value: u64,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    return _write_hex_at(value, mutable out, offset, 87)?
}

public stable function write_u64_hex_upper(
    value: u64,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    return _write_hex_at(value, mutable out, offset, 55)?
}

public stable function write_u64_hex_padded(
    value: u64,
    width: usize,
    pad_byte: u8,
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: ItoaError}
{
    let n: usize = out.len()
    let digits: usize = hex_digit_count_u64(value)
    let total: usize = if width > digits { width } else { digits }
    if offset + total > n {
        raise ItoaError.buffer_too_small
    }
    let pad_count: usize = total - digits
    var i: usize = 0
    loop
        decreases pad_count - i
    {
        if i >= pad_count { break }
        out[offset + i] = pad_byte
        i += 1
    }
    return write_u64_hex(value, mutable out, offset + pad_count)?
}

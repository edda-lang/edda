
module std.text.lines

import std.core.option


public type LineEntry {
    start: usize
    end: usize
    resume: usize
}

public type Position {
    line: usize
    column: usize
}

spec std.core.option.Option(LineEntry)
spec std.core.option.Option(usize)


public stable function next_line(input: [u8], pos: usize) -> Option_LineEntry {
    let n: usize = input.len()
    if pos >= n {
        return Option_LineEntry.none
    }
    var i: usize = pos
    loop
        decreases n - i
    {
        if i >= n {
            let entry = LineEntry { start: pos, end: n, resume: n }
            return Option_LineEntry.some(value: entry)
        }
        let byte: u8 = input[i]
        if byte == 10 {
            let entry = LineEntry { start: pos, end: i, resume: i + 1 }
            return Option_LineEntry.some(value: entry)
        }
        if byte == 13 && i + 1 < n && input[i + 1] == 10 {
            let entry = LineEntry { start: pos, end: i, resume: i + 2 }
            return Option_LineEntry.some(value: entry)
        }
        i += 1
    }
}


public stable function count_lines(input: [u8]) -> usize {
    let n: usize = input.len()
    if n == 0 { return 0 }
    var count: usize = 0
    var pos: usize = 0
    loop
        decreases n + 1 - pos
    {
        if pos > n { break }
        if pos == n { break }
        count += 1
        var i: usize = pos
        loop
            decreases n - i
        {
            if i >= n {
                pos = n + 1
                break
            }
            let byte: u8 = input[i]
            if byte == 10 {
                pos = i + 1
                break
            }
            if byte == 13 && i + 1 < n && input[i + 1] == 10 {
                pos = i + 2
                break
            }
            i += 1
        }
    }
    return count
}

public stable function line_at(input: [u8], index: usize) -> Option_LineEntry {
    var pos: usize = 0
    var current: usize = 0
    let n: usize = input.len()
    loop
        decreases n + 1 - pos
    {
        if pos > n { return Option_LineEntry.none }
        match next_line(input, pos) {
            case .some(let entry) => {
                if current == index {
                    return Option_LineEntry.some(value: entry)
                }
                current += 1
                pos = entry.resume
            }
            case .none => return Option_LineEntry.none
        }
    }
}

public stable function position_at_offset(input: [u8], offset: usize) -> Position {
    let n: usize = input.len()
    let target: usize = if offset > n { n } else { offset }
    var line: usize = 0
    var line_start: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= target { break }
        let byte: u8 = input[i]
        if byte == 10 {
            line += 1
            line_start = i + 1
            i += 1
        } else if byte == 13 && i + 1 < n && input[i + 1] == 10 {
            line += 1
            line_start = i + 2
            i += 2
        } else {
            i += 1
        }
    }
    return Position { line: line, column: target - line_start }
}

public stable function offset_at_position(input: [u8], pos: Position) -> Option_usize {
    match line_at(input, pos.line) {
        case .some(let entry) => {
            let line_len: usize = entry.end - entry.start
            if pos.column > line_len {
                return Option_usize.none
            }
            return Option_usize.some(value: entry.start + pos.column)
        }
        case .none => return Option_usize.none
    }
}

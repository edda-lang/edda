
module std.text.htmlescape


public type HtmlEscapeError {
    case buffer_too_small
}


public stable function max_escaped_len(n: usize) -> usize
    ensures result >= n
{
    return n * 6
}


public stable function escape_html(
    input: [u8],
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: HtmlEscapeError}
{
    let n: usize = input.len()
    var i: usize = 0
    var w: usize = offset

    loop
        decreases n - i
    {
        if i >= n { break }
        let byte: u8 = input[i]
        if byte == 38 {
            w = _write_entity_amp(mutable out, w)?
        } else if byte == 60 {
            w = _write_entity_lt(mutable out, w)?
        } else if byte == 62 {
            w = _write_entity_gt(mutable out, w)?
        } else if byte == 34 {
            w = _write_entity_quot(mutable out, w)?
        } else {
            w = _write_one(mutable out, w, byte)?
        }
        i += 1
    }
    return w
}

public stable function escape_html_attr(
    input: [u8],
    out: mutable [u8],
    offset: usize,
) -> usize
    with {err: HtmlEscapeError}
{
    let n: usize = input.len()
    var i: usize = 0
    var w: usize = offset

    loop
        decreases n - i
    {
        if i >= n { break }
        let byte: u8 = input[i]
        if byte == 38 {
            w = _write_entity_amp(mutable out, w)?
        } else if byte == 60 {
            w = _write_entity_lt(mutable out, w)?
        } else if byte == 62 {
            w = _write_entity_gt(mutable out, w)?
        } else if byte == 34 {
            w = _write_entity_quot(mutable out, w)?
        } else if byte == 39 {
            w = _write_entity_apos(mutable out, w)?
        } else {
            w = _write_one(mutable out, w, byte)?
        }
        i += 1
    }
    return w
}


stable function _write_entity_amp(out: mutable [u8], w: usize) -> usize
    with {err: HtmlEscapeError}
{
    if w + 4 >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = 38
    out[w + 1] = 97
    out[w + 2] = 109
    out[w + 3] = 112
    out[w + 4] = 59
    return w + 5
}

stable function _write_entity_lt(out: mutable [u8], w: usize) -> usize
    with {err: HtmlEscapeError}
{
    if w + 3 >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = 38
    out[w + 1] = 108
    out[w + 2] = 116
    out[w + 3] = 59
    return w + 4
}

stable function _write_entity_gt(out: mutable [u8], w: usize) -> usize
    with {err: HtmlEscapeError}
{
    if w + 3 >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = 38
    out[w + 1] = 103
    out[w + 2] = 116
    out[w + 3] = 59
    return w + 4
}

stable function _write_entity_quot(out: mutable [u8], w: usize) -> usize
    with {err: HtmlEscapeError}
{
    if w + 5 >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = 38
    out[w + 1] = 113
    out[w + 2] = 117
    out[w + 3] = 111
    out[w + 4] = 116
    out[w + 5] = 59
    return w + 6
}

stable function _write_entity_apos(out: mutable [u8], w: usize) -> usize
    with {err: HtmlEscapeError}
{
    if w + 4 >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = 38
    out[w + 1] = 35
    out[w + 2] = 51
    out[w + 3] = 57
    out[w + 4] = 59
    return w + 5
}

stable function _write_one(out: mutable [u8], w: usize, byte: u8) -> usize
    with {err: HtmlEscapeError}
{
    if w >= out.len() { raise HtmlEscapeError.buffer_too_small }
    out[w] = byte
    return w + 1
}

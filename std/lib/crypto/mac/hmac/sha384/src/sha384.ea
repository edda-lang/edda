
module std.crypto.mac.hmac.sha384

import std.crypto.hash.sha512 as sha2


function _hmac384_kp_byte(
    i: usize,
    key: [u8],
    key_needs_hashing: bool,
    k_hashed: sha2.Sha512Hash,
) -> u8 {
    if key_needs_hashing {
        if i >= 48 { return 0 }
        let word_idx: usize = i / 8
        let byte_idx: usize = i % 8
        let shift_amount: u64 = (((7 as usize) - byte_idx) * 8) as u64
        var w: u64 = 0
        if word_idx == 0 {
            w = k_hashed.h0
        } else if word_idx == 1 {
            w = k_hashed.h1
        } else if word_idx == 2 {
            w = k_hashed.h2
        } else if word_idx == 3 {
            w = k_hashed.h3
        } else if word_idx == 4 {
            w = k_hashed.h4
        } else {
            w = k_hashed.h5
        }
        return ((w >> shift_amount) & 0xff) as u8
    }
    if i >= key.len() { return 0 }
    return key[i]
}

function _hmac384_pad_word(
    word_idx: usize,
    key: [u8],
    key_needs_hashing: bool,
    k_hashed: sha2.Sha512Hash,
    xor_pad: u8,
) -> u64 {
    let base: usize = word_idx * 8
    let b0: u8 = _hmac384_kp_byte(base, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b1: u8 = _hmac384_kp_byte(base + 1, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b2: u8 = _hmac384_kp_byte(base + 2, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b3: u8 = _hmac384_kp_byte(base + 3, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b4: u8 = _hmac384_kp_byte(base + 4, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b5: u8 = _hmac384_kp_byte(base + 5, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b6: u8 = _hmac384_kp_byte(base + 6, key, key_needs_hashing, k_hashed) ^ xor_pad
    let b7: u8 = _hmac384_kp_byte(base + 7, key, key_needs_hashing, k_hashed) ^ xor_pad
    return ((b0 as u64) << 56)
        | ((b1 as u64) << 48)
        | ((b2 as u64) << 40)
        | ((b3 as u64) << 32)
        | ((b4 as u64) << 24)
        | ((b5 as u64) << 16)
        | ((b6 as u64) << 8)
        | (b7 as u64)
}

function _hmac384_pad_block(
    key: [u8],
    key_needs_hashing: bool,
    k_hashed: sha2.Sha512Hash,
    xor_pad: u8,
) -> sha2.Sha512Block {
    return sha2.Sha512Block {
        w0: _hmac384_pad_word(0, key, key_needs_hashing, k_hashed, xor_pad),
        w1: _hmac384_pad_word(1, key, key_needs_hashing, k_hashed, xor_pad),
        w2: _hmac384_pad_word(2, key, key_needs_hashing, k_hashed, xor_pad),
        w3: _hmac384_pad_word(3, key, key_needs_hashing, k_hashed, xor_pad),
        w4: _hmac384_pad_word(4, key, key_needs_hashing, k_hashed, xor_pad),
        w5: _hmac384_pad_word(5, key, key_needs_hashing, k_hashed, xor_pad),
        w6: _hmac384_pad_word(6, key, key_needs_hashing, k_hashed, xor_pad),
        w7: _hmac384_pad_word(7, key, key_needs_hashing, k_hashed, xor_pad),
        w8: _hmac384_pad_word(8, key, key_needs_hashing, k_hashed, xor_pad),
        w9: _hmac384_pad_word(9, key, key_needs_hashing, k_hashed, xor_pad),
        w10: _hmac384_pad_word(10, key, key_needs_hashing, k_hashed, xor_pad),
        w11: _hmac384_pad_word(11, key, key_needs_hashing, k_hashed, xor_pad),
        w12: _hmac384_pad_word(12, key, key_needs_hashing, k_hashed, xor_pad),
        w13: _hmac384_pad_word(13, key, key_needs_hashing, k_hashed, xor_pad),
        w14: _hmac384_pad_word(14, key, key_needs_hashing, k_hashed, xor_pad),
        w15: _hmac384_pad_word(15, key, key_needs_hashing, k_hashed, xor_pad),
    }
}

function _hmac384_outer_final_block(inner: sha2.Sha512Hash) -> sha2.Sha512Block {
    return sha2.Sha512Block {
        w0: inner.h0,
        w1: inner.h1,
        w2: inner.h2,
        w3: inner.h3,
        w4: inner.h4,
        w5: inner.h5,
        w6: 0x8000000000000000,
        w7: 0,
        w8: 0,
        w9: 0,
        w10: 0,
        w11: 0,
        w12: 0,
        w13: 0,
        w14: 0,
        w15: 1408,
    }
}


function _hmac384_prehash_key(key: [u8]) -> sha2.Sha512Hash {
    var h: sha2.Sha512Hash = sha2._sha384_init()
    let n: usize = key.len()
    let full_blocks: usize = n / 128
    var b: usize = 0
    loop
        decreases full_blocks - b
    {
        if b >= full_blocks { break }
        sha2._sha512_process_block(mutable h, key, b * 128)
        b += 1
    }
    let tail_start: usize = full_blocks * 128
    let tail_len: usize = n - tail_start
    let total_bits: u64 = (n as u64) *% 8
    sha2._sha512_finalize(mutable h, key, tail_start, tail_len, total_bits)
    return h
}

public function hmac_sha384(
    key: [u8],
    data: [u8],
    out: mutable [u8],
    offset: usize where offset + 48 <= out.len(),
) -> () {
    let key_needs_hashing: bool = key.len() > 128
    var k_hashed: sha2.Sha512Hash = sha2.Sha512Hash {
        h0: 0,
        h1: 0,
        h2: 0,
        h3: 0,
        h4: 0,
        h5: 0,
        h6: 0,
        h7: 0,
    }
    if key_needs_hashing {
        k_hashed = _hmac384_prehash_key(key)
    }

    var inner: sha2.Sha512Hash = sha2._sha384_init()
    let ipad_block: sha2.Sha512Block = _hmac384_pad_block(key, key_needs_hashing, k_hashed, 0x36)
    sha2._sha512_compress(mutable inner, ipad_block)

    let dn: usize = data.len()
    let data_full_blocks: usize = dn / 128
    var db: usize = 0
    loop
        decreases data_full_blocks - db
    {
        if db >= data_full_blocks { break }
        sha2._sha512_process_block(mutable inner, data, db * 128)
        db += 1
    }
    let tail_start: usize = data_full_blocks * 128
    let tail_len: usize = dn - tail_start
    let inner_total_bits: u64 = ((128 as u64) +% (dn as u64)) *% 8
    sha2._sha512_finalize(mutable inner, data, tail_start, tail_len, inner_total_bits)

    var outer: sha2.Sha512Hash = sha2._sha384_init()
    let opad_block: sha2.Sha512Block = _hmac384_pad_block(key, key_needs_hashing, k_hashed, 0x5c)
    sha2._sha512_compress(mutable outer, opad_block)
    let outer_final: sha2.Sha512Block = _hmac384_outer_final_block(inner)
    sha2._sha512_compress(mutable outer, outer_final)

    sha2._sha384_write_digest(outer, mutable out, offset)
}

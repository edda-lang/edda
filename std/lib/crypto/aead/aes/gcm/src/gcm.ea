
module std.crypto.aead.aes.gcm

public type AeadError {
    case auth_failed
}

public function encrypt_128(
    key: [u8] where key.len() == 16,
    nonce: [u8] where nonce.len() == 12,
    plaintext: [u8],
    aad: [u8],
    ciphertext: mutable [u8] where ciphertext.len() == plaintext.len(),
    tag: mutable [u8] where tag.len() == 16,
) -> ()
    extern "__edda_aes128_gcm_encrypt"

public function decrypt_128(
    key: [u8] where key.len() == 16,
    nonce: [u8] where nonce.len() == 12,
    ciphertext: [u8],
    aad: [u8],
    tag: [u8] where tag.len() == 16,
    plaintext: mutable [u8] where plaintext.len() == ciphertext.len(),
) -> ()
    with {err: AeadError}
    extern "__edda_aes128_gcm_decrypt"

public function encrypt_256(
    key: [u8] where key.len() == 32,
    nonce: [u8] where nonce.len() == 12,
    plaintext: [u8],
    aad: [u8],
    ciphertext: mutable [u8] where ciphertext.len() == plaintext.len(),
    tag: mutable [u8] where tag.len() == 16,
) -> ()
    extern "__edda_aes256_gcm_encrypt"

public function decrypt_256(
    key: [u8] where key.len() == 32,
    nonce: [u8] where nonce.len() == 12,
    ciphertext: [u8],
    aad: [u8],
    tag: [u8] where tag.len() == 16,
    plaintext: mutable [u8] where plaintext.len() == ciphertext.len(),
) -> ()
    with {err: AeadError}
    extern "__edda_aes256_gcm_decrypt"

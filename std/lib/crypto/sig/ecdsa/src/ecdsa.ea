    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p384_sign_raw"

public function verify_p384_der(
    public_key: [u8] where public_key.len() == 97,
    message: [u8],
    signature: [u8],
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p384_verify_der"

public function verify_p384_raw(
    public_key: [u8] where public_key.len() == 97,
    message: [u8],
    signature: [u8] where signature.len() == 96,
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p384_verify_raw"


public function sign_p521_der(
    private_scalar: [u8] where private_scalar.len() == 66,
    message: [u8],
    sig_der_out: mutable [u8],
    sig_der_len: mutable usize,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p521_sign_der"

public function sign_p521_raw(
    private_scalar: [u8] where private_scalar.len() == 66,
    message: [u8],
    sig_raw_out: mutable [u8] where sig_raw_out.len() == 132,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p521_sign_raw"

public function verify_p521_der(
    public_key: [u8] where public_key.len() == 133,
    message: [u8],
    signature: [u8],
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p521_verify_der"

public function verify_p521_raw(
    public_key: [u8] where public_key.len() == 133,
    message: [u8],
    signature: [u8] where signature.len() == 132,
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p521_verify_raw"


public function point_compress_p256(
    uncompressed: [u8] where uncompressed.len() == 65,
    compressed_out: mutable [u8] where compressed_out.len() == 33,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_point_compress"

public function point_decompress_p256(
    compressed: [u8] where compressed.len() == 33,
    uncompressed_out: mutable [u8] where uncompressed_out.len() == 65,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_point_decompress"

public function point_compress_p384(
    uncompressed: [u8] where uncompressed.len() == 97,
    compressed_out: mutable [u8] where compressed_out.len() == 49,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p384_point_compress"

public function point_decompress_p384(
    compressed: [u8] where compressed.len() == 49,
    uncompressed_out: mutable [u8] where uncompressed_out.len() == 97,


module std.crypto.sig.ecdsa


public type EcdsaSigError {
    case invalid_private_key_format
    case invalid_public_key_format
    case point_not_on_curve
    case invalid_signature_format
    case der_buffer_too_small
    case internal_error
}


public function sign_p256_der(
    private_scalar: [u8] where private_scalar.len() == 32,
    message: [u8],
    sig_der_out: mutable [u8],
    sig_der_len: mutable usize,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_sign_der"

public function sign_p256_raw(
    private_scalar: [u8] where private_scalar.len() == 32,
    message: [u8],
    sig_raw_out: mutable [u8] where sig_raw_out.len() == 64,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_sign_raw"

public function verify_p256_der(
    public_key: [u8] where public_key.len() == 65,
    message: [u8],
    signature: [u8],
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_verify_der"

public function verify_p256_raw(
    public_key: [u8] where public_key.len() == 65,
    message: [u8],
    signature: [u8] where signature.len() == 64,
) -> bool
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p256_verify_raw"


public function sign_p384_der(
    private_scalar: [u8] where private_scalar.len() == 48,
    message: [u8],
    sig_der_out: mutable [u8],
    sig_der_len: mutable usize,

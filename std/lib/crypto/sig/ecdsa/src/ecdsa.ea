    uncompressed: [u8] where uncompressed.len() == 133,
    compressed_out: mutable [u8] where compressed_out.len() == 67,
) -> ()
    with {err: EcdsaSigError}
    extern "__edda_ecdsa_p521_point_compress"

public function point_decompress_p521(
    compressed: [u8] where compressed.len() == 67,
    uncompressed_out: mutable [u8] where uncompressed_out.len() == 133,

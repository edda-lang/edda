public function parse_spki(
    spki_der: [u8],
    n_out: mutable [u8],
    n_len_out: mutable usize,
    e_out: mutable [u8],
    e_len_out: mutable usize,
) -> ()
    with {err: RsaSigError}
    extern "__edda_rsa_parse_spki"

public function encode_spki(
    n_be: [u8],
    e_be: [u8],
    spki_out: mutable [u8],
    spki_len_out: mutable usize,
) -> ()
    with {err: RsaSigError}
    extern "__edda_rsa_encode_spki"


public function pkcs8_public_components(
    private_key_pkcs8_der: [u8],
    n_out: mutable [u8],
    n_len_out: mutable usize,
    e_out: mutable [u8],
    e_len_out: mutable usize,
) -> ()
    with {err: RsaSigError}
    extern "__edda_rsa_pkcs8_public_components"

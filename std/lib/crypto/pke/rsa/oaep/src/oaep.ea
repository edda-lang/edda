public function decrypt_sha256(
    private_key_pkcs8_der: [u8],
    ciphertext: [u8],
    plaintext_out: mutable [u8],
    plaintext_len_out: mutable usize,
) -> ()
    with {err: RsaOaepError}
    extern "__edda_rsa_oaep_decrypt_sha256"


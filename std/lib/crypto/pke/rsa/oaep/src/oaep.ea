    plaintext: [u8],
    ciphertext_out: mutable [u8],
    ciphertext_len_out: mutable usize,
) -> ()
    with {random, err: RsaOaepError}
    extern "__edda_rsa_oaep_encrypt_sha512"


public function encrypt_sha256_with_label(
    random: Random,
    public_key_spki_der: [u8],
    plaintext: [u8],
    label: [u8],
    ciphertext_out: mutable [u8],
    ciphertext_len_out: mutable usize,
) -> ()
    with {random, err: RsaOaepError}
    extern "__edda_rsa_oaep_encrypt_sha256_lbl"


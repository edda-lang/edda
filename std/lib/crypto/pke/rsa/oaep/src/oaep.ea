
module std.crypto.pke.rsa.oaep


public type RsaOaepError {
    case invalid_spki_format
    case invalid_pkcs8_format
    case unsupported_modulus_size
    case ciphertext_length_mismatch
    case plaintext_too_long
    case ciphertext_buffer_too_small
    case plaintext_buffer_too_small
    case decryption_error
    case internal_error
}


public function encrypt_sha256(
    random: Random,
    public_key_spki_der: [u8],
    plaintext: [u8],
    ciphertext_out: mutable [u8],
    ciphertext_len_out: mutable usize,
) -> ()
    with {random, err: RsaOaepError}
    extern "__edda_rsa_oaep_encrypt_sha256"

public function encrypt_sha384(
    random: Random,
    public_key_spki_der: [u8],
    plaintext: [u8],
    ciphertext_out: mutable [u8],
    ciphertext_len_out: mutable usize,
) -> ()
    with {random, err: RsaOaepError}
    extern "__edda_rsa_oaep_encrypt_sha384"


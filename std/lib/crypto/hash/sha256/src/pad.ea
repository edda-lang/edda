
module std.crypto.hash.sha256.pad

function _sha256_final_byte(
    p: usize,
    data: [u8],
    tail_start: usize,
    tail_len: usize,
    total_bits: u64,
    final_size: usize,
) -> u8 {
    let len_field_start: usize = final_size - 8
    if p < tail_len {
        return data[tail_start + p]
    }
    if p == tail_len {
        return 0x80
    }
    if p < len_field_start {
        return 0
    }
    let byte_idx: usize = p - len_field_start
    let shift_amount: u64 = (((7 as usize) - byte_idx) * 8) as u64
    return ((total_bits >> shift_amount) & 0xff) as u8
}

public function _sha256_final_word(
    data: [u8],
    tail_start: usize,
    tail_len: usize,
    total_bits: u64,
    final_size: usize,
    word_idx: usize,
) -> u32 {
    let base: usize = word_idx * 4
    let b0: u8 = _sha256_final_byte(base, data, tail_start, tail_len, total_bits, final_size)
    let b1: u8 = _sha256_final_byte(base + 1, data, tail_start, tail_len, total_bits, final_size)
    let b2: u8 = _sha256_final_byte(base + 2, data, tail_start, tail_len, total_bits, final_size)
    let b3: u8 = _sha256_final_byte(base + 3, data, tail_start, tail_len, total_bits, final_size)
    return ((b0 as u32) << 24) | ((b1 as u32) << 16) | ((b2 as u32) << 8) | (b3 as u32)
}

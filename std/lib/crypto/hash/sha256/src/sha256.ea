
module std.crypto.hash.sha256

import std.mem.bits
import std.mem.byteorder
import local.pad as pad


public type Sha256Hash {
    h0: u32
    h1: u32
    h2: u32
    h3: u32
    h4: u32
    h5: u32
    h6: u32
    h7: u32
}

public type Sha256Block {
    w0: u32
    w1: u32
    w2: u32
    w3: u32
    w4: u32
    w5: u32
    w6: u32
    w7: u32
    w8: u32
    w9: u32
    w10: u32
    w11: u32
    w12: u32
    w13: u32
    w14: u32
    w15: u32
}

type _Sha256Working {
    a: u32
    b: u32
    c: u32
    d: u32
    e: u32
    f: u32
    g: u32
    h: u32
}


function _ch32(x: u32, y: u32, z: u32) -> u32 {
    return (x & y) ^ ((~x) & z)
}

function _maj32(x: u32, y: u32, z: u32) -> u32 {
    return (x & y) ^ (x & z) ^ (y & z)
}

function _big_sigma0_256(x: u32) -> u32 {
    return bits.rotate_right_u32(x, 2) ^ bits.rotate_right_u32(x, 13) ^ bits.rotate_right_u32(x, 22)
}

function _big_sigma1_256(x: u32) -> u32 {
    return bits.rotate_right_u32(x, 6) ^ bits.rotate_right_u32(x, 11) ^ bits.rotate_right_u32(x, 25)
}

function _small_sigma0_256(x: u32) -> u32 {
    return bits.rotate_right_u32(x, 7) ^ bits.rotate_right_u32(x, 18) ^ (x >> 3)
}

function _small_sigma1_256(x: u32) -> u32 {
    return bits.rotate_right_u32(x, 17) ^ bits.rotate_right_u32(x, 19) ^ (x >> 10)
}

function _sha256_round(s: mutable _Sha256Working, k: u32, w: u32) -> () {
    let t1: u32 = s.h +% _big_sigma1_256(s.e) +% _ch32(s.e, s.f, s.g) +% k +% w
    let t2: u32 = _big_sigma0_256(s.a) +% _maj32(s.a, s.b, s.c)
    s.h = s.g
    s.g = s.f
    s.f = s.e
    s.e = s.d +% t1
    s.d = s.c
    s.c = s.b
    s.b = s.a
    s.a = t1 +% t2
}


public function _sha256_compress(h: mutable Sha256Hash, block: Sha256Block) -> () {
    let w0: u32 = block.w0
    let w1: u32 = block.w1
    let w2: u32 = block.w2
    let w3: u32 = block.w3
    let w4: u32 = block.w4
    let w5: u32 = block.w5
    let w6: u32 = block.w6
    let w7: u32 = block.w7
    let w8: u32 = block.w8
    let w9: u32 = block.w9
    let w10: u32 = block.w10
    let w11: u32 = block.w11
    let w12: u32 = block.w12
    let w13: u32 = block.w13
    let w14: u32 = block.w14
    let w15: u32 = block.w15

    let w16: u32 = _small_sigma1_256(w14) +% w9 +% _small_sigma0_256(w1) +% w0
    let w17: u32 = _small_sigma1_256(w15) +% w10 +% _small_sigma0_256(w2) +% w1
    let w18: u32 = _small_sigma1_256(w16) +% w11 +% _small_sigma0_256(w3) +% w2
    let w19: u32 = _small_sigma1_256(w17) +% w12 +% _small_sigma0_256(w4) +% w3
    let w20: u32 = _small_sigma1_256(w18) +% w13 +% _small_sigma0_256(w5) +% w4
    let w21: u32 = _small_sigma1_256(w19) +% w14 +% _small_sigma0_256(w6) +% w5
    let w22: u32 = _small_sigma1_256(w20) +% w15 +% _small_sigma0_256(w7) +% w6
    let w23: u32 = _small_sigma1_256(w21) +% w16 +% _small_sigma0_256(w8) +% w7
    let w24: u32 = _small_sigma1_256(w22) +% w17 +% _small_sigma0_256(w9) +% w8
    let w25: u32 = _small_sigma1_256(w23) +% w18 +% _small_sigma0_256(w10) +% w9
    let w26: u32 = _small_sigma1_256(w24) +% w19 +% _small_sigma0_256(w11) +% w10
    let w27: u32 = _small_sigma1_256(w25) +% w20 +% _small_sigma0_256(w12) +% w11
    let w28: u32 = _small_sigma1_256(w26) +% w21 +% _small_sigma0_256(w13) +% w12
    let w29: u32 = _small_sigma1_256(w27) +% w22 +% _small_sigma0_256(w14) +% w13
    let w30: u32 = _small_sigma1_256(w28) +% w23 +% _small_sigma0_256(w15) +% w14
    let w31: u32 = _small_sigma1_256(w29) +% w24 +% _small_sigma0_256(w16) +% w15
    let w32: u32 = _small_sigma1_256(w30) +% w25 +% _small_sigma0_256(w17) +% w16
    let w33: u32 = _small_sigma1_256(w31) +% w26 +% _small_sigma0_256(w18) +% w17
    let w34: u32 = _small_sigma1_256(w32) +% w27 +% _small_sigma0_256(w19) +% w18
    let w35: u32 = _small_sigma1_256(w33) +% w28 +% _small_sigma0_256(w20) +% w19
    let w36: u32 = _small_sigma1_256(w34) +% w29 +% _small_sigma0_256(w21) +% w20
    let w37: u32 = _small_sigma1_256(w35) +% w30 +% _small_sigma0_256(w22) +% w21
    let w38: u32 = _small_sigma1_256(w36) +% w31 +% _small_sigma0_256(w23) +% w22
    let w39: u32 = _small_sigma1_256(w37) +% w32 +% _small_sigma0_256(w24) +% w23
    let w40: u32 = _small_sigma1_256(w38) +% w33 +% _small_sigma0_256(w25) +% w24
    let w41: u32 = _small_sigma1_256(w39) +% w34 +% _small_sigma0_256(w26) +% w25
    let w42: u32 = _small_sigma1_256(w40) +% w35 +% _small_sigma0_256(w27) +% w26
    let w43: u32 = _small_sigma1_256(w41) +% w36 +% _small_sigma0_256(w28) +% w27
    let w44: u32 = _small_sigma1_256(w42) +% w37 +% _small_sigma0_256(w29) +% w28
    let w45: u32 = _small_sigma1_256(w43) +% w38 +% _small_sigma0_256(w30) +% w29
    let w46: u32 = _small_sigma1_256(w44) +% w39 +% _small_sigma0_256(w31) +% w30
    let w47: u32 = _small_sigma1_256(w45) +% w40 +% _small_sigma0_256(w32) +% w31
    let w48: u32 = _small_sigma1_256(w46) +% w41 +% _small_sigma0_256(w33) +% w32
    let w49: u32 = _small_sigma1_256(w47) +% w42 +% _small_sigma0_256(w34) +% w33
    let w50: u32 = _small_sigma1_256(w48) +% w43 +% _small_sigma0_256(w35) +% w34
    let w51: u32 = _small_sigma1_256(w49) +% w44 +% _small_sigma0_256(w36) +% w35
    let w52: u32 = _small_sigma1_256(w50) +% w45 +% _small_sigma0_256(w37) +% w36
    let w53: u32 = _small_sigma1_256(w51) +% w46 +% _small_sigma0_256(w38) +% w37
    let w54: u32 = _small_sigma1_256(w52) +% w47 +% _small_sigma0_256(w39) +% w38
    let w55: u32 = _small_sigma1_256(w53) +% w48 +% _small_sigma0_256(w40) +% w39
    let w56: u32 = _small_sigma1_256(w54) +% w49 +% _small_sigma0_256(w41) +% w40
    let w57: u32 = _small_sigma1_256(w55) +% w50 +% _small_sigma0_256(w42) +% w41
    let w58: u32 = _small_sigma1_256(w56) +% w51 +% _small_sigma0_256(w43) +% w42
    let w59: u32 = _small_sigma1_256(w57) +% w52 +% _small_sigma0_256(w44) +% w43
    let w60: u32 = _small_sigma1_256(w58) +% w53 +% _small_sigma0_256(w45) +% w44
    let w61: u32 = _small_sigma1_256(w59) +% w54 +% _small_sigma0_256(w46) +% w45
    let w62: u32 = _small_sigma1_256(w60) +% w55 +% _small_sigma0_256(w47) +% w46
    let w63: u32 = _small_sigma1_256(w61) +% w56 +% _small_sigma0_256(w48) +% w47

    var s: _Sha256Working = _Sha256Working {
        a: h.h0,
        b: h.h1,
        c: h.h2,
        d: h.h3,
        e: h.h4,
        f: h.h5,
        g: h.h6,
        h: h.h7,
    }

    _sha256_round(mutable s, 0x428a2f98, w0)
    _sha256_round(mutable s, 0x71374491, w1)
    _sha256_round(mutable s, 0xb5c0fbcf, w2)
    _sha256_round(mutable s, 0xe9b5dba5, w3)
    _sha256_round(mutable s, 0x3956c25b, w4)
    _sha256_round(mutable s, 0x59f111f1, w5)
    _sha256_round(mutable s, 0x923f82a4, w6)
    _sha256_round(mutable s, 0xab1c5ed5, w7)
    _sha256_round(mutable s, 0xd807aa98, w8)
    _sha256_round(mutable s, 0x12835b01, w9)
    _sha256_round(mutable s, 0x243185be, w10)
    _sha256_round(mutable s, 0x550c7dc3, w11)
    _sha256_round(mutable s, 0x72be5d74, w12)
    _sha256_round(mutable s, 0x80deb1fe, w13)
    _sha256_round(mutable s, 0x9bdc06a7, w14)
    _sha256_round(mutable s, 0xc19bf174, w15)
    _sha256_round(mutable s, 0xe49b69c1, w16)
    _sha256_round(mutable s, 0xefbe4786, w17)
    _sha256_round(mutable s, 0x0fc19dc6, w18)
    _sha256_round(mutable s, 0x240ca1cc, w19)
    _sha256_round(mutable s, 0x2de92c6f, w20)
    _sha256_round(mutable s, 0x4a7484aa, w21)
    _sha256_round(mutable s, 0x5cb0a9dc, w22)
    _sha256_round(mutable s, 0x76f988da, w23)
    _sha256_round(mutable s, 0x983e5152, w24)
    _sha256_round(mutable s, 0xa831c66d, w25)
    _sha256_round(mutable s, 0xb00327c8, w26)
    _sha256_round(mutable s, 0xbf597fc7, w27)
    _sha256_round(mutable s, 0xc6e00bf3, w28)
    _sha256_round(mutable s, 0xd5a79147, w29)
    _sha256_round(mutable s, 0x06ca6351, w30)
    _sha256_round(mutable s, 0x14292967, w31)
    _sha256_round(mutable s, 0x27b70a85, w32)
    _sha256_round(mutable s, 0x2e1b2138, w33)
    _sha256_round(mutable s, 0x4d2c6dfc, w34)
    _sha256_round(mutable s, 0x53380d13, w35)
    _sha256_round(mutable s, 0x650a7354, w36)
    _sha256_round(mutable s, 0x766a0abb, w37)
    _sha256_round(mutable s, 0x81c2c92e, w38)
    _sha256_round(mutable s, 0x92722c85, w39)
    _sha256_round(mutable s, 0xa2bfe8a1, w40)
    _sha256_round(mutable s, 0xa81a664b, w41)
    _sha256_round(mutable s, 0xc24b8b70, w42)
    _sha256_round(mutable s, 0xc76c51a3, w43)
    _sha256_round(mutable s, 0xd192e819, w44)
    _sha256_round(mutable s, 0xd6990624, w45)
    _sha256_round(mutable s, 0xf40e3585, w46)
    _sha256_round(mutable s, 0x106aa070, w47)
    _sha256_round(mutable s, 0x19a4c116, w48)
    _sha256_round(mutable s, 0x1e376c08, w49)
    _sha256_round(mutable s, 0x2748774c, w50)
    _sha256_round(mutable s, 0x34b0bcb5, w51)
    _sha256_round(mutable s, 0x391c0cb3, w52)
    _sha256_round(mutable s, 0x4ed8aa4a, w53)
    _sha256_round(mutable s, 0x5b9cca4f, w54)
    _sha256_round(mutable s, 0x682e6ff3, w55)
    _sha256_round(mutable s, 0x748f82ee, w56)
    _sha256_round(mutable s, 0x78a5636f, w57)
    _sha256_round(mutable s, 0x84c87814, w58)
    _sha256_round(mutable s, 0x8cc70208, w59)
    _sha256_round(mutable s, 0x90befffa, w60)
    _sha256_round(mutable s, 0xa4506ceb, w61)
    _sha256_round(mutable s, 0xbef9a3f7, w62)
    _sha256_round(mutable s, 0xc67178f2, w63)

    h.h0 = h.h0 +% s.a
    h.h1 = h.h1 +% s.b
    h.h2 = h.h2 +% s.c
    h.h3 = h.h3 +% s.d
    h.h4 = h.h4 +% s.e
    h.h5 = h.h5 +% s.f
    h.h6 = h.h6 +% s.g
    h.h7 = h.h7 +% s.h
}


public function _sha256_init() -> Sha256Hash {
    return Sha256Hash {
        h0: 0x6a09e667,
        h1: 0xbb67ae85,
        h2: 0x3c6ef372,
        h3: 0xa54ff53a,
        h4: 0x510e527f,
        h5: 0x9b05688c,
        h6: 0x1f83d9ab,
        h7: 0x5be0cd19,
    }
}

public function _sha256_process_block(
    h: mutable Sha256Hash,
    data: [u8],
    block_offset: usize where block_offset + 64 <= data.len(),
) -> () {
    let block: Sha256Block = Sha256Block {
        w0: byteorder.read_u32_be(data, block_offset),
        w1: byteorder.read_u32_be(data, block_offset + 4),
        w2: byteorder.read_u32_be(data, block_offset + 8),
        w3: byteorder.read_u32_be(data, block_offset + 12),
        w4: byteorder.read_u32_be(data, block_offset + 16),
        w5: byteorder.read_u32_be(data, block_offset + 20),
        w6: byteorder.read_u32_be(data, block_offset + 24),
        w7: byteorder.read_u32_be(data, block_offset + 28),
        w8: byteorder.read_u32_be(data, block_offset + 32),
        w9: byteorder.read_u32_be(data, block_offset + 36),
        w10: byteorder.read_u32_be(data, block_offset + 40),
        w11: byteorder.read_u32_be(data, block_offset + 44),
        w12: byteorder.read_u32_be(data, block_offset + 48),
        w13: byteorder.read_u32_be(data, block_offset + 52),
        w14: byteorder.read_u32_be(data, block_offset + 56),
        w15: byteorder.read_u32_be(data, block_offset + 60),
    }
    _sha256_compress(mutable h, block)
}

public function _sha256_finalize(
    h: mutable Sha256Hash,
    data: [u8],
    tail_start: usize,
    tail_len: usize,
    total_bits: u64,
) -> ()
    requires tail_len < 64
    requires tail_start + tail_len <= data.len()
{
    if tail_len < 56 {
        let block: Sha256Block = Sha256Block {
            w0:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 0),
            w1:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 1),
            w2:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 2),
            w3:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 3),
            w4:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 4),
            w5:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 5),
            w6:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 6),
            w7:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 7),
            w8:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 8),
            w9:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 9),
            w10: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 10),
            w11: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 11),
            w12: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 12),
            w13: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 13),
            w14: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 14),
            w15: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 64, 15),
        }
        _sha256_compress(mutable h, block)
    } else {
        let block_a: Sha256Block = Sha256Block {
            w0:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 0),
            w1:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 1),
            w2:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 2),
            w3:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 3),
            w4:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 4),
            w5:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 5),
            w6:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 6),
            w7:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 7),
            w8:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 8),
            w9:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 9),
            w10: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 10),
            w11: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 11),
            w12: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 12),
            w13: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 13),
            w14: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 14),
            w15: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 15),
        }
        _sha256_compress(mutable h, block_a)
        let block_b: Sha256Block = Sha256Block {
            w0:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 16),
            w1:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 17),
            w2:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 18),
            w3:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 19),
            w4:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 20),
            w5:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 21),
            w6:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 22),
            w7:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 23),
            w8:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 24),
            w9:  pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 25),
            w10: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 26),
            w11: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 27),
            w12: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 28),
            w13: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 29),
            w14: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 30),
            w15: pad._sha256_final_word(data, tail_start, tail_len, total_bits, 128, 31),
        }
        _sha256_compress(mutable h, block_b)
    }
}

public function _sha256_write_digest(
    h: Sha256Hash,
    out: mutable [u8],
    offset: usize where offset + 32 <= out.len(),
) -> () {
    byteorder.write_u32_be(mutable out, offset, h.h0)
    byteorder.write_u32_be(mutable out, offset + 4, h.h1)
    byteorder.write_u32_be(mutable out, offset + 8, h.h2)
    byteorder.write_u32_be(mutable out, offset + 12, h.h3)
    byteorder.write_u32_be(mutable out, offset + 16, h.h4)
    byteorder.write_u32_be(mutable out, offset + 20, h.h5)
    byteorder.write_u32_be(mutable out, offset + 24, h.h6)
    byteorder.write_u32_be(mutable out, offset + 28, h.h7)
}

public function sha256(
    data: [u8],
    out: mutable [u8],
    offset: usize where offset + 32 <= out.len(),
) -> () {
    var h: Sha256Hash = _sha256_init()
    let n: usize = data.len()
    let full_blocks: usize = n / 64
    var b: usize = 0
    loop
        decreases full_blocks - b
    {
        if b >= full_blocks { break }
        _sha256_process_block(mutable h, data, b * 64)
        b += 1
    }
    let tail_start: usize = full_blocks * 64
    let tail_len: usize = n - tail_start
    let total_bits: u64 = (n as u64) *% 8
    _sha256_finalize(mutable h, data, tail_start, tail_len, total_bits)
    _sha256_write_digest(h, mutable out, offset)
}


module std.crypto.hash.sha512.pad

function _sha512_final_byte(
    p: usize,
    data: [u8],
    tail_start: usize,
    tail_len: usize,
    total_bits: u64,
    final_size: usize,
) -> u8 {
    let len_field_start: usize = final_size - 16
    if p < tail_len {
        return data[tail_start + p]
    }
    if p == tail_len {
        return 0x80
    }
    if p < len_field_start {
        return 0
    }
    let byte_idx: usize = p - len_field_start
    if byte_idx < 8 {
        return 0
    }
    let low_byte_idx: usize = byte_idx - 8
    let shift_amount: u64 = (((7 as usize) - low_byte_idx) * 8) as u64
    return ((total_bits >> shift_amount) & 0xff) as u8
}

public function _sha512_final_word(
    data: [u8],
    tail_start: usize,
    tail_len: usize,
    total_bits: u64,
    final_size: usize,
    word_idx: usize,
) -> u64 {
    let base: usize = word_idx * 8
    let b0: u8 = _sha512_final_byte(base, data, tail_start, tail_len, total_bits, final_size)
    let b1: u8 = _sha512_final_byte(base + 1, data, tail_start, tail_len, total_bits, final_size)
    let b2: u8 = _sha512_final_byte(base + 2, data, tail_start, tail_len, total_bits, final_size)
    let b3: u8 = _sha512_final_byte(base + 3, data, tail_start, tail_len, total_bits, final_size)
    let b4: u8 = _sha512_final_byte(base + 4, data, tail_start, tail_len, total_bits, final_size)
    let b5: u8 = _sha512_final_byte(base + 5, data, tail_start, tail_len, total_bits, final_size)
    let b6: u8 = _sha512_final_byte(base + 6, data, tail_start, tail_len, total_bits, final_size)
    let b7: u8 = _sha512_final_byte(base + 7, data, tail_start, tail_len, total_bits, final_size)
    return ((b0 as u64) << 56)
        | ((b1 as u64) << 48)
        | ((b2 as u64) << 40)
        | ((b3 as u64) << 32)
        | ((b4 as u64) << 24)
        | ((b5 as u64) << 16)
        | ((b6 as u64) << 8)
        | (b7 as u64)
}

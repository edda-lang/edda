    cert: Certificate,
    out: mutable [u8],
    out_len_out: mutable usize,
) -> ()
    with {err: X509Error}
    extern "__edda_x509_spki_der"

function expected_raw_len(alg: PublicKeyAlgorithm) -> usize
    with {err: X509Error}
{
    return match alg {
        case .ecdsa_p256 => 65
        case .ecdsa_p384 => 97
        case .ecdsa_p521 => 133
        case .ed25519 => 32
        case .ed448 => 57
        case .rsa => raise X509Error.unsupported_algorithm
        case .unsupported => raise X509Error.unsupported_algorithm
    }
}

function is_ec_point(alg: PublicKeyAlgorithm) -> bool {
    return match alg {
        case .ecdsa_p256 | .ecdsa_p384 | .ecdsa_p521 => true
        case _ => false
    }
}

function spki_bit_string(buf: [u8], spki_len: usize) -> asn1.BitStringView
    with {err: asn1.Asn1Error}
{
    let spki: asn1.Element = asn1.read_element(buf, 0)?
    asn1.expect(spki, asn1.TagClass.universal, 16, true)?
    if spki.total_end != spki_len {
        raise asn1.Asn1Error.trailing_bytes
    }
    var c: asn1.Cursor = asn1.children_cursor(spki)
    let _alg: asn1.Element = match asn1.next(mutable c, buf)? {
        case .some(let el) => el
        case .none => raise asn1.Asn1Error.truncated
    }
    let bits: asn1.Element = match asn1.next(mutable c, buf)? {
        case .some(let el) => el
        case .none => raise asn1.Asn1Error.truncated
    }
    asn1.expect(bits, asn1.TagClass.universal, 3, false)?
    return asn1.read_bit_string(buf, bits)?
}

public function public_key_raw(
    cert: Certificate,
    out: mutable [u8],
    out_len_out: mutable usize,
) -> ()
    with {err: X509Error}
{
    let alg: PublicKeyAlgorithm = public_key_algorithm(cert)
    let expected: usize = expected_raw_len(alg)?
    var spki_len: usize = 0
    public_key_spki_der(cert, mutable out, mutable spki_len)?
    if spki_len > out.len() { raise X509Error.internal_error }
    let view: asn1.BitStringView = handle err: asn1.Asn1Error as _e -> (raise X509Error.malformed_der) {
        spki_bit_string(out, spki_len)?
    }
    if view.unused_bits != 0 { raise X509Error.malformed_der }
    if view.content_start > view.content_end || view.content_end > spki_len {
        raise X509Error.malformed_der
    }
    let raw_len: usize = view.content_end - view.content_start
    if raw_len != expected { raise X509Error.malformed_der }
    if is_ec_point(alg) && out[view.content_start] != 0x04 {
        raise X509Error.malformed_der
    }
    var i: usize = 0
    loop
        decreases raw_len - i
    {
        if i >= raw_len { break }
        out[i] = out[view.content_start + i]
        i = i + 1
    }
    out_len_out = raw_len
}


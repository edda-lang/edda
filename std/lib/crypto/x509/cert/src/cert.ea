
module std.crypto.x509.cert

import std.encoding.asn1


public type X509Error {
    case malformed_der
    case unsupported_version
    case unsupported_algorithm
    case missing_required_extension
    case malformed_extension
    case malformed_san
    case malformed_name
    case malformed_validity
    case integer_out_of_range
    case allocator_failed
    case buffer_too_small
    case index_out_of_range
    case internal_error
}


public type SignatureAlgorithm {
    case rsa_pkcs1_sha256
    case rsa_pkcs1_sha384
    case rsa_pkcs1_sha512
    case rsa_pss_sha256
    case rsa_pss_sha384
    case rsa_pss_sha512
    case ecdsa_p256_sha256
    case ecdsa_p384_sha384
    case ecdsa_p521_sha512
    case ed25519
    case ed448
    case unsupported
}

public type PublicKeyAlgorithm {
    case rsa
    case ecdsa_p256
    case ecdsa_p384
    case ecdsa_p521
    case ed25519
    case ed448
    case unsupported
}




module std.crypto.ecdh


public type X25519Error {
    case invalid_peer_public
}

public type P256Error {
    case invalid_private_key
    case invalid_peer_public
}

public type P384Error {
    case invalid_private_key
    case invalid_peer_public
}


public function generate_keypair_x25519(
    random: Random,
    private_key: mutable [u8] where private_key.len() == 32,
    public_key: mutable [u8] where public_key.len() == 32,
) -> ()
    with {random}
    extern "__edda_ecdh_x25519_generate_keypair"

public function derive_public_key_x25519(
    private_key: [u8] where private_key.len() == 32,
    public_key: mutable [u8] where public_key.len() == 32,
) -> ()
    extern "__edda_ecdh_x25519_derive_public"

public function derive_shared_secret_x25519(
    private_key: [u8] where private_key.len() == 32,
    peer_public_key: [u8] where peer_public_key.len() == 32,
    shared_secret: mutable [u8] where shared_secret.len() == 32,
) -> ()
    with {err: X25519Error}
    extern "__edda_ecdh_x25519_derive_shared"


public function generate_keypair_p256(
    random: Random,
    private_key: mutable [u8] where private_key.len() == 32,
    public_key: mutable [u8] where public_key.len() == 65,
) -> ()
    with {random}
    extern "__edda_ecdh_p256_generate_keypair"

public function derive_public_key_p256(
    private_key: [u8] where private_key.len() == 32,
    public_key: mutable [u8] where public_key.len() == 65,
) -> ()
    with {err: P256Error}
    extern "__edda_ecdh_p256_derive_public"

public function derive_shared_secret_p256(
    private_key: [u8] where private_key.len() == 32,
    peer_public_key: [u8] where peer_public_key.len() == 65,
    shared_secret: mutable [u8] where shared_secret.len() == 32,
) -> ()
    with {err: P256Error}
    extern "__edda_ecdh_p256_derive_shared"


public function generate_keypair_p384(
    random: Random,
    private_key: mutable [u8] where private_key.len() == 48,
    public_key: mutable [u8] where public_key.len() == 97,
) -> ()
    with {random}
    extern "__edda_ecdh_p384_generate_keypair"

public function derive_public_key_p384(
    private_key: [u8] where private_key.len() == 48,
    public_key: mutable [u8] where public_key.len() == 97,
) -> ()
    with {err: P384Error}
    extern "__edda_ecdh_p384_derive_public"

public function derive_shared_secret_p384(
    private_key: [u8] where private_key.len() == 48,
    peer_public_key: [u8] where peer_public_key.len() == 97,
    shared_secret: mutable [u8] where shared_secret.len() == 48,
) -> ()
    with {err: P384Error}
    extern "__edda_ecdh_p384_derive_shared"

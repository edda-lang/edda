
module std.crypto.field.gfp.p384

import std.collections.array
import std.core.option

spec std.collections.array.Array(u8, 48)
spec std.core.option.Option(Element)


public type Element {
    bytes: Array_u8_48
}


public function add(a: Element, b: Element) -> Element
    extern "__edda_gfp_p384_add"

public function sub(a: Element, b: Element) -> Element
    extern "__edda_gfp_p384_sub"

public function mul(a: Element, b: Element) -> Element
    extern "__edda_gfp_p384_mul"

public function square(a: Element) -> Element
    extern "__edda_gfp_p384_square"

public function neg(a: Element) -> Element
    extern "__edda_gfp_p384_neg"

public function inv(a: Element) -> Option_Element
    extern "__edda_gfp_p384_inv"

public function pow(a: Element, exponent: [u8]) -> Element
    extern "__edda_gfp_p384_pow"


public function is_zero(a: Element) -> bool
    extern "__edda_gfp_p384_is_zero"

public function eq(a: Element, b: Element) -> bool
    extern "__edda_gfp_p384_eq"

public function select(cond: bool, a: Element, b: Element) -> Element
    extern "__edda_gfp_p384_select"


public function from_bytes_be(bytes: [u8] where bytes.len() == 48) -> Option_Element
    extern "__edda_gfp_p384_from_bytes_be"

public function to_bytes_be(a: Element, out: mutable [u8] where out.len() == 48) -> ()
    extern "__edda_gfp_p384_to_bytes_be"

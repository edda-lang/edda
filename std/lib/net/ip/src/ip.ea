
module std.net.ip


public type ParseAddrError {
    case invalid_format
    case octet_out_of_range
    case too_many_octets
    case too_few_octets
}


public type Ipv4Addr {
    a: u8
    b: u8
    c: u8
    d: u8
}


public stable function new_v4(a: u8, b: u8, c: u8, d: u8) -> Ipv4Addr {
    return Ipv4Addr { a: a, b: b, c: c, d: d }
}

public stable function unspecified_v4() -> Ipv4Addr {
    return Ipv4Addr { a: 0, b: 0, c: 0, d: 0 }
}

public stable function localhost_v4() -> Ipv4Addr {
    return Ipv4Addr { a: 127, b: 0, c: 0, d: 1 }
}

public stable function broadcast_v4() -> Ipv4Addr {
    return Ipv4Addr { a: 255, b: 255, c: 255, d: 255 }
}

public stable function from_u32(packed: u32) -> Ipv4Addr {
    let a: u8 = ((packed >> 24) & 255) as u8
    let b: u8 = ((packed >> 16) & 255) as u8
    let c: u8 = ((packed >> 8) & 255) as u8
    let d: u8 = (packed & 255) as u8
    return Ipv4Addr { a: a, b: b, c: c, d: d }
}


public stable function to_u32(addr: Ipv4Addr) -> u32 {
    let a: u32 = addr.a as u32
    let b: u32 = addr.b as u32
    let c: u32 = addr.c as u32
    let d: u32 = addr.d as u32
    return (a << 24) | (b << 16) | (c << 8) | d
}


public stable function equals_v4(x: Ipv4Addr, y: Ipv4Addr) -> bool {
    return x.a == y.a && x.b == y.b && x.c == y.c && x.d == y.d
}


public stable function is_unspecified_v4(addr: Ipv4Addr) -> bool {
    return addr.a == 0 && addr.b == 0 && addr.c == 0 && addr.d == 0
}

public stable function is_loopback_v4(addr: Ipv4Addr) -> bool {
    return addr.a == 127
}

public stable function is_private_v4(addr: Ipv4Addr) -> bool {
    if addr.a == 10 { return true }
    if addr.a == 172 && addr.b >= 16 && addr.b <= 31 { return true }
    if addr.a == 192 && addr.b == 168 { return true }
    return false
}

public stable function is_link_local_v4(addr: Ipv4Addr) -> bool {
    return addr.a == 169 && addr.b == 254
}

public stable function is_multicast_v4(addr: Ipv4Addr) -> bool {
    return addr.a >= 224 && addr.a <= 239
}

public stable function is_broadcast_v4(addr: Ipv4Addr) -> bool {
    return addr.a == 255 && addr.b == 255 && addr.c == 255 && addr.d == 255
}

public stable function is_documentation_v4(addr: Ipv4Addr) -> bool {
    if addr.a == 192 && addr.b == 0 && addr.c == 2 { return true }
    if addr.a == 198 && addr.b == 51 && addr.c == 100 { return true }
    if addr.a == 203 && addr.b == 0 && addr.c == 113 { return true }
    return false
}


public stable function parse_v4(bytes: [u8]) -> Ipv4Addr
    with {err: ParseAddrError}
{
    let n: usize = bytes.len()
    if n < 7 { raise ParseAddrError.too_few_octets }
    if n > 15 { raise ParseAddrError.too_many_octets }

    var packed: u32 = 0
    var i: usize = 0
    var dots_seen: usize = 0
    var current_value: u32 = 0
    var current_digits: usize = 0

    loop
        decreases n - i
    {
        if i >= n { break }
        let byte: u8 = bytes[i]
        if byte >= 48 && byte <= 57 {
            if current_digits >= 3 {
                raise ParseAddrError.invalid_format
            }
            let digit: u32 = (byte - 48) as u32
            let next_value: u32 = current_value * 10 + digit
            if next_value > 255 {
                raise ParseAddrError.octet_out_of_range
            }
            current_value = next_value
            current_digits += 1
        } else if byte == 46 {
            if current_digits == 0 {
                raise ParseAddrError.invalid_format
            }
            if dots_seen >= 3 {
                raise ParseAddrError.too_many_octets
            }
            packed = (packed << 8) | current_value
            dots_seen += 1
            current_value = 0
            current_digits = 0
        } else {
            raise ParseAddrError.invalid_format
        }
        i += 1
    }

    if current_digits == 0 {
        raise ParseAddrError.invalid_format
    }
    if dots_seen != 3 {
        raise ParseAddrError.too_few_octets
    }
    packed = (packed << 8) | current_value
    return from_u32(packed)
}


public type Ipv6Addr {
    g0: u16
    g1: u16
    g2: u16
    g3: u16
    g4: u16
    g5: u16
    g6: u16
    g7: u16
}


public stable function new_v6(
    g0: u16, g1: u16, g2: u16, g3: u16,
    g4: u16, g5: u16, g6: u16, g7: u16,
) -> Ipv6Addr {
    return Ipv6Addr {
        g0: g0, g1: g1, g2: g2, g3: g3,
        g4: g4, g5: g5, g6: g6, g7: g7,
    }
}

public stable function unspecified_v6() -> Ipv6Addr {
    return Ipv6Addr { g0: 0, g1: 0, g2: 0, g3: 0, g4: 0, g5: 0, g6: 0, g7: 0 }
}

public stable function localhost_v6() -> Ipv6Addr {
    return Ipv6Addr { g0: 0, g1: 0, g2: 0, g3: 0, g4: 0, g5: 0, g6: 0, g7: 1 }
}


public stable function equals_v6(x: Ipv6Addr, y: Ipv6Addr) -> bool {
    if x.g0 != y.g0 { return false }
    if x.g1 != y.g1 { return false }
    if x.g2 != y.g2 { return false }
    if x.g3 != y.g3 { return false }
    if x.g4 != y.g4 { return false }
    if x.g5 != y.g5 { return false }
    if x.g6 != y.g6 { return false }
    if x.g7 != y.g7 { return false }
    return true
}


public stable function is_unspecified_v6(addr: Ipv6Addr) -> bool {
    return addr.g0 == 0 && addr.g1 == 0 && addr.g2 == 0 && addr.g3 == 0
        && addr.g4 == 0 && addr.g5 == 0 && addr.g6 == 0 && addr.g7 == 0
}

public stable function is_loopback_v6(addr: Ipv6Addr) -> bool {
    return addr.g0 == 0 && addr.g1 == 0 && addr.g2 == 0 && addr.g3 == 0
        && addr.g4 == 0 && addr.g5 == 0 && addr.g6 == 0 && addr.g7 == 1
}

public stable function is_multicast_v6(addr: Ipv6Addr) -> bool {
    return (addr.g0 >> 8) == 255
}
